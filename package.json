{
  "name": "k-document-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && npm run analytics:check && npm run test:seo && astro build && npm run perf:budget",
    "preview": "astro preview",
    "check": "astro check && npm run analytics:check",
    "analytics:check": "node scripts/check-analytics-contract.mjs && node scripts/check-funnel-contract.mjs",
    "analytics:funnel": "node scripts/funnel-report.mjs",
    "analytics:migrate:local": "wrangler d1 migrations apply k-document-tool-analytics --local",
    "analytics:migrate:preview": "wrangler d1 migrations apply ANALYTICS_DB --env preview --remote",
    "analytics:migrate:production": "wrangler d1 migrations apply k-document-tool-analytics --remote",
    "perf:budget": "node scripts/check-build-budget.mjs",
    "seo:health": "node scripts/seo-health.mjs",
    "seo:indexnow": "node scripts/submit-indexnow.mjs",
    "test:seo": "node --test tests/sitemap-lastmod.test.mjs",
    "test:funnel": "node --test tests/funnel-client.test.mjs tests/funnel-function.test.mjs tests/funnel-report.test.mjs tests/funnel-d1-integration.test.mjs",
    "test:smoke": "node tests/smoke.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@lucide/astro": "^1.22.0",
    "astro": "^7.0.2",
    "exifr": "^7.1.3",
    "gifenc": "^1.0.3",
    "heic-to": "^1.5.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "miniflare": "4.20260625.0",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
