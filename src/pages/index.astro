---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { toolCategories, tools } from "@/data/tools";
import { toolItemListSchema, websiteSchema } from "@/data/seo";
import { prepShortcuts } from "@/data/prepShortcuts";

const structuredData = [websiteSchema(), toolItemListSchema(tools)];
const submissionPrep = {
  title: "제출용 파일 준비",
  path: "/tools/submission-file-prep/",
  description:
    "사진, 스캔본, 업무 문서를 제출처 조건에 맞게 형식 변환, 용량 줄이기, PDF 묶기 순서로 정리합니다."
};
const workflowCards = [
  {
    title: submissionPrep.title,
    path: submissionPrep.path,
    tag: "제출용 파일 만들기",
    description: submissionPrep.description,
    trustNote: "파일 도구는 브라우저 처리 원칙을 유지하고, 상황별로 필요한 도구만 연결합니다."
  },
  {
    title: "이미지 제출 준비",
    path: "/categories/image/",
    tag: "사진 용량 줄이기",
    description: "HEIC, WebP, JPG, PNG 사진을 제출 가능한 크기, 형식, 방향, 자르기 영역으로 정리합니다.",
    trustNote: "이미지 파일과 파일명은 분석 이벤트로 보내지 않는 흐름을 우선합니다."
  },
  {
    title: "스캔본 PDF 만들기",
    path: "/tools/jpg-to-pdf-converter/",
    tag: "JPG PDF 변환",
    description: "여러 장의 증빙 사진이나 스캔 이미지를 한 개의 PDF로 묶습니다.",
    trustNote: "이미지를 서버 업로드 없이 브라우저에서 PDF로 정리합니다."
  }
];
---

<BaseLayout
  title="K문서툴 - 무료 업무 문서 도구"
  description="제출용 파일 준비, 사업자 명판, 거래명세서, 견적서, 청구서, 영수증, 부가세 계산, 도장 배경 제거, JPG PDF 변환, 사진 용량 줄이기, 이미지 리사이즈, 이미지 자르기, 이미지 회전, HEIC JPG 변환을 로그인 없이 사용하는 한국형 무료 문서 도구입니다."
  structuredData={structuredData}
>
  <main class="page-shell" data-page-type="home">
    <section class="tool-intro">
      <div>
        <h1>K문서툴로 문서 제출 직전을 가볍게</h1>
        <p>
          제출용 파일 준비, 사업자 명판, 거래명세서, 견적서, 청구서, 영수증, 부가세 계산, 금액 한글 변환, 3.3% 계산, 도장 배경 제거, JPG PDF 변환, 사진 용량 줄이기, 이미지 리사이즈, 이미지 자르기, 이미지 회전, WebP JPG 변환, HEIC JPG 변환을 브라우저에서 바로 사용하세요. 한국 업무 문서에
          필요한 작은 도구를 로그인 없이 빠르게 제공합니다.
        </p>
      </div>
      <div class="quick-links" aria-label="도구 바로가기">
        <a
          href="/tools/"
          data-analytics-event="catalog_quick_link_click"
          data-analytics-label="전체 도구"
        >
          전체 도구
        </a>
        <a
          href={submissionPrep.path}
          data-analytics-event="home_workflow_quick_link_click"
          data-analytics-label={submissionPrep.title}
        >
          제출 준비
        </a>
        {
          toolCategories.map((category) => (
            <a
              href={category.path}
              data-analytics-event="category_quick_link_click"
              data-analytics-label={category.shortTitle}
            >
              {category.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>추천 흐름</h2>
        <p>업로드 오류와 제출처 조건에 맞춰 여러 도구를 한 번에 고를 수 있습니다.</p>
      </div>
      <div class="tool-grid">
        {
          workflowCards.map((card) => (
            <a
              class="tool-card"
              href={card.path}
              data-analytics-event="home_workflow_click"
              data-analytics-label={card.title}
            >
              <span class="meta">
                <span class="meta-tag">{card.tag}</span>
              </span>
              <strong>{card.title}</strong>
              <p>{card.description}</p>
              <p class="trust-note">{card.trustNote}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section" data-prep-shortcuts>
      <div class="section-heading">
        <h2>문제상황 바로가기</h2>
        <p>제출처 오류 문구가 보이면 도구 이름을 몰라도 해당 설정으로 바로 시작합니다.</p>
      </div>
      <div class="tool-grid">
        {
          prepShortcuts.map((shortcut) => (
            <a
              class="tool-card"
              href={shortcut.path}
              data-analytics-event="home_prep_shortcut_click"
              data-analytics-shortcut-id={shortcut.id}
              data-analytics-tool-id={shortcut.targetToolId}
              data-analytics-tool-title={shortcut.targetToolTitle}
              data-analytics-target-preset={shortcut.targetPreset}
              data-analytics-label={shortcut.label}
            >
              <span class="meta">
                <span class="meta-tag">{shortcut.label}</span>
              </span>
              <strong>{shortcut.title}</strong>
              <p>{shortcut.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>사용 가능한 도구</h2>
        <p>검색으로 들어온 사용자가 바로 제출용 문서와 파일을 만들 수 있는 도구부터 확장합니다.</p>
      </div>
      <div class="tool-grid">
        {
          tools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="home_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.description}</p>
              <p class="trust-note">{tool.trustNote}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>카테고리</h2>
        <p>업무 문서 도구에서 시작해, 브라우저에서 안전하게 처리할 수 있는 PDF와 이미지 도구로 확장합니다.</p>
      </div>
      <div class="tool-grid">
        {
          toolCategories.map((category) => (
            <a
              class="tool-card"
              href={category.path}
              data-analytics-event="home_category_click"
              data-analytics-label={category.title}
            >
              <span class="meta">
                <span class={`meta-tag${category.status === "planned" ? " muted" : ""}`}>
                  {category.status === "active" ? "운영 중" : "준비 중"}
                </span>
              </span>
              <strong>{category.title}</strong>
              <p>{category.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
