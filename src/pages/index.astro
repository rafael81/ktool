---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { toolCategories, tools, type ToolCategoryId, type ToolId } from "@/data/tools";
import { getProblemPage, problemPages, type ProblemPageId } from "@/data/problemPages";
import { toolItemListSchema, webPageSchema, websiteSchema } from "@/data/seo";
import {
  Archive,
  Calculator,
  Crop,
  FileText,
  Files,
  Image,
  RotateCw,
  Search,
  Smartphone,
  Stamp,
  Video,
  type IconProps
} from "@lucide/astro";

const homeTitle = "K문서툴 - 무료 PDF 이미지 문서 도구";
const homeDescription =
  "설치 없이 쓰는 무료 PDF·이미지·업무 문서 도구입니다. JPG PDF, 사진 1MB 줄이기, HEIC JPG, 사업자 명판까지 브라우저에서 처리하고 파일은 서버로 전송되지 않습니다.";
const structuredData = [
  websiteSchema(),
  webPageSchema({
    name: "K문서툴",
    description: homeDescription,
    path: "/",
    keywords: [
      "무료 문서 도구",
      "무료 PDF 도구",
      "무료 이미지 변환",
      "사업자 명판 만들기",
      "파일 서버 전송 없음"
    ]
  }),
  toolItemListSchema(tools)
];
const categoryById = new Map(toolCategories.map((category) => [category.id, category]));
const toolCountLabel = `${tools.length}종`;
const featuredToolIds: ToolId[] = [
  "transaction-statement",
  "jpg-to-pdf",
  "image-compressor",
  "heic-to-jpg"
];
const featuredToolSet = new Set<ToolId>(featuredToolIds);
const featuredTools = featuredToolIds
  .map((id) => tools.find((tool) => tool.id === id))
  .filter((tool): tool is (typeof tools)[number] => Boolean(tool));
const homeQuickStarts: {
  label: string;
  detail: string;
  path: string;
  toolId: ToolId;
  preset?: string;
}[] = [
  {
    label: "JPG PDF",
    detail: "여러 장 묶기",
    path: "/tools/jpg-to-pdf-converter/?from=quick-start&source=home-quick-start",
    toolId: "jpg-to-pdf"
  },
  {
    label: "사진 1MB",
    detail: "용량 줄이기",
    path: "/tools/photo-size-reducer/?preset=1mb&source=home-quick-start",
    toolId: "image-compressor",
    preset: "1mb"
  },
  {
    label: "HEIC JPG",
    detail: "아이폰 사진",
    path: "/tools/heic-jpg-converter/?preset=jpg&source=home-quick-start",
    toolId: "heic-to-jpg",
    preset: "jpg"
  },
  {
    label: "거래명세서",
    detail: "문서 작성",
    path: "/tools/transaction-statement-generator/?source=home-quick-start",
    toolId: "transaction-statement"
  },
  {
    label: "명판 PNG",
    detail: "도장 합성",
    path: "/tools/business-nameplate-maker/?source=home-quick-start",
    toolId: "business-nameplate"
  }
];
const homeProblemStartIds = [
  "images-to-one-pdf",
  "photo-under-1mb",
  "heic-jpg-submit",
  "business-nameplate-stamp"
] satisfies ProblemPageId[];
const homeProblemStarts = homeProblemStartIds.map((id) => {
  const problemPage = getProblemPage(id);
  const targetTool = tools.find((tool) => tool.id === problemPage.targetToolId);
  if (!targetTool) throw new Error(`Unknown problem target tool: ${problemPage.targetToolId}`);
  return {
    ...problemPage,
    targetTool
  };
});
const emptySearchLinks = [
  { label: "사진 용량 줄이기", path: "/tools/photo-size-reducer/" },
  { label: "JPG PDF 변환", path: "/tools/jpg-to-pdf-converter/" },
  { label: "HEIC JPG 변환", path: "/tools/heic-jpg-converter/" },
  { label: "문제 해결", path: "/problems/" }
];
const toolsByCategory = new Map(
  toolCategories.map((category) => [
    category.id,
    tools.filter((tool) => tool.category === category.id)
  ])
);
type LucideIcon = (_props: IconProps) => unknown;
const categoryIconById: Record<ToolCategoryId, LucideIcon> = {
  business: FileText,
  pdf: Files,
  image: Image
};
const toolIconById: Partial<Record<ToolId, LucideIcon>> = {
  "transaction-statement": FileText,
  "pdf-edit": FileText,
  "pdf-split-half": Files,
  "pdf-two-up": Files,
  "pdf-crop": Crop,
  "pdf-text-extract": FileText,
  "pdf-split": Files,
  "pdf-delete-pages": Files,
  "pdf-merge": Files,
  "pdf-to-image": Files,
  "jpg-to-pdf": Files,
  "photo-date-stamp": Image,
  "photo-merge": Image,
  "image-compressor": Archive,
  "heic-to-jpg": Smartphone,
  "image-converter": Image,
  "svg-crop": Crop,
  "image-base64": Image,
  "video-to-gif": Video,
  "image-resizer": Image,
  "image-cropper": Crop,
  "image-rotator": RotateCw,
  "business-nameplate": FileText,
  estimate: FileText,
  receipt: FileText,
  invoice: FileText,
  "vat-calculator": Calculator,
  "amount-korean": Calculator,
  "withholding-tax": Calculator,
  "stamp-background": Stamp
};
function iconForTool(toolId: ToolId) {
  return toolIconById[toolId] ?? FileText;
}
---

<BaseLayout
  title={homeTitle}
  description={homeDescription}
  structuredData={structuredData}
>
  <main class="page-shell home-page" data-page-type="home" data-tool-count={tools.length}>
    <section class="home-start" aria-labelledby="home-title">
      <div class="home-start-copy">
        <div class="home-hero-visual" aria-hidden="true">
          <svg class="home-hero-illust" viewBox="0 0 240 170" focusable="false">
            <defs>
              <filter id="hero-soft-shadow" x="-30%" y="-30%" width="160%" height="170%">
                <feDropShadow dx="0" dy="10" stdDeviation="8" flood-color="#344054" flood-opacity="0.18" />
              </filter>
            </defs>
            <ellipse class="hero-stage-shadow" cx="124" cy="142" rx="62" ry="13" />
            <g class="hero-tool-panel hero-tool-panel-left" filter="url(#hero-soft-shadow)">
              <rect class="hero-panel-surface" x="20" y="38" width="65" height="72" rx="15" />
              <rect class="hero-panel-chip" x="33" y="51" width="23" height="23" rx="5" />
              <path class="hero-panel-line" d="M63 56h13M33 83h36M33 94h27" />
              <path class="hero-mini-chart" d="M33 72l12-10 10 7 14-16" />
            </g>
            <g class="hero-tool-panel hero-tool-panel-right" filter="url(#hero-soft-shadow)">
              <rect class="hero-panel-surface" x="163" y="44" width="57" height="52" rx="14" />
              <rect class="hero-image-tile" x="174" y="56" width="22" height="21" rx="5" />
              <path class="hero-image-mountain" d="M176 75l8-9 6 6 6-8" />
              <path class="hero-convert-arrow" d="M201 67h12M209 61l6 6-6 6" />
            </g>
            <g class="hero-tool-strip" filter="url(#hero-soft-shadow)">
              <rect class="hero-panel-surface" x="61" y="120" width="126" height="32" rx="16" />
              <path class="hero-tool-icon" d="M78 129h16v16H78zM82 125v8M74 133h8" />
              <path class="hero-tool-icon" d="M112 130l7-7M118 123h-6M119 124v6M103 143l7-7M104 137v6M110 144h-6" />
              <path class="hero-tool-icon" d="M139 128c6-4 14-1 15 6M155 128v7h-7M153 143c-6 4-14 1-15-6M137 143v-7h7" />
              <path class="hero-tool-icon-muted" d="M169 128h8v8h-8zM181 128h8v8h-8zM169 140h8v8h-8zM181 140h8v8h-8z" />
            </g>
            <g class="hero-document-mascot" filter="url(#hero-soft-shadow)">
              <path class="hero-arm hero-arm-left" d="M91 86c-15 2-19 18-31 11-7-4-7-13-2-19" />
              <path class="hero-arm hero-arm-right" d="M165 88c15 2 19 18 31 11 7-4 7-13 2-19" />
              <path class="hero-document-page" d="M101 27h42l29 29v66a16 16 0 0 1-16 16h-55a16 16 0 0 1-16-16V43a16 16 0 0 1 16-16Z" />
              <path class="hero-document-fold-fill" d="M143 27v21a8 8 0 0 0 8 8h21" />
              <path class="hero-document-fold" d="M143 27v21a8 8 0 0 0 8 8h21" />
              <circle class="hero-eye" cx="111" cy="75" r="3.7" />
              <circle class="hero-eye" cx="146" cy="75" r="3.7" />
              <path class="hero-smile" d="M118 88c6 8 18 8 24 0" />
              <path class="hero-shield-base" d="M128 95l15 5v15c0 10-6.2 17-15 20-8.8-3-15-10-15-20v-15l15-5Z" />
              <path class="hero-shield-check" d="M121 115l5 5 11-13" />
              <path class="hero-leg hero-leg-left" d="M111 138v14" />
              <path class="hero-leg hero-leg-right" d="M145 138v14" />
            </g>
            <circle class="hero-orbit-dot hero-orbit-dot-one" cx="92" cy="31" r="3" />
            <circle class="hero-orbit-dot hero-orbit-dot-two" cx="189" cy="111" r="3.2" />
          </svg>
        </div>
        <h1 id="home-title">K문서툴</h1>
        <p class="home-hero-lead">설치 없이 쓰는 무료 도구 {toolCountLabel}</p>
        <p class="home-hero-subcopy">PDF, 이미지, 업무 문서를 브라우저에서 바로 처리합니다.</p>
        <div class="home-trust-badges" aria-label="주요 장점">
          <span>설치 없음</span>
          <span>무료</span>
          <span>서버 전송 없음</span>
        </div>
      </div>

      <section id="tool-search" class="home-tool-finder" aria-label="도구 검색">
        <form class="hero-search home-search-panel" data-home-tool-search role="search">
          <label class="hero-search-field">
            <span class="visually-hidden">도구 검색</span>
            <Search class="home-search-icon" aria-hidden="true" />
            <input
              type="search"
              autocomplete="off"
              inputmode="search"
              placeholder="PDF, HEIC, 1MB, 명판"
              aria-label="도구와 문제 검색"
              data-home-search-input
            />
            <kbd>Enter</kbd>
          </label>

        <div class="home-filter-bar">
          <div class="home-filter-list" aria-label="카테고리 필터">
            <button class="is-active" type="button" data-home-category-filter="all">전체</button>
            {
              toolCategories.map((category) => (
                <button type="button" data-home-category-filter={category.id}>
                  {category.shortTitle}
                </button>
              ))
            }
          </div>
          <div class="hero-search-meta">
            <span data-home-search-count>인기 도구 {featuredTools.length}개</span>
          </div>
        </div>

        <div class="home-quick-starts" aria-label="빠른 시작">
          {
            homeQuickStarts.map((item) => {
              const tool = tools.find((toolItem) => toolItem.id === item.toolId);
              if (!tool) return null;
              const QuickIcon = iconForTool(item.toolId);

              return (
                <a
                  class="home-quick-start"
                  href={item.path}
                  data-home-quick-start
                  data-analytics-event="home_quick_start_click"
                  data-analytics-tool-id={tool.id}
                  data-analytics-tool-title={tool.title}
                  data-analytics-target-preset={item.preset}
                  data-analytics-label={item.label}
                >
                  <span class="home-quick-icon" aria-hidden="true">
                    <QuickIcon class="home-icon" />
                  </span>
                  <span>
                    <strong>{item.label}</strong>
                    <em>{item.detail}</em>
                  </span>
                </a>
              );
            })
          }
        </div>

        <section class="home-problem-starts" data-home-problem-starts aria-label="자주 막히는 문제">
          <div class="home-problem-starts-heading">
            <span>막혔나요?</span>
            <a
              href="/problems/"
              data-analytics-event="home_problem_all_click"
              data-analytics-label="문제 전체"
            >
              전체
            </a>
          </div>
          <div class="home-problem-start-grid">
            {
              homeProblemStarts.map((problemPage) => (
                <a
                  class="home-problem-start"
                  href={problemPage.path}
                  data-home-problem-start
                  data-analytics-event="home_problem_start_click"
                  data-analytics-problem-id={problemPage.id}
                  data-analytics-target-problem-id={problemPage.id}
                  data-analytics-target-problem-title={problemPage.title}
                  data-analytics-target-tool-id={problemPage.targetTool.id}
                  data-analytics-target-tool-title={problemPage.targetTool.title}
                  data-analytics-target-preset={problemPage.targetPreset}
                  data-analytics-label={problemPage.title}
                >
                  <strong>{problemPage.shortTitle}</strong>
                  <span>{problemPage.targetLabel}</span>
                </a>
              ))
            }
          </div>
        </section>

        <div class="hero-search-results home-result-list" data-home-search-results hidden>
          {
            tools.map((tool) => {
              const ToolIcon = iconForTool(tool.id);

              return (
                <a
                  class:list={{
                    "hero-search-row": true,
                    "is-default": featuredToolSet.has(tool.id)
                  }}
                  href={tool.path}
                  hidden={!featuredToolSet.has(tool.id)}
                  data-home-search-item
                  data-home-search-category={tool.category}
                  data-default-visible={featuredToolSet.has(tool.id) ? "true" : "false"}
                  data-analytics-event="home_search_tool_click"
                  data-analytics-tool-id={tool.id}
                  data-analytics-tool-title={tool.title}
                  data-analytics-label={tool.title}
                  data-home-search-text={[
                    tool.title,
                    tool.shortTitle,
                    tool.primaryQuery,
                    ...tool.secondaryQueries,
                    tool.description,
                    tool.userMoment,
                    categoryById.get(tool.category)?.title ?? ""
                  ].join(" ")}
                >
                  <span class="home-row-meta">
                    <span class="home-icon-tile">
                      <ToolIcon class="home-icon" aria-hidden="true" />
                    </span>
                    <span>{categoryById.get(tool.category)?.shortTitle}</span>
                  </span>
                  <span class="home-row-copy">
                    <strong>{tool.title}</strong>
                    <span>{tool.shortTitle}</span>
                  </span>
                  <em aria-hidden="true">실행</em>
                </a>
              );
            })
          }
          {
            problemPages.map((problemPage) => {
              const targetTool = tools.find((tool) => tool.id === problemPage.targetToolId);
              if (!targetTool) return null;
              const ProblemIcon = iconForTool(targetTool.id);

              return (
                <a
                  class="hero-search-row"
                  href={problemPage.path}
                  hidden
                  data-home-search-item
                  data-home-search-category={targetTool.category}
                  data-default-visible="false"
                  data-analytics-event="home_search_problem_click"
                  data-analytics-tool-id={targetTool.id}
                  data-analytics-tool-title={targetTool.title}
                  data-analytics-target-preset={problemPage.targetPreset}
                  data-analytics-label={problemPage.title}
                  data-home-search-text={[
                    problemPage.title,
                    problemPage.shortTitle,
                    problemPage.primaryQuery,
                    ...problemPage.secondaryQueries,
                    ...problemPage.intentQueries,
                    problemPage.description,
                    problemPage.actionNote,
                    targetTool.title,
                    targetTool.shortTitle,
                    categoryById.get(targetTool.category)?.title ?? ""
                  ].join(" ")}
                >
                  <span class="home-row-meta">
                    <span class="home-icon-tile">
                      <ProblemIcon class="home-icon" aria-hidden="true" />
                    </span>
                    <span>문제 해결</span>
                  </span>
                  <span class="home-row-copy">
                    <strong>{problemPage.title}</strong>
                    <span>{problemPage.shortTitle}</span>
                  </span>
                  <em aria-hidden="true">보기</em>
                </a>
              );
            })
          }
        </div>
          <p class="hero-search-empty" data-home-search-empty hidden>
            결과 없음
          </p>
          <div class="search-empty-actions" data-home-search-suggestions hidden>
            {
              emptySearchLinks.map((link) => (
                <a
                  href={link.path}
                  data-analytics-event="home_search_empty_click"
                  data-analytics-label={link.label}
                >
                  {link.label}
                </a>
              ))
            }
          </div>
        </form>
      </section>
    </section>

    <section class="home-category-catalog" aria-labelledby="home-catalog-title">
      <div class="home-section-title">
        <h2 id="home-catalog-title">전체 도구</h2>
        <a
          class="section-mini-link"
          href="/tools/"
          data-analytics-event="home_catalog_all_click"
          data-analytics-label="전체 도구"
        >
          목록 보기
        </a>
      </div>
      <div class="home-category-stack">
        {
          toolCategories.map((category) => {
            const CategoryIcon = categoryIconById[category.id];
            const categoryTools = toolsByCategory.get(category.id) ?? [];

            return (
              <section class="home-category-section" data-home-category-section={category.id}>
                <div class="home-category-heading">
                  <span class="home-category-icon" aria-hidden="true">
                    <CategoryIcon class="home-icon" />
                  </span>
                  <div>
                    <h3>{category.shortTitle}</h3>
                    <p>{categoryTools.length}개 도구</p>
                  </div>
                </div>
                <div class="home-category-tools">
                  {categoryTools.map((tool) => {
                    const ToolIcon = iconForTool(tool.id);

                    return (
                      <a
                        class="home-tool-card"
                        href={tool.path}
                        data-home-all-tool
                        data-analytics-event="home_all_tool_click"
                        data-analytics-tool-id={tool.id}
                        data-analytics-tool-title={tool.title}
                        data-analytics-label={tool.title}
                      >
                        <span class="home-tool-card-icon" aria-hidden="true">
                          <ToolIcon class="home-icon" />
                        </span>
                        <span class="home-tool-card-copy">
                          <strong>{tool.title}</strong>
                          <span>{tool.description}</span>
                        </span>
                        <em aria-hidden="true">실행</em>
                      </a>
                    );
                  })}
                </div>
              </section>
            );
          })
        }
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-home-tool-search]");
    if (!root) return;

    const searchInput = root.querySelector("[data-home-search-input]");
    const items = Array.from(root.querySelectorAll("[data-home-search-item]"));
    const resultsNode = root.querySelector("[data-home-search-results]");
    const filterButtons = Array.from(root.querySelectorAll("[data-home-category-filter]"));
    const countNode = root.querySelector("[data-home-search-count]");
    const emptyNode = root.querySelector("[data-home-search-empty]");
    const suggestionNode = root.querySelector("[data-home-search-suggestions]");
    let activeCategory = "all";
    let searchTimer = 0;

    function normalize(value) {
      return String(value || "").toLowerCase().replace(/\s+/g, " ").trim();
    }

    function visibleItems() {
      return items.filter((item) => !item.hidden);
    }

    function track(visibleCount) {
      window.kdocTrack?.("home_search_change", {
        search_query_length: normalize(searchInput?.value).length,
        search_category: activeCategory,
        visible_count: visibleCount
      });
    }

    function applySearch({ shouldTrack } = {}) {
      const query = normalize(searchInput?.value);
      const defaultMode = !query && activeCategory === "all";
      let visibleCount = 0;

      items.forEach((item) => {
        const matchesQuery = query ? normalize(item.dataset.homeSearchText).includes(query) : true;
        const matchesCategory =
          activeCategory === "all" || item.dataset.homeSearchCategory === activeCategory;
        const visible = !defaultMode && matchesQuery && matchesCategory;
        item.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (resultsNode) resultsNode.hidden = defaultMode;
      if (countNode) {
        countNode.textContent = defaultMode ? "검색어 입력" : `${visibleCount}개 결과`;
      }
      if (emptyNode) emptyNode.hidden = defaultMode || visibleCount !== 0;
      if (suggestionNode) suggestionNode.hidden = defaultMode || visibleCount !== 0;
      if (shouldTrack) track(visibleCount);
    }

    root.addEventListener("submit", (event) => {
      event.preventDefault();
      const firstResult = visibleItems()[0];
      if (firstResult instanceof HTMLAnchorElement) {
        window.location.href = firstResult.href;
      }
    });

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.dataset.homeCategoryFilter || "all";
        filterButtons.forEach((filterButton) => {
          filterButton.classList.toggle("is-active", filterButton === button);
        });
        applySearch({ shouldTrack: true });
      });
    });

    searchInput?.addEventListener("input", () => {
      applySearch();
      clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => {
        applySearch({ shouldTrack: true });
      }, 350);
    });

    const initialQuery = new URLSearchParams(window.location.search).get("q");
    if (searchInput && initialQuery) {
      searchInput.value = initialQuery.trim().slice(0, 80);
    }
    applySearch();
  })();
</script>
