---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { toolCategories, tools, type ToolCategoryId, type ToolId } from "@/data/tools";
import { toolItemListSchema, websiteSchema } from "@/data/seo";
import { prepShortcuts } from "@/data/prepShortcuts";

const structuredData = [websiteSchema(), toolItemListSchema(tools)];
const categoryById = new Map(toolCategories.map((category) => [category.id, category]));
const featuredToolIds: ToolId[] = [
  "transaction-statement",
  "jpg-to-pdf",
  "image-compressor",
  "heic-to-jpg"
];
const featuredToolSet = new Set<ToolId>(featuredToolIds);
const featuredTools = featuredToolIds
  .map((id) => tools.find((tool) => tool.id === id))
  .filter((tool): tool is (typeof tools)[number] => Boolean(tool));
const primaryShortcuts = prepShortcuts;
const toolIconById: Partial<Record<ToolId, string>> = {
  "transaction-statement": "file-text",
  "jpg-to-pdf": "file-stack",
  "image-compressor": "compress",
  "heic-to-jpg": "phone-image",
  "image-converter": "image",
  "image-resizer": "image",
  "image-cropper": "crop",
  "image-rotator": "rotate",
  "business-nameplate": "file-text",
  estimate: "file-text",
  receipt: "file-text",
  invoice: "file-text",
  "vat-calculator": "calculator",
  "amount-korean": "calculator",
  "withholding-tax": "calculator",
  "stamp-background": "stamp"
};
const categoryIconById: Record<ToolCategoryId, string> = {
  business: "file-text",
  pdf: "file-stack",
  image: "image"
};
const shortcutIconById: Record<string, string> = {
  "format-jpg": "alert",
  "heic-jpg": "phone-image",
  "compress-1mb": "compress",
  "resize-long-1200": "image",
  "rotate-right": "rotate",
  "crop-document": "crop",
  "bundle-jpg-pdf": "file-stack"
};
function iconForTool(toolId: ToolId) {
  return toolIconById[toolId] ?? "file-text";
}
---

<BaseLayout
  title="K문서툴 - 무료 업무 문서 도구"
  description="제출용 파일 준비, 사업자 명판, 거래명세서, 견적서, 청구서, 영수증, 부가세 계산, 도장 배경 제거, JPG PDF 변환, 사진 용량 줄이기, 이미지 리사이즈, 이미지 자르기, 이미지 회전, HEIC JPG 변환을 로그인 없이 사용하는 한국형 무료 문서 도구입니다."
  structuredData={structuredData}
>
  <main class="page-shell home-page" data-page-type="home">
    <svg aria-hidden="true" class="home-icons">
      <symbol id="icon-search" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.2-3.2"></path>
      </symbol>
      <symbol id="icon-grid" viewBox="0 0 24 24">
        <rect x="3" y="3" width="7" height="7" rx="1.5"></rect>
        <rect x="14" y="3" width="7" height="7" rx="1.5"></rect>
        <rect x="3" y="14" width="7" height="7" rx="1.5"></rect>
        <rect x="14" y="14" width="7" height="7" rx="1.5"></rect>
      </symbol>
      <symbol id="icon-file-text" viewBox="0 0 24 24">
        <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"></path>
        <path d="M14 2v5h5"></path>
        <path d="M8 13h8"></path>
        <path d="M8 17h5"></path>
      </symbol>
      <symbol id="icon-file-stack" viewBox="0 0 24 24">
        <path d="M8 7V5a2 2 0 0 1 2-2h6l4 4v10a2 2 0 0 1-2 2h-2"></path>
        <path d="M16 3v5h4"></path>
        <path d="M4 9h7l4 4v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2z"></path>
        <path d="M11 9v4h4"></path>
      </symbol>
      <symbol id="icon-image" viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="16" rx="2"></rect>
        <circle cx="8.5" cy="9" r="1.5"></circle>
        <path d="m21 16-5-5L5 20"></path>
      </symbol>
      <symbol id="icon-phone-image" viewBox="0 0 24 24">
        <rect x="7" y="2.5" width="10" height="19" rx="2.4"></rect>
        <path d="M10 6h4"></path>
        <path d="M10 15.5 12 13l5 5"></path>
        <circle cx="10.5" cy="10.5" r="1"></circle>
      </symbol>
      <symbol id="icon-compress" viewBox="0 0 24 24">
        <path d="M8 3v5H3"></path>
        <path d="M3 8 9 2"></path>
        <path d="M16 21v-5h5"></path>
        <path d="m21 16-6 6"></path>
        <path d="M21 8h-5V3"></path>
        <path d="m15 9 6-6"></path>
        <path d="M3 16h5v5"></path>
        <path d="m9 15-6 6"></path>
      </symbol>
      <symbol id="icon-alert" viewBox="0 0 24 24">
        <path d="M12 9v4"></path>
        <path d="M12 17h.01"></path>
        <path d="M10.3 3.8 2.6 17.1A2 2 0 0 0 4.3 20h15.4a2 2 0 0 0 1.7-2.9L13.7 3.8a2 2 0 0 0-3.4 0z"></path>
      </symbol>
      <symbol id="icon-crop" viewBox="0 0 24 24">
        <path d="M6 2v14a2 2 0 0 0 2 2h14"></path>
        <path d="M18 22V8a2 2 0 0 0-2-2H2"></path>
      </symbol>
      <symbol id="icon-rotate" viewBox="0 0 24 24">
        <path d="M21 12a9 9 0 1 1-3-6.7"></path>
        <path d="M21 3v6h-6"></path>
      </symbol>
      <symbol id="icon-calculator" viewBox="0 0 24 24">
        <rect x="5" y="2" width="14" height="20" rx="2"></rect>
        <path d="M8 6h8"></path>
        <path d="M8 10h.01"></path>
        <path d="M12 10h.01"></path>
        <path d="M16 10h.01"></path>
        <path d="M8 14h.01"></path>
        <path d="M12 14h.01"></path>
        <path d="M16 14h.01"></path>
        <path d="M8 18h.01"></path>
        <path d="M12 18h.01"></path>
        <path d="M16 18h.01"></path>
      </symbol>
      <symbol id="icon-stamp" viewBox="0 0 24 24">
        <path d="M9 13h6l1 6H8z"></path>
        <path d="M12 13V4"></path>
        <path d="M9 7h6"></path>
        <path d="M6 21h12"></path>
      </symbol>
    </svg>

    <section class="home-console" aria-label="K문서툴 홈">
      <aside class="home-sidebar" aria-label="도구 분류">
        <a class="home-side-link is-active" href="/">
          <svg class="home-icon" aria-hidden="true"><use href="#icon-grid"></use></svg>
          <span>도구 바로 쓰기</span>
          <em>{tools.length}</em>
        </a>
        {
          toolCategories.map((category) => (
            <a class="home-side-link" href={category.path}>
              <svg class="home-icon" aria-hidden="true">
                <use href={`#icon-${categoryIconById[category.id]}`}></use>
              </svg>
              <span>{category.shortTitle}</span>
              <em>{tools.filter((tool) => tool.category === category.id).length}</em>
            </a>
          ))
        }
      </aside>

      <section class="home-workbench">
        <div class="home-main-head">
          <div>
            <h1>도구 바로 쓰기</h1>
            <p>검색하고 바로 실행하세요.</p>
          </div>
          <a
            class="home-all-link"
            href="/tools/"
            data-analytics-event="home_search_all_tools_click"
            data-analytics-label="전체 도구"
          >
            전체 {tools.length}개
          </a>
        </div>

        <form class="hero-search" data-home-tool-search role="search">
          <label class="hero-search-field">
            <span class="visually-hidden">도구 검색</span>
            <svg class="home-search-icon" aria-hidden="true"><use href="#icon-search"></use></svg>
            <input
              type="search"
              autocomplete="off"
              inputmode="search"
              placeholder="PDF, HEIC, 거래명세서"
              data-home-search-input
            />
            <kbd>Enter</kbd>
          </label>

          <div class="home-filter-list" aria-label="카테고리 필터">
            <button class="is-active" type="button" data-home-category-filter="all">전체</button>
            {
              toolCategories.map((category) => (
                <button type="button" data-home-category-filter={category.id}>
                  {category.shortTitle}
                </button>
              ))
            }
          </div>

          <div class="hero-search-meta">
            <span data-home-search-count>인기 도구 {featuredTools.length}개</span>
          </div>

          <div class="hero-search-results">
            {
              tools.map((tool) => (
                <a
                  class:list={{
                    "hero-search-row": true,
                    "is-default": featuredToolSet.has(tool.id)
                  }}
                  href={tool.path}
                  hidden={!featuredToolSet.has(tool.id)}
                  data-home-search-item
                  data-home-search-category={tool.category}
                  data-default-visible={featuredToolSet.has(tool.id) ? "true" : "false"}
                  data-analytics-event="home_search_tool_click"
                  data-analytics-tool-id={tool.id}
                  data-analytics-tool-title={tool.title}
                  data-analytics-label={tool.title}
                  data-home-search-text={[
                    tool.title,
                    tool.shortTitle,
                    tool.primaryQuery,
                    ...tool.secondaryQueries,
                    tool.description,
                    tool.userMoment,
                    categoryById.get(tool.category)?.title ?? ""
                  ].join(" ")}
                >
                  <span class="home-icon-tile">
                    <svg class="home-icon" aria-hidden="true">
                      <use href={`#icon-${iconForTool(tool.id)}`}></use>
                    </svg>
                  </span>
                  <span class="home-row-copy">
                    <strong>{tool.title}</strong>
                    <span>{categoryById.get(tool.category)?.shortTitle}</span>
                  </span>
                  <em aria-hidden="true">실행</em>
                </a>
              ))
            }
          </div>
          <p class="hero-search-empty" data-home-search-empty hidden>
            결과 없음
          </p>
        </form>
      </section>

      <aside class="home-issue-panel" aria-label="자주 발생하는 문제" data-prep-shortcuts>
        <h2>자주 발생하는 문제</h2>
        <div class="home-shortcut-stack">
          {
            primaryShortcuts.map((shortcut) => (
              <a
                class="home-problem-row"
                href={shortcut.path}
                data-analytics-event="home_prep_shortcut_click"
                data-analytics-shortcut-id={shortcut.id}
                data-analytics-tool-id={shortcut.targetToolId}
                data-analytics-tool-title={shortcut.targetToolTitle}
                data-analytics-target-preset={shortcut.targetPreset}
                data-analytics-label={shortcut.label}
              >
                <span class="home-icon-tile">
                  <svg class="home-icon" aria-hidden="true">
                    <use href={`#icon-${shortcutIconById[shortcut.id] ?? "alert"}`}></use>
                  </svg>
                </span>
                <strong>{shortcut.label}</strong>
                <em aria-hidden="true">실행</em>
              </a>
            ))
          }
        </div>
      </aside>
    </section>

    <section class="content-section home-catalog-summary">
      <div class="section-heading">
        <h2>전체 도구</h2>
        <a class="section-mini-link" href="/tools/">목록 보기</a>
      </div>
      <div class="home-tool-groups">
        {
          toolCategories.map((category) => (
            <section class="home-tool-group">
              <h3>{category.shortTitle}</h3>
              <div class="home-tool-chip-list">
                {tools
                  .filter((tool) => tool.category === category.id)
                  .map((tool) => (
                    <a
                      class="home-tool-chip"
                      href={tool.path}
                      data-home-all-tool
                      data-analytics-event="home_all_tool_click"
                      data-analytics-tool-id={tool.id}
                      data-analytics-tool-title={tool.title}
                      data-analytics-label={tool.title}
                    >
                      <span>{tool.title}</span>
                      <em aria-hidden="true">실행</em>
                    </a>
                  ))}
              </div>
            </section>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-home-tool-search]");
    if (!root) return;

    const searchInput = root.querySelector("[data-home-search-input]");
    const items = Array.from(root.querySelectorAll("[data-home-search-item]"));
    const filterButtons = Array.from(root.querySelectorAll("[data-home-category-filter]"));
    const countNode = root.querySelector("[data-home-search-count]");
    const emptyNode = root.querySelector("[data-home-search-empty]");
    const defaultCount = items.filter((item) => item.dataset.defaultVisible === "true").length;
    let activeCategory = "all";
    let searchTimer = 0;

    function normalize(value) {
      return String(value || "").toLowerCase().replace(/\s+/g, " ").trim();
    }

    function visibleItems() {
      return items.filter((item) => !item.hidden);
    }

    function track(visibleCount) {
      window.kdocTrack?.("home_search_change", {
        search_query_length: normalize(searchInput?.value).length,
        search_category: activeCategory,
        visible_count: visibleCount
      });
    }

    function applySearch({ shouldTrack } = {}) {
      const query = normalize(searchInput?.value);
      let visibleCount = 0;

      items.forEach((item) => {
        const matchesQuery = query ? normalize(item.dataset.homeSearchText).includes(query) : true;
        const matchesCategory =
          activeCategory === "all" || item.dataset.homeSearchCategory === activeCategory;
        const defaultVisible =
          !query && activeCategory === "all" ? item.dataset.defaultVisible === "true" : true;
        const visible = matchesQuery && matchesCategory && defaultVisible;
        item.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (countNode) {
        if (query || activeCategory !== "all") {
          countNode.textContent = `${visibleCount}개 결과`;
        } else {
          countNode.textContent = `인기 도구 ${defaultCount}개`;
        }
      }
      if (emptyNode) emptyNode.hidden = visibleCount !== 0;
      if (shouldTrack) track(visibleCount);
    }

    root.addEventListener("submit", (event) => {
      event.preventDefault();
      const firstResult = visibleItems()[0];
      if (firstResult instanceof HTMLAnchorElement) {
        window.location.href = firstResult.href;
      }
    });

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.dataset.homeCategoryFilter || "all";
        filterButtons.forEach((filterButton) => {
          filterButton.classList.toggle("is-active", filterButton === button);
        });
        applySearch({ shouldTrack: true });
      });
    });

    searchInput?.addEventListener("input", () => {
      applySearch();
      clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => {
        applySearch({ shouldTrack: true });
      }, 350);
    });

    applySearch();
  })();
</script>
