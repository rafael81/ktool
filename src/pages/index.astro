---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { toolCategories, tools, type ToolId } from "@/data/tools";
import { problemPages } from "@/data/problemPages";
import { toolItemListSchema, webPageSchema, websiteSchema } from "@/data/seo";
import {
  Archive,
  ArrowRight,
  Calculator,
  Crop,
  FileText,
  Files,
  Image,
  RotateCw,
  Search,
  Smartphone,
  Stamp,
  Video,
  type IconProps
} from "@lucide/astro";

const homeTitle = "K문서툴 - 무료 PDF 이미지 문서 도구";
const homeDescription =
  "설치 없이 쓰는 무료 PDF·이미지·업무 문서 도구입니다. JPG PDF, 사진 1MB 줄이기, HEIC JPG, 사업자 명판까지 브라우저에서 처리하고 파일은 서버로 전송되지 않습니다.";
const structuredData = [
  websiteSchema(),
  webPageSchema({
    name: "K문서툴",
    description: homeDescription,
    path: "/",
    keywords: [
      "무료 문서 도구",
      "무료 PDF 도구",
      "무료 이미지 변환",
      "사업자 명판 만들기",
      "파일 서버 전송 없음"
    ]
  }),
  toolItemListSchema(tools)
];
const categoryById = new Map(toolCategories.map((category) => [category.id, category]));
const toolCountLabel = `${tools.length}종`;
const homeQuickStarts: {
  label: string;
  detail: string;
  path: string;
  toolId: ToolId;
  preset?: string;
}[] = [
  {
    label: "JPG PDF",
    detail: "여러 장 묶기",
    path: "/tools/jpg-to-pdf-converter/?from=quick-start&source=home-quick-start",
    toolId: "jpg-to-pdf"
  },
  {
    label: "사진 1MB",
    detail: "용량 줄이기",
    path: "/tools/photo-size-reducer/?preset=1mb&source=home-quick-start",
    toolId: "image-compressor",
    preset: "1mb"
  },
  {
    label: "HEIC JPG",
    detail: "아이폰 사진",
    path: "/tools/heic-jpg-converter/?preset=jpg&source=home-quick-start",
    toolId: "heic-to-jpg",
    preset: "jpg"
  },
  {
    label: "거래명세서",
    detail: "문서 작성",
    path: "/tools/transaction-statement-generator/?source=home-quick-start",
    toolId: "transaction-statement"
  },
  {
    label: "명판 PNG",
    detail: "도장 합성",
    path: "/tools/business-nameplate-maker/?source=home-quick-start",
    toolId: "business-nameplate"
  }
];
const emptySearchLinks = [
  { label: "사진 용량 줄이기", path: "/tools/photo-size-reducer/" },
  { label: "JPG PDF 변환", path: "/tools/jpg-to-pdf-converter/" },
  { label: "HEIC JPG 변환", path: "/tools/heic-jpg-converter/" },
  { label: "문제 해결", path: "/problems/" }
];
type LucideIcon = (_props: IconProps) => unknown;
const toolIconById: Partial<Record<ToolId, LucideIcon>> = {
  "transaction-statement": FileText,
  "pdf-edit": FileText,
  "pdf-split-half": Files,
  "pdf-two-up": Files,
  "pdf-crop": Crop,
  "pdf-text-extract": FileText,
  "pdf-split": Files,
  "pdf-delete-pages": Files,
  "pdf-merge": Files,
  "pdf-to-image": Files,
  "jpg-to-pdf": Files,
  "photo-date-stamp": Image,
  "photo-merge": Image,
  "image-compressor": Archive,
  "heic-to-jpg": Smartphone,
  "image-converter": Image,
  "svg-crop": Crop,
  "image-base64": Image,
  "video-to-gif": Video,
  "image-resizer": Image,
  "image-cropper": Crop,
  "image-rotator": RotateCw,
  "business-nameplate": FileText,
  estimate: FileText,
  receipt: FileText,
  invoice: FileText,
  "vat-calculator": Calculator,
  "amount-korean": Calculator,
  "withholding-tax": Calculator,
  "stamp-background": Stamp
};
function iconForTool(toolId: ToolId) {
  return toolIconById[toolId] ?? FileText;
}
---

<BaseLayout
  title={homeTitle}
  description={homeDescription}
  structuredData={structuredData}
>
  <main class="hallmark-home" data-page-type="home" data-tool-count={tools.length}>
    <section class="hallmark-command-head" aria-labelledby="home-title">
      <div class="hallmark-identity">
        <svg class="hallmark-mascot" viewBox="0 0 76 84" aria-hidden="true">
          <g class="hallmark-mascot-ear"><path d="M18 22 7 31l12 8Z" /></g>
          <path class="hallmark-mascot-page" d="M24 6h25l17 17v43a12 12 0 0 1-12 12H24a12 12 0 0 1-12-12V18A12 12 0 0 1 24 6Z" />
          <path class="hallmark-mascot-fold" d="M49 6v11a6 6 0 0 0 6 6h11Z" />
          <circle class="hallmark-mascot-eye" cx="29" cy="34" r="2.3" />
          <circle class="hallmark-mascot-eye" cx="49" cy="34" r="2.3" />
          <path class="hallmark-mascot-smile" d="M32 43c4 5 10 5 14 0" />
          <path class="hallmark-mascot-shield" d="M39 49l11 4v10c0 7-4 11-11 13-7-2-11-6-11-13V53l11-4Z" />
          <path class="hallmark-mascot-check" d="m34 62 4 4 7-9" />
        </svg>
        <div class="hallmark-identity-copy">
          <h1 id="home-title">K문서툴</h1>
          <p>설치 없이 쓰는 무료 도구 {toolCountLabel}</p>
          <div class="hallmark-trust-line" aria-label="서비스 특징">
            <span>무료</span>
            <span>설치 없음</span>
            <span>서버 전송 없음</span>
          </div>
        </div>
      </div>

      <form id="tool-search" class="hallmark-command-panel" data-home-tool-search role="search">
        <label class="hallmark-search-box">
          <span class="visually-hidden">도구 검색</span>
          <Search aria-hidden="true" />
          <input
            type="search"
            autocomplete="off"
            inputmode="search"
            placeholder="필요한 작업을 입력하세요"
            aria-label="도구와 문제 검색"
            data-home-search-input
          />
          <kbd>Enter</kbd>
        </label>

        <nav class="hallmark-quick-rail" aria-label="빠른 시작">
          {
            homeQuickStarts.slice(0, 4).map((item) => {
              const tool = tools.find((toolItem) => toolItem.id === item.toolId);
              if (!tool) return null;
              const QuickIcon = iconForTool(item.toolId);

              return (
                <a
                  class="hallmark-quick-link"
                  href={item.path}
                  data-home-quick-start
                  data-analytics-event="home_quick_start_click"
                  data-analytics-tool-id={tool.id}
                  data-analytics-tool-title={tool.title}
                  data-analytics-target-preset={item.preset}
                  data-analytics-label={item.label}
                >
                  <QuickIcon aria-hidden="true" />
                  <span>
                    <strong>{item.label}</strong>
                    <small>{item.detail}</small>
                  </span>
                </a>
              );
            })
          }
        </nav>

        <div class="hallmark-search-results" data-home-search-results hidden>
          {
            tools.map((tool) => {
              const ToolIcon = iconForTool(tool.id);

              return (
                <a
                  class="hallmark-search-row"
                  href={tool.path}
                  hidden
                  data-home-search-item
                  data-category={tool.category}
                  data-home-search-category={tool.category}
                  data-analytics-event="home_search_tool_click"
                  data-analytics-tool-id={tool.id}
                  data-analytics-tool-title={tool.title}
                  data-analytics-label={tool.title}
                  data-home-search-text={[
                    tool.title,
                    tool.shortTitle,
                    tool.primaryQuery,
                    ...tool.secondaryQueries,
                    tool.description,
                    tool.userMoment,
                    categoryById.get(tool.category)?.title ?? ""
                  ].join(" ")}
                >
                  <span class="hallmark-row-icon" data-category={tool.category}>
                    <ToolIcon aria-hidden="true" />
                  </span>
                  <span class="hallmark-row-copy">
                    <strong>{tool.title}</strong>
                    <span>{tool.shortTitle}</span>
                  </span>
                  <ArrowRight class="hallmark-row-arrow" aria-hidden="true" />
                </a>
              );
            })
          }
          {
            problemPages.map((problemPage) => {
              const targetTool = tools.find((tool) => tool.id === problemPage.targetToolId);
              if (!targetTool) return null;
              const ProblemIcon = iconForTool(targetTool.id);

              return (
                <a
                  class="hallmark-search-row"
                  href={problemPage.path}
                  hidden
                  data-home-search-item
                  data-category={targetTool.category}
                  data-home-search-category={targetTool.category}
                  data-default-visible="false"
                  data-analytics-event="home_search_problem_click"
                  data-analytics-tool-id={targetTool.id}
                  data-analytics-tool-title={targetTool.title}
                  data-analytics-target-preset={problemPage.targetPreset}
                  data-analytics-label={problemPage.title}
                  data-home-search-text={[
                    problemPage.title,
                    problemPage.shortTitle,
                    problemPage.primaryQuery,
                    ...problemPage.secondaryQueries,
                    ...problemPage.intentQueries,
                    problemPage.description,
                    problemPage.actionNote,
                    targetTool.title,
                    targetTool.shortTitle,
                    categoryById.get(targetTool.category)?.title ?? ""
                  ].join(" ")}
                >
                  <span class="hallmark-row-icon" data-category={targetTool.category}>
                    <ProblemIcon aria-hidden="true" />
                  </span>
                  <span class="hallmark-row-copy">
                    <strong>{problemPage.title}</strong>
                    <span>{problemPage.shortTitle}</span>
                  </span>
                  <ArrowRight class="hallmark-row-arrow" aria-hidden="true" />
                </a>
              );
            })
          }
        </div>
        <div class="hallmark-search-empty" data-home-search-empty hidden>
          <p>검색 결과가 없습니다.</p>
          <div data-home-search-suggestions hidden>
            {emptySearchLinks.map((link) => <a href={link.path}>{link.label}</a>)}
          </div>
        </div>
      </form>
    </section>

    <section class="hallmark-catalogue" aria-labelledby="home-catalog-title">
      <aside class="hallmark-catalogue-nav">
        <h2 id="home-catalog-title">전체 도구</h2>
        <div class="hallmark-category-tabs" aria-label="카테고리 필터">
          <button class="is-active" type="button" data-home-category-filter="all">전체 {tools.length}</button>
          {toolCategories.map((category) => (
            <button type="button" data-home-category-filter={category.id}>
              {category.shortTitle} {tools.filter((tool) => tool.category === category.id).length}
            </button>
          ))}
        </div>
        <div class="hallmark-catalogue-meta">
          <span data-home-search-count>{tools.length}개 표시</span>
          <a href="/problems/">문제 해결</a>
        </div>
      </aside>

      <div class="hallmark-tool-index">
        {tools.map((tool) => {
          const ToolIcon = iconForTool(tool.id);
          return (
            <a
              class="hallmark-tool-row"
              href={tool.path}
              data-home-index-tool
              data-category={tool.category}
              data-home-index-category={tool.category}
              data-home-index-search={[
                tool.title,
                tool.shortTitle,
                tool.primaryQuery,
                ...tool.secondaryQueries,
                tool.description,
                tool.userMoment,
                categoryById.get(tool.category)?.title ?? ""
              ].join(" ")}
              data-analytics-event="home_all_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="hallmark-row-icon" data-category={tool.category} aria-hidden="true">
                <ToolIcon />
              </span>
              <span class="hallmark-row-copy">
                <strong>{tool.title}</strong>
                <span>{tool.shortTitle}</span>
              </span>
              <ArrowRight class="hallmark-row-arrow" aria-hidden="true" />
            </a>
          );
        })}
        <p class="hallmark-index-empty" data-home-index-empty hidden>검색 결과가 없습니다.</p>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-home-tool-search]");
    if (!root) return;

    const searchInput = root.querySelector("[data-home-search-input]");
    const items = Array.from(root.querySelectorAll("[data-home-search-item]"));
    const resultsNode = root.querySelector("[data-home-search-results]");
    const indexItems = Array.from(document.querySelectorAll("[data-home-index-tool]"));
    const filterButtons = Array.from(document.querySelectorAll("[data-home-category-filter]"));
    const countNode = document.querySelector("[data-home-search-count]");
    const emptyNode = root.querySelector("[data-home-search-empty]");
    const suggestionNode = root.querySelector("[data-home-search-suggestions]");
    const indexEmptyNode = document.querySelector("[data-home-index-empty]");
    let activeCategory = "all";
    let searchTimer = 0;

    function normalize(value) {
      return String(value || "").toLowerCase().replace(/\s+/g, " ").trim();
    }

    function track(visibleCount) {
      window.kdocTrack?.("home_search_change", {
        search_query_length: normalize(searchInput?.value).length,
        search_category: activeCategory,
        visible_count: visibleCount
      });
    }

    function applySearch({ shouldTrack } = {}) {
      const query = normalize(searchInput?.value);
      let searchVisibleCount = 0;
      let indexVisibleCount = 0;

      items.forEach((item) => {
        const matchesQuery = query ? normalize(item.dataset.homeSearchText).includes(query) : true;
        const matchesCategory =
          activeCategory === "all" || item.dataset.homeSearchCategory === activeCategory;
        const visible = Boolean(query) && matchesQuery && matchesCategory;
        item.hidden = !visible;
        if (visible) searchVisibleCount += 1;
      });

      indexItems.forEach((item) => {
        const matchesQuery = query ? normalize(item.dataset.homeIndexSearch).includes(query) : true;
        const matchesCategory =
          activeCategory === "all" || item.dataset.homeIndexCategory === activeCategory;
        const visible = matchesQuery && matchesCategory;
        item.hidden = !visible;
        if (visible) indexVisibleCount += 1;
      });

      if (resultsNode) resultsNode.hidden = !query;
      if (countNode) countNode.textContent = `${indexVisibleCount}개 표시`;
      if (emptyNode) emptyNode.hidden = !query || searchVisibleCount !== 0;
      if (suggestionNode) suggestionNode.hidden = !query || searchVisibleCount !== 0;
      if (indexEmptyNode) indexEmptyNode.hidden = indexVisibleCount !== 0;
      if (shouldTrack) track(indexVisibleCount);
    }

    root.addEventListener("submit", (event) => {
      event.preventDefault();
      const firstResult = items.find((item) => !item.hidden) ?? indexItems.find((item) => !item.hidden);
      if (firstResult instanceof HTMLAnchorElement) {
        window.location.href = firstResult.href;
      }
    });

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.dataset.homeCategoryFilter || "all";
        filterButtons.forEach((filterButton) => {
          filterButton.classList.toggle("is-active", filterButton === button);
        });
        applySearch({ shouldTrack: true });
      });
    });

    searchInput?.addEventListener("input", () => {
      applySearch();
      clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => {
        applySearch({ shouldTrack: true });
      }, 350);
    });

    const initialQuery = new URLSearchParams(window.location.search).get("q");
    if (searchInput && initialQuery) {
      searchInput.value = initialQuery.trim().slice(0, 80);
    }
    applySearch();
  })();
</script>

<style>
  .hallmark-home {
    --hallmark-ink: #111827;
    --hallmark-muted: #667085;
    --hallmark-rule: #d0d5dd;
    --hallmark-rule-soft: #eaecf0;
    --hallmark-canvas: #f6f7f9;
    --hallmark-business: #155eef;
    --hallmark-business-soft: #eff4ff;
    --hallmark-pdf: #be123c;
    --hallmark-pdf-soft: #fff1f3;
    --hallmark-image: #9a4708;
    --hallmark-image-soft: #fff8eb;
    width: min(1180px, 100%);
    margin: 0 auto;
    padding: 32px 24px 72px;
    color: var(--hallmark-ink);
  }

  .hallmark-command-head {
    display: grid;
    grid-template-columns: minmax(250px, 0.72fr) minmax(0, 1.6fr);
    gap: 48px;
    align-items: center;
    padding: 12px 0 34px;
  }

  .hallmark-identity {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 16px;
    align-items: center;
  }

  .hallmark-mascot {
    width: 66px;
    height: 72px;
  }

  .hallmark-mascot-page,
  .hallmark-mascot-fold,
  .hallmark-mascot-ear path {
    stroke: var(--hallmark-ink);
    stroke-width: 2.2;
    stroke-linejoin: round;
  }

  .hallmark-mascot-page { fill: #fff; }
  .hallmark-mascot-fold,
  .hallmark-mascot-ear path { fill: var(--hallmark-business-soft); }
  .hallmark-mascot-eye { fill: var(--hallmark-ink); }
  .hallmark-mascot-smile {
    fill: none;
    stroke: var(--hallmark-ink);
    stroke-width: 2.2;
    stroke-linecap: round;
  }
  .hallmark-mascot-shield {
    fill: var(--hallmark-business);
    stroke: var(--hallmark-ink);
    stroke-width: 1.6;
    stroke-linejoin: round;
  }
  .hallmark-mascot-check {
    fill: none;
    stroke: #fff;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .hallmark-mascot-ear {
    transform-origin: 19px 24px;
    animation: hallmark-ear-wave 4.8s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }

  .hallmark-identity-copy { min-width: 0; }
  .hallmark-identity-copy h1 {
    margin: 0;
    color: var(--hallmark-ink);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.1;
  }
  .hallmark-identity-copy > p {
    margin: 7px 0 0;
    color: var(--hallmark-muted);
    font-size: 13px;
    line-height: 1.4;
  }
  .hallmark-trust-line {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    margin-top: 10px;
    color: var(--hallmark-ink);
    font-size: 12px;
    font-weight: 700;
  }
  .hallmark-trust-line span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .hallmark-trust-line span::before {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--hallmark-business);
    content: "";
  }

  .hallmark-command-panel { min-width: 0; }
  .hallmark-search-box {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    min-height: 58px;
    align-items: center;
    gap: 12px;
    border: 2px solid var(--hallmark-ink);
    border-radius: 6px;
    background: #fff;
    padding: 0 16px;
  }
  .hallmark-search-box:focus-within {
    border-color: var(--hallmark-business);
    outline: 3px solid var(--hallmark-business-soft);
  }
  .hallmark-search-box > svg {
    width: 20px;
    height: 20px;
    color: var(--hallmark-muted);
  }
  .hallmark-search-box input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--hallmark-ink);
    font: inherit;
    font-size: 16px;
    font-weight: 650;
  }
  .hallmark-search-box input::placeholder { color: #858c9b; opacity: 1; }
  .hallmark-search-box kbd {
    border: 1px solid var(--hallmark-rule);
    border-radius: 4px;
    background: var(--hallmark-canvas);
    color: var(--hallmark-muted);
    font-family: inherit;
    font-size: 11px;
    padding: 3px 6px;
  }

  .hallmark-quick-rail {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin-top: 12px;
    border: 1px solid var(--hallmark-rule);
    background: var(--hallmark-rule);
  }
  .hallmark-quick-link {
    display: flex;
    min-width: 0;
    min-height: 58px;
    align-items: center;
    gap: 10px;
    background: #fff;
    color: var(--hallmark-ink);
    padding: 10px 12px;
  }
  .hallmark-quick-link:hover,
  .hallmark-quick-link:focus-visible { background: #f9fafb; outline: none; }
  .hallmark-quick-link > svg {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
  }
  .hallmark-quick-link > span {
    display: grid;
    min-width: 0;
  }
  .hallmark-quick-link strong,
  .hallmark-quick-link small {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .hallmark-quick-link strong { font-size: 12px; line-height: 1.35; }
  .hallmark-quick-link small { color: var(--hallmark-muted); font-size: 10.5px; }

  .hallmark-search-results {
    max-height: 384px;
    margin-top: 10px;
    overflow-y: auto;
    border: 1px solid var(--hallmark-rule);
    background: #fff;
  }
  .hallmark-search-results[hidden] { display: none; }
  .hallmark-search-row,
  .hallmark-tool-row {
    --hallmark-row-accent: var(--hallmark-business);
    --hallmark-row-soft: var(--hallmark-business-soft);
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 13px;
    border-bottom: 1px solid var(--hallmark-rule-soft);
    background: #fff;
    color: var(--hallmark-ink);
  }
  .hallmark-search-row { min-height: 64px; padding: 10px 12px; }
  .hallmark-tool-row { min-height: 74px; padding: 12px; }
  .hallmark-search-row[hidden],
  .hallmark-tool-row[hidden] { display: none; }
  .hallmark-search-row:hover,
  .hallmark-search-row:focus-visible,
  .hallmark-tool-row:hover,
  .hallmark-tool-row:focus-visible { background: var(--hallmark-row-soft); outline: none; }
  .hallmark-search-row[data-category="pdf"],
  .hallmark-tool-row[data-category="pdf"] {
    --hallmark-row-accent: var(--hallmark-pdf);
    --hallmark-row-soft: var(--hallmark-pdf-soft);
  }
  .hallmark-search-row[data-category="image"],
  .hallmark-tool-row[data-category="image"] {
    --hallmark-row-accent: var(--hallmark-image);
    --hallmark-row-soft: var(--hallmark-image-soft);
  }

  .hallmark-row-icon {
    display: grid;
    width: 38px;
