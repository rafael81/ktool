---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { toolCategories, tools } from "@/data/tools";
import { toolItemListSchema, websiteSchema } from "@/data/seo";

const structuredData = [websiteSchema(), toolItemListSchema(tools)];
---

<BaseLayout
  title="K문서툴 - 무료 업무 문서 도구"
  description="사업자 명판, 거래명세서, 견적서, 청구서, 영수증, 부가세 계산, 금액 한글 변환, 3.3% 계산, 도장 배경 제거, JPG PDF 변환, 사진 용량 줄이기, 이미지 리사이즈, WebP JPG 변환, HEIC JPG 변환을 로그인 없이 브라우저에서 사용하는 한국형 무료 문서 도구입니다."
  structuredData={structuredData}
>
  <main class="page-shell" data-page-type="home">
    <section class="tool-intro">
      <div>
        <h1>K문서툴로 문서 제출 직전을 가볍게</h1>
        <p>
          사업자 명판, 거래명세서, 견적서, 청구서, 영수증, 부가세 계산, 금액 한글 변환, 3.3% 계산, 도장 배경 제거, JPG PDF 변환, 사진 용량 줄이기, 이미지 리사이즈, WebP JPG 변환, HEIC JPG 변환을 브라우저에서 바로 사용하세요. 한국 업무 문서에
          필요한 작은 도구를 로그인 없이 빠르게 제공합니다.
        </p>
      </div>
      <div class="quick-links" aria-label="도구 바로가기">
        <a
          href="/tools/"
          data-analytics-event="catalog_quick_link_click"
          data-analytics-label="전체 도구"
        >
          전체 도구
        </a>
        {
          toolCategories.map((category) => (
            <a
              href={category.path}
              data-analytics-event="category_quick_link_click"
              data-analytics-label={category.shortTitle}
            >
              {category.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>사용 가능한 도구</h2>
        <p>검색으로 들어온 사용자가 바로 제출용 문서와 파일을 만들 수 있는 도구부터 확장합니다.</p>
      </div>
      <div class="tool-grid">
        {
          tools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="home_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.description}</p>
              <p class="trust-note">{tool.trustNote}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>카테고리</h2>
        <p>업무 문서 도구에서 시작해, 브라우저에서 안전하게 처리할 수 있는 PDF와 이미지 도구로 확장합니다.</p>
      </div>
      <div class="tool-grid">
        {
          toolCategories.map((category) => (
            <a
              class="tool-card"
              href={category.path}
              data-analytics-event="home_category_click"
              data-analytics-label={category.title}
            >
              <span class="meta">
                <span class={`meta-tag${category.status === "planned" ? " muted" : ""}`}>
                  {category.status === "active" ? "운영 중" : "준비 중"}
                </span>
              </span>
              <strong>{category.title}</strong>
              <p>{category.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
