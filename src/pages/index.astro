---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { tools } from "@/data/tools";
import { toolItemListSchema, websiteSchema } from "@/data/seo";

const structuredData = [websiteSchema(), toolItemListSchema(tools)];
---

<BaseLayout
  title="K문서툴 - 무료 업무 문서 도구"
  description="사업자 명판, 거래명세서, 견적서를 로그인 없이 브라우저에서 작성하는 한국형 무료 업무 문서 도구입니다."
  structuredData={structuredData}
>
  <main class="page-shell" data-page-type="home">
    <section class="tool-intro">
      <div>
        <h1>K문서툴로 문서 제출 직전을 가볍게</h1>
        <p>
          사업자 명판, 거래명세서, 견적서를 브라우저에서 바로 작성하세요. 한국 업무 문서에
          필요한 작은 도구를 로그인 없이 빠르게 제공합니다.
        </p>
      </div>
      <div class="quick-links" aria-label="도구 바로가기">
        {
          tools.map((tool) => (
            <a
              href={tool.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.shortTitle}
            >
              {tool.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <h2>첫 도구</h2>
      <div class="home-tools">
        {
          tools.map((tool) => (
            <a
              class="home-tool"
              href={tool.path}
              data-analytics-event="home_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span>{tool.shortTitle}</span>
              <strong>{tool.title}</strong>
              <p>{tool.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home-tools {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .home-tool {
    display: grid;
    min-height: 190px;
    align-content: start;
    gap: 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 20px;
    box-shadow: var(--shadow);
  }

  .home-tool span {
    color: var(--accent);
    font-size: 13px;
    font-weight: 900;
  }

  .home-tool strong {
    color: var(--ink);
    font-size: 22px;
    line-height: 1.25;
  }

  .home-tool p {
    margin: 0;
  }

  @media (max-width: 800px) {
    .home-tools {
      grid-template-columns: 1fr;
    }
  }
</style>
