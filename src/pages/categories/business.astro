---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getToolCategory, getToolsByCategory } from "@/data/tools";
import { collectionPageSchema } from "@/data/seo";

const category = getToolCategory("business");
const businessTools = getToolsByCategory("business");
const submissionPrepPath = "/tools/submission-file-prep/";
const structuredData = [
  collectionPageSchema({
    name: category.title,
    description: category.description,
    path: category.path,
    tools: businessTools
  })
];
---

<BaseLayout
  title={`${category.title} - K문서툴`}
  description={category.description}
  canonicalPath={category.path}
  structuredData={structuredData}
>
  <main class="page-shell">
    <section class="tool-intro">
      <div>
        <h1>{category.title}</h1>
        <p>{category.description}</p>
      </div>
      <div class="quick-links" aria-label="업무 문서 도구 바로가기">
        <a
          href={submissionPrepPath}
          data-analytics-event="category_workflow_quick_link_click"
          data-analytics-label="제출용 파일 준비"
        >
          제출 준비
        </a>
        {
          businessTools.map((tool) => (
            <a
              href={tool.path}
              data-analytics-event="category_tool_quick_link_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.shortTitle}
            >
              {tool.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>문서 제출 흐름</h2>
        <p>작성한 문서에 도장·명판 이미지를 넣거나, 증빙 사진을 PDF로 묶어 함께 제출할 수 있습니다.</p>
      </div>
      <div class="tool-grid single-card-grid">
        <a
          class="tool-card"
          href={submissionPrepPath}
          data-analytics-event="category_workflow_click"
          data-analytics-label="제출용 파일 준비"
        >
          <span class="meta">
            <span class="meta-tag">제출용 파일 만들기</span>
          </span>
          <strong>제출용 파일 준비</strong>
          <p>거래 문서, 도장·명판 이미지, 증빙 사진, PDF 묶기를 제출 전 흐름으로 정리합니다.</p>
          <p class="trust-note">업무 문서와 파일 도구를 상황별로 연결하되 법적·세무 효력을 대신하지 않습니다.</p>
        </a>
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>문서 제출 직전 도구</h2>
        <p>회사 정보, 거래 내역, 견적 금액처럼 반복 입력이 많은 문서부터 빠르게 작성합니다.</p>
      </div>
      <div class="tool-grid">
        {
          businessTools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="category_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.userMoment}</p>
              <p class="trust-note">{tool.trustNote}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
