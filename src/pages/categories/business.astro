---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getToolCategory, getToolsByCategory } from "@/data/tools";
import { collectionPageSchema } from "@/data/seo";

const category = getToolCategory("business");
const businessTools = getToolsByCategory("business");
const structuredData = [
  collectionPageSchema({
    name: category.title,
    description: category.description,
    path: category.path,
    tools: businessTools
  })
];
---

<BaseLayout
  title={`${category.title} - K문서툴`}
  description={category.description}
  canonicalPath={category.path}
  structuredData={structuredData}
>
  <main class="page-shell">
    <section class="tool-intro">
      <div>
        <h1>{category.title}</h1>
        <p>{category.description}</p>
      </div>
      <div class="quick-links" aria-label="업무 문서 도구 바로가기">
        {
          businessTools.map((tool) => (
            <a
              href={tool.path}
              data-analytics-event="category_tool_quick_link_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.shortTitle}
            >
              {tool.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>문서 제출 직전 도구</h2>
        <p>회사 정보, 거래 내역, 견적 금액처럼 반복 입력이 많은 문서부터 빠르게 작성합니다.</p>
      </div>
      <div class="tool-grid">
        {
          businessTools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="category_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.userMoment}</p>
              <p class="trust-note">{tool.trustNote}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <h2>업무 문서 도구를 먼저 키우는 이유</h2>
      <p>
        PDF 합치기나 압축은 수요가 크지만 강한 해외 도구와 정면으로 경쟁합니다. K문서툴은
        먼저 한국 업무 문서처럼 검색 결과가 더 파편화된 영역에서 실제 사용 데이터를 쌓고,
        이후 PDF와 이미지 도구를 업무 흐름에 맞춰 붙입니다.
      </p>
    </section>
  </main>
</BaseLayout>
