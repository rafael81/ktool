---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getToolCategory, getToolsByCategory } from "@/data/tools";

const category = getToolCategory("pdf");
const businessTools = getToolsByCategory("business");
const plannedPdfTools = [
  "PDF 합치기",
  "PDF 나누기",
  "PDF 압축",
  "PDF JPG 변환",
  "JPG PDF 변환"
];
---

<BaseLayout
  title={`${category.title} - 준비 중 | K문서툴`}
  description={category.description}
  canonicalPath={category.path}
  robots="noindex,follow"
>
  <main class="page-shell">
    <section class="tool-intro">
      <div>
        <h1>{category.title}</h1>
        <p>{category.description}</p>
      </div>
      <div class="quick-links" aria-label="현재 사용 가능한 도구">
        {
          businessTools.map((tool) => (
            <a
              href={tool.path}
              data-analytics-event="planned_category_related_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.shortTitle}
            >
              {tool.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>준비 중인 PDF 도구</h2>
        <p>PDF 도구는 파일 크기, 브라우저 성능, 개인정보 처리 기준을 먼저 정한 뒤 추가합니다.</p>
      </div>
      <div class="tool-grid">
        {
          plannedPdfTools.map((title) => (
            <article class="tool-card">
              <span class="meta">
                <span class="meta-tag muted">준비 중</span>
              </span>
              <strong>{title}</strong>
              <p>
                한국 업무 문서 제출 흐름에 맞춰 브라우저 처리, 파일 제한, 진행 상태, 오류 복구를
                갖춘 뒤 공개할 예정입니다.
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <h2>왜 바로 PDF부터 만들지 않나요?</h2>
      <p>
        PDF 합치기, 나누기, 압축은 검색 수요가 크지만 iLovePDF, Adobe, Smallpdf, PDF24 같은
        강한 도구가 이미 자리 잡고 있습니다. K문서툴은 먼저 업무 문서 도구에서 사용 데이터를
        확인하고, 이후 개인정보와 성능 기준을 지키는 PDF 도구로 확장합니다.
      </p>
    </section>
  </main>
</BaseLayout>
