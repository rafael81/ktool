---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getToolCategory, getToolsByCategory } from "@/data/tools";
import { collectionPageSchema } from "@/data/seo";
import { prepShortcuts } from "@/data/prepShortcuts";

const category = getToolCategory("pdf");
const pdfTools = getToolsByCategory("pdf");
const submissionPrepPath = "/tools/submission-file-prep/";
const relatedTools = [...getToolsByCategory("image"), ...getToolsByCategory("business")].filter((tool) =>
  ["image-compressor", "stamp-background", "business-nameplate", "transaction-statement"].includes(tool.id)
);
const plannedPdfTools = ["PDF 합치기", "PDF 나누기", "PDF 압축", "PDF JPG 변환", "PDF 회전"];
const structuredData = [
  collectionPageSchema({
    name: category.title,
    description: category.description,
    path: category.path,
    tools: pdfTools
  })
];
---

<BaseLayout
  title={`${category.title} - K문서툴`}
  description={category.description}
  canonicalPath={category.path}
  structuredData={structuredData}
>
  <main class="page-shell">
    <section class="tool-intro">
      <div>
        <h1>{category.title}</h1>
        <p>{category.description} 사진으로 받은 서류, 스캔본, 증빙 이미지를 제출하기 쉬운 PDF로 정리합니다.</p>
      </div>
      <div class="quick-links" aria-label="PDF 도구 바로가기">
        <a
          href={submissionPrepPath}
          data-analytics-event="category_workflow_quick_link_click"
          data-analytics-label="제출용 파일 준비"
        >
          제출 준비
        </a>
        {
          pdfTools.map((tool) => (
            <a
              href={tool.path}
              data-analytics-event="category_tool_quick_link_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.shortTitle}
            >
              {tool.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>PDF 제출 흐름</h2>
        <p>사진과 스캔 이미지를 PDF로 묶기 전 형식, 크기, 용량을 먼저 맞출 수 있습니다.</p>
      </div>
      <div class="tool-grid single-card-grid">
        <a
          class="tool-card"
          href={submissionPrepPath}
          data-analytics-event="category_workflow_click"
          data-analytics-label="제출용 파일 준비"
        >
          <span class="meta">
            <span class="meta-tag">제출용 파일 만들기</span>
          </span>
          <strong>제출용 파일 준비</strong>
          <p>여러 이미지를 PDF로 묶기 전 HEIC 변환, 사진 용량 줄이기, 이미지 리사이즈 순서를 확인합니다.</p>
          <p class="trust-note">이미지 원본과 파일명은 서버로 보내지 않는 브라우저 처리 흐름을 우선합니다.</p>
        </a>
      </div>
    </section>

    <section class="content-section" data-prep-shortcuts>
      <div class="section-heading">
        <h2>PDF 만들기 전 바로가기</h2>
        <p>여러 장을 PDF로 묶기 전에 형식, 용량, 크기, 방향, 여백 문제를 먼저 정리합니다.</p>
      </div>
      <div class="tool-grid">
        {
          prepShortcuts.map((shortcut) => (
            <a
              class="tool-card"
              href={shortcut.path}
              data-analytics-event="category_prep_shortcut_click"
              data-analytics-shortcut-id={shortcut.id}
              data-analytics-tool-id={shortcut.targetToolId}
              data-analytics-tool-title={shortcut.targetToolTitle}
              data-analytics-target-preset={shortcut.targetPreset}
              data-analytics-label={shortcut.label}
            >
              <span class="meta">
                <span class="meta-tag">{shortcut.label}</span>
              </span>
              <strong>{shortcut.title}</strong>
              <p>{shortcut.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>사용 가능한 PDF 도구</h2>
        <p>파일은 가능한 한 브라우저에서만 처리하고, 제출 직전의 작은 변환 문제부터 해결합니다.</p>
      </div>
      <div class="tool-grid">
        {
          pdfTools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="category_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.userMoment}</p>
              <p class="trust-note">{tool.trustNote}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>같이 쓰면 좋은 도구</h2>
        <p>이미지를 PDF로 묶기 전후에 사진 용량, 문서 삽입용 이미지, 업무 문서를 함께 정리할 수 있습니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>다음 PDF 도구 후보</h2>
        <p>범용 PDF 경쟁이 강한 도구는 사용 데이터와 브라우저 처리 안정성을 확인한 뒤 추가합니다.</p>
      </div>
      <div class="tool-grid">
        {
          plannedPdfTools.map((title) => (
            <article class="tool-card">
              <span class="meta">
                <span class="meta-tag muted">후보</span>
              </span>
              <strong>{title}</strong>
              <p>
                한국 업무 문서 제출 흐름에 맞는 파일 제한, 진행 상태, 오류 복구 기준을 먼저
                정한 뒤 공개합니다.
              </p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
