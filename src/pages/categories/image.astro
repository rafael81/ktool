---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getToolCategory, getToolsByCategory } from "@/data/tools";
import { collectionPageSchema } from "@/data/seo";
import { prepShortcuts } from "@/data/prepShortcuts";

const category = getToolCategory("image");
const imageTools = getToolsByCategory("image");
const submissionPrepPath = "/tools/submission-file-prep/";
const relatedTools = [...getToolsByCategory("pdf"), ...getToolsByCategory("business")].filter((tool) =>
  ["jpg-to-pdf", "stamp-background", "business-nameplate"].includes(tool.id)
);
const structuredData = [
  collectionPageSchema({
    name: category.title,
    description: category.description,
    path: category.path,
    tools: imageTools
  })
];
---

<BaseLayout
  title={`${category.title} - K문서툴`}
  description={category.description}
  canonicalPath={category.path}
  structuredData={structuredData}
>
  <main class="page-shell category-page">
    <section class="tool-intro">
      <div>
        <h1>{category.title}</h1>
        <p>{category.description} 사진 첨부, 스캔 이미지 제출, 문서 삽입 전에 파일을 가볍게 정리합니다.</p>
      </div>
      <div class="quick-links" aria-label="이미지 도구 바로가기">
        <a
          href={submissionPrepPath}
          data-analytics-event="category_workflow_quick_link_click"
          data-analytics-label="제출용 파일 준비"
        >
          제출 준비
        </a>
        {
          imageTools.map((tool) => (
            <a
              href={tool.path}
              data-analytics-event="category_tool_quick_link_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.shortTitle}
            >
              {tool.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>이미지 제출 흐름</h2>
        <p>HEIC, WebP, JPG, PNG 파일을 제출 조건에 맞게 돌리고, 자르고, 줄이고, 변환하는 순서를 먼저 확인합니다.</p>
      </div>
      <div class="tool-grid single-card-grid">
        <a
          class="tool-card"
          href={submissionPrepPath}
          data-analytics-event="category_workflow_click"
          data-analytics-label="제출용 파일 준비"
        >
          <span class="meta">
            <span class="meta-tag">제출용 파일 만들기</span>
          </span>
          <strong>제출용 파일 준비</strong>
          <p>형식 오류, 방향 오류, 용량 초과, 픽셀 제한, 자르기 영역, PDF 제출 요구에 맞춰 이미지 도구를 순서대로 고릅니다.</p>
          <p class="trust-note">파일은 서버로 전송되지 않고 브라우저 안에서 처리됩니다.</p>
        </a>
      </div>
    </section>

    <section class="content-section" data-prep-shortcuts>
      <div class="section-heading">
        <h2>이미지 문제 바로가기</h2>
        <p>업로드 오류 문구나 제출처 제한 조건에 맞는 이미지 도구 설정으로 바로 시작합니다.</p>
      </div>
      <div class="shortcut-list">
        {
          prepShortcuts.map((shortcut) => (
            <a
              class="shortcut-row"
              href={shortcut.path}
              data-analytics-event="category_prep_shortcut_click"
              data-analytics-shortcut-id={shortcut.id}
              data-analytics-tool-id={shortcut.targetToolId}
              data-analytics-tool-title={shortcut.targetToolTitle}
              data-analytics-target-preset={shortcut.targetPreset}
              data-analytics-label={shortcut.label}
            >
              <span class="shortcut-row-label">{shortcut.label}</span>
              <span class="shortcut-row-copy">
                <strong>{shortcut.title}</strong>
                <span>{shortcut.description}</span>
              </span>
              <span class="shortcut-row-tool">{shortcut.targetToolTitle}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>사용 가능한 이미지 도구</h2>
        <p>업로드 제한에 걸리는 파일의 용량, 픽셀 크기, 이미지 형식을 브라우저에서 처리해 제출 가능한 상태로 만듭니다.</p>
      </div>
      <div class="tool-grid">
        {
          imageTools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="category_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.userMoment}</p>
              <p class="trust-note">{tool.trustNote}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>같이 쓰면 좋은 도구</h2>
        <p>이미지를 줄인 뒤 PDF로 묶거나, 도장·명판 이미지로 문서에 넣을 수 있습니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.description}</p>
            </a>
          ))
        }
      </div>
    </section>

  </main>
</BaseLayout>
