---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getToolCategory, getToolsByCategory } from "@/data/tools";
import { collectionPageSchema } from "@/data/seo";

const category = getToolCategory("image");
const imageTools = getToolsByCategory("image");
const relatedTools = [...getToolsByCategory("pdf"), ...getToolsByCategory("business")].filter((tool) =>
  ["jpg-to-pdf", "stamp-background", "business-nameplate"].includes(tool.id)
);
const plannedImageTools = ["이미지 Base64 변환", "QR 코드 읽기", "사진 배경 제거", "이미지 자르기"];
const structuredData = [
  collectionPageSchema({
    name: category.title,
    description: category.description,
    path: category.path,
    tools: imageTools
  })
];
---

<BaseLayout
  title={`${category.title} - K문서툴`}
  description={category.description}
  canonicalPath={category.path}
  structuredData={structuredData}
>
  <main class="page-shell">
    <section class="tool-intro">
      <div>
        <h1>{category.title}</h1>
        <p>{category.description} 사진 첨부, 스캔 이미지 제출, 문서 삽입 전에 파일을 가볍게 정리합니다.</p>
      </div>
      <div class="quick-links" aria-label="이미지 도구 바로가기">
        {
          imageTools.map((tool) => (
            <a
              href={tool.path}
              data-analytics-event="category_tool_quick_link_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.shortTitle}
            >
              {tool.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>사용 가능한 이미지 도구</h2>
        <p>업로드 제한에 걸리는 파일의 용량, 픽셀 크기, 이미지 형식을 브라우저에서 처리해 제출 가능한 상태로 만듭니다.</p>
      </div>
      <div class="tool-grid">
        {
          imageTools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="category_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.userMoment}</p>
              <p class="trust-note">{tool.trustNote}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>같이 쓰면 좋은 도구</h2>
        <p>이미지를 줄인 뒤 PDF로 묶거나, 도장·명판 이미지로 문서에 넣을 수 있습니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((tool) => (
            <a
              class="tool-card"
              href={tool.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
            >
              <span class="meta">
                <span class="meta-tag">{tool.primaryQuery}</span>
              </span>
              <strong>{tool.title}</strong>
              <p>{tool.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>다음 이미지 도구 후보</h2>
        <p>이미지 변환 도구는 브라우저 지원, 파일 제한, 개인정보 기준을 확인한 뒤 추가합니다.</p>
      </div>
      <div class="tool-grid">
        {
          plannedImageTools.map((title) => (
            <article class="tool-card">
              <span class="meta">
                <span class="meta-tag muted">후보</span>
              </span>
              <strong>{title}</strong>
              <p>문서 제출 흐름과 맞는지, 브라우저에서 안정적으로 처리할 수 있는지 확인한 뒤 공개합니다.</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
