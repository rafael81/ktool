---
import BaseLayout from "@/layouts/BaseLayout.astro";
import IconGlyph from "@/components/IconGlyph.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema, webPageSchema } from "@/data/seo";

const tool = getTool("stamp-background");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  webPageSchema({
    name: tool.title,
    description: tool.metaDescription,
    path: tool.path,
    keywords: [
      tool.primaryQuery,
      ...tool.secondaryQueries,
      "도장 배경 제거 무료",
      "도장 투명 PNG 저장",
      "도장 이미지 서버 전송 없음"
    ]
  }),
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main
    class="page-shell"
    data-tool-id={tool.id}
    data-tool-title={tool.title}
  >
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>스캔 도장 이미지를 선택하면 흰 배경을 제거해 문서에 넣기 좋은 투명 PNG로 저장할 수 있습니다.</p>
        <div class="tool-trust-badges" data-stamp-trust-badges aria-label="주요 장점">
          <span>무료</span>
          <span>설치 없음</span>
          <span>서버 전송 없음</span>
          <span>PNG 저장</span>
        </div>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="stamp-workspace" data-stamp-tool>
      <form class="panel stamp-panel" aria-label="도장 배경 제거 입력">
        <div class="panel-title">
          <h2>이미지 입력</h2>
        </div>

        <label class="field">
          <span>도장 이미지</span>
          <span class="file-control">
            <input data-image-input type="file" accept="image/png,image/jpeg,image/webp" />
            <span data-file-label>PNG/JPG/WebP 선택</span>
          </span>
        </label>

        <label class="field range-field">
          <span>배경 제거 강도 <strong data-threshold-label>230</strong></span>
          <input data-threshold type="range" min="160" max="250" step="1" value="230" />
        </label>

        <label class="field range-field">
          <span>선명화 <strong data-boost-label>24</strong></span>
          <input data-red-boost type="range" min="0" max="60" step="1" value="24" />
        </label>

        <label class="toggle-field">
          <input data-red-only type="checkbox" />
          <span>붉은 도장 중심으로 정리</span>
        </label>

        <p class="note-box">
          흰 종이에 찍은 도장이나 서명처럼 배경이 밝은 이미지에 맞춘 빠른 처리입니다. 중요한 인감 이미지는 보관과 공유에 주의하세요.
        </p>

        <div class="button-row">
          <button class="btn" type="button" data-sample>
            <IconGlyph name="plus" aria-hidden="true" />
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <IconGlyph name="refresh" aria-hidden="true" />
            초기화
          </button>
          <button class="btn primary" type="button" data-download disabled>
            <IconGlyph name="download" aria-hidden="true" />
            PNG 저장
          </button>
        </div>
      </form>

      <section class="preview-panel stamp-preview-panel" aria-label="도장 배경 제거 미리보기">
        <div class="preview-grid">
          <div class="canvas-card">
            <span>원본</span>
            <canvas data-source-canvas width="480" height="360">원본 도장 이미지 미리보기</canvas>
          </div>
          <div class="canvas-card result">
            <span>투명 PNG 결과</span>
            <canvas data-result-canvas width="480" height="360">배경을 제거한 도장 이미지 미리보기</canvas>
          </div>
        </div>
      </section>

    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>스캔하거나 촬영한 도장 이미지를 선택합니다.</li>
        <li>배경 제거 강도와 선명화를 조절해 미리보기를 확인합니다.</li>
        <li>투명 PNG로 저장한 뒤 문서나 명판 도구에 삽입합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-stamp-tool]");
      if (!root) return;

      const input = root.querySelector("[data-image-input]");
      const fileLabel = root.querySelector("[data-file-label]");
      const thresholdInput = root.querySelector("[data-threshold]");
      const thresholdLabel = root.querySelector("[data-threshold-label]");
      const boostInput = root.querySelector("[data-red-boost]");
      const boostLabel = root.querySelector("[data-boost-label]");
      const redOnlyInput = root.querySelector("[data-red-only]");
      const sourceCanvas = root.querySelector("[data-source-canvas]");
      const resultCanvas = root.querySelector("[data-result-canvas]");
      const sourceCtx = sourceCanvas.getContext("2d", { willReadFrequently: true });
      const resultCtx = resultCanvas.getContext("2d", { willReadFrequently: true });
      const downloadButton = root.querySelector("[data-download]");
      const sampleButton = root.querySelector("[data-sample]");
      const resetButton = root.querySelector("[data-reset]");
      let sourceImage = null;
      let sourceName = "stamp";

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "stamp-background",
          tool_title: "도장 배경 제거",
          ...params
        });
      }

      function clearCanvas(ctx, canvas) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }

      function drawEmpty() {
        clearCanvas(sourceCtx, sourceCanvas);
        clearCanvas(resultCtx, resultCanvas);
        for (const [ctx, canvas, label] of [
          [sourceCtx, sourceCanvas, "이미지를 선택하세요"],
          [resultCtx, resultCanvas, "결과 미리보기"]
        ]) {
          ctx.fillStyle = "#f8fbfc";
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          ctx.fillStyle = "#607080";
          ctx.font = "700 18px sans-serif";
          ctx.textAlign = "center";
          ctx.fillText(label, canvas.width / 2, canvas.height / 2);
        }
      }

      function fitImage(img, canvas) {
        const ratio = Math.min(canvas.width / img.width, canvas.height / img.height, 1);
        const width = Math.max(1, Math.round(img.width * ratio));
        const height = Math.max(1, Math.round(img.height * ratio));
        const x = Math.round((canvas.width - width) / 2);
        const y = Math.round((canvas.height - height) / 2);
        return { x, y, width, height };
      }

      function renderSource() {
        clearCanvas(sourceCtx, sourceCanvas);
        if (!sourceImage) {
          drawEmpty();
          return null;
        }
        sourceCtx.fillStyle = "#fff";
        sourceCtx.fillRect(0, 0, sourceCanvas.width, sourceCanvas.height);
        const rect = fitImage(sourceImage, sourceCanvas);
        sourceCtx.drawImage(sourceImage, rect.x, rect.y, rect.width, rect.height);
        return rect;
      }

      function processImage() {
        thresholdLabel.textContent = thresholdInput.value;
        boostLabel.textContent = boostInput.value;
        const rect = renderSource();
        clearCanvas(resultCtx, resultCanvas);
        if (!sourceImage || !rect) {
          downloadButton.disabled = true;
          return;
        }

        resultCtx.drawImage(sourceCanvas, 0, 0);
        const imageData = resultCtx.getImageData(0, 0, resultCanvas.width, resultCanvas.height);
        const data = imageData.data;
        const threshold = Number(thresholdInput.value);
        const boost = Number(boostInput.value);
        const redOnly = redOnlyInput.checked;

        for (let index = 0; index < data.length; index += 4) {
          const r = data[index];
          const g = data[index + 1];
          const b = data[index + 2];
          const a = data[index + 3];
          if (a === 0) continue;

          const max = Math.max(r, g, b);
          const min = Math.min(r, g, b);
          const saturation = max - min;
          const brightness = (r + g + b) / 3;
          const redDominant = r > g * 1.18 && r > b * 1.18 && r > 70;
          const inkLike = redOnly ? redDominant : saturation > 32 || brightness < threshold - 42;
          const backgroundLike = brightness >= threshold && saturation < 45 && !redDominant;

          if (backgroundLike || !inkLike) {
            const distance = Math.max(0, threshold - brightness);
            data[index + 3] = backgroundLike ? 0 : Math.min(120, Math.round(distance * 4));
          } else {
            data[index] = redDominant ? Math.min(255, r + boost) : r;
            data[index + 1] = redDominant ? Math.max(0, g - Math.round(boost * 0.45)) : g;
            data[index + 2] = redDominant ? Math.max(0, b - Math.round(boost * 0.45)) : b;
            data[index + 3] = 255;
          }
        }

        resultCtx.clearRect(0, 0, resultCanvas.width, resultCanvas.height);
        resultCtx.putImageData(imageData, 0, 0);
        downloadButton.disabled = false;
      }

      function loadImageFromUrl(url, name = "stamp") {
        return new Promise((resolve, reject) => {
          const img = new Image();
          img.onload = () => {
            sourceImage = img;
            sourceName = name;
            processImage();
            resolve();
          };
          img.onerror = reject;
          img.src = url;
        });
      }

      function sampleDataUrl() {
        const canvas = document.createElement("canvas");
        canvas.width = 680;
        canvas.height = 420;
        const ctx = canvas.getContext("2d");
        ctx.fillStyle = "#fffdf8";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = "#c9302c";
        ctx.lineWidth = 18;
        ctx.beginPath();
        ctx.ellipse(340, 210, 190, 120, -0.08, 0, Math.PI * 2);
        ctx.stroke();
        ctx.strokeStyle = "#d43f35";
        ctx.lineWidth = 12;
        ctx.strokeRect(238, 132, 204, 156);
        ctx.fillStyle = "#d43f35";
        ctx.font = "900 72px sans-serif";
        ctx.textAlign = "center";
        ctx.fillText("샘플", 340, 235);
        ctx.globalAlpha = 0.18;
        ctx.fillStyle = "#9b7b62";
        for (let i = 0; i < 70; i += 1) {
          ctx.fillRect((i * 97) % canvas.width, (i * 53) % canvas.height, 1.5, 1.5);
        }
        return canvas.toDataURL("image/png");
      }

      input.addEventListener("change", async (event) => {
        const file = event.target.files?.[0];
        if (!file) return;
        if (file.size > 8 * 1024 * 1024) {
          track("stamp_background_validation_error", { reason: "file_too_large", file_size: file.size });
          alert("이미지는 8MB 이하만 사용할 수 있습니다.");
          input.value = "";
          return;
        }
        if (!file.type.startsWith("image/")) {
          track("stamp_background_validation_error", { reason: "unsupported_file_type" });
          alert("PNG, JPG, WebP 이미지만 사용할 수 있습니다.");
          input.value = "";
          return;
        }

        const reader = new FileReader();
        reader.onload = async () => {
          await loadImageFromUrl(String(reader.result || ""), file.name.replace(/\.[^.]+$/, "") || "stamp");
          fileLabel.textContent = file.name;
          track("stamp_background_file_select", { file_type: file.type, file_size: file.size });
        };
        reader.readAsDataURL(file);
      });

      thresholdInput.addEventListener("input", () => {
        processImage();
        track("stamp_background_adjust", { control: "threshold" });
      });
      boostInput.addEventListener("input", () => {
        processImage();
        track("stamp_background_adjust", { control: "boost" });
      });
      redOnlyInput.addEventListener("change", () => {
        processImage();
        track("stamp_background_adjust", { control: "red_only", enabled: redOnlyInput.checked });
      });

      sampleButton.addEventListener("click", async () => {
        await loadImageFromUrl(sampleDataUrl(), "sample-stamp");
        fileLabel.textContent = "샘플 도장";
        track("stamp_background_sample_apply");
      });

      resetButton.addEventListener("click", () => {
        sourceImage = null;
        sourceName = "stamp";
        input.value = "";
        fileLabel.textContent = "PNG/JPG/WebP 선택";
        thresholdInput.value = "230";
        boostInput.value = "24";
        redOnlyInput.checked = false;
        drawEmpty();
        downloadButton.disabled = true;
        track("stamp_background_reset");
      });

      downloadButton.addEventListener("click", () => {
        if (downloadButton.disabled) return;
        const link = document.createElement("a");
        link.download = `${sourceName || "stamp"}-transparent.png`;
        link.href = resultCanvas.toDataURL("image/png");
        link.click();
        track("stamp_background_download", {
          threshold: Number(thresholdInput.value),
          red_only: redOnlyInput.checked
        });
      });

      drawEmpty();
    })();
  </script>
</BaseLayout>

<style>
  .stamp-workspace {
    display: grid;
    grid-template-columns: minmax(280px, 380px) minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .stamp-panel,
  .stamp-preview-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 18px;
  }

  .file-control {
    position: relative;
    display: flex;
    min-height: 44px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--muted);
    font-size: 14px;
    font-weight: 800;
    padding: 11px 12px;
  }

  .file-control input {
    position: absolute;
    inset: 0;
    cursor: pointer;
    opacity: 0;
  }

  .file-control:has(input:focus-visible) {
    border-color: var(--accent);
    outline: 3px solid color-mix(in srgb, var(--accent) 22%, transparent);
    outline-offset: 2px;
  }

  .range-field input {
    padding-inline: 0;
    accent-color: var(--accent);
  }

  .range-field strong {
    color: var(--accent-dark);
  }

  .toggle-field {
    display: flex;
    align-items: center;
    gap: 9px;
    color: #344457;
    font-size: 14px;
    font-weight: 800;
    margin-top: 12px;
  }

  .toggle-field input {
    width: 18px;
    height: 18px;
    accent-color: var(--accent);
  }

  .button-row .btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .canvas-card {
    display: grid;
    gap: 10px;
  }

  .canvas-card span {
    color: #344457;
    font-size: 13px;
    font-weight: 900;
  }

  .canvas-card canvas {
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  .canvas-card.result canvas {
    background:
      linear-gradient(45deg, #eef3f6 25%, transparent 25%),
      linear-gradient(-45deg, #eef3f6 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #eef3f6 75%),
      linear-gradient(-45deg, transparent 75%, #eef3f6 75%);
    background-position: 0 0, 0 10px, 10px -10px, -10px 0;
    background-size: 20px 20px;
  }

  .tool-trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 8px;
    margin-top: 12px;
  }

  .tool-trust-badges span {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    border: 1px solid #d0d5dd;
    border-radius: 999px;
    background: #fff;
    color: #344054;
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    padding: 8px 12px;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .stamp-workspace,
    .preview-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
