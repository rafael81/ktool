---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema, webPageSchema } from "@/data/seo";
import { Crop as CropIcon, Download, FileOutput, FolderOpen, Plus, RefreshCw, Sparkles } from "@lucide/astro";

const tool = getTool("pdf-crop");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  webPageSchema({
    name: tool.title,
    description: tool.metaDescription,
    path: tool.path,
    keywords: [tool.primaryQuery, ...tool.secondaryQueries, "PDF 자르기", "PDF 크롭", "스캔 문서 여백 제거"]
  }),
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main class="page-shell file-tool-shell" data-tool-id={tool.id} data-tool-title={tool.title}>
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>스캔 PDF의 큰 흰 여백과 바깥 테두리를 잘라 본문 영역만 남기세요.</p>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="pdf-crop-workspace" data-pdf-crop-tool>
      <form class="panel pdf-crop-panel pdf-upload-panel" aria-label="PDF 여백 자르기 입력">
        <label class="pdf-dropzone upload-dropzone file-control" data-upload-zone>
          <input data-pdf-input type="file" accept="application/pdf,.pdf" />
          <span class="pdf-upload-icon" aria-hidden="true">
            <FolderOpen aria-hidden="true" />
          </span>
          <strong>여백을 자를 PDF를 선택하세요</strong>
          <span data-file-label>PDF 1개 선택 · 전체 페이지에 같은 여백 적용</span>
          <span class="pdf-dropzone-badges" data-upload-badges aria-label="주요 장점">
            <span>무료</span>
            <span>설치 없음</span>
            <span>서버 전송 없음</span>
          </span>
          <em>PDF 선택</em>
          <small>최대 80MB · 스캔 문서, 검은 테두리, 큰 흰 여백 정리</small>
        </label>

        <div class="crop-options-card">
          <div class="panel-title">
            <h2>여백 설정</h2>
            <span class="format-badge" data-page-count-badge>0쪽</span>
          </div>
          <button class="btn auto-detect-button" type="button" data-auto-detect disabled>
            <Sparkles aria-hidden="true" />
            자동 감지
          </button>
          <div class="margin-preset-row" aria-label="여백 빠른 설정">
            <button type="button" data-margin-preset="0">0pt</button>
            <button type="button" data-margin-preset="18">18pt</button>
            <button type="button" data-margin-preset="36">36pt</button>
            <button type="button" data-margin-preset="54">54pt</button>
          </div>
          <div class="margin-grid">
            <label>
              <span>왼쪽</span>
              <input data-margin-left data-margin-input inputmode="numeric" value="36" />
            </label>
            <label>
              <span>오른쪽</span>
              <input data-margin-right data-margin-input inputmode="numeric" value="36" />
            </label>
            <label>
              <span>위</span>
              <input data-margin-top data-margin-input inputmode="numeric" value="36" />
            </label>
            <label>
              <span>아래</span>
              <input data-margin-bottom data-margin-input inputmode="numeric" value="36" />
            </label>
          </div>
          <p data-margin-helper>pt 단위입니다. A4 기준 36pt는 약 12.7mm입니다.</p>
        </div>

        <div class="preflight-card" data-preflight aria-live="polite">
          <strong>자르기 전 확인</strong>
          <ul>
            <li data-preflight-item="file">PDF를 선택해 주세요.</li>
            <li data-preflight-item="pages">페이지 수는 선택 후 확인합니다.</li>
            <li data-preflight-item="margins">상하좌우 36pt 여백을 자릅니다.</li>
            <li data-preflight-item="output">PDF 여백 자르기 후 저장 버튼이 열립니다.</li>
          </ul>
        </div>

        <div class="button-row pdf-action-row">
          <button class="btn" type="button" data-sample>
            <Plus aria-hidden="true" />
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <RefreshCw aria-hidden="true" />
            초기화
          </button>
          <button class="btn primary" type="button" data-generate disabled>
            <FileOutput aria-hidden="true" />
            <span data-generate-label>PDF 여백 자르기</span>
          </button>
        </div>
      </form>

      <section class="preview-panel pdf-preview-panel" aria-label="PDF 여백 자르기 결과">
        <div class="panel-title">
          <h2>자르기 결과</h2>
          <span class="format-badge">PDF</span>
        </div>

        <div class="crop-preview-card">
          <span>미리보기</span>
          <div class="crop-diagram" data-crop-diagram>
            <div class="crop-box" data-crop-box>
              <CropIcon aria-hidden="true" />
            </div>
          </div>
          <p data-crop-preview-text>PDF를 선택하면 첫 페이지 기준 자르기 영역이 표시됩니다.</p>
        </div>

        <div class="pdf-result-card">
          <span>상태</span>
          <strong data-output-status>PDF를 선택하면 여백을 자를 수 있습니다.</strong>
          <p data-output-meta>파일은 아직 준비되지 않았습니다.</p>
          <div class="download-action-strip" data-pdf-download-hint hidden>
            <strong>저장 준비 완료</strong>
            <span>PDF 저장을 눌러 여백이 잘린 파일을 내려받으세요.</span>
          </div>
          <a
            class="btn primary disabled"
            href="#"
            download="k-document-cropped.pdf"
            aria-disabled="true"
            data-download
          >
            <Download aria-hidden="true" />
            PDF 저장
          </a>
        </div>
      </section>
    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>여백을 자를 PDF 파일을 선택합니다.</li>
        <li>자동 감지를 누르거나 상하좌우 여백을 직접 입력합니다.</li>
        <li>전체 페이지에 같은 여백을 적용한 새 PDF를 저장합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline src="/scripts/file-tool-utils.js"></script>
  <script>
    // @ts-nocheck
    import pdfWorkerUrl from "pdfjs-dist/build/pdf.worker.mjs?url";

    const root = document.querySelector("[data-pdf-crop-tool]");
    if (root) {
      const fileTools = window.KdocFileTools;
      if (!fileTools) throw new Error("file_tool_utils_unavailable");

      const maxFileSize = 80 * 1024 * 1024;
      const maxPages = 150;
      const minCropSize = 72;
      const input = root.querySelector("[data-pdf-input]");
      const dropzone = root.querySelector("[data-upload-zone]");
      const fileLabel = root.querySelector("[data-file-label]");
      const pageCountBadge = root.querySelector("[data-page-count-badge]");
      const marginInputs = Array.from(root.querySelectorAll("[data-margin-input]"));
      const marginLeftInput = root.querySelector("[data-margin-left]");
      const marginRightInput = root.querySelector("[data-margin-right]");
      const marginTopInput = root.querySelector("[data-margin-top]");
      const marginBottomInput = root.querySelector("[data-margin-bottom]");
      const marginHelper = root.querySelector("[data-margin-helper]");
      const presetButtons = Array.from(root.querySelectorAll("[data-margin-preset]"));
      const autoDetectButton = root.querySelector("[data-auto-detect]");
      const generateButton = root.querySelector("[data-generate]");
      const generateLabel = root.querySelector("[data-generate-label]");
      const resetButton = root.querySelector("[data-reset]");
      const sampleButton = root.querySelector("[data-sample]");
      const outputStatus = root.querySelector("[data-output-status]");
      const outputMeta = root.querySelector("[data-output-meta]");
      const downloadLink = root.querySelector("[data-download]");
      const downloadHint = root.querySelector("[data-pdf-download-hint]");
      const cropBox = root.querySelector("[data-crop-box]");
      const cropPreviewText = root.querySelector("[data-crop-preview-text]");
      const preflightItems = {
        file: root.querySelector('[data-preflight-item="file"]'),
        pages: root.querySelector('[data-preflight-item="pages"]'),
        margins: root.querySelector('[data-preflight-item="margins"]'),
        output: root.querySelector('[data-preflight-item="output"]')
      };
      const formatter = new Intl.NumberFormat("ko-KR");
      let fileItems = [];
      let pageCount = 0;
      let sourcePageSizes = [];
      let outputUrl = "";
      let outputBytes = 0;
      let outputPageCount = 0;
      let lastMarginMode = "manual";
      let nextItemId = 1;
      let pdfLibPromise = null;
      let pdfJsPromise = null;

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "pdf-crop",
          tool_title: "PDF 여백 자르기",
          ...params
        });
      }

      function formatBytes(bytes) {
        return fileTools.formatBytes(bytes);
      }

      function selectedFile() {
        return fileItems[0]?.file || null;
      }

      function isPdfFile(file) {
        return file.type === "application/pdf" || /\.pdf$/i.test(file.name || "");
      }

      function validatePdfFiles(files) {
        if (files.length === 0) return { ok: false, reason: "empty" };
        if (files.length > 1) return { ok: false, reason: "too_many_files" };
        const file = files[0];
        if (!isPdfFile(file)) return { ok: false, reason: "unsupported_file_type" };
        if (file.size > maxFileSize) return { ok: false, reason: "file_too_large" };
        return { ok: true };
      }

      function validationMessage(reason) {
        if (reason === "too_many_files") return "PDF는 1개만 선택할 수 있습니다.";
        if (reason === "file_too_large") return "PDF는 80MB 이하만 사용할 수 있습니다.";
        if (reason === "unsupported_file_type") return "PDF 파일만 선택할 수 있습니다.";
        if (reason === "too_many_pages") return "PDF는 최대 150쪽까지 처리할 수 있습니다.";
        if (reason === "crop_too_large") return "여백이 너무 커서 남는 영역이 부족합니다.";
        if (reason === "auto_detect_empty") return "자동 감지할 본문 영역을 찾지 못했습니다.";
        return "PDF를 선택해 주세요.";
      }

      function numberValue(inputElement) {
        const parsed = Number(String(inputElement.value || "").replace(/[^\d.]/g, ""));
        if (!Number.isFinite(parsed)) return 0;
        return Math.max(0, Math.min(600, Math.round(parsed)));
      }

      function marginValues() {
        return {
          left: numberValue(marginLeftInput),
          right: numberValue(marginRightInput),
          top: numberValue(marginTopInput),
          bottom: numberValue(marginBottomInput)
        };
      }

      function marginPayload() {
        const margins = marginValues();
        return {
          margin_left: margins.left,
          margin_right: margins.right,
          margin_top: margins.top,
          margin_bottom: margins.bottom,
          crop_mode: lastMarginMode,
          page_count: pageCount
        };
      }

      function setMargins(margins, mode = "manual") {
        marginLeftInput.value = String(Math.max(0, Math.round(margins.left || 0)));
        marginRightInput.value = String(Math.max(0, Math.round(margins.right || 0)));
        marginTopInput.value = String(Math.max(0, Math.round(margins.top || 0)));
        marginBottomInput.value = String(Math.max(0, Math.round(margins.bottom || 0)));
        lastMarginMode = mode;
        clearOutput();
        updatePreflight();
        updateCropPreview();
      }

      function cropSizeForPage(size, margins = marginValues()) {
        return {
          width: size.width - margins.left - margins.right,
          height: size.height - margins.top - margins.bottom
        };
      }

      function marginSummary() {
        const margins = marginValues();
        return `좌 ${margins.left}pt · 우 ${margins.right}pt · 위 ${margins.top}pt · 아래 ${margins.bottom}pt`;
      }

      function validateCropMargins(margins = marginValues()) {
        if (!sourcePageSizes.length) return { ok: false, reason: "empty" };
        const invalid = sourcePageSizes.some((size) => {
          const cropped = cropSizeForPage(size, margins);
          return cropped.width < minCropSize || cropped.height < minCropSize;
        });
        if (invalid) return { ok: false, reason: "crop_too_large" };
        return { ok: true };
      }

      function setMessage(status, meta = "") {
        outputStatus.textContent = status;
        outputMeta.textContent = meta;
      }

      function setPreflightItem(key, status, text) {
        const item = preflightItems[key];
        if (!item) return;
        item.dataset.status = status;
        item.textContent = text;
      }

      function clearOutput() {
        if (outputUrl) URL.revokeObjectURL(outputUrl);
        outputUrl = "";
        outputBytes = 0;
        outputPageCount = 0;
        downloadHint.hidden = true;
        downloadLink.href = "#";
        downloadLink.classList.add("disabled");
        downloadLink.setAttribute("aria-disabled", "true");
        downloadLink.dataset.outputSize = "";
        downloadLink.dataset.outputPageCount = "";
        downloadLink.dataset.sourcePageCount = "";
      }

      async function loadPdfLib() {
        if (!pdfLibPromise) pdfLibPromise = import("pdf-lib");
        return pdfLibPromise;
      }

      async function loadPdfJs() {
        if (!pdfJsPromise) {
          pdfJsPromise = import("pdfjs-dist").then((pdfjs) => {
            pdfjs.GlobalWorkerOptions.workerSrc = pdfWorkerUrl;
            return pdfjs;
          });
        }
        return pdfJsPromise;
      }

      async function loadPdfDocument(file) {
        const pdfjs = await loadPdfJs();
        const bytes = new Uint8Array(await file.arrayBuffer());
        return pdfjs.getDocument({
          data: bytes,
          stopAtErrors: true
        }).promise;
      }

      function canGenerate() {
        return Boolean(selectedFile()) && pageCount > 0 && validateCropMargins().ok;
      }

      function syncGenerateButton() {
        generateButton.disabled = !canGenerate();
        autoDetectButton.disabled = !selectedFile();
      }

      function setBusy(isBusy) {
        generateButton.disabled = isBusy || !canGenerate();
        generateLabel.textContent = isBusy ? "처리 중" : "PDF 여백 자르기";
        sampleButton.disabled = isBusy;
        resetButton.disabled = isBusy;
        autoDetectButton.disabled = isBusy || !selectedFile();
        for (const control of [...marginInputs, ...presetButtons]) control.disabled = isBusy;
      }

      function updatePreflight() {
        const file = selectedFile();
        const margins = marginValues();
        if (!file) {
          setPreflightItem("file", "pending", "PDF를 선택해 주세요.");
          setPreflightItem("pages", "pending", "페이지 수는 선택 후 확인합니다.");
          setPreflightItem("margins", "pending", `${marginSummary()} 여백을 자릅니다.`);
          setPreflightItem("output", "pending", "PDF 여백 자르기 후 저장 버튼이 열립니다.");
          syncGenerateButton();
          return;
        }

        const validation = validateCropMargins(margins);
        const firstCropped = sourcePageSizes[0] ? cropSizeForPage(sourcePageSizes[0], margins) : null;
        setPreflightItem("file", "ready", `PDF 1개 선택됨, ${formatBytes(file.size)}`);
        setPreflightItem("pages", "ready", `${formatter.format(pageCount)}쪽 PDF, 전체 페이지에 같은 여백 적용`);
        setPreflightItem(
          "margins",
          validation.ok ? "ready" : "error",
          validation.ok && firstCropped
            ? `${marginSummary()} → 첫 페이지 ${Math.round(firstCropped.width)}×${Math.round(firstCropped.height)}pt`
            : validationMessage(validation.reason)
        );
        setPreflightItem(
          "output",
          outputUrl ? "ready" : "pending",
          outputUrl
            ? `저장 준비 완료, ${formatter.format(outputPageCount)}쪽 · ${formatBytes(outputBytes)}`
            : "PDF 여백 자르기를 누르면 저장 버튼이 열립니다."
        );
        syncGenerateButton();
      }

      function updateCropPreview() {
        if (!sourcePageSizes.length) {
          cropBox.style.left = "14%";
          cropBox.style.top = "14%";
          cropBox.style.width = "72%";
          cropBox.style.height = "72%";
          cropPreviewText.textContent = "PDF를 선택하면 첫 페이지 기준 자르기 영역이 표시됩니다.";
          marginHelper.textContent = "pt 단위입니다. A4 기준 36pt는 약 12.7mm입니다.";
          return;
        }
        const size = sourcePageSizes[0];
        const margins = marginValues();
        const cropped = cropSizeForPage(size, margins);
        const valid = cropped.width >= minCropSize && cropped.height >= minCropSize;
        const left = Math.max(0, Math.min(95, (margins.left / size.width) * 100));
        const top = Math.max(0, Math.min(95, (margins.top / size.height) * 100));
        const width = Math.max(4, Math.min(100 - left, (cropped.width / size.width) * 100));
        const height = Math.max(4, Math.min(100 - top, (cropped.height / size.height) * 100));
        cropBox.style.left = `${left}%`;
        cropBox.style.top = `${top}%`;
        cropBox.style.width = `${width}%`;
        cropBox.style.height = `${height}%`;
        cropBox.dataset.invalid = valid ? "false" : "true";
        cropPreviewText.textContent = valid
          ? `첫 페이지 ${Math.round(size.width)}×${Math.round(size.height)}pt → ${Math.round(cropped.width)}×${Math.round(cropped.height)}pt`
          : "남는 영역이 너무 작습니다. 여백값을 줄여 주세요.";
        marginHelper.textContent = `${lastMarginMode === "auto" ? "자동 감지값" : "수동 설정값"} · ${marginSummary()}`;
      }

      function releaseItems(items = fileItems) {
        fileTools.revokePreviewItems(items);
      }

      function resetState() {
        releaseItems();
        clearOutput();
        fileItems = [];
        pageCount = 0;
        sourcePageSizes = [];
        pageCountBadge.textContent = "0쪽";
        fileLabel.textContent = "PDF 1개 선택 · 전체 페이지에 같은 여백 적용";
        input.value = "";
        lastMarginMode = "manual";
        setMargins({ left: 36, right: 36, top: 36, bottom: 36 }, "manual");
        setMessage("PDF를 선택하면 여백을 자를 수 있습니다.", "파일은 아직 준비되지 않았습니다.");
        updatePreflight();
        updateCropPreview();
      }

      async function inspectPdf(file, method = "picker") {
        setBusy(true);
        setMessage("PDF 읽는 중", "페이지 수와 페이지 크기를 확인하고 있습니다.");

        try {
          const { PDFDocument } = await loadPdfLib();
          const sourcePdf = await PDFDocument.load(await file.arrayBuffer());
          pageCount = sourcePdf.getPageCount();
          if (pageCount > maxPages) throw new Error("too_many_pages");
          sourcePageSizes = sourcePdf.getPages().map((page) => ({ width: page.getWidth(), height: page.getHeight() }));
          pageCountBadge.textContent = `${formatter.format(pageCount)}쪽`;
          fileLabel.textContent = `${formatter.format(pageCount)}쪽 PDF 선택`;
          setMessage(`${formatter.format(pageCount)}쪽 PDF`, "자동 감지 또는 직접 여백 조정 후 저장할 수 있습니다.");
          updateCropPreview();
          updatePreflight();
          track("pdf_crop_file_select", {
            method,
            ...fileTools.safeFileAnalyticsPayload([file]),
            page_count: pageCount,
            ...marginPayload()
          });
        } catch (error) {
          resetState();
          const reason = error?.message === "too_many_pages" ? "too_many_pages" : error?.message || "pdf_read_failed";
          setMessage(validationMessage(reason), "암호가 있거나 손상된 PDF인지 확인해 주세요.");
          track("pdf_crop_validation_error", { reason });
        } finally {
          setBusy(false);
        }
      }

      function setFile(file, method = "picker") {
        releaseItems();
        clearOutput();
        pageCount = 0;
        sourcePageSizes = [];
        fileItems = fileTools.createFileItems([file], () => nextItemId++);
        pageCountBadge.textContent = "읽는 중";
        inspectPdf(file, method);
      }

      async function createSamplePdf() {
        const { PDFDocument, StandardFonts, rgb } = await loadPdfLib();
        const pdfDoc = await PDFDocument.create();
        const titleFont = await pdfDoc.embedFont(StandardFonts.HelveticaBold);
        const bodyFont = await pdfDoc.embedFont(StandardFonts.Helvetica);
        const colors = [rgb(0.08, 0.37, 0.94), rgb(0.72, 0.25, 0.02)];
        for (let index = 0; index < 2; index += 1) {
          const page = pdfDoc.addPage([595.28, 841.89]);
          page.drawRectangle({ x: 54, y: 70, width: 487, height: 708, borderColor: rgb(0.04, 0.08, 0.14), borderWidth: 2 });
          page.drawRectangle({ x: 96, y: 674, width: 230, height: 24, color: colors[index] });
          page.drawText(`CROP SAMPLE ${index + 1}`, { x: 96, y: 610, size: 34, font: titleFont, color: rgb(0.08, 0.13, 0.19) });
          page.drawText("This page has large outer margins for crop testing.", {
            x: 96,
            y: 568,
            size: 14,
            font: bodyFont,
            color: rgb(0.35, 0.41, 0.5)
          });
          page.drawText("The saved PDF should keep this content and remove the empty edge.", {
            x: 96,
            y: 538,
            size: 12,
            font: bodyFont,
            color: rgb(0.48, 0.54, 0.62)
          });
        }
        const bytes = await pdfDoc.save();
        return new File([bytes], "pdf-crop-sample.pdf", { type: "application/pdf" });
      }

      async function autoDetectMargins() {
        const file = selectedFile();
        if (!file) {
          setMessage(validationMessage("empty"), "파일을 먼저 선택해 주세요.");
          track("pdf_crop_validation_error", { reason: "empty" });
          return;
        }

        setBusy(true);
        setMessage("자동 감지 중", "첫 페이지를 렌더링해 바깥 여백을 찾고 있습니다.");

        let pdfDocument = null;
        try {
          pdfDocument = await loadPdfDocument(file);
          const page = await pdfDocument.getPage(1);
          const viewport = page.getViewport({ scale: 1 });
          const canvas = document.createElement("canvas");
          canvas.width = Math.max(1, Math.ceil(viewport.width));
          canvas.height = Math.max(1, Math.ceil(viewport.height));
          const context = canvas.getContext("2d", { alpha: false });
          if (!context) throw new Error("canvas_context_unavailable");
          context.fillStyle = "#ffffff";
          context.fillRect(0, 0, canvas.width, canvas.height);
          await page.render({ canvasContext: context, viewport }).promise;
          const imageData = context.getImageData(0, 0, canvas.width, canvas.height).data;
          let minX = canvas.width;
          let minY = canvas.height;
          let maxX = -1;
          let maxY = -1;
          for (let y = 0; y < canvas.height; y += 1) {
            for (let x = 0; x < canvas.width; x += 1) {
              const offset = (y * canvas.width + x) * 4;
              const red = imageData[offset];
              const green = imageData[offset + 1];
              const blue = imageData[offset + 2];
              if (red < 244 || green < 244 || blue < 244) {
                minX = Math.min(minX, x);
                minY = Math.min(minY, y);
                maxX = Math.max(maxX, x);
                maxY = Math.max(maxY, y);
              }
            }
          }
          page.cleanup?.();
          if (maxX < 0 || maxY < 0) throw new Error("auto_detect_empty");

          const firstPageSize = sourcePageSizes[0];
          const pointPerX = firstPageSize.width / canvas.width;
          const pointPerY = firstPageSize.height / canvas.height;
          const padding = 14;
          const detected = {
            left: Math.max(0, Math.floor(minX * pointPerX - padding)),
            right: Math.max(0, Math.floor((canvas.width - 1 - maxX) * pointPerX - padding)),
            top: Math.max(0, Math.floor(minY * pointPerY - padding)),
            bottom: Math.max(0, Math.floor((canvas.height - 1 - maxY) * pointPerY - padding))
          };
          setMargins(detected, "auto");
          setMessage("자동 감지 완료", marginSummary());
          track("pdf_crop_auto_detect", {
            ...marginPayload(),
            detected_width: maxX - minX + 1,
            detected_height: maxY - minY + 1
          });
        } catch (error) {
          const reason = error?.message || "auto_detect_failed";
          setMessage(validationMessage(reason), "수동 여백값으로 조정해 다시 시도할 수 있습니다.");
          track("pdf_crop_validation_error", { reason });
        } finally {
          try {
            await pdfDocument?.destroy?.();
          } catch {}
          setBusy(false);
        }
      }

      async function cropPdf() {
        const file = selectedFile();
        if (!file) {
          setMessage(validationMessage("empty"), "파일을 다시 선택해 주세요.");
          track("pdf_crop_validation_error", { reason: "empty" });
          return;
        }
        const validation = validateCropMargins();
        if (!validation.ok) {
          setMessage(validationMessage(validation.reason), "여백값을 줄여 주세요.");
          track("pdf_crop_validation_error", {
            reason: validation.reason,
            ...marginPayload()
          });
          return;
        }

        clearOutput();
        setBusy(true);
        setMessage("PDF 여백 자르는 중", `${formatter.format(pageCount)}쪽을 처리하고 있습니다.`);

        try {
          const { PDFDocument } = await loadPdfLib();
          const sourcePdf = await PDFDocument.load(await file.arrayBuffer());
          const outputPdf = await PDFDocument.create();
          const margins = marginValues();
          const pages = sourcePdf.getPages();

          for (const sourcePage of pages) {
            const width = sourcePage.getWidth();
            const height = sourcePage.getHeight();
            const croppedWidth = width - margins.left - margins.right;
            const croppedHeight = height - margins.top - margins.bottom;
            if (croppedWidth < minCropSize || croppedHeight < minCropSize) throw new Error("crop_too_large");
            const targetPage = outputPdf.addPage([croppedWidth, croppedHeight]);
            const embedded = await outputPdf.embedPage(sourcePage);
            targetPage.drawPage(embedded, {
              x: -margins.left,
              y: -margins.bottom,
              width,
              height
            });
          }

          const bytes = await outputPdf.save();
          const blob = new Blob([bytes], { type: "application/pdf" });
          outputUrl = URL.createObjectURL(blob);
          outputBytes = blob.size;
          outputPageCount = outputPdf.getPageCount();
          downloadLink.href = outputUrl;
          downloadLink.classList.remove("disabled");
          downloadLink.removeAttribute("aria-disabled");
          downloadLink.dataset.outputSize = String(outputBytes);
          downloadLink.dataset.outputPageCount = String(outputPageCount);
          downloadLink.dataset.sourcePageCount = String(pageCount);
          downloadHint.hidden = false;
          setMessage("PDF 준비 완료", `${formatter.format(outputPageCount)}쪽 · ${formatBytes(outputBytes)}`);
          updatePreflight();
          track("pdf_crop_generate", {
            ...fileTools.safeFileAnalyticsPayload([file]),
            ...marginPayload(),
            output_page_count: outputPageCount,
            output_size: outputBytes
          });
        } catch (error) {
          clearOutput();
          setMessage("PDF 여백을 자르지 못했습니다.", "여백값이 너무 크거나 손상된 PDF인지 확인해 주세요.");
          track("pdf_crop_validation_error", {
            reason: error?.message || "pdf_crop_failed",
            ...marginPayload()
          });
        } finally {
          setBusy(false);
        }
      }

      function handleSelectedFiles(files, method = "picker") {
        const validation = validatePdfFiles(files);
        if (!validation.ok) {
          resetState();
          setMessage(validationMessage(validation.reason), "파일을 다시 선택해 주세요.");
          track("pdf_crop_validation_error", {
            reason: validation.reason,
            ...fileTools.safeFileAnalyticsPayload(files)
          });
          return;
        }
        setFile(files[0], method);
      }

      input.addEventListener("change", (event) => {
        handleSelectedFiles(Array.from(event.target.files || []), "picker");
      });

      if (dropzone) {
        ["dragenter", "dragover"].forEach((eventName) => {
          dropzone.addEventListener(eventName, (event) => {
            event.preventDefault();
            dropzone.classList.add("is-drag-over");
          });
        });
        ["dragleave", "drop"].forEach((eventName) => {
          dropzone.addEventListener(eventName, () => dropzone.classList.remove("is-drag-over"));
        });
        dropzone.addEventListener("drop", (event) => {
          event.preventDefault();
          handleSelectedFiles(Array.from(event.dataTransfer?.files || []), "drop");
        });
      }

      for (const control of marginInputs) {
        control.addEventListener("input", () => {
          lastMarginMode = "manual";
          clearOutput();
          updatePreflight();
          updateCropPreview();
          track("pdf_crop_margin_change", marginPayload());
        });
      }

      for (const button of presetButtons) {
        button.addEventListener("click", () => {
          const value = Number(button.dataset.marginPreset || 0);
          setMargins({ left: value, right: value, top: value, bottom: value }, "preset");
          setMessage("여백 빠른 설정 적용", `${value}pt 여백을 전체 방향에 적용했습니다.`);
          track("pdf_crop_preset_apply", {
            preset_margin: value,
            ...marginPayload()
          });
        });
      }

      autoDetectButton.addEventListener("click", autoDetectMargins);
      generateButton.addEventListener("click", cropPdf);
      sampleButton.addEventListener("click", async () => {
        setBusy(true);
        try {
          const file = await createSamplePdf();
          track("pdf_crop_sample_apply", { file_count: 1 });
          setFile(file, "sample");
        } catch (error) {
          setMessage("샘플 PDF를 만들지 못했습니다.", "잠시 후 다시 시도해 주세요.");
          track("pdf_crop_validation_error", { reason: error?.message || "sample_create_failed" });
        } finally {
          setBusy(false);
        }
      });
      resetButton.addEventListener("click", () => {
        resetState();
        track("pdf_crop_reset");
      });
      downloadLink.addEventListener("click", (event) => {
        if (!outputUrl) {
          event.preventDefault();
          return;
        }
        track("pdf_crop_download", {
          ...marginPayload(),
          output_page_count: outputPageCount,
          output_size: outputBytes
        });
      });

      updatePreflight();
      updateCropPreview();
    }
  </script>
</BaseLayout>

