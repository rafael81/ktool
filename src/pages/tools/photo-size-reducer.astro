---
import BaseLayout from "@/layouts/BaseLayout.astro";
import IconGlyph from "@/components/IconGlyph.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema } from "@/data/seo";

const tool = getTool("image-compressor");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main
    class="page-shell"
    data-tool-id={tool.id}
    data-tool-title={tool.title}
  >
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>{tool.description} 업로드 제한에 걸리는 사진을 제출 가능한 크기로 빠르게 정리합니다.</p>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="compress-workspace" data-image-compressor>
      <form class="panel compress-panel" aria-label="사진 용량 줄이기 입력">
        <div class="panel-title">
          <h2>이미지 입력</h2>
        </div>

        <label class="field">
          <span>이미지 파일</span>
          <span class="file-control">
            <input data-image-input type="file" accept="image/png,image/jpeg,image/webp" multiple />
            <span data-file-label>JPG/PNG/WebP 여러 장 선택</span>
          </span>
        </label>

        <label class="field preset-field">
          <span>제출 기준</span>
          <select data-compress-preset>
            <option value="1mb">1MB 이하</option>
            <option value="500kb">500KB 이하</option>
            <option value="3mb">3MB 이하</option>
            <option value="custom">직접 설정</option>
          </select>
          <small data-preset-note>제출 호환성이 좋은 JPG로 1MB 이하를 우선 맞춥니다.</small>
        </label>

        <div class="field-grid two-columns">
          <label class="field">
            <span>출력 형식</span>
            <select data-output-format>
              <option value="image/jpeg">JPG</option>
              <option value="image/webp">WebP</option>
            </select>
          </label>

          <label class="field">
            <span>최대 크기</span>
            <select data-max-side>
              <option value="1600">긴 변 1600px</option>
              <option value="1200">긴 변 1200px</option>
              <option value="2000">긴 변 2000px</option>
              <option value="original">원본 크기 유지</option>
            </select>
          </label>
        </div>

        <label class="field range-field">
          <span>품질 <strong data-quality-label>82</strong></span>
          <input data-quality type="range" min="45" max="95" step="1" value="82" />
        </label>

        <p class="note-box">
          최대 20장, 총 50MB, 파일당 12MB까지 처리합니다. 원본 이미지는 바꾸지 않고 새 압축 파일을 만듭니다.
        </p>

        <div class="compression-check" data-compression-check aria-live="polite">
          <strong>제출 기준 확인</strong>
          <ul>
            <li data-compression-check-item="target">1MB 이하 압축 기준</li>
            <li data-compression-check-item="settings">JPG · 긴 변 1600px · 품질 82</li>
            <li data-compression-check-item="result">용량 줄이기 후 기준 통과 여부를 확인합니다.</li>
          </ul>
        </div>

        <div class="button-row">
          <button class="btn" type="button" data-sample>
            <IconGlyph name="plus" aria-hidden="true" />
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <IconGlyph name="refresh" aria-hidden="true" />
            초기화
          </button>
          <button class="btn primary" type="button" data-compress disabled>
            <IconGlyph name="sliders" aria-hidden="true" />
            <span data-compress-label>용량 줄이기</span>
          </button>
        </div>
      </form>

      <section class="preview-panel compress-preview-panel" aria-label="이미지 압축 결과">
        <div class="panel-title">
          <h2>압축 결과</h2>
          <span class="format-badge" data-format-badge>JPG</span>
        </div>

        <div class="compress-summary">
          <span>상태</span>
          <strong data-output-status>이미지를 선택하면 용량을 줄일 수 있습니다.</strong>
          <p data-output-meta>압축된 파일은 아직 준비되지 않았습니다.</p>
        </div>

        <div class="compress-list" data-compress-list aria-live="polite">
          <p class="empty-state">선택된 이미지가 없습니다.</p>
        </div>

        <div class="next-pdf-card" data-next-pdf hidden>
          <strong>다음 단계: PDF로 묶기</strong>
          <p data-next-pdf-message>
            압축 이미지를 저장한 뒤 JPG PDF 변환에서 다시 선택하면 여러 장을 한 파일로 묶을 수 있습니다.
          </p>
          <ol>
            <li>각 압축 이미지의 저장 버튼을 눌러 파일을 저장합니다.</li>
            <li>JPG PDF 변환에서 저장한 이미지를 선택합니다.</li>
            <li>제출 전 마지막 확인에서 순서와 용량을 확인합니다.</li>
          </ol>
          <a
            class="btn primary"
            href="/tools/jpg-to-pdf-converter/?from=compressed-images"
            data-next-pdf-link
          >
            JPG PDF 변환 열기
          </a>
        </div>
      </section>

      <aside class="side-panel">
        <div class="panel-title">
          <h3>서버 전송 없음</h3>
        </div>
        <ul class="status-list">
          <li><span class="status-dot"></span><span>이미지는 브라우저 캔버스에서만 처리합니다.</span></li>
          <li><span class="status-dot"></span><span>파일명과 원본 이미지는 분석 이벤트로 보내지 않습니다.</span></li>
          <li><span class="status-dot"></span><span>PNG 투명 배경은 흰 배경으로 합성될 수 있습니다.</span></li>
        </ul>
      </aside>
    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>용량을 줄일 JPG, PNG, WebP 이미지를 선택합니다.</li>
        <li>출력 형식, 최대 크기, 품질을 조절합니다.</li>
        <li>용량 줄이기를 누른 뒤 준비된 압축 이미지를 저장합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline src="/scripts/file-tool-utils.js"></script>
  <script is:inline>
    (() => {
      const root = document.querySelector("[data-image-compressor]");
      if (!root) return;
      const fileTools = window.KdocFileTools;
      if (!fileTools) return;

      const maxFiles = 20;
      const maxFileSize = 12 * 1024 * 1024;
      const maxTotalSize = 50 * 1024 * 1024;
      const input = root.querySelector("[data-image-input]");
      const fileLabel = root.querySelector("[data-file-label]");
      const presetSelect = root.querySelector("[data-compress-preset]");
      const presetNote = root.querySelector("[data-preset-note]");
      const compressionCheckItems = {
        target: root.querySelector('[data-compression-check-item="target"]'),
        settings: root.querySelector('[data-compression-check-item="settings"]'),
        result: root.querySelector('[data-compression-check-item="result"]')
      };
      const outputFormat = root.querySelector("[data-output-format]");
      const maxSideSelect = root.querySelector("[data-max-side]");
      const qualityInput = root.querySelector("[data-quality]");
      const qualityLabel = root.querySelector("[data-quality-label]");
      const formatBadge = root.querySelector("[data-format-badge]");
      const compressButton = root.querySelector("[data-compress]");
      const compressLabel = root.querySelector("[data-compress-label]");
      const resetButton = root.querySelector("[data-reset]");
      const sampleButton = root.querySelector("[data-sample]");
      const outputStatus = root.querySelector("[data-output-status]");
      const outputMeta = root.querySelector("[data-output-meta]");
      const compressList = root.querySelector("[data-compress-list]");
      const nextPdfCard = root.querySelector("[data-next-pdf]");
      const nextPdfMessage = root.querySelector("[data-next-pdf-message]");
      const nextPdfLink = root.querySelector("[data-next-pdf-link]");
      const formatter = new Intl.NumberFormat("ko-KR");
      let fileItems = [];
      let nextItemId = 1;
      let isApplyingPreset = false;

      const compressionPresets = {
        "500kb": {
          label: "500KB 이하",
          note: "용량 제한이 빡빡한 민원·학교 업로드에 맞춥니다.",
          targetBytes: 500 * 1024,
          outputFormat: "image/jpeg",
          maxSide: "1200",
          quality: "76"
        },
        "1mb": {
          label: "1MB 이하",
          note: "제출 호환성이 좋은 JPG로 1MB 이하를 우선 맞춥니다.",
          targetBytes: 1024 * 1024,
          outputFormat: "image/jpeg",
          maxSide: "1600",
          quality: "82"
        },
        "3mb": {
          label: "3MB 이하",
          note: "화질을 조금 더 남기면서 일반 업로드 제한에 맞춥니다.",
          targetBytes: 3 * 1024 * 1024,
          outputFormat: "image/jpeg",
          maxSide: "2000",
          quality: "86"
        },
        custom: {
          label: "직접 설정",
          note: "출력 형식, 최대 크기, 품질을 직접 조절합니다.",
          targetBytes: 0,
          outputFormat: "",
          maxSide: "",
          quality: ""
        }
      };
      const requestedPreset = new URLSearchParams(window.location.search).get("preset");
      const initialPreset =
        requestedPreset && Object.prototype.hasOwnProperty.call(compressionPresets, requestedPreset)
          ? requestedPreset
          : "";

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "image-compressor",
          tool_title: "사진 용량 줄이기",
          ...params
        });
      }

      function toFiles(items = fileItems) {
        return items.map((item) => item.file);
      }

      function totalSize(nextFiles = toFiles()) {
        return fileTools.totalSize(nextFiles);
      }

      function totalOutputSize(items = fileItems) {
        return items.reduce((sum, item) => sum + (item.result?.size || 0), 0);
      }

      function outputExtension() {
        return fileTools.outputExtension(outputFormat.value);
      }

      function selectedPreset() {
        return compressionPresets[presetSelect.value] || compressionPresets.custom;
      }

      function formatTargetSize(bytes) {
        if (!bytes) return "직접 설정";
        if (bytes % (1024 * 1024) === 0) return `${bytes / 1024 / 1024}MB 이하`;
        return `${fileTools.formatBytes(bytes)} 이하`;
      }

      function qualitySteps(startQuality) {
        const candidates = [startQuality, 78, 72, 66, 60, 54, 48, 44];
        return [...new Set(candidates)]
          .filter((quality) => quality <= startQuality && quality >= 40)
          .sort((a, b) => b - a);
      }

      function maxSideSteps(startMaxSide) {
        const base = Number.isFinite(startMaxSide) ? startMaxSide : 2000;
        const candidates = [base, 1800, 1600, 1400, 1200, 1000, 800];
        return [...new Set(candidates)]
          .filter((side) => side <= base && side >= 640)
          .sort((a, b) => b - a);
      }

      function outputFormatLabel() {
        return outputFormat.value === "image/webp" ? "WebP" : "JPG";
      }

      function maxSideLabel() {
        return maxSideSelect.value === "original" ? "원본 크기 유지" : `긴 변 ${maxSideSelect.value}px`;
      }

      function resultTargetSummary() {
        const preset = selectedPreset();
        if (!preset.targetBytes) return "직접 설정한 값으로 압축합니다.";
        const readyItems = fileItems.filter((item) => item.result);
        if (readyItems.length === 0) return "용량 줄이기 후 기준 통과 여부를 확인합니다.";
        const passed = readyItems.filter((item) => item.result.size <= preset.targetBytes).length;
        if (passed === readyItems.length) {
          return `${formatter.format(passed)}장 모두 ${formatTargetSize(preset.targetBytes)} 통과`;
        }
        return `${formatter.format(readyItems.length - passed)}장이 ${formatTargetSize(preset.targetBytes)} 초과`;
      }

      function updateCompressionCheck() {
        const preset = selectedPreset();
        presetNote.textContent = preset.note;
        compressionCheckItems.target.textContent = preset.targetBytes
          ? `${formatTargetSize(preset.targetBytes)} 압축 기준`
          : "직접 설정한 압축 기준";
        compressionCheckItems.settings.textContent = `${outputFormatLabel()} · ${maxSideLabel()} · 품질 ${qualityInput.value}`;
        compressionCheckItems.result.textContent = resultTargetSummary();
      }

      function applyPreset(resetResults = true) {
        const preset = selectedPreset();
        isApplyingPreset = true;
        if (preset.outputFormat) outputFormat.value = preset.outputFormat;
        if (preset.maxSide) maxSideSelect.value = preset.maxSide;
        if (preset.quality) qualityInput.value = preset.quality;
        isApplyingPreset = false;
        if (resetResults) {
          for (const item of fileItems) releaseResult(item);
        }
        renderFiles();
      }

      function setMessage(status, meta = "") {
        outputStatus.textContent = status;
        outputMeta.textContent = meta;
      }

      function setBusy(isBusy) {
        compressButton.disabled = isBusy || fileItems.length === 0;
        compressLabel.textContent = isBusy ? "압축 중" : "용량 줄이기";
      }

      function updateNextPdfCard(readyCount = 0) {
        if (readyCount === 0) {
          nextPdfCard.hidden = true;
          return;
        }
        nextPdfCard.hidden = false;
        nextPdfMessage.textContent =
          `${formatter.format(readyCount)}장 압축 완료. 먼저 저장 버튼으로 압축 이미지를 저장한 뒤 JPG PDF 변환에서 다시 선택하세요.`;
      }

      function releaseResult(item) {
        fileTools.revokeResult(item.result);
        item.result = null;
      }

      function releaseItems(items = fileItems) {
        fileTools.revokePreviewItems(items);
      }

      function setFileItems(nextFiles) {
        releaseItems();
        fileItems = fileTools.createFileItems(nextFiles, () => nextItemId++);
        renderFiles();
      }

      function renderFiles() {
        compressButton.disabled = fileItems.length === 0;
        formatBadge.textContent = outputFormatLabel();
        qualityLabel.textContent = qualityInput.value;
        updateCompressionCheck();

        if (fileItems.length === 0) {
          fileLabel.textContent = "JPG/PNG/WebP 여러 장 선택";
          compressList.innerHTML = '<p class="empty-state">선택된 이미지가 없습니다.</p>';
          updateNextPdfCard(0);
          setMessage("이미지를 선택하면 용량을 줄일 수 있습니다.", "압축된 파일은 아직 준비되지 않았습니다.");
          return;
        }

        fileLabel.textContent = `${formatter.format(fileItems.length)}장 선택`;
        compressList.innerHTML = fileItems
          .map((item, index) => {
            const result = item.result;
            const saved = result ? Math.max(0, item.file.size - result.size) : 0;
            const savedRate = result ? Math.round((saved / item.file.size) * 100) : 0;
            const preset = selectedPreset();
            const targetPassed = result && preset.targetBytes && result.size <= preset.targetBytes;
            const targetLabel = result && preset.targetBytes
              ? `<span class="target-badge ${targetPassed ? "is-pass" : "is-warn"}">${targetPassed ? "기준 통과" : "기준 초과"}</span>`
              : "";
            return `
              <div class="compress-row" data-compress-row>
                <img src="${item.previewUrl}" alt="" loading="lazy" />
                <div>
                  <strong>${index + 1}번 이미지</strong>
                  <p>${fileTools.formatBytes(item.file.size)}${result ? ` → ${fileTools.formatBytes(result.size)} (${savedRate}% 감소)` : " 선택됨"}</p>
                  ${targetLabel}
                </div>
                ${
                  result
                    ? `<a class="btn primary" href="${result.url}" download="compressed-image-${index + 1}.${outputExtension()}" data-download-image data-before-size="${item.file.size}" data-after-size="${result.size}">저장</a>`
                    : '<span class="pending-badge">대기</span>'
                }
              </div>
            `;
          })
          .join("");

        const readyCount = fileItems.filter((item) => item.result).length;
        if (readyCount > 0) {
          updateNextPdfCard(readyCount);
          setMessage(
            `압축 완료: ${formatter.format(readyCount)}장`,
            `총 ${fileTools.formatBytes(totalSize())} → ${fileTools.formatBytes(totalOutputSize())}. ${resultTargetSummary()}`
          );
        } else {
          updateNextPdfCard(0);
          setMessage(
            `${formatter.format(fileItems.length)}장 선택됨`,
            `총 ${fileTools.formatBytes(totalSize())}, ${formatTargetSize(selectedPreset().targetBytes)} 기준으로 압축합니다.`
          );
        }
      }

      function validateFiles(nextFiles) {
        return fileTools.validateImageFiles(nextFiles, { maxFiles, maxFileSize, maxTotalSize });
      }

      function validationMessage(reason) {
        return fileTools.validationMessage(reason, "용량을 줄일 이미지를 선택해 주세요.");
      }

      async function compressItem(item) {
        const preset = selectedPreset();
        const maxSide = maxSideSelect.value === "original" ? Infinity : Number(maxSideSelect.value);
        const startQuality = Number(qualityInput.value);
        const targetBytes = preset.targetBytes;

        let result = await fileTools.exportImageFile(item.file, {
          maxSide,
          type: outputFormat.value,
          quality: startQuality / 100
        });

        if (targetBytes && result.blob.size > targetBytes) {
          let bestResult = result;
          const sideSteps = maxSideSteps(maxSide);
          for (const side of sideSteps) {
            for (const quality of qualitySteps(startQuality)) {
              const candidate = await fileTools.exportImageFile(item.file, {
                maxSide: side,
                type: outputFormat.value,
                quality: quality / 100
              });
              if (candidate.blob.size < bestResult.blob.size) bestResult = candidate;
              if (candidate.blob.size <= targetBytes) {
                bestResult = candidate;
                break;
              }
            }
            if (bestResult.blob.size <= targetBytes) break;
          }
          result = bestResult;
        }

        releaseResult(item);
        item.result = {
          size: result.blob.size,
          url: URL.createObjectURL(result.blob),
          width: result.width,
          height: result.height
        };
      }

      async function compressImages() {
        const validation = validateFiles(toFiles());
        if (!validation.ok) {
          const message = validationMessage(validation.reason);
          setMessage(message, "파일을 다시 선택한 뒤 시도해 주세요.");
          track("image_compressor_validation_error", { reason: validation.reason });
          return;
        }

        setBusy(true);
        setMessage("이미지 압축 중", `${formatter.format(fileItems.length)}장 이미지를 정리하고 있습니다.`);
        try {
          for (const item of fileItems) {
            await compressItem(item);
          }
          renderFiles();
          track("image_compressor_compress", {
            ...fileTools.safeFileAnalyticsPayload(toFiles()),
            output_size: totalOutputSize(),
            output_format: outputFormat.value,
            quality: Number(qualityInput.value),
            max_side: maxSideSelect.value,
            preset: presetSelect.value,
            target_size: selectedPreset().targetBytes || null
          });
        } catch (error) {
          setMessage("이미지를 압축하지 못했습니다.", "이미지 파일을 다시 선택하거나 장수를 줄여서 시도해 주세요.");
          track("image_compressor_validation_error", {
            reason: error?.message || "compression_failed"
          });
        } finally {
          setBusy(false);
        }
      }

      function sampleFile(label, color, width, height) {
        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext("2d");
        const gradient = ctx.createLinearGradient(0, 0, width, height);
        gradient.addColorStop(0, "#ffffff");
        gradient.addColorStop(1, "#eef3f6");
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, width, height);
        ctx.fillStyle = color;
        ctx.fillRect(0, Math.round(height * 0.62), width, Math.round(height * 0.38));
        ctx.fillStyle = "rgba(255,255,255,0.76)";
        for (let i = 0; i < 22; i += 1) {
          ctx.beginPath();
          ctx.arc((i * 193) % width, (i * 137) % height, 42 + (i % 5) * 8, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.fillStyle = "#14212f";
        ctx.font = "900 72px sans-serif";
        ctx.fillText(label, 90, 160);
        return new Promise((resolve) => {
          canvas.toBlob((blob) => {
            resolve(new File([blob], `${label}.jpg`, { type: "image/jpeg" }));
          }, "image/jpeg", 0.96);
        });
      }

      input.addEventListener("change", (event) => {
        const nextFiles = Array.from(event.target.files || []);
        const validation = validateFiles(nextFiles);
        if (!validation.ok) {
          const message = validationMessage(validation.reason);
          setFileItems([]);
          input.value = "";
          setMessage(message, "파일을 다시 선택해 주세요.");
          track("image_compressor_validation_error", {
            reason: validation.reason,
            ...fileTools.safeFileAnalyticsPayload(nextFiles)
          });
          return;
        }
        setFileItems(nextFiles);
        track("image_compressor_file_select", {
          ...fileTools.safeFileAnalyticsPayload(toFiles())
        });
      });

      for (const control of [outputFormat, maxSideSelect, qualityInput]) {
        control.addEventListener("input", () => {
          if (!isApplyingPreset) presetSelect.value = "custom";
          for (const item of fileItems) releaseResult(item);
          renderFiles();
        });
      }

      presetSelect.addEventListener("change", () => {
        applyPreset(true);
        track("image_compressor_preset_change", {
          preset: presetSelect.value,
          target_size: selectedPreset().targetBytes || null
        });
      });

      sampleButton.addEventListener("click", async () => {
        setFileItems([
          await sampleFile("sample-photo", "#117a7a", 2400, 1600),
          await sampleFile("document-photo", "#b54708", 1800, 2400)
        ]);
        input.value = "";
        track("image_compressor_sample_apply", { file_count: fileItems.length });
      });

      resetButton.addEventListener("click", () => {
        setFileItems([]);
        input.value = "";
        presetSelect.value = "1mb";
        applyPreset(false);
        track("image_compressor_reset");
      });

      compressButton.addEventListener("click", compressImages);

      compressList.addEventListener("click", (event) => {
        const link =
          event.target instanceof Element ? event.target.closest("[data-download-image]") : null;
        if (!link) return;
        track("image_compressor_download", {
          output_format: outputFormat.value,
          before_size: Number(link.dataset.beforeSize || 0),
          after_size: Number(link.dataset.afterSize || 0)
        });
      });

      nextPdfLink.addEventListener("click", () => {
        track("image_compressor_next_pdf_click", {
          file_count: fileItems.filter((item) => item.result).length,
          output_size: totalOutputSize(),
          preset: presetSelect.value,
          target_size: selectedPreset().targetBytes || null,
          target_tool_id: "jpg-to-pdf",
          href: "/tools/jpg-to-pdf-converter/?from=compressed-images"
        });
      });

      window.addEventListener("pagehide", () => releaseItems());

      if (initialPreset) presetSelect.value = initialPreset;
      applyPreset(false);
      if (initialPreset) {
        track("image_compressor_preset_arrival", {
          preset: presetSelect.value,
          target_size: selectedPreset().targetBytes || null,
          source: "submission-prep"
        });
      }
    })();
  </script>
</BaseLayout>

