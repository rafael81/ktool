  }

  .crop-result {
    margin-top: 16px;
  }

  :global(.crop-row) {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 12px;
  }

  :global(.crop-row img) {
