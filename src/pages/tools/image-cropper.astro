    font-size: 13px;
    font-weight: 700;
    line-height: 1.45;
  }

  .hidden {
    display: none !important;
  }

  .format-badge {
    border-radius: 7px;
    background: #e8f4f2;
    color: var(--accent-dark);
    font-size: 13px;
    font-weight: 900;
    padding: 5px 8px;
  }

  .crop-summary {
    display: grid;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #f8fbfc;
    padding: 18px;
  }

  .crop-summary > span,
  :global(.crop-row strong) {
    color: #344457;
    font-size: 13px;
    font-weight: 900;
  }

  .crop-summary strong {
    color: var(--ink);
    font-size: 24px;
    line-height: 1.3;
  }

  .crop-summary p,
  :global(.crop-row p) {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .crop-canvas-frame {
    display: grid;
    min-height: 280px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      linear-gradient(45deg, #f2f6f8 25%, transparent 25%),
      linear-gradient(-45deg, #f2f6f8 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #f2f6f8 75%),
      linear-gradient(-45deg, transparent 75%, #f2f6f8 75%),
      #fff;
    background-position:
      0 0,
      0 10px,
