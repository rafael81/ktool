---
import BaseLayout from "@/layouts/BaseLayout.astro";
import IconGlyph from "@/components/IconGlyph.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema } from "@/data/seo";

const tool = getTool("image-resizer");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main
    class="page-shell"
    data-tool-id={tool.id}
    data-tool-title={tool.title}
  >
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>{tool.description} 제출처의 픽셀 제한이나 문서 삽입 크기에 맞춰 이미지를 빠르게 정리합니다.</p>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="resize-workspace" data-image-resizer>
      <form class="panel resize-panel" aria-label="이미지 리사이즈 입력">
        <div class="panel-title">
          <h2>이미지 입력</h2>
        </div>

        <label class="field">
          <span>이미지 파일</span>
          <span class="file-control">
            <input data-image-input type="file" accept="image/png,image/jpeg,image/webp" multiple />
            <span data-file-label>JPG/PNG/WebP 여러 장 선택</span>
          </span>
        </label>

        <label class="field">
          <span>리사이즈 방식</span>
          <select data-resize-mode>
            <option value="long-side">긴 변 기준</option>
            <option value="exact">직접 크기</option>
          </select>
        </label>

        <label class="field preset-field">
          <span>제출 크기 프리셋</span>
          <select data-resize-preset>
            <option value="long-1200">기본 제출 · 긴 변 1200px</option>
            <option value="long-800">용량 우선 · 긴 변 800px</option>
            <option value="long-1600">글자 선명 · 긴 변 1600px</option>
            <option value="square-800">800×800 제한 · 비율 유지</option>
            <option value="custom">직접 설정</option>
          </select>
          <small data-resize-preset-note>제출 호환성이 좋은 긴 변 1200px JPG로 맞춥니다.</small>
        </label>

        <div class="field-grid two-columns" data-long-side-controls>
          <label class="field">
            <span>긴 변 크기</span>
            <input data-long-side inputmode="numeric" value="1200" />
          </label>
          <label class="field">
            <span>출력 형식</span>
            <select data-output-format>
              <option value="image/jpeg">JPG</option>
              <option value="image/png">PNG</option>
              <option value="image/webp">WebP</option>
            </select>
          </label>
        </div>

        <div class="field-grid two-columns hidden" data-exact-controls>
          <label class="field">
            <span>가로 px</span>
            <input data-target-width inputmode="numeric" value="800" />
          </label>
          <label class="field">
            <span>세로 px</span>
            <input data-target-height inputmode="numeric" value="800" />
          </label>
        </div>

        <label class="check-field hidden" data-aspect-control>
          <input data-keep-aspect type="checkbox" checked />
          <span>원본 비율 유지</span>
        </label>

        <label class="field range-field">
          <span>품질 <strong data-quality-label>88</strong></span>
          <input data-quality type="range" min="50" max="95" step="1" value="88" />
        </label>

        <p class="note-box">
          최대 20장, 총 50MB, 파일당 12MB까지 처리합니다. 원본 파일은 바꾸지 않고 새 리사이즈 이미지를 만듭니다.
        </p>

        <div class="button-row">
          <button class="btn" type="button" data-sample>
            <IconGlyph name="plus" aria-hidden="true" />
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <IconGlyph name="refresh" aria-hidden="true" />
            초기화
          </button>
          <button class="btn primary" type="button" data-resize disabled>
            <IconGlyph name="maximize" aria-hidden="true" />
            <span data-resize-label>크기 줄이기</span>
          </button>
        </div>
      </form>

      <section class="preview-panel resize-preview-panel" aria-label="이미지 리사이즈 결과">
        <div class="panel-title">
          <h2>리사이즈 결과</h2>
          <span class="format-badge" data-format-badge>JPG</span>
        </div>

        <div class="resize-summary">
          <span>상태</span>
          <strong data-output-status>이미지를 선택하면 크기를 줄일 수 있습니다.</strong>
          <p data-output-meta>리사이즈된 파일은 아직 준비되지 않았습니다.</p>
        </div>

        <div class="resize-list" data-resize-list aria-live="polite">
          <p class="empty-state">선택된 이미지가 없습니다.</p>
        </div>

        <div class="next-pdf-card" data-next-pdf hidden>
          <strong>다음 단계: PDF로 묶기</strong>
          <p data-next-pdf-message>
            리사이즈 이미지를 저장한 뒤 JPG PDF 변환에서 다시 선택하면 여러 장을 한 파일로 묶을 수 있습니다.
          </p>
          <div class="next-action-strip" data-next-save-hint>
            <strong>1. 저장 버튼을 먼저 누르세요</strong>
            <span>저장한 이미지를 다시 선택해야 PDF로 묶을 수 있습니다.</span>
          </div>
          <ol>
            <li>각 리사이즈 이미지의 저장 버튼을 눌러 파일을 저장합니다.</li>
            <li>JPG PDF 변환에서 저장한 이미지를 선택합니다.</li>
            <li>제출 전 마지막 확인에서 크기와 페이지 순서를 확인합니다.</li>
          </ol>
          <a
            class="btn primary"
            href="/tools/jpg-to-pdf-converter/?from=resized-images"
            data-next-pdf-link
          >
            JPG PDF 변환 열기
          </a>
        </div>
      </section>

      <aside class="side-panel">
        <div class="panel-title">
          <h3>서버 전송 없음</h3>
        </div>
        <ul class="status-list">
          <li><span class="status-dot"></span><span>이미지는 브라우저 캔버스에서만 처리합니다.</span></li>
          <li><span class="status-dot"></span><span>파일명과 원본 이미지는 분석 이벤트로 보내지 않습니다.</span></li>
          <li><span class="status-dot"></span><span>긴 변 기준은 원본 비율을 유지합니다.</span></li>
        </ul>
      </aside>
    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>크기를 줄일 JPG, PNG, WebP 이미지를 선택합니다.</li>
        <li>긴 변 기준 또는 직접 크기 방식을 고릅니다.</li>
        <li>크기 줄이기를 누른 뒤 준비된 이미지를 저장합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline src="/scripts/file-tool-utils.js"></script>
  <script is:inline>
    (() => {
      const root = document.querySelector("[data-image-resizer]");
      if (!root) return;
      const fileTools = window.KdocFileTools;
      if (!fileTools) return;

      const maxFiles = 20;
      const maxFileSize = 12 * 1024 * 1024;
      const maxTotalSize = 50 * 1024 * 1024;
      const minDimension = 16;
      const maxDimension = 5000;
      const input = root.querySelector("[data-image-input]");
      const fileLabel = root.querySelector("[data-file-label]");
      const resizeMode = root.querySelector("[data-resize-mode]");
      const resizePreset = root.querySelector("[data-resize-preset]");
      const resizePresetNote = root.querySelector("[data-resize-preset-note]");
      const outputFormat = root.querySelector("[data-output-format]");
      const longSideInput = root.querySelector("[data-long-side]");
      const widthInput = root.querySelector("[data-target-width]");
      const heightInput = root.querySelector("[data-target-height]");
      const keepAspect = root.querySelector("[data-keep-aspect]");
      const longSideControls = root.querySelector("[data-long-side-controls]");
      const exactControls = root.querySelector("[data-exact-controls]");
      const aspectControl = root.querySelector("[data-aspect-control]");
      const qualityInput = root.querySelector("[data-quality]");
      const qualityLabel = root.querySelector("[data-quality-label]");
      const formatBadge = root.querySelector("[data-format-badge]");
      const resizeButton = root.querySelector("[data-resize]");
      const resizeLabel = root.querySelector("[data-resize-label]");
      const resetButton = root.querySelector("[data-reset]");
      const sampleButton = root.querySelector("[data-sample]");
      const outputStatus = root.querySelector("[data-output-status]");
      const outputMeta = root.querySelector("[data-output-meta]");
      const resizeList = root.querySelector("[data-resize-list]");
      const nextPdfCard = root.querySelector("[data-next-pdf]");
      const nextPdfMessage = root.querySelector("[data-next-pdf-message]");
      const nextPdfLink = root.querySelector("[data-next-pdf-link]");
      const formatter = new Intl.NumberFormat("ko-KR");
      let fileItems = [];
      let nextItemId = 1;
      let isApplyingPreset = false;
      const resizePresets = {
        "long-1200": {
          mode: "long-side",
          longSide: "1200",
          outputFormat: "image/jpeg",
          quality: "88",
          note: "제출 호환성이 좋은 긴 변 1200px JPG로 맞춥니다."
        },
        "long-800": {
          mode: "long-side",
          longSide: "800",
          outputFormat: "image/jpeg",
          quality: "84",
          note: "용량을 더 줄여야 할 때 긴 변 800px JPG로 낮춥니다."
        },
        "long-1600": {
          mode: "long-side",
          longSide: "1600",
          outputFormat: "image/jpeg",
          quality: "90",
          note: "글자 판독이 중요하면 긴 변 1600px JPG로 여유를 둡니다."
        },
        "square-800": {
          mode: "exact",
          width: "800",
          height: "800",
          keepAspect: true,
          outputFormat: "image/jpeg",
          quality: "88",
          note: "프로필·증명용처럼 800×800px 제한이 있을 때 원본 비율을 유지해 맞춥니다."
        },
        custom: {
          note: "제출처 안내에 맞춰 크기와 형식을 직접 조정합니다."
        }
      };
      const searchParams = new URLSearchParams(window.location.search);
      const requestedPreset = searchParams.get("preset");
      const requestedSource = searchParams.get("source");
      const requestedShortcutId = searchParams.get("shortcut_id");
      const initialPreset =
        requestedPreset && Object.prototype.hasOwnProperty.call(resizePresets, requestedPreset)
          ? requestedPreset
          : "";
      const arrivalSource = /^[a-z0-9-]{1,80}$/i.test(requestedSource || "")
        ? requestedSource
        : "submission-prep";
      const shortcutId = /^[a-z0-9-]{1,80}$/i.test(requestedShortcutId || "") ? requestedShortcutId : "";

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "image-resizer",
          tool_title: "이미지 리사이즈",
          ...params
        });
      }

      function toFiles(items = fileItems) {
        return items.map((item) => item.file);
      }

      function totalSize(nextFiles = toFiles()) {
        return fileTools.totalSize(nextFiles);
      }

      function totalOutputSize(items = fileItems) {
        return items.reduce((sum, item) => sum + (item.result?.size || 0), 0);
      }

      function outputExtension() {
        return fileTools.outputExtension(outputFormat.value);
      }

      function selectedPreset() {
        return resizePresets[resizePreset.value] || resizePresets.custom;
      }

      function presetPayload() {
        return {
          preset: resizePreset.value,
          resize_mode: resizeMode.value,
          long_side: resizeMode.value === "long-side" ? numberValue(longSideInput) : null,
          width: resizeMode.value === "exact" ? numberValue(widthInput) : null,
          height: resizeMode.value === "exact" ? numberValue(heightInput) : null,
          keep_aspect: keepAspect.checked
        };
      }

      function updatePresetNote() {
        resizePresetNote.textContent = selectedPreset().note;
      }

      function setMessage(status, meta = "") {
        outputStatus.textContent = status;
        outputMeta.textContent = meta;
      }

      function setBusy(isBusy) {
        resizeButton.disabled = isBusy || fileItems.length === 0;
        resizeLabel.textContent = isBusy ? "처리 중" : "크기 줄이기";
      }

      function numberValue(inputElement) {
        const value = Number(String(inputElement.value || "").replaceAll(",", ""));
        return Number.isFinite(value) ? Math.round(value) : 0;
      }

      function dimensionValidation() {
        const values =
          resizeMode.value === "long-side"
            ? [numberValue(longSideInput)]
            : [numberValue(widthInput), numberValue(heightInput)];
        if (values.some((value) => value < minDimension)) {
          return { ok: false, reason: "dimension_too_small" };
        }
        if (values.some((value) => value > maxDimension)) {
          return { ok: false, reason: "dimension_too_large" };
        }
        return { ok: true };
      }

      function validationMessage(reason) {
        if (reason === "dimension_too_small") return "이미지 크기는 16px 이상으로 입력해 주세요.";
        if (reason === "dimension_too_large") return "이미지 크기는 5000px 이하로 입력해 주세요.";
        return fileTools.validationMessage(reason, "크기를 줄일 이미지를 선택해 주세요.");
      }

      function validateFiles(nextFiles) {
        return fileTools.validateImageFiles(nextFiles, { maxFiles, maxFileSize, maxTotalSize });
      }

      function releaseResult(item) {
        fileTools.revokeResult(item.result);
        item.result = null;
      }

      function releaseItems(items = fileItems) {
        fileTools.revokePreviewItems(items);
      }

      function setFileItems(nextFiles) {
        releaseItems();
        fileItems = fileTools.createFileItems(nextFiles, () => nextItemId++);
        renderFiles();
      }

      function updateControlVisibility() {
        const exact = resizeMode.value === "exact";
        longSideControls.classList.toggle("hidden", exact);
        exactControls.classList.toggle("hidden", !exact);
        aspectControl.classList.toggle("hidden", !exact);
        formatBadge.textContent = outputExtension().toUpperCase();
        qualityLabel.textContent = qualityInput.value;
        updatePresetNote();
      }

      function applyResizePreset(shouldTrack = true) {
        const preset = selectedPreset();
        if (resizePreset.value !== "custom") {
          isApplyingPreset = true;
          resizeMode.value = preset.mode;
          outputFormat.value = preset.outputFormat;
          qualityInput.value = preset.quality;
          if (preset.mode === "long-side") {
            longSideInput.value = preset.longSide;
          } else {
            widthInput.value = preset.width;
            heightInput.value = preset.height;
            keepAspect.checked = preset.keepAspect;
          }
          isApplyingPreset = false;
        }
        for (const item of fileItems) releaseResult(item);
        renderFiles();
        if (shouldTrack) {
          track("image_resize_preset_change", presetPayload());
        }
      }

      function renderFiles() {
        updateControlVisibility();
        resizeButton.disabled = fileItems.length === 0;

        if (fileItems.length === 0) {
          fileLabel.textContent = "JPG/PNG/WebP 여러 장 선택";
          resizeList.innerHTML = '<p class="empty-state">선택된 이미지가 없습니다.</p>';
          nextPdfCard.hidden = true;
          setMessage("이미지를 선택하면 크기를 줄일 수 있습니다.", "리사이즈된 파일은 아직 준비되지 않았습니다.");
          return;
        }

        fileLabel.textContent = `${formatter.format(fileItems.length)}장 선택`;
        resizeList.innerHTML = fileItems
          .map((item, index) => {
            const result = item.result;
            return `
              <div class="resize-row" data-resize-row>
                <img src="${item.previewUrl}" alt="" loading="lazy" />
                <div>
                  <strong>${index + 1}번 이미지</strong>
                  <p>${fileTools.formatBytes(item.file.size)}${result ? ` → ${fileTools.formatBytes(result.size)} · ${result.width}×${result.height}px` : " 선택됨"}</p>
                </div>
                ${
                  result
                    ? `<a class="btn primary" href="${result.url}" download="resized-image-${index + 1}.${outputExtension()}" data-download-image data-before-size="${item.file.size}" data-after-size="${result.size}" data-output-width="${result.width}" data-output-height="${result.height}">저장</a>`
                    : '<span class="pending-badge">대기</span>'
                }
              </div>
            `;
          })
          .join("");

        const readyCount = fileItems.filter((item) => item.result).length;
        if (readyCount > 0) {
          setMessage(
            `리사이즈 완료: ${formatter.format(readyCount)}장`,
            `총 ${fileTools.formatBytes(totalSize())} → ${fileTools.formatBytes(totalOutputSize())}`
          );
          nextPdfCard.hidden = false;
          nextPdfMessage.textContent = `${formatter.format(readyCount)}장 리사이즈 완료. 먼저 저장 버튼으로 리사이즈 이미지를 저장한 뒤 JPG PDF 변환에서 다시 선택하세요.`;
        } else {
          nextPdfCard.hidden = true;
          setMessage(
            `${formatter.format(fileItems.length)}장 선택됨`,
            `총 ${fileTools.formatBytes(totalSize())}, 크기 줄이기를 누르면 처리합니다.`
          );
        }
      }

      function targetDimensions(sourceWidth, sourceHeight) {
        if (resizeMode.value === "long-side") {
          const longSide = numberValue(longSideInput);
          const scale = Math.min(1, longSide / Math.max(sourceWidth, sourceHeight));
          return {
            width: Math.max(1, Math.round(sourceWidth * scale)),
            height: Math.max(1, Math.round(sourceHeight * scale))
          };
        }

        const targetWidth = numberValue(widthInput);
        const targetHeight = numberValue(heightInput);
        if (!keepAspect.checked) return { width: targetWidth, height: targetHeight };
        const scale = Math.min(targetWidth / sourceWidth, targetHeight / sourceHeight);
        return {
          width: Math.max(1, Math.round(sourceWidth * scale)),
          height: Math.max(1, Math.round(sourceHeight * scale))
        };
      }

      async function resizeItem(item) {
        const image = await fileTools.imageFromFile(item.file);
        const sourceWidth = image.naturalWidth || image.width;
        const sourceHeight = image.naturalHeight || image.height;
        if (!sourceWidth || !sourceHeight) throw new Error("image_decode_failed");

        const dimensions = targetDimensions(sourceWidth, sourceHeight);
        const canvas = fileTools.drawImageOnWhiteCanvas(image, dimensions.width, dimensions.height);
        const blob = await fileTools.canvasToBlob(
          canvas,
          outputFormat.value,
          Number(qualityInput.value) / 100
        );
        releaseResult(item);
        item.result = {
          size: blob.size,
          url: URL.createObjectURL(blob),
          width: dimensions.width,
          height: dimensions.height
        };
      }

      async function resizeImages() {
        const files = toFiles();
        const fileValidation = validateFiles(files);
        const sizeValidation = dimensionValidation();
        const validation = fileValidation.ok ? sizeValidation : fileValidation;
        if (!validation.ok) {
          const message = validationMessage(validation.reason);
          setMessage(message, "입력값을 다시 확인한 뒤 시도해 주세요.");
          track("image_resize_validation_error", {
            reason: validation.reason,
            ...fileTools.safeFileAnalyticsPayload(files)
          });
          return;
        }

        setBusy(true);
        setMessage("이미지 리사이즈 중", `${formatter.format(fileItems.length)}장 이미지를 정리하고 있습니다.`);
        try {
          for (const item of fileItems) {
            await resizeItem(item);
          }
          renderFiles();
          track("image_resize_resize", {
            ...fileTools.safeFileAnalyticsPayload(files),
            output_size: totalOutputSize(),
            resize_mode: resizeMode.value,
            output_format: outputFormat.value,
            quality: Number(qualityInput.value),
            keep_aspect: keepAspect.checked,
            preset: resizePreset.value
          });
        } catch (error) {
          setMessage("이미지를 리사이즈하지 못했습니다.", "이미지 파일을 다시 선택하거나 장수를 줄여서 시도해 주세요.");
          track("image_resize_validation_error", {
            reason: error?.message || "resize_failed"
          });
        } finally {
          setBusy(false);
        }
      }

      function sampleFile(label, color, width, height) {
        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext("2d");
        const gradient = ctx.createLinearGradient(0, 0, width, height);
        gradient.addColorStop(0, "#ffffff");
        gradient.addColorStop(1, "#eef3f6");
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, width, height);
        ctx.fillStyle = color;
        ctx.fillRect(0, Math.round(height * 0.58), width, Math.round(height * 0.42));
        ctx.strokeStyle = "rgba(20,33,47,0.22)";
        ctx.lineWidth = 10;
        ctx.strokeRect(70, 70, width - 140, height - 140);
        ctx.fillStyle = "#14212f";
        ctx.font = "900 72px sans-serif";
        ctx.fillText(label, 90, 165);
        ctx.font = "700 34px sans-serif";
        ctx.fillText(`${width} x ${height}`, 90, 225);
        return new Promise((resolve) => {
          canvas.toBlob((blob) => {
            resolve(new File([blob], `${label}.jpg`, { type: "image/jpeg" }));
          }, "image/jpeg", 0.94);
        });
      }

      input.addEventListener("change", (event) => {
        const nextFiles = Array.from(event.target.files || []);
        const validation = validateFiles(nextFiles);
        if (!validation.ok) {
          const message = validationMessage(validation.reason);
          setFileItems([]);
          input.value = "";
          setMessage(message, "파일을 다시 선택해 주세요.");
          track("image_resize_validation_error", {
            reason: validation.reason,
            ...fileTools.safeFileAnalyticsPayload(nextFiles)
          });
          return;
        }
        setFileItems(nextFiles);
        track("image_resize_file_select", {
          ...fileTools.safeFileAnalyticsPayload(toFiles())
        });
      });

      for (const control of [resizeMode, outputFormat, longSideInput, widthInput, heightInput, keepAspect, qualityInput]) {
        control.addEventListener("input", () => {
          if (!isApplyingPreset) resizePreset.value = "custom";
          for (const item of fileItems) releaseResult(item);
          renderFiles();
        });
        control.addEventListener("change", () => {
          if (!isApplyingPreset) resizePreset.value = "custom";
          for (const item of fileItems) releaseResult(item);
          renderFiles();
        });
      }

      resizePreset.addEventListener("change", () => applyResizePreset(true));

      sampleButton.addEventListener("click", async () => {
        setFileItems([
          await sampleFile("sample-photo", "#117a7a", 2400, 1600),
          await sampleFile("document-photo", "#b54708", 1800, 2400)
        ]);
        input.value = "";
        track("image_resize_sample_apply", { file_count: fileItems.length });
      });

      resetButton.addEventListener("click", () => {
        setFileItems([]);
        input.value = "";
        resizePreset.value = "long-1200";
        applyResizePreset(false);
        track("image_resize_reset");
      });

      resizeButton.addEventListener("click", resizeImages);

      resizeList.addEventListener("click", (event) => {
        const link =
          event.target instanceof Element ? event.target.closest("[data-download-image]") : null;
        if (!link) return;
        track("image_resize_download", {
          output_format: outputFormat.value,
          before_size: Number(link.dataset.beforeSize || 0),
          after_size: Number(link.dataset.afterSize || 0),
          output_width: Number(link.dataset.outputWidth || 0),
          output_height: Number(link.dataset.outputHeight || 0)
        });
      });

      nextPdfLink.addEventListener("click", () => {
        track("image_resize_next_pdf_click", {
          file_count: fileItems.filter((item) => item.result).length,
          output_size: totalOutputSize(),
          output_format: outputFormat.value,
          resize_mode: resizeMode.value,
          preset: resizePreset.value,
          target_tool_id: "jpg-to-pdf",
          href: "/tools/jpg-to-pdf-converter/?from=resized-images"
        });
      });

      window.addEventListener("pagehide", () => releaseItems());

      if (initialPreset) resizePreset.value = initialPreset;
      applyResizePreset(false);
      if (initialPreset) {
        track("image_resize_preset_arrival", {
          source: arrivalSource,
          ...(shortcutId ? { shortcut_id: shortcutId } : {}),
          ...presetPayload()
        });
      }
    })();
  </script>
</BaseLayout>

