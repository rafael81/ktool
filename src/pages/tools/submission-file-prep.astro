      </div>
      <div class="compact-tool-grid">
        {documentTools.map((tool) => (
          <a
            class="compact-tool"
            href={tool.path}
            data-analytics-event="prep_tool_click"
            data-analytics-tool-id={tool.id}
            data-analytics-tool-title={tool.title}
            data-analytics-label={tool.title}
          >
            <strong>{tool.title}</strong>
            <span>{tool.primaryQuery}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>FAQ</h2>
        <p>제출 전 파일을 다룰 때 자주 막히는 부분입니다.</p>
      </div>
      <div class="faq-list">
        {faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>
  </main>
</BaseLayout>

