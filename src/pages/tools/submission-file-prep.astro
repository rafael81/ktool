---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTool } from "@/data/tools";
import { collectionPageSchema, faqPageSchema } from "@/data/seo";

const pagePath = "/tools/submission-file-prep/";
const pageTitle = "제출용 파일 준비 - 사진 PDF 문서 제출 도구 모음";
const pageDescription =
  "사진 용량 줄이기, HEIC JPG 변환, WebP JPG 변환, 이미지 회전, 이미지 자르기, 이미지 리사이즈, JPG PDF 변환, 도장 배경 제거, 업무 문서 작성 도구를 제출 상황별로 빠르게 고르세요.";

const primaryTools = [
  getTool("heic-to-jpg"),
  getTool("image-converter"),
  getTool("image-rotator"),
  getTool("image-cropper"),
  getTool("image-resizer"),
  getTool("image-compressor"),
  getTool("jpg-to-pdf")
];

const documentTools = [
  getTool("transaction-statement"),
  getTool("estimate"),
  getTool("invoice"),
  getTool("receipt"),
  getTool("vat-calculator"),
  getTool("amount-korean"),
  getTool("withholding-tax")
];

const stampTools = [getTool("stamp-background"), getTool("business-nameplate")];

const flowGroups = [
  {
    title: "사진이나 스캔본을 제출할 때",
    description: "iPhone 사진, 스캔 이미지, 증빙 사진을 업로드 가능한 형식과 용량으로 맞춥니다.",
    steps: [
      {
        label: "HEIC 사진",
        detail: "iPhone HEIC가 열리지 않으면 먼저 JPG로 바꿉니다.",
        tool: getTool("heic-to-jpg")
      },
      {
        label: "WebP 오류",
        detail: "WebP나 PNG 형식을 JPG로 바꿔 제출 호환성을 맞춥니다.",
        tool: getTool("image-converter")
      },
      {
        label: "누운 사진",
        detail: "스캔본이나 사진이 옆으로 누워 있으면 방향을 돌립니다.",
        tool: getTool("image-rotator")
      },
      {
        label: "용량 초과",
        detail: "업로드 제한보다 큰 사진은 용량을 줄입니다.",
        tool: getTool("image-compressor")
      },
      {
        label: "불필요한 여백",
        detail: "주변 배경이나 빈 여백은 제출할 영역만 남깁니다.",
        tool: getTool("image-cropper")
      },
      {
        label: "픽셀 제한",
        detail: "가로·세로 또는 긴 변 기준이 있으면 크기를 맞춥니다.",
        tool: getTool("image-resizer")
      },
      {
        label: "PDF 한 개",
        detail: "여러 장의 이미지가 필요하면 한 PDF로 묶습니다.",
        tool: getTool("jpg-to-pdf")
      }
    ]
  },
  {
    title: "거래 문서를 바로 만들어야 할 때",
    description: "거래처에 보낼 기본 문서와 금액 계산을 브라우저에서 작성합니다.",
    steps: [
      {
        label: "거래 내역",
        detail: "품목과 단가를 넣어 거래명세서를 만듭니다.",
        tool: getTool("transaction-statement")
      },
      {
        label: "견적 전달",
        detail: "거래 전 금액과 조건은 견적서로 정리합니다.",
        tool: getTool("estimate")
      },
      {
        label: "입금 요청",
        detail: "완료된 작업의 청구 금액과 입금기한을 적습니다.",
        tool: getTool("invoice")
      },
      {
        label: "금액 확인",
        detail: "부가세, 한글 금액, 3.3% 원천징수를 빠르게 맞춥니다.",
        tool: getTool("vat-calculator")
      }
    ]
  },
  {
    title: "문서에 회사 정보나 도장을 넣을 때",
    description: "스캔 도장과 사업자 정보를 문서에 삽입하기 좋은 이미지로 정리합니다.",
    steps: [
      {
        label: "도장 배경",
        detail: "종이에 찍은 도장의 흰 배경을 투명하게 정리합니다.",
        tool: getTool("stamp-background")
      },
      {
        label: "사업자 명판",
        detail: "상호, 대표자, 사업자등록번호, 주소를 이미지로 만듭니다.",
        tool: getTool("business-nameplate")
      },
      {
        label: "이미지 형식",
        detail: "문서 편집기가 WebP를 받지 않으면 JPG나 PNG로 바꿉니다.",
        tool: getTool("image-converter")
      }
    ]
  }
];

const situations = [
  { label: "iPhone HEIC 사진이 안 열림", tool: getTool("heic-to-jpg") },
  { label: "WebP·PNG·JPG 형식을 바꿔야 함", tool: getTool("image-converter") },
  { label: "사진 방향이 잘못됨", tool: getTool("image-rotator") },
  { label: "파일 용량이 너무 큼", tool: getTool("image-compressor") },
  { label: "불필요한 여백을 잘라야 함", tool: getTool("image-cropper") },
  { label: "사진 크기 제한이 있음", tool: getTool("image-resizer") },
  { label: "이미지 여러 장을 PDF로 제출", tool: getTool("jpg-to-pdf") },
  { label: "거래처 문서가 필요함", tool: getTool("transaction-statement") },
  { label: "도장·명판 이미지를 넣어야 함", tool: getTool("business-nameplate") }
];

const pdfPathTools = [
  {
    label: "1",
    title: "iPhone HEIC",
    detail: "HEIC면 먼저 JPG로 바꿉니다.",
    tool: getTool("heic-to-jpg")
  },
  {
    label: "2",
    title: "방향·여백",
    detail: "누운 사진은 돌리고, 주변 여백은 자릅니다.",
    tool: getTool("image-rotator")
  },
  {
    label: "3",
    title: "크기·용량",
    detail: "업로드 제한에 맞춰 리사이즈하거나 압축합니다.",
    tool: getTool("image-resizer")
  },
  {
    label: "4",
    title: "PDF 묶기",
    detail: "마지막에 여러 장을 한 PDF로 저장합니다.",
    tool: getTool("jpg-to-pdf")
  }
];

const pdfDecisionHints = [
  {
    signal: "파일 형식 오류",
    recommendation: "변환 후 PDF",
    detail: "HEIC는 HEIC JPG, WebP는 WebP JPG 변환 후 묶습니다.",
    tool: getTool("image-converter")
  },
  {
    signal: "용량 초과",
    recommendation: "사진압축 먼저",
    detail: "압축 후에도 여러 장이면 마지막에 PDF로 묶습니다.",
    tool: getTool("image-compressor")
  },
  {
    signal: "여러 파일 업로드 불가",
    recommendation: "JPG PDF 변환",
    detail: "목록 순서와 여백을 확인하고 한 파일로 저장합니다.",
    tool: getTool("jpg-to-pdf")
  },
  {
    signal: "사진이 옆으로 돌아감",
    recommendation: "회전 후 PDF",
    detail: "방향을 맞춘 뒤 PDF 페이지 순서를 확인합니다.",
    tool: getTool("image-rotator")
  },
  {
    signal: "여백·배경이 많음",
    recommendation: "자르기 후 PDF",
    detail: "제출할 영역만 남기고 여러 장을 PDF로 묶습니다.",
    tool: getTool("image-cropper")
  }
];

const formatPathTools = [
  {
    label: "1",
    title: "iPhone HEIC",
    detail: "HEIC/HEIF 사진이 열리지 않으면 JPG 또는 PNG로 저장합니다.",
    tool: getTool("heic-to-jpg")
  },
  {
    label: "2",
    title: "WebP·PNG·JPG",
    detail: "제출처가 받는 이미지 형식으로 다시 저장합니다.",
    tool: getTool("image-converter")
  },
  {
    label: "3",
    title: "여러 장 제출",
    detail: "변환한 이미지를 저장한 뒤 한 PDF로 묶습니다.",
    tool: getTool("jpg-to-pdf")
  }
];

const compressionPathTools = [
  {
    label: "500KB",
    title: "빡빡한 업로드",
    detail: "민원·학교처럼 제한이 작을 때 먼저 500KB 기준으로 줄입니다.",
    href: `${getTool("image-compressor").path}?preset=500kb`,
    tool: getTool("image-compressor")
  },
  {
    label: "1MB",
    title: "기본 제출",
    detail: "대부분의 사진 제출은 1MB 이하 JPG 기준으로 먼저 확인합니다.",
    href: `${getTool("image-compressor").path}?preset=1mb`,
    tool: getTool("image-compressor")
  },
  {
    label: "3MB",
    title: "화질 우선",
    detail: "글자나 증빙이 작게 보이면 3MB 기준으로 여유를 둡니다.",
    href: `${getTool("image-compressor").path}?preset=3mb`,
    tool: getTool("image-compressor")
  },
  {
    label: "PDF",
    title: "여러 장 제출",
    detail: "압축 이미지를 저장한 뒤 마지막에 한 PDF로 묶습니다.",
    href: getTool("jpg-to-pdf").path,
    tool: getTool("jpg-to-pdf")
  }
];

const faqs = [
  [
    "제출용 파일은 어떤 순서로 준비하면 되나요?",
    "제출처가 요구하는 파일 형식, 용량, 픽셀 크기, PDF 여부를 먼저 확인한 뒤 형식 변환, 리사이즈, 용량 줄이기, PDF 묶기 순서로 처리하면 재작업을 줄일 수 있습니다."
  ],
  [
    "iPhone HEIC 사진은 바로 PDF로 묶어도 되나요?",
    "제출 호환성을 우선하면 HEIC를 JPG로 먼저 바꾼 뒤 필요하면 용량이나 크기를 줄이고 JPG PDF 변환으로 묶는 편이 안정적입니다."
  ],
  [
    "파일이 서버에 업로드되나요?",
    "K문서툴의 이미지와 PDF 파일 도구는 브라우저 안에서 처리하는 원칙으로 만들었습니다. 원본 파일과 파일명은 분석 이벤트로 보내지 않습니다."
  ],
  [
    "거래명세서나 청구서를 공식 세금 문서로 써도 되나요?",
    "아니요. K문서툴의 업무 문서 도구는 일반 문서 작성 보조용입니다. 세금계산서, 현금영수증, 전자서명, 법적 인증을 대신하지 않습니다."
  ],
  [
    "어떤 도구부터 써야 할지 모르겠어요.",
    "업로드 오류 문구를 기준으로 고르면 쉽습니다. HEIC 오류는 HEIC JPG 변환, WebP나 이미지 형식 오류는 WebP JPG 변환, 방향 문제는 이미지 회전, 용량 오류는 사진 용량 줄이기, 여백이나 배경 문제는 이미지 자르기, 크기 오류는 이미지 리사이즈, 여러 장 제출은 JPG PDF 변환부터 시작하세요."
  ],
  [
    "용량 제한이 500KB, 1MB, 3MB처럼 다르면 어떻게 고르나요?",
    "제출처 안내에 적힌 제한값을 먼저 고르세요. 제한이 1MB 이하라면 1MB 프리셋, 더 빡빡하면 500KB, 글자 판독이 중요하고 제한이 넉넉하면 3MB 프리셋으로 압축한 뒤 여러 장은 JPG PDF 변환으로 묶으면 됩니다."
  ]
] satisfies [string, string][];

const structuredData = [
  collectionPageSchema({
    name: "제출용 파일 준비",
    description: pageDescription,
    path: pagePath,
    tools: [...primaryTools, ...documentTools, ...stampTools]
  }),
  faqPageSchema(faqs)
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={pagePath}
  structuredData={structuredData}
>
  <main class="page-shell" data-submission-prep>
    <section class="tool-intro">
      <div>
        <h1>제출용 파일 준비</h1>
        <p>
          관공서, 학교, 회사, 거래처에 파일을 올리기 직전 필요한 형식 변환, 용량 줄이기,
          이미지 회전, 자르기, 크기 조정, PDF 묶기, 업무 문서 작성을 한 흐름으로 고릅니다.
        </p>
      </div>
      <div class="quick-links" aria-label="제출용 파일 준비 바로가기">
        {primaryTools.map((tool) => (
          <a
            href={tool.path}
            data-analytics-event="prep_quick_tool_click"
            data-analytics-tool-id={tool.id}
            data-analytics-tool-title={tool.title}
            data-analytics-label={tool.shortTitle}
          >
            {tool.shortTitle}
          </a>
        ))}
      </div>
    </section>

    <section class="pdf-path" data-pdf-path aria-label="사진 여러 장 PDF 제출 경로">
      <div class="pdf-path-copy">
        <span>가장 많이 쓰는 제출 흐름</span>
        <h2>사진 여러 장을 PDF 한 개로 제출</h2>
        <p>
          이미지가 여러 장이면 먼저 방향, 여백, 크기, 용량을 맞춘 뒤 마지막에 JPG PDF 변환으로 묶는 순서가 재작업을 줄입니다.
        </p>
      </div>
      <div class="pdf-path-steps">
        {pdfPathTools.map((step) => (
          <a
            href={step.tool.path}
            data-analytics-event="prep_pdf_path_click"
            data-analytics-tool-id={step.tool.id}
            data-analytics-tool-title={step.tool.title}
            data-analytics-label={step.title}
          >
            <span>{step.label}</span>
            <strong>{step.title}</strong>
            <p>{step.detail}</p>
          </a>
        ))}
      </div>
      <div class="pdf-path-diagnostics" data-pdf-decision>
        <strong>오류 문구별 추천 순서</strong>
        <div>
          {pdfDecisionHints.map((hint) => (
            <a
              href={hint.tool.path}
              data-analytics-event="prep_pdf_decision_click"
              data-analytics-tool-id={hint.tool.id}
              data-analytics-tool-title={hint.tool.title}
              data-analytics-label={hint.signal}
            >
              <span>{hint.signal}</span>
              <b>{hint.recommendation}</b>
              <p>{hint.detail}</p>
            </a>
          ))}
        </div>
      </div>
      <a
        class="pdf-path-cta"
        href={getTool("jpg-to-pdf").path}
        data-analytics-event="prep_pdf_path_click"
        data-analytics-tool-id={getTool("jpg-to-pdf").id}
        data-analytics-tool-title={getTool("jpg-to-pdf").title}
        data-analytics-label="PDF 묶기 CTA"
      >
        JPG PDF 변환으로 바로가기
      </a>
    </section>

    <section class="format-path" data-format-path aria-label="파일 형식 오류 해결 경로">
      <div class="format-path-copy">
        <span>형식 오류가 뜰 때</span>
        <h2>먼저 JPG로 맞추고, 여러 장이면 PDF로 묶기</h2>
        <p>
          HEIC, WebP처럼 제출처에서 열리지 않는 사진은 먼저 호환되는 이미지로 저장한 뒤
          필요한 경우 JPG PDF 변환에서 한 파일로 묶습니다.
        </p>
      </div>
      <div class="format-path-steps">
        {formatPathTools.map((step) => (
          <a
            href={step.tool.path}
            data-analytics-event="prep_format_path_click"
            data-analytics-tool-id={step.tool.id}
            data-analytics-tool-title={step.tool.title}
            data-analytics-label={step.title}
          >
            <span>{step.label}</span>
            <strong>{step.title}</strong>
            <p>{step.detail}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="compression-path" data-compression-path aria-label="파일 용량 초과 해결 경로">
      <div class="compression-path-copy">
        <span>용량 초과가 뜰 때</span>
        <h2>제출처 제한값에 맞춰 압축하고, 여러 장이면 PDF로 묶기</h2>
        <p>
          업로드 제한이 500KB, 1MB, 3MB처럼 적혀 있으면 해당 기준으로 먼저 줄입니다.
          압축한 이미지가 여러 장이면 저장 후 JPG PDF 변환에서 한 파일로 묶습니다.
        </p>
      </div>
      <div class="compression-path-steps">
        {compressionPathTools.map((step) => (
          <a
            href={step.href}
            data-analytics-event="prep_compression_path_click"
            data-analytics-tool-id={step.tool.id}
            data-analytics-tool-title={step.tool.title}
            data-analytics-label={step.title}
          >
            <span>{step.label}</span>
            <strong>{step.title}</strong>
            <p>{step.detail}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="prep-overview" aria-label="제출 상황별 바로가기">
      {situations.map((item) => (
        <a
          class="situation-link"
          href={item.tool.path}
          data-analytics-event="prep_situation_click"
          data-analytics-tool-id={item.tool.id}
          data-analytics-tool-title={item.tool.title}
          data-analytics-label={item.label}
        >
          <span>{item.label}</span>
          <strong>{item.tool.shortTitle}</strong>
        </a>
      ))}
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>제출 흐름</h2>
        <p>업로드 오류나 제출처 안내 문구에 맞춰 필요한 도구만 순서대로 사용합니다.</p>
      </div>
      <div class="flow-grid">
        {flowGroups.map((group) => (
          <section class="flow-panel">
            <div class="flow-heading">
              <h3>{group.title}</h3>
              <p>{group.description}</p>
            </div>
            <ol class="flow-steps">
              {group.steps.map((step) => (
                <li>
                  <div>
                    <span>{step.label}</span>
                    <p>{step.detail}</p>
                  </div>
                  <a
                    href={step.tool.path}
                    data-analytics-event="prep_flow_tool_click"
                    data-analytics-tool-id={step.tool.id}
                    data-analytics-tool-title={step.tool.title}
                    data-analytics-label={`${group.title} - ${step.label}`}
                  >
                    {step.tool.shortTitle}
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>파일 제출 도구</h2>
        <p>사진, 스캔본, 증빙 이미지를 제출 가능한 형식과 크기로 맞춥니다.</p>
      </div>
      <div class="tool-grid">
        {primaryTools.map((tool) => (
          <a
            class="tool-card"
            href={tool.path}
            data-analytics-event="prep_tool_click"
            data-analytics-tool-id={tool.id}
