---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema } from "@/data/seo";

const tool = getTool("withholding-tax");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main
    class="page-shell"
    data-tool-id={tool.id}
    data-tool-title={tool.title}
  >
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>{tool.description} 청구서나 영수증에 넣기 전 총 지급액, 원천징수액, 실수령액을 빠르게 맞춥니다.</p>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="calculator-workspace" data-withholding-calculator>
      <form class="panel calculator-panel" aria-label="3.3% 원천징수 계산 입력">
        <div class="panel-title">
          <h2>계산 입력</h2>
        </div>

        <fieldset class="mode-field">
          <legend>입력 기준</legend>
          <label class="mode-option">
            <input type="radio" name="withholding-mode" value="gross" checked data-withholding-mode />
            <span>총 지급액 기준</span>
          </label>
          <label class="mode-option">
            <input type="radio" name="withholding-mode" value="net" data-withholding-mode />
            <span>실수령액 기준</span>
          </label>
        </fieldset>

        <label class="field amount-field">
          <span data-amount-label>총 지급액</span>
          <input
            data-withholding-amount
            inputmode="numeric"
            autocomplete="off"
            value="1000000"
            aria-describedby="withholding-help"
          />
        </label>

        <p class="note-box" id="withholding-help">
          인적용역 사업소득 3.3% 간편 계산입니다. 사업소득세 3%와 개인지방소득세 0.3%를 원 단위로 반올림합니다.
        </p>

        <div class="button-row">
          <button class="btn" type="button" data-sample>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7M3 3v6h6"/></svg>
            초기화
          </button>
          <button class="btn primary" type="button" data-copy-result>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M8 8h10v12H8z"/><path d="M6 16H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            복사
          </button>
        </div>
      </form>

      <section class="result-panel" aria-label="3.3% 원천징수 계산 결과">
        <div class="panel-title">
          <h2>계산 결과</h2>
          <span class="rate-badge">3.3%</span>
        </div>
        <div class="result-grid">
          <div class="result-card total">
            <span>총 지급액</span>
            <strong data-gross-result>1,000,000원</strong>
          </div>
          <div class="result-card">
            <span>사업소득세 3%</span>
            <strong data-income-tax-result>30,000원</strong>
          </div>
          <div class="result-card">
            <span>개인지방소득세 0.3%</span>
            <strong data-local-tax-result>3,000원</strong>
          </div>
          <div class="result-card accent">
            <span>원천징수 합계</span>
            <strong data-tax-result>33,000원</strong>
          </div>
          <div class="result-card total net-card">
            <span>실수령액</span>
            <strong data-net-result>967,000원</strong>
          </div>
        </div>
        <div class="formula-box" data-formula>
          총 지급액 1,000,000원 - 원천징수 33,000원 = 실수령액 967,000원
        </div>
      </section>

      <aside class="side-panel">
        <div class="panel-title">
          <h3>확인 사항</h3>
        </div>
        <ul class="status-list">
          <li><span class="status-dot"></span><span>인적용역 사업소득 3.3% 기준의 단순 계산입니다.</span></li>
          <li><span class="status-dot"></span><span>근로소득, 기타소득, 비거주자 지급에는 다른 기준이 적용될 수 있습니다.</span></li>
          <li><span class="status-dot"></span><span>입력한 금액은 서버로 보내지 않습니다.</span></li>
        </ul>
      </aside>
    </section>

    <section class="content-section">
      <h2>계산 기준</h2>
      <p>
        K문서툴 3.3% 계산기는 국세청의 종합소득세 신고 안내에 나온 인적용역 사업소득 원천징수 설명을 기준으로 합니다.
        국세청은 인적용역 소득자에게 사업소득을 지급할 때 사업소득세 3%와 개인지방소득세 0.3%를 원천징수한다고 안내합니다.
        기준 확인일은 2026년 6월 27일입니다.
      </p>
      <ol>
        <li>총 지급액 기준: 총 지급액 × 3% = 사업소득세, 총 지급액 × 0.3% = 개인지방소득세</li>
        <li>실수령액 기준: 실수령액 ÷ 96.7% = 총 지급액 추정</li>
        <li>계산 결과는 원 단위로 반올림해 표시합니다.</li>
      </ol>
      <p>
        공식 안내는
        <a href="https://www.nts.go.kr/nts/cm/cntnts/cntntsView.do?cntntsId=239072" rel="noreferrer">국세청 종합소득세 확정신고 안내</a>를 확인하세요.
      </p>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-withholding-calculator]");
      if (!root) return;

      const currency = new Intl.NumberFormat("ko-KR");
      const amountInput = root.querySelector("[data-withholding-amount]");
      const amountLabel = root.querySelector("[data-amount-label]");
      const modeInputs = [...root.querySelectorAll("[data-withholding-mode]")];
      const grossResult = root.querySelector("[data-gross-result]");
      const incomeTaxResult = root.querySelector("[data-income-tax-result]");
      const localTaxResult = root.querySelector("[data-local-tax-result]");
      const taxResult = root.querySelector("[data-tax-result]");
      const netResult = root.querySelector("[data-net-result]");
      const formula = root.querySelector("[data-formula]");
      const copyButton = root.querySelector("[data-copy-result]");
      const sampleButton = root.querySelector("[data-sample]");
      const resetButton = root.querySelector("[data-reset]");

      function parseAmount(value) {
        const normalized = String(value || "").replace(/[^\d.-]/g, "");
        const parsed = Number(normalized);
        return Number.isFinite(parsed) ? Math.max(0, parsed) : 0;
      }

      function won(value) {
        return `${currency.format(Math.round(value))}원`;
      }

      function currentMode() {
        return modeInputs.find((input) => input.checked)?.value || "gross";
      }

      function calculate() {
        const mode = currentMode();
        const amount = Math.round(parseAmount(amountInput.value));
        const gross = mode === "net" ? Math.round(amount / 0.967) : amount;
        const incomeTax = Math.round(gross * 0.03);
        const localTax = Math.round(gross * 0.003);
        const tax = incomeTax + localTax;
        const net = gross - tax;

        amountLabel.textContent = mode === "net" ? "실수령액" : "총 지급액";
        grossResult.textContent = won(gross);
        incomeTaxResult.textContent = won(incomeTax);
        localTaxResult.textContent = won(localTax);
        taxResult.textContent = won(tax);
        netResult.textContent = won(net);
        formula.textContent = `총 지급액 ${won(gross)} - 원천징수 ${won(tax)} = 실수령액 ${won(net)}`;
        return { mode, gross, incomeTax, localTax, tax, net };
      }

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "withholding-tax",
          tool_title: "3.3% 계산기",
          ...params
        });
      }

      amountInput.addEventListener("input", calculate);
      for (const input of modeInputs) {
        input.addEventListener("change", () => {
          calculate();
          track("withholding_calculator_mode_change", { calculator_mode: currentMode() });
        });
      }

      sampleButton?.addEventListener("click", () => {
        amountInput.value = currentMode() === "net" ? "967000" : "1000000";
        calculate();
        track("withholding_calculator_sample_apply", { calculator_mode: currentMode() });
      });

      resetButton?.addEventListener("click", () => {
        amountInput.value = "";
        calculate();
        track("withholding_calculator_reset", { calculator_mode: currentMode() });
      });

      copyButton?.addEventListener("click", async () => {
        const result = calculate();
        const text = `총 지급액 ${won(result.gross)} / 사업소득세 ${won(result.incomeTax)} / 개인지방소득세 ${won(result.localTax)} / 실수령액 ${won(result.net)}`;
        try {
          await navigator.clipboard.writeText(text);
          copyButton.textContent = "복사됨";
          setTimeout(() => {
            copyButton.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M8 8h10v12H8z"/><path d="M6 16H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>복사';
          }, 1200);
          track("withholding_calculator_copy", { calculator_mode: result.mode });
        } catch {
          track("withholding_calculator_copy_error", { calculator_mode: result.mode });
        }
      });

      calculate();
    })();
  </script>
</BaseLayout>

<style>
  .calculator-workspace {
    display: grid;
    grid-template-columns: minmax(280px, 380px) minmax(0, 1fr) minmax(240px, 300px);
    gap: 18px;
    align-items: start;
  }

  .calculator-panel,
  .result-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 18px;
  }

  .mode-field {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    border: 0;
    margin: 0 0 14px;
    padding: 0;
  }

  .mode-field legend {
    grid-column: 1 / -1;
    color: #344457;
    font-size: 13px;
    font-weight: 800;
    margin-bottom: 6px;
  }

  .mode-option {
    display: flex;
    min-height: 44px;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--ink);
    cursor: pointer;
    font-size: 14px;
    font-weight: 800;
    padding: 10px;
  }

  .mode-option:has(input:checked) {
    border-color: var(--accent);
    background: #e8f4f2;
    color: var(--accent-dark);
  }

  .mode-option input {
    width: 16px;
    height: 16px;
    accent-color: var(--accent);
  }

  .amount-field input {
    font-size: 24px;
    font-weight: 900;
  }

  .result-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 12px;
  }

  .result-card {
    display: grid;
    min-height: 124px;
    align-content: center;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    grid-column: span 2;
    padding: 18px;
  }

  .result-card span {
    color: var(--muted);
    font-size: 14px;
    font-weight: 800;
  }

  .result-card strong {
    color: var(--ink);
    font-size: clamp(22px, 2.7vw, 32px);
    line-height: 1.1;
    white-space: nowrap;
    word-break: keep-all;
  }

  .result-card.accent {
    background: #f8fbfc;
  }

  .result-card.total {
    border-color: var(--accent);
    background: #e8f4f2;
  }

  .net-card {
    grid-column: span 4;
  }

  .rate-badge {
    border-radius: 7px;
    background: #e8f4f2;
    color: var(--accent-dark);
    font-size: 13px;
    font-weight: 900;
    padding: 5px 8px;
  }

  .formula-box {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #f8fbfc;
    color: #344457;
    font-size: 16px;
    font-weight: 800;
    line-height: 1.6;
    margin-top: 14px;
    padding: 16px;
  }

  .content-section :where(p, li) > a {
    color: var(--accent-dark);
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 1100px) {
    .calculator-workspace {
      grid-template-columns: minmax(280px, 380px) minmax(0, 1fr);
    }

    .calculator-workspace .side-panel {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 760px) {
    .calculator-workspace,
    .mode-field {
      grid-template-columns: 1fr;
    }

    .result-grid {
      grid-template-columns: 1fr;
    }

    .result-card,
    .net-card {
      grid-column: auto;
    }
  }
</style>
