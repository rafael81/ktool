---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema, webPageSchema } from "@/data/seo";
import { FileOutput, FolderOpen, Plus, RefreshCw } from "@lucide/astro";

const tool = getTool("pdf-split");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  webPageSchema({
    name: tool.title,
    description: tool.metaDescription,
    path: tool.path,
    keywords: [tool.primaryQuery, ...tool.secondaryQueries, "PDF 나누기 무료", "PDF 분할 서버 전송 없음"]
  }),
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main
    class="page-shell file-tool-shell"
    data-tool-id={tool.id}
    data-tool-title={tool.title}
  >
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>PDF를 페이지별 또는 원하는 범위별로 나눠 저장하세요.</p>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="pdf-split-workspace" data-pdf-split-tool>
      <form class="panel pdf-split-panel pdf-upload-panel" aria-label="PDF 나누기 입력">
        <label class="pdf-dropzone upload-dropzone file-control" data-upload-zone>
          <input data-pdf-input type="file" accept="application/pdf,.pdf" />
          <span class="pdf-upload-icon" aria-hidden="true">
            <FolderOpen aria-hidden="true" />
          </span>
          <strong>PDF를 여기로 끌어다 놓으세요</strong>
          <span data-file-label>PDF 1개 선택 · 범위별로 나눕니다</span>
          <span class="pdf-dropzone-badges" data-upload-badges aria-label="주요 장점">
            <span>무료</span>
            <span>설치 없음</span>
            <span>서버 전송 없음</span>
          </span>
          <em>PDF 선택</em>
          <small>최대 80MB · 암호 없는 PDF 지원</small>
        </label>

        <div class="split-range-card">
          <div class="panel-title">
            <h2>분할 범위</h2>
            <span class="format-badge" data-page-count-badge>0쪽</span>
          </div>
          <label class="field">
            <span>페이지 범위</span>
            <input
              type="text"
              inputmode="text"
              placeholder="예: 1-2,3-5"
              data-range-input
            />
          </label>
          <p data-range-helper>PDF를 선택하면 예시 범위를 자동으로 넣습니다.</p>
          <div class="split-range-actions">
            <button class="btn" type="button" data-split-all disabled>페이지별 나누기</button>
            <button class="btn" type="button" data-split-half disabled>반으로 나누기</button>
          </div>
          <div class="range-preview" data-range-preview aria-live="polite">
            <p class="empty-state">분할 범위가 없습니다.</p>
          </div>
        </div>

        <div class="preflight-card" data-preflight aria-live="polite">
          <strong>분할 전 마지막 확인</strong>
          <ul>
            <li data-preflight-item="file">PDF를 선택해 주세요.</li>
            <li data-preflight-item="pages">페이지 수는 선택 후 확인합니다.</li>
            <li data-preflight-item="ranges">분할 범위를 입력해 주세요.</li>
            <li data-preflight-item="output">PDF 나누기 후 다운로드 링크가 열립니다.</li>
          </ul>
        </div>

        <div class="button-row pdf-action-row">
          <button class="btn" type="button" data-sample>
            <Plus aria-hidden="true" />
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <RefreshCw aria-hidden="true" />
            초기화
          </button>
          <button class="btn primary" type="button" data-generate disabled>
            <FileOutput aria-hidden="true" />
            <span data-generate-label>PDF 나누기</span>
          </button>
        </div>
      </form>

      <section class="preview-panel pdf-preview-panel" aria-label="PDF 분할 상태">
        <div class="panel-title">
          <h2>분할 결과</h2>
          <span class="format-badge">PDF</span>
        </div>

        <div class="pdf-result-card">
          <span>상태</span>
          <strong data-output-status>PDF를 선택하면 나눌 수 있습니다.</strong>
          <p data-output-meta>파일은 아직 준비되지 않았습니다.</p>
          <div class="download-list" data-download-list hidden></div>
        </div>
      </section>
    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>나눌 PDF 파일을 선택합니다.</li>
        <li>1-2,3-5처럼 쉼표로 분할 범위를 입력합니다.</li>
        <li>PDF 나누기 후 생성된 다운로드 링크를 저장합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline src="/scripts/file-tool-utils.js"></script>
  <script>
    // @ts-nocheck
    const root = document.querySelector("[data-pdf-split-tool]");
    if (root) {
      const fileTools = window.KdocFileTools;
      if (!fileTools) throw new Error("file_tool_utils_unavailable");

      const maxFileSize = 80 * 1024 * 1024;
      const maxRanges = 50;

      const input = root.querySelector("[data-pdf-input]");
      const dropzone = root.querySelector("[data-upload-zone]");
      const fileLabel = root.querySelector("[data-file-label]");
      const pageCountBadge = root.querySelector("[data-page-count-badge]");
      const rangeInput = root.querySelector("[data-range-input]");
      const rangeHelper = root.querySelector("[data-range-helper]");
      const rangePreview = root.querySelector("[data-range-preview]");
      const splitAllButton = root.querySelector("[data-split-all]");
      const splitHalfButton = root.querySelector("[data-split-half]");
      const generateButton = root.querySelector("[data-generate]");
      const generateLabel = root.querySelector("[data-generate-label]");
      const resetButton = root.querySelector("[data-reset]");
      const sampleButton = root.querySelector("[data-sample]");
      const outputStatus = root.querySelector("[data-output-status]");
      const outputMeta = root.querySelector("[data-output-meta]");
      const downloadList = root.querySelector("[data-download-list]");
      const preflightItems = {
        file: root.querySelector('[data-preflight-item="file"]'),
        pages: root.querySelector('[data-preflight-item="pages"]'),
        ranges: root.querySelector('[data-preflight-item="ranges"]'),
        output: root.querySelector('[data-preflight-item="output"]')
      };
      const formatter = new Intl.NumberFormat("ko-KR");
      let fileItems = [];
      let pageCount = 0;
      let parsedRanges = [];
      let rangeError = "";
      let outputItems = [];
      let outputBytes = 0;
      let nextItemId = 1;
      let pdfLibPromise = null;

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "pdf-split",
          tool_title: "PDF 나누기",
          ...params
        });
      }

      function formatBytes(bytes) {
        return fileTools.formatBytes(bytes);
      }

      function selectedFile() {
        return fileItems[0]?.file || null;
      }

      function isPdfFile(file) {
        return file.type === "application/pdf" || /\.pdf$/i.test(file.name || "");
      }

      function validatePdfFiles(files) {
        if (files.length === 0) return { ok: false, reason: "empty" };
        if (files.length > 1) return { ok: false, reason: "too_many_files" };
        const file = files[0];
        if (!isPdfFile(file)) return { ok: false, reason: "unsupported_file_type" };
        if (file.size > maxFileSize) return { ok: false, reason: "file_too_large" };
        return { ok: true };
      }

      function validationMessage(reason) {
        if (reason === "too_many_files") return "PDF는 1개만 선택할 수 있습니다.";
        if (reason === "file_too_large") return "PDF는 80MB 이하만 사용할 수 있습니다.";
        if (reason === "unsupported_file_type") return "PDF 파일만 선택할 수 있습니다.";
        if (reason === "empty_range") return "분할 범위를 입력해 주세요.";
        if (reason === "too_many_ranges") return "분할 범위는 최대 50개까지 입력할 수 있습니다.";
        if (reason === "invalid_range") return "범위는 1-2,3-5처럼 입력해 주세요.";
        if (reason === "range_out_of_bounds") return "PDF 페이지 수 안의 범위만 입력해 주세요.";
        if (reason === "range_reversed") return "범위의 시작 페이지가 끝 페이지보다 클 수 없습니다.";
        return "PDF를 선택해 주세요.";
      }

      function setMessage(status, meta = "") {
        outputStatus.textContent = status;
        outputMeta.textContent = meta;
      }

      function setPreflightItem(key, status, text) {
        const item = preflightItems[key];
        if (!item) return;
        item.dataset.status = status;
        item.textContent = text;
      }

      function revokeOutputs() {
        for (const item of outputItems) {
          if (item.url) URL.revokeObjectURL(item.url);
        }
        outputItems = [];
      }

      function clearOutputs() {
        revokeOutputs();
        outputBytes = 0;
        downloadList.hidden = true;
        downloadList.innerHTML = "";
        updatePreflight();
      }

      function canGenerate() {
        return Boolean(selectedFile()) && pageCount > 0 && parsedRanges.length > 0 && !rangeError;
      }

      function syncGenerateButton() {
        generateButton.disabled = !canGenerate();
      }

      function parseRanges(value) {
        const text = String(value || "").trim();
        if (!text) return { ok: false, reason: "empty_range", ranges: [] };
        const parts = text.split(",").map((part) => part.trim()).filter(Boolean);
        if (parts.length === 0) return { ok: false, reason: "empty_range", ranges: [] };
        if (parts.length > maxRanges) return { ok: false, reason: "too_many_ranges", ranges: [] };

        const ranges = [];
        for (const part of parts) {
          const match = part.match(/^(\d+)(?:\s*-\s*(\d+))?$/);
          if (!match) return { ok: false, reason: "invalid_range", ranges: [] };
          const start = Number(match[1]);
          const end = match[2] ? Number(match[2]) : start;
          if (start > end) return { ok: false, reason: "range_reversed", ranges: [] };
          if (start < 1 || end > pageCount) return { ok: false, reason: "range_out_of_bounds", ranges: [] };
          ranges.push({
            label: start === end ? `${start}` : `${start}-${end}`,
            start,
            end,
            pageCount: end - start + 1,
            indices: Array.from({ length: end - start + 1 }, (_, index) => start - 1 + index)
          });
        }
        return { ok: true, ranges };
      }

      function renderRangePreview() {
        if (!selectedFile() || pageCount === 0) {
          rangePreview.innerHTML = '<p class="empty-state">분할 범위가 없습니다.</p>';
          return;
        }
        if (rangeError) {
          rangePreview.innerHTML = `<p class="empty-state">${validationMessage(rangeError)}</p>`;
          return;
        }
        if (parsedRanges.length === 0) {
          rangePreview.innerHTML = '<p class="empty-state">분할 범위를 입력해 주세요.</p>';
          return;
        }
        rangePreview.innerHTML = parsedRanges
          .map(
            (range, index) => `
              <div class="range-chip">
                <span>${index + 1}</span>
                <strong>${range.label}</strong>
                <em>${range.pageCount}쪽</em>
              </div>
            `
          )
          .join("");
      }

      function updateRangeState() {
        clearOutputs();
        if (!selectedFile() || pageCount === 0) {
          parsedRanges = [];
          rangeError = "";
          renderRangePreview();
          updatePreflight();
          return;
        }
        const result = parseRanges(rangeInput.value);
        parsedRanges = result.ok ? result.ranges : [];
        rangeError = result.ok ? "" : result.reason;
        rangeHelper.textContent = result.ok
          ? `${formatter.format(parsedRanges.length)}개 PDF로 나눕니다.`
          : validationMessage(rangeError);
        renderRangePreview();
        updatePreflight();
      }

      function updatePreflight() {
        const file = selectedFile();
        if (!file) {
          setPreflightItem("file", "pending", "PDF를 선택해 주세요.");
          setPreflightItem("pages", "pending", "페이지 수는 선택 후 확인합니다.");
          setPreflightItem("ranges", "pending", "분할 범위를 입력해 주세요.");
          setPreflightItem("output", "pending", "PDF 나누기 후 다운로드 링크가 열립니다.");
          syncGenerateButton();
          return;
        }

        setPreflightItem("file", "ready", `PDF 1개 선택됨, ${formatBytes(file.size)}`);
        setPreflightItem("pages", "ready", `${formatter.format(pageCount)}쪽 PDF`);
        setPreflightItem(
          "ranges",
          parsedRanges.length > 0 && !rangeError ? "ready" : "pending",
          parsedRanges.length > 0 && !rangeError
            ? `${formatter.format(parsedRanges.length)}개 파일, 총 ${formatter.format(parsedRanges.reduce((sum, range) => sum + range.pageCount, 0))}쪽`
            : validationMessage(rangeError || "empty_range")
        );
        setPreflightItem(
          "output",
          outputItems.length > 0 ? "ready" : "pending",
          outputItems.length > 0
            ? `저장 준비 완료, ${formatter.format(outputItems.length)}개 · ${formatBytes(outputBytes)}`
            : "PDF 나누기를 누르면 다운로드 링크가 열립니다."
        );
        syncGenerateButton();
      }

      function setBusy(isBusy) {
        generateButton.disabled = isBusy || !canGenerate();
        generateLabel.textContent = isBusy ? "나누는 중" : "PDF 나누기";
        sampleButton.disabled = isBusy;
        resetButton.disabled = isBusy;
        splitAllButton.disabled = isBusy || pageCount === 0;
        splitHalfButton.disabled = isBusy || pageCount < 2;
      }

      function releaseItems(items = fileItems) {
        fileTools.revokePreviewItems(items);
      }

      function resetState() {
        releaseItems();
        revokeOutputs();
        fileItems = [];
        pageCount = 0;
        parsedRanges = [];
        rangeError = "";
        outputBytes = 0;
        pageCountBadge.textContent = "0쪽";
        fileLabel.textContent = "PDF 1개 선택 · 범위별로 나눕니다";
        rangeInput.value = "";
        rangeHelper.textContent = "PDF를 선택하면 예시 범위를 자동으로 넣습니다.";
        rangePreview.innerHTML = '<p class="empty-state">분할 범위가 없습니다.</p>';
        downloadList.hidden = true;
        downloadList.innerHTML = "";
        splitAllButton.disabled = true;
        splitHalfButton.disabled = true;
        setMessage("PDF를 선택하면 나눌 수 있습니다.", "파일은 아직 준비되지 않았습니다.");
        updatePreflight();
      }

      async function loadPdfLib() {
        if (!pdfLibPromise) pdfLibPromise = import("pdf-lib");
        return pdfLibPromise;
      }

      function defaultHalfRanges() {
        if (pageCount < 2) return "1";
        const midpoint = Math.ceil(pageCount / 2);
        return `1-${midpoint},${midpoint + 1}-${pageCount}`;
      }

      async function inspectPdf(file, method = "picker") {
        setBusy(true);
        setMessage("PDF 읽는 중", "페이지 수를 확인하고 있습니다.");
        rangePreview.innerHTML = '<p class="empty-state">PDF 페이지를 읽고 있습니다.</p>';

        try {
          const { PDFDocument } = await loadPdfLib();
          const sourcePdf = await PDFDocument.load(await file.arrayBuffer());
          pageCount = sourcePdf.getPageCount();
          pageCountBadge.textContent = `${formatter.format(pageCount)}쪽`;
          fileLabel.textContent = `${formatter.format(pageCount)}쪽 PDF 선택`;
          splitAllButton.disabled = false;
          splitHalfButton.disabled = pageCount < 2;
          rangeInput.value = defaultHalfRanges();
          setMessage(`${formatter.format(pageCount)}쪽 PDF`, "분할 범위를 확인하고 PDF 나누기를 누르세요.");
          updateRangeState();
          track("pdf_split_file_select", {
            method,
            ...fileTools.safeFileAnalyticsPayload([file]),
            page_count: pageCount
          });
        } catch (error) {
          resetState();
          setMessage("PDF를 읽지 못했습니다.", "암호가 있거나 손상된 PDF인지 확인해 주세요.");
          track("pdf_split_validation_error", {
            reason: error?.message || "pdf_read_failed"
          });
        } finally {
          setBusy(false);
        }
      }

      function setFile(file, method = "picker") {
        releaseItems();
        clearOutputs();
        parsedRanges = [];
        rangeError = "";
        pageCount = 0;
        fileItems = fileTools.createFileItems([file], () => nextItemId++);
        pageCountBadge.textContent = "읽는 중";
        inspectPdf(file, method);
      }

      async function createSamplePdf() {
        const { PDFDocument, StandardFonts, rgb } = await loadPdfLib();
        const pdfDoc = await PDFDocument.create();
        const titleFont = await pdfDoc.embedFont(StandardFonts.HelveticaBold);
        const bodyFont = await pdfDoc.embedFont(StandardFonts.Helvetica);
        const colors = [
          rgb(0.08, 0.37, 0.94),
          rgb(0.07, 0.48, 0.48),
          rgb(0.71, 0.27, 0.03),
          rgb(0.34, 0.24, 0.74),
          rgb(0.04, 0.52, 0.27)
        ];
        for (let index = 0; index < 5; index += 1) {
          const page = pdfDoc.addPage([595.28, 841.89]);
          page.drawRectangle({ x: 42, y: 42, width: 511, height: 758, borderColor: rgb(0.85, 0.89, 0.94), borderWidth: 2 });
          page.drawRectangle({ x: 72, y: 708, width: 210, height: 18, color: colors[index] });
          page.drawText(`Split Page ${index + 1}`, { x: 72, y: 646, size: 34, font: titleFont, color: rgb(0.08, 0.13, 0.19) });
          page.drawText("K Document Tool sample PDF", {
            x: 72,
            y: 604,
            size: 16,
            font: bodyFont,
            color: rgb(0.32, 0.38, 0.46)
          });
        }
        const bytes = await pdfDoc.save();
        return new File([bytes], "pdf-split-sample.pdf", { type: "application/pdf" });
      }

      async function generateSplitPdfs() {
        const file = selectedFile();
        if (!file) {
          setMessage(validationMessage("empty"), "파일을 다시 선택해 주세요.");
          track("pdf_split_validation_error", { reason: "empty" });
          return;
        }
        if (!canGenerate()) {
          setMessage(validationMessage(rangeError || "empty_range"), "분할 범위를 다시 확인해 주세요.");
          track("pdf_split_validation_error", { reason: rangeError || "empty_range" });
          return;
        }

        clearOutputs();
        setBusy(true);
        setMessage("PDF 나누는 중", `${formatter.format(parsedRanges.length)}개 PDF를 만들고 있습니다.`);

        try {
          const { PDFDocument } = await loadPdfLib();
          const sourcePdf = await PDFDocument.load(await file.arrayBuffer());
          const nextOutputItems = [];
          let nextOutputBytes = 0;

          for (const [index, range] of parsedRanges.entries()) {
            const splitPdf = await PDFDocument.create();
            const pages = await splitPdf.copyPages(sourcePdf, range.indices);
            for (const page of pages) {
              splitPdf.addPage(page);
            }
            const pdfBytes = await splitPdf.save();
            const blob = new Blob([pdfBytes], { type: "application/pdf" });
            const url = URL.createObjectURL(blob);
            nextOutputBytes += pdfBytes.byteLength;
            nextOutputItems.push({
              url,
              bytes: pdfBytes.byteLength,
              pageCount: range.pageCount,
              label: range.label,
              fileName: `k-document-split-${index + 1}.pdf`
            });
          }

          outputItems = nextOutputItems;
          outputBytes = nextOutputBytes;
          downloadList.hidden = false;
          downloadList.innerHTML = outputItems
            .map(
              (item, index) => `
                <a
                  class="split-download-link"
                  href="${item.url}"
                  download="${item.fileName}"
                  data-split-download
                  data-split-index="${index}"
                >
                  <span>${index + 1}</span>
                  <strong>${item.label}</strong>
                  <em>${item.pageCount}쪽 · ${formatBytes(item.bytes)}</em>
                </a>
              `
            )
            .join("");
          setMessage(
            `PDF 준비 완료: ${formatter.format(outputItems.length)}개`,
            `총 ${formatter.format(parsedRanges.reduce((sum, range) => sum + range.pageCount, 0))}쪽 · ${formatBytes(outputBytes)}`
          );
          updatePreflight();
          track("pdf_split_generate", {
            ...fileTools.safeFileAnalyticsPayload([file]),
            page_count: pageCount,
            range_count: parsedRanges.length,
            output_page_count: parsedRanges.reduce((sum, range) => sum + range.pageCount, 0),
            output_size: outputBytes
          });
        } catch (error) {
          clearOutputs();
          setMessage("PDF를 나누지 못했습니다.", "암호가 있거나 손상된 PDF인지 확인해 주세요.");
          track("pdf_split_validation_error", {
            reason: error?.message || "pdf_split_failed"
          });
        } finally {
          setBusy(false);
        }
      }

      function handleSelectedFiles(files, method = "picker") {
        const validation = validatePdfFiles(files);
        if (!validation.ok) {
          resetState();
          setMessage(validationMessage(validation.reason), "파일을 다시 선택해 주세요.");
          track("pdf_split_validation_error", {
            reason: validation.reason,
            ...fileTools.safeFileAnalyticsPayload(files)
          });
          return;
        }
        setFile(files[0], method);
      }

      input.addEventListener("change", (event) => {
        handleSelectedFiles(Array.from(event.target.files || []), "picker");
      });

      if (dropzone) {
        ["dragenter", "dragover"].forEach((eventName) => {
          dropzone.addEventListener(eventName, (event) => {
            event.preventDefault();
            event.stopPropagation();
            dropzone.classList.add("is-drag-over");
          });
        });

        ["dragleave", "drop"].forEach((eventName) => {
          dropzone.addEventListener(eventName, (event) => {
            event.preventDefault();
            event.stopPropagation();
            dropzone.classList.remove("is-drag-over");
          });
        });

        dropzone.addEventListener("drop", (event) => {
          const files = Array.from(event.dataTransfer?.files || []);
          if (!files.length) return;
          input.value = "";
          handleSelectedFiles(files, "drop");
        });
      }

      rangeInput.addEventListener("input", () => {
        updateRangeState();
        track("pdf_split_range_change", {
          page_count: pageCount,
          range_count: parsedRanges.length,
          has_error: Boolean(rangeError),
          range_text_length: rangeInput.value.length
        });
      });

      splitAllButton.addEventListener("click", () => {
        if (pageCount === 0) return;
        rangeInput.value = Array.from({ length: pageCount }, (_, index) => String(index + 1)).join(",");
        updateRangeState();
        track("pdf_split_preset_apply", { preset: "each_page", page_count: pageCount, range_count: parsedRanges.length });
      });

      splitHalfButton.addEventListener("click", () => {
        if (pageCount < 2) return;
        rangeInput.value = defaultHalfRanges();
        updateRangeState();
        track("pdf_split_preset_apply", { preset: "half", page_count: pageCount, range_count: parsedRanges.length });
      });

      sampleButton.addEventListener("click", async () => {
        setBusy(true);
        setMessage("샘플 PDF 준비 중", "브라우저 안에서 5쪽 테스트 PDF를 만들고 있습니다.");
        const file = await createSamplePdf();
        input.value = "";
        setFile(file, "sample");
        track("pdf_split_sample_apply", { file_count: 1 });
      });

      resetButton.addEventListener("click", () => {
        input.value = "";
        resetState();
        track("pdf_split_reset");
      });

      generateButton.addEventListener("click", generateSplitPdfs);

      downloadList.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const link = target?.closest("[data-split-download]");
        if (!link) return;
        track("pdf_split_download", {
          file_count: 1,
          page_count: pageCount,
          range_count: outputItems.length,
          output_size: outputBytes,
          split_index: Number(link.dataset.splitIndex) + 1
        });
      });

      window.addEventListener("pagehide", () => {
        releaseItems();
        revokeOutputs();
      });

      resetState();
    }
  </script>
</BaseLayout>

