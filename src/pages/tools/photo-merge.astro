---
import BaseLayout from "@/layouts/BaseLayout.astro";
import IconGlyph from "@/components/IconGlyph.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema, webPageSchema } from "@/data/seo";

const tool = getTool("photo-merge");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  webPageSchema({
    name: tool.title,
    description: tool.metaDescription,
    path: tool.path,
    keywords: [tool.primaryQuery, ...tool.secondaryQueries, "사진 한 장으로 합치기", "이미지 이어붙이기"]
  }),
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main
    class="page-shell"
    data-tool-id={tool.id}
    data-tool-title={tool.title}
  >
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>여러 장의 사진을 세로, 가로, 격자 배치로 한 장 이미지로 합치세요.</p>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="merge-workspace" data-photo-merge>
      <form class="panel merge-panel" aria-label="사진 합치기 입력">
        <div class="panel-title">
          <h2>사진 입력</h2>
        </div>

        <label class="field">
          <span>이미지 파일</span>
          <span class="file-control upload-dropzone" data-upload-zone>
            <input data-image-input type="file" accept="image/png,image/jpeg,image/webp" multiple />
            <span class="upload-icon" aria-hidden="true">
              <IconGlyph name="plus" />
            </span>
            <strong>합칠 사진을 선택하세요</strong>
            <span data-file-label>JPG/PNG/WebP 여러 장 선택</span>
            <span class="upload-trust-badges" data-upload-badges aria-label="주요 장점">
              <span>무료</span>
              <span>설치 없음</span>
              <span>서버 전송 없음</span>
            </span>
            <em>파일 선택</em>
            <small>최대 20장 · 총 50MB · 원본 유지</small>
          </span>
        </label>

        <div class="field-grid two-columns">
          <label class="field">
            <span>배치</span>
            <select data-layout-mode>
              <option value="vertical">세로로 이어붙이기</option>
              <option value="horizontal">가로로 이어붙이기</option>
              <option value="grid">2열 격자</option>
            </select>
          </label>

          <label class="field">
            <span>출력 형식</span>
            <select data-output-format>
              <option value="image/jpeg">JPG</option>
              <option value="image/png">PNG</option>
            </select>
          </label>
        </div>

        <div class="field-grid three-columns">
          <label class="field">
            <span>여백</span>
            <input data-padding type="number" min="0" max="160" step="4" value="24" />
          </label>
          <label class="field">
            <span>간격</span>
            <input data-gap type="number" min="0" max="120" step="4" value="16" />
          </label>
          <label class="field">
            <span>테두리</span>
            <select data-border-mode>
              <option value="on">표시</option>
              <option value="off">없음</option>
            </select>
          </label>
        </div>

        <div class="field-grid two-columns">
          <label class="field">
            <span>번호·설명</span>
            <select data-label-mode>
              <option value="number-caption">번호 + 설명</option>
              <option value="number">번호만</option>
              <option value="none">표시 안 함</option>
            </select>
          </label>
          <label class="field range-field">
            <span>JPG 품질 <strong data-quality-label>90</strong></span>
            <input data-quality type="range" min="70" max="95" value="90" />
          </label>
        </div>

        <p class="note-box">
          사진과 설명은 브라우저 캔버스에서만 처리합니다. 중고거래 목록, 전후 비교, 서류 사진 정리에 맞춰 한 장 이미지로 저장할 수 있습니다.
        </p>

        <div class="button-row">
          <button class="btn" type="button" data-sample>
            <IconGlyph name="plus" aria-hidden="true" />
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <IconGlyph name="refresh" aria-hidden="true" />
            초기화
          </button>
          <button class="btn primary" type="button" data-merge disabled>
            <IconGlyph name="repeat" aria-hidden="true" />
            <span data-merge-label>사진 합치기</span>
          </button>
        </div>
      </form>

      <section class="preview-panel merge-preview-panel" aria-label="사진 합치기 결과">
        <div class="panel-title">
          <h2>합치기 결과</h2>
          <span class="format-badge" data-format-badge>JPG</span>
        </div>

        <div class="merge-summary">
          <span>상태</span>
          <strong data-output-status>사진을 선택하면 한 장으로 합칠 수 있습니다.</strong>
          <p data-output-meta>합친 이미지는 아직 준비되지 않았습니다.</p>
          <a
            class="btn primary disabled"
            href="#"
            download="k-document-merged-photos.jpg"
            aria-disabled="true"
            data-download-image
          >
            합친 이미지 저장
          </a>
        </div>

        <div class="merge-preview-box" data-preview-box aria-live="polite">
          <p class="empty-state">선택된 사진이 없습니다.</p>
        </div>

        <div class="merge-list" data-merge-list aria-live="polite">
          <p class="empty-state">사진을 선택하면 설명을 입력할 수 있습니다.</p>
        </div>
      </section>

      <aside class="side-panel">
        <div class="panel-title">
          <h3>서버 전송 없음</h3>
        </div>
        <ul class="status-list">
          <li><span class="status-dot"></span><span>사진과 설명은 브라우저 안에서만 처리합니다.</span></li>
          <li><span class="status-dot"></span><span>파일명과 원본 이미지는 분석 이벤트로 보내지 않습니다.</span></li>
          <li><span class="status-dot"></span><span>PNG 출력은 투명 영역을 유지할 수 있고 JPG는 흰 배경으로 저장합니다.</span></li>
        </ul>
      </aside>
    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>한 장으로 합칠 JPG, PNG, WebP 사진을 선택합니다.</li>
        <li>세로, 가로, 2열 격자 배치와 간격, 여백, 테두리를 고릅니다.</li>
        <li>필요하면 사진별 설명을 입력한 뒤 합친 이미지를 저장합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline src="/scripts/file-tool-utils.js"></script>
  <script is:inline>
    (() => {
      const root = document.querySelector("[data-photo-merge]");
      if (!root) return;
      const fileTools = window.KdocFileTools;
      if (!fileTools) return;

      const maxFiles = 20;
      const maxFileSize = 12 * 1024 * 1024;
      const maxTotalSize = 50 * 1024 * 1024;
      const maxItemSide = 1200;
      const maxCanvasSide = 16000;
      const input = root.querySelector("[data-image-input]");
      const dropzone = root.querySelector("[data-upload-zone]");
      const fileLabel = root.querySelector("[data-file-label]");
      const layoutMode = root.querySelector("[data-layout-mode]");
      const outputFormat = root.querySelector("[data-output-format]");
      const paddingInput = root.querySelector("[data-padding]");
      const gapInput = root.querySelector("[data-gap]");
      const borderMode = root.querySelector("[data-border-mode]");
      const labelMode = root.querySelector("[data-label-mode]");
      const qualityInput = root.querySelector("[data-quality]");
      const qualityLabel = root.querySelector("[data-quality-label]");
      const formatBadge = root.querySelector("[data-format-badge]");
      const mergeButton = root.querySelector("[data-merge]");
      const mergeLabel = root.querySelector("[data-merge-label]");
      const resetButton = root.querySelector("[data-reset]");
      const sampleButton = root.querySelector("[data-sample]");
      const outputStatus = root.querySelector("[data-output-status]");
      const outputMeta = root.querySelector("[data-output-meta]");
      const downloadLink = root.querySelector("[data-download-image]");
      const previewBox = root.querySelector("[data-preview-box]");
      const mergeList = root.querySelector("[data-merge-list]");
      const formatter = new Intl.NumberFormat("ko-KR");

      let fileItems = [];
      let outputUrl = "";
      let outputBytes = 0;
      let outputWidth = 0;
      let outputHeight = 0;
      let nextItemId = 1;

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "photo-merge",
          tool_title: "사진 합치기",
          ...params
        });
      }

      function formatBytes(bytes) {
        return fileTools.formatBytes(bytes);
      }

      function files() {
        return fileItems.map((item) => item.file);
      }

      function formatLabel() {
        return outputFormat.value === "image/png" ? "PNG" : "JPG";
      }

      function outputExtension() {
        return outputFormat.value === "image/png" ? "png" : "jpg";
      }

      function numericValue(inputElement, fallback, min, max) {
        const value = Number(inputElement.value);
        if (!Number.isFinite(value)) return fallback;
        return Math.max(min, Math.min(max, Math.round(value)));
      }

      function layoutLabel() {
        if (layoutMode.value === "horizontal") return "가로";
        if (layoutMode.value === "grid") return "2열 격자";
        return "세로";
      }

      function setMessage(status, meta = "") {
        outputStatus.textContent = status;
        outputMeta.textContent = meta;
      }

      function clearOutput() {
        if (outputUrl) URL.revokeObjectURL(outputUrl);
        outputUrl = "";
        outputBytes = 0;
        outputWidth = 0;
        outputHeight = 0;
        downloadLink.href = "#";
        downloadLink.download = `k-document-merged-photos.${outputExtension()}`;
        downloadLink.classList.add("disabled");
        downloadLink.setAttribute("aria-disabled", "true");
        downloadLink.dataset.mergedOutputFormat = "";
        downloadLink.dataset.outputWidth = "";
        downloadLink.dataset.outputHeight = "";
        downloadLink.dataset.outputSize = "";
      }

      function setBusy(isBusy) {
        mergeButton.disabled = isBusy || fileItems.length === 0;
        mergeLabel.textContent = isBusy ? "합치는 중" : "사진 합치기";
        sampleButton.disabled = isBusy;
        resetButton.disabled = isBusy;
      }

      function validationMessage(reason) {
        return fileTools.validationMessage(reason, "합칠 사진을 선택해 주세요.");
      }

      function escapeAttribute(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll('"', "&quot;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;");
      }

      function validateFiles(nextFiles) {
        return fileTools.validateImageFiles(nextFiles, { maxFiles, maxFileSize, maxTotalSize });
      }

      function releaseItems(items = fileItems) {
        fileTools.revokePreviewItems(items);
      }

      function syncFormatUi() {
        formatBadge.textContent = formatLabel();
        qualityInput.closest(".range-field").hidden = outputFormat.value !== "image/jpeg";
      }

      function syncButton() {
        mergeButton.disabled = fileItems.length === 0;
      }

      function renderList() {
        clearOutput();
        syncFormatUi();
        syncButton();

        if (fileItems.length === 0) {
          fileLabel.textContent = "JPG/PNG/WebP 여러 장 선택";
          mergeList.innerHTML = '<p class="empty-state">사진을 선택하면 설명을 입력할 수 있습니다.</p>';
          previewBox.innerHTML = '<p class="empty-state">선택된 사진이 없습니다.</p>';
          setMessage("사진을 선택하면 한 장으로 합칠 수 있습니다.", "합친 이미지는 아직 준비되지 않았습니다.");
          return;
        }

        fileLabel.textContent = `${formatter.format(fileItems.length)}장 선택`;
        previewBox.innerHTML = `<div class="merge-preview-placeholder">${layoutLabel()} 배치 · ${formatLabel()} 저장 준비</div>`;
        mergeList.innerHTML = fileItems
          .map(
            (item, index) => `
              <div class="merge-row" data-merge-row data-file-index="${index}">
                <img src="${item.previewUrl}" alt="" loading="lazy" />
                <span>${index + 1}</span>
                <label>
                  <strong>${formatBytes(item.file.size)}</strong>
                  <input data-caption-input="${index}" type="text" maxlength="60" value="${escapeAttribute(item.caption)}" aria-label="${index + 1}번째 사진 설명" />
                </label>
                <div class="file-actions">
                  <button type="button" data-move-file="${index}" data-direction="up" aria-label="${index + 1}번째 사진을 앞으로 이동" ${index === 0 ? "disabled" : ""}>↑</button>
                  <button type="button" data-move-file="${index}" data-direction="down" aria-label="${index + 1}번째 사진을 뒤로 이동" ${index === fileItems.length - 1 ? "disabled" : ""}>↓</button>
                  <button type="button" data-remove-file="${index}" aria-label="${index + 1}번째 사진 삭제">×</button>
                </div>
              </div>
            `
          )
          .join("");
        setMessage(
          `${formatter.format(fileItems.length)}장 선택됨`,
          `${layoutLabel()} 배치 · 여백 ${paddingInput.value}px · 간격 ${gapInput.value}px`
        );
      }

      function optionPayload() {
        return {
          layout_mode: layoutMode.value,
          output_format: formatLabel().toLowerCase(),
          gap: numericValue(gapInput, 16, 0, 120),
          padding: numericValue(paddingInput, 24, 0, 160),
          border: borderMode.value === "on",
          label_mode: labelMode.value
        };
      }

      function updateOptionState() {
        clearOutput();
        syncFormatUi();
        if (fileItems.length > 0) {
          previewBox.innerHTML = `<div class="merge-preview-placeholder">${layoutLabel()} 배치 · ${formatLabel()} 저장 준비</div>`;
          setMessage(
            `${formatter.format(fileItems.length)}장 선택됨`,
            `${layoutLabel()} 배치 · 여백 ${paddingInput.value}px · 간격 ${gapInput.value}px`
          );
        }
      }

      function createFileItems(nextFiles) {
        return fileTools.createFileItems(nextFiles, () => nextItemId++).map((item, index) => ({
          ...item,
          caption: `사진 ${index + 1}`
        }));
      }

      function setFileItems(nextFiles) {
        releaseItems();
        fileItems = createFileItems(nextFiles);
        renderList();
      }

      function reorderFile(fromIndex, toIndex) {
        if (fromIndex === toIndex) return;
        if (fromIndex < 0 || fromIndex >= fileItems.length) return;
        if (toIndex < 0 || toIndex >= fileItems.length) return;
        const nextItems = [...fileItems];
        const [movedItem] = nextItems.splice(fromIndex, 1);
        nextItems.splice(toIndex, 0, movedItem);
        fileItems = nextItems;
        renderList();
        track("photo_merge_reorder", {
          from_position: fromIndex + 1,
          to_position: toIndex + 1,
          file_count: fileItems.length
        });
      }

      function removeFile(index) {
        if (index < 0 || index >= fileItems.length) return;
        const nextItems = [...fileItems];
        const [removedItem] = nextItems.splice(index, 1);
        releaseItems([removedItem]);
        fileItems = nextItems;
        if (fileItems.length === 0) input.value = "";
        renderList();
        track("photo_merge_remove", {
          from_position: index + 1,
          file_count: fileItems.length
        });
      }

      function handleSelectedFiles(nextFiles, method = "picker") {
        const validation = validateFiles(nextFiles);
        if (!validation.ok) {
          resetState();
          setMessage(validationMessage(validation.reason), "파일을 다시 선택해 주세요.");
          track("photo_merge_validation_error", {
            reason: validation.reason,
            ...fileTools.safeFileAnalyticsPayload(nextFiles)
          });
          return;
        }
        setFileItems(nextFiles);
        track("photo_merge_file_select", {
          method,
          ...fileTools.safeFileAnalyticsPayload(nextFiles)
        });
      }

      async function makeSampleImage(index, color, label) {
        const canvas = document.createElement("canvas");
        canvas.width = index === 1 ? 900 : 1200;
        canvas.height = index === 2 ? 900 : 760;
        const context = canvas.getContext("2d");
        if (!context) throw new Error("canvas_context_unavailable");
        context.fillStyle = color;
        context.fillRect(0, 0, canvas.width, canvas.height);
        context.fillStyle = "rgba(255,255,255,0.16)";
        context.fillRect(48, 48, canvas.width - 96, canvas.height - 96);
        context.fillStyle = "#ffffff";
        context.font = "700 64px sans-serif";
        context.fillText(label, 72, 132);
        context.font = "500 30px sans-serif";
        context.fillText("K Document Tool sample", 72, 184);
        const blob = await fileTools.canvasToBlob(canvas, "image/jpeg", 0.9);
        return new File([blob], `photo-merge-sample-${index + 1}.jpg`, { type: "image/jpeg" });
      }

      async function createSampleFiles() {
        return Promise.all([
          makeSampleImage(0, "#155eef", "Before"),
          makeSampleImage(1, "#00856f", "Detail"),
          makeSampleImage(2, "#c2410c", "After")
        ]);
      }

      function imageSideLimit() {
        const count = Math.max(1, fileItems.length);
        const gap = numericValue(gapInput, 16, 0, 120);
        const padding = numericValue(paddingInput, 24, 0, 160);
        const usableSide = maxCanvasSide - padding * 2;
        if (layoutMode.value === "horizontal" || layoutMode.value === "vertical") {
          return Math.max(240, Math.min(maxItemSide, Math.floor((usableSide - gap * (count - 1)) / count)));
        }
        const rowCount = Math.ceil(count / 2);
        const rowLimit = Math.floor((usableSide - gap * (rowCount - 1)) / rowCount);
        return Math.max(240, Math.min(maxItemSide, rowLimit));
      }

      async function loadImages() {
        const loaded = [];
        const sideLimit = imageSideLimit();
        for (const item of fileItems) {
          const image = await fileTools.imageFromFile(item.file);
          const width = image.naturalWidth || image.width;
          const height = image.naturalHeight || image.height;
          const scale = Math.min(1, sideLimit / Math.max(width, height));
          loaded.push({
            item,
            image,
            width: Math.max(1, Math.round(width * scale)),
            height: Math.max(1, Math.round(height * scale))
          });
        }
        return loaded;
      }

      function measureTextHeight() {
        if (labelMode.value === "none") return 0;
        return labelMode.value === "number" ? 42 : 72;
      }

      function computeLayout(images) {
        const gap = numericValue(gapInput, 16, 0, 120);
        const padding = numericValue(paddingInput, 24, 0, 160);
        const labelHeight = measureTextHeight();
        const cells = [];
        let contentWidth = 0;
        let contentHeight = 0;

        if (layoutMode.value === "horizontal") {
          let x = padding;
          const maxHeight = Math.max(...images.map((image) => image.height + labelHeight));
          for (const image of images) {
            cells.push({ image, x, y: padding, width: image.width, height: image.height, labelHeight });
            x += image.width + gap;
          }
          contentWidth = x - gap + padding;
          contentHeight = padding * 2 + maxHeight;
        } else if (layoutMode.value === "grid") {
          const columns = 2;
          const columnWidth = Math.max(...images.map((image) => image.width));
          const rowHeights = [];
          images.forEach((image, index) => {
            const rowIndex = Math.floor(index / columns);
            rowHeights[rowIndex] = Math.max(rowHeights[rowIndex] || 0, image.height + labelHeight);
          });
          let y = padding;
          for (let rowIndex = 0; rowIndex < rowHeights.length; rowIndex += 1) {
            for (let columnIndex = 0; columnIndex < columns; columnIndex += 1) {
              const index = rowIndex * columns + columnIndex;
              const image = images[index];
              if (!image) continue;
              cells.push({
                image,
                x: padding + columnIndex * (columnWidth + gap),
                y,
                width: image.width,
                height: image.height,
                labelHeight
              });
            }
            y += rowHeights[rowIndex] + gap;
          }
          contentWidth = padding * 2 + columns * columnWidth + gap;
          contentHeight = y - gap + padding;
        } else {
          const maxWidth = Math.max(...images.map((image) => image.width));
          let y = padding;
          for (const image of images) {
            cells.push({ image, x: padding, y, width: image.width, height: image.height, labelHeight });
            y += image.height + labelHeight + gap;
          }
          contentWidth = padding * 2 + maxWidth;
          contentHeight = y - gap + padding;
        }

        return {
          cells,
          width: Math.max(1, Math.ceil(contentWidth)),
          height: Math.max(1, Math.ceil(contentHeight))
        };
      }

      function drawLabel(context, cell, index) {
        if (labelMode.value === "none") return;
        const textY = cell.y + cell.height + 28;
        context.fillStyle = "#111827";
        context.font = "700 24px sans-serif";
        context.fillText(`${index + 1}`, cell.x, textY);
        if (labelMode.value !== "number") {
          context.font = "500 22px sans-serif";
          context.fillStyle = "#475467";
          const caption = String(cell.image.item.caption || `사진 ${index + 1}`).slice(0, 60);
          context.fillText(caption, cell.x + 42, textY);
        }
      }

      async function mergePhotos() {
        const nextFiles = files();
        const validation = validateFiles(nextFiles);
        if (!validation.ok) {
          setMessage(validationMessage(validation.reason), "파일을 다시 선택해 주세요.");
          track("photo_merge_validation_error", { reason: validation.reason });
          return;
        }

        clearOutput();
        setBusy(true);
        setMessage("사진 합치는 중", `${formatter.format(fileItems.length)}장을 한 장으로 만들고 있습니다.`);

        try {
          const images = await loadImages();
          const layout = computeLayout(images);
          if (layout.width > maxCanvasSide || layout.height > maxCanvasSide) {
            throw new Error("canvas_too_large");
          }
          const canvas = document.createElement("canvas");
          canvas.width = layout.width;
          canvas.height = layout.height;
          const context = canvas.getContext("2d");
          if (!context) throw new Error("canvas_context_unavailable");
          context.fillStyle = "#ffffff";
          context.fillRect(0, 0, canvas.width, canvas.height);

          layout.cells.forEach((cell, index) => {
            context.drawImage(cell.image.image, cell.x, cell.y, cell.width, cell.height);
            if (borderMode.value === "on") {
              context.strokeStyle = "#d0d5dd";
              context.lineWidth = 2;
              context.strokeRect(cell.x + 1, cell.y + 1, cell.width - 2, cell.height - 2);
            }
            drawLabel(context, cell, index);
          });

          const quality = Math.max(0.7, Math.min(0.95, Number(qualityInput.value) / 100 || 0.9));
          const blob = await fileTools.canvasToBlob(canvas, outputFormat.value, quality);
          outputBytes = blob.size;
          outputWidth = canvas.width;
          outputHeight = canvas.height;
          outputUrl = URL.createObjectURL(blob);
          downloadLink.href = outputUrl;
          downloadLink.download = `k-document-merged-photos.${outputExtension()}`;
          downloadLink.classList.remove("disabled");
          downloadLink.removeAttribute("aria-disabled");
          downloadLink.dataset.mergedOutputFormat = outputFormat.value;
          downloadLink.dataset.outputWidth = String(outputWidth);
          downloadLink.dataset.outputHeight = String(outputHeight);
          downloadLink.dataset.outputSize = String(outputBytes);
          previewBox.innerHTML = "";
          const image = document.createElement("img");
          image.src = outputUrl;
          image.alt = "합친 사진 미리보기";
          previewBox.append(image);
          setMessage(
            `합치기 완료: ${formatter.format(fileItems.length)}장`,
            `${outputWidth}×${outputHeight}px · ${formatBytes(outputBytes)}`
          );
          track("photo_merge_generate", {
            ...fileTools.safeFileAnalyticsPayload(nextFiles),
            output_size: outputBytes,
            output_width: outputWidth,
            output_height: outputHeight,
            output_format: formatLabel().toLowerCase(),
            layout_mode: layoutMode.value,
            gap: numericValue(gapInput, 16, 0, 120),
            padding: numericValue(paddingInput, 24, 0, 160),
            border: borderMode.value === "on",
            label_mode: labelMode.value
          });
        } catch (error) {
          clearOutput();
          setMessage("사진을 합치지 못했습니다.", "이미지를 다시 선택하거나 장수를 줄여서 시도해 주세요.");
          track("photo_merge_validation_error", {
            reason: error?.message || "photo_merge_failed"
          });
        } finally {
          setBusy(false);
        }
      }

      function resetState() {
        releaseItems();
        clearOutput();
        fileItems = [];
        input.value = "";
        fileLabel.textContent = "JPG/PNG/WebP 여러 장 선택";
        mergeList.innerHTML = '<p class="empty-state">사진을 선택하면 설명을 입력할 수 있습니다.</p>';
        previewBox.innerHTML = '<p class="empty-state">선택된 사진이 없습니다.</p>';
        setMessage("사진을 선택하면 한 장으로 합칠 수 있습니다.", "합친 이미지는 아직 준비되지 않았습니다.");
        syncFormatUi();
        syncButton();
      }

      input.addEventListener("change", (event) => {
        handleSelectedFiles(Array.from(event.target.files || []), "picker");
      });

      if (dropzone) {
        ["dragenter", "dragover"].forEach((eventName) => {
          dropzone.addEventListener(eventName, (event) => {
            event.preventDefault();
            dropzone.classList.add("is-drag-over");
          });
        });
        ["dragleave", "drop"].forEach((eventName) => {
          dropzone.addEventListener(eventName, () => {
            dropzone.classList.remove("is-drag-over");
          });
        });
        dropzone.addEventListener("drop", (event) => {
          event.preventDefault();
          handleSelectedFiles(Array.from(event.dataTransfer?.files || []), "drop");
        });
      }

      mergeList.addEventListener("input", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;
        const index = Number(target.dataset.captionInput);
        if (!Number.isInteger(index) || !fileItems[index]) return;
        fileItems[index].caption = target.value.slice(0, 60);
        clearOutput();
      });

      mergeList.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const moveButton = target?.closest("[data-move-file]");
        const removeButton = target?.closest("[data-remove-file]");
        if (moveButton) {
          const index = Number(moveButton.dataset.moveFile);
          reorderFile(index, index + (moveButton.dataset.direction === "up" ? -1 : 1));
          return;
        }
        if (removeButton) {
          removeFile(Number(removeButton.dataset.removeFile));
        }
      });

      [layoutMode, paddingInput, gapInput, borderMode, labelMode].forEach((control) => {
        control.addEventListener("change", () => {
          updateOptionState();
          track("photo_merge_layout_change", optionPayload());
        });
        control.addEventListener("input", updateOptionState);
      });

      outputFormat.addEventListener("change", () => {
        updateOptionState();
        track("photo_merge_format_change", optionPayload());
      });

      qualityInput.addEventListener("input", () => {
        qualityLabel.textContent = qualityInput.value;
        clearOutput();
      });

      mergeButton.addEventListener("click", mergePhotos);

      sampleButton.addEventListener("click", async () => {
        setBusy(true);
        try {
          const sampleFiles = await createSampleFiles();
          track("photo_merge_sample_apply", { file_count: sampleFiles.length });
          setFileItems(sampleFiles);
        } catch (error) {
          setMessage("샘플 사진을 만들지 못했습니다.", "잠시 후 다시 시도해 주세요.");
          track("photo_merge_validation_error", {
            reason: error?.message || "sample_create_failed"
          });
        } finally {
          setBusy(false);
        }
      });

      resetButton.addEventListener("click", () => {
        resetState();
        track("photo_merge_reset");
      });

      downloadLink.addEventListener("click", (event) => {
        if (!outputUrl) {
          event.preventDefault();
          return;
        }
        track("photo_merge_download", {
          file_count: fileItems.length,
          output_size: outputBytes,
          output_width: outputWidth,
          output_height: outputHeight,
          output_format: formatLabel().toLowerCase(),
          layout_mode: layoutMode.value
        });
      });

      syncFormatUi();
      syncButton();
    })();
  </script>
</BaseLayout>

