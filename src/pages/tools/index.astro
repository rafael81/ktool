---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { toolCategories, tools } from "@/data/tools";
import { collectionPageSchema, toolItemListSchema, websiteSchema } from "@/data/seo";
import { prepShortcuts } from "@/data/prepShortcuts";
import { workflowPackages } from "@/data/workflowPackages";

const structuredData = [
  websiteSchema(),
  toolItemListSchema(tools),
  collectionPageSchema({
    name: "K문서툴 전체 도구",
    description: "로그인 없이 브라우저에서 사용하는 한국형 무료 업무 문서 도구 목록입니다.",
    path: "/tools/",
    tools
  })
];
const submissionPrep = {
  title: "제출용 파일 준비",
  path: "/tools/submission-file-prep/",
  description:
    "사진 형식, 용량, 크기, PDF 묶기, 업무 문서 작성까지 제출 직전 흐름으로 필요한 도구를 고릅니다."
};
const categoryById = new Map(toolCategories.map((category) => [category.id, category]));
---

<BaseLayout
  title="전체 도구 - K문서툴"
  description="제출용 파일 준비, 사업자 명판, 거래명세서, 견적서, 청구서, 영수증, 부가세 계산, 도장 배경 제거, JPG PDF 변환, 사진 용량 줄이기, 이미지 리사이즈, 이미지 자르기, 이미지 회전, HEIC JPG 변환 등 한국 업무 문서와 파일을 로그인 없이 처리하는 무료 도구 목록입니다."
  canonicalPath="/tools/"
  structuredData={structuredData}
>
  <main class="page-shell">
    <section class="tool-intro">
      <div>
        <h1>전체 도구</h1>
        <p>
          K문서툴은 검색으로 들어온 사용자가 바로 문서와 파일을 완성할 수 있도록, 업무 문서와
          브라우저 처리형 PDF·이미지 도구를 검증된 순서로 확장합니다.
        </p>
      </div>
      <div class="quick-links" aria-label="카테고리 바로가기">
        <a
          href={submissionPrep.path}
          data-analytics-event="catalog_workflow_quick_link_click"
          data-analytics-label={submissionPrep.title}
        >
          제출 준비
        </a>
        {
          workflowPackages.map((workflowPackage) => (
            <a
              href={workflowPackage.path}
              data-analytics-event="package_nav_click"
              data-analytics-package-id={workflowPackage.id}
              data-analytics-label={workflowPackage.title}
            >
              {workflowPackage.shortTitle}
            </a>
          ))
        }
        {
          toolCategories.map((category) => (
            <a
              href={category.path}
              data-analytics-event="catalog_category_click"
              data-analytics-label={category.title}
            >
              {category.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>흐름별 패키지</h2>
        <p>처음 온 사용자는 도구 이름보다 제출 상황을 먼저 고르는 편이 빠릅니다.</p>
      </div>
      <div class="workflow-list">
        {
          workflowPackages.map((workflowPackage) => (
            <a
              class="workflow-row"
              href={workflowPackage.path}
              data-analytics-event="package_nav_click"
              data-analytics-package-id={workflowPackage.id}
              data-analytics-label={workflowPackage.title}
            >
              <span class="workflow-row-kicker">{workflowPackage.eyebrow}</span>
              <span class="workflow-row-copy">
                <strong>{workflowPackage.title}</strong>
                <span>{workflowPackage.description}</span>
              </span>
              <span class="workflow-row-meta">
                {workflowPackage.secondaryQueries.slice(0, 3).map((query) => (
                  <span>{query}</span>
                ))}
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section" data-prep-shortcuts>
      <div class="section-heading">
        <h2>문제상황 바로가기</h2>
        <p>제출처 오류 문구나 제한 조건을 기준으로 필요한 도구 설정을 바로 엽니다.</p>
      </div>
      <div class="tool-grid">
        {
          prepShortcuts.map((shortcut) => (
            <a
              class="tool-card"
              href={shortcut.path}
              data-analytics-event="catalog_prep_shortcut_click"
              data-analytics-shortcut-id={shortcut.id}
              data-analytics-tool-id={shortcut.targetToolId}
              data-analytics-tool-title={shortcut.targetToolTitle}
              data-analytics-target-preset={shortcut.targetPreset}
              data-analytics-label={shortcut.label}
            >
              <span class="meta">
                <span class="meta-tag">{shortcut.label}</span>
              </span>
              <strong>{shortcut.title}</strong>
              <p>{shortcut.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section" data-tool-catalog>
      <div class="section-heading">
        <h2>도구 찾기</h2>
        <p>문서 이름, 파일 형식, 오류 상황으로 바로 좁힙니다. 검색어 원문은 분석 이벤트로 보내지 않습니다.</p>
      </div>
      <div class="catalog-toolbar">
        <label class="catalog-search-field">
          <span>검색</span>
          <input
            type="search"
            autocomplete="off"
            inputmode="search"
            placeholder="거래명세서, HEIC, PDF, 3.3%"
            data-tool-search
          />
        </label>
        <div class="catalog-filter-group" aria-label="도구 카테고리 필터">
          <button type="button" class="is-active" aria-pressed="true" data-tool-filter="all">
            전체
          </button>
          {
            toolCategories.map((category) => (
              <button type="button" aria-pressed="false" data-tool-filter={category.id}>
                {category.shortTitle}
              </button>
            ))
          }
        </div>
        <p class="catalog-count">
          <span data-tool-result-count>{tools.length}개 도구</span>
        </p>
      </div>
      <div class="catalog-tool-list">
        {
          tools.map((tool) => (
            <a
              class="catalog-tool-row"
              href={tool.path}
              data-analytics-event="catalog_tool_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.title}
              data-tool-search-item
              data-tool-category={tool.category}
              data-tool-search-text={[
                tool.title,
                tool.shortTitle,
                tool.primaryQuery,
                ...tool.secondaryQueries,
                tool.description,
                tool.userMoment,
                categoryById.get(tool.category)?.title ?? ""
              ].join(" ")}
            >
              <span class="catalog-tool-category">{categoryById.get(tool.category)?.shortTitle}</span>
              <span class="catalog-tool-copy">
                <strong>{tool.title}</strong>
                <span>{tool.description}</span>
              </span>
              <span class="catalog-tool-queries">
                {[tool.primaryQuery, ...tool.secondaryQueries.slice(0, 2)].map((query) => (
                  <span>{query}</span>
                ))}
              </span>
            </a>
          ))
        }
      </div>
      <p class="catalog-empty" data-tool-empty hidden>
        조건에 맞는 도구가 없습니다. 검색어를 줄이거나 전체 카테고리를 선택하세요.
      </p>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>확장 원칙</h2>
        <p>새 도구는 검색 수요, 경쟁 약점, 한국 업무 흐름 적합도, 구현 안전성을 함께 보고 추가합니다.</p>
      </div>
      <ol>
        <li>먼저 검색 의도와 사용자 순간을 정합니다.</li>
        <li>입력값과 파일은 가능한 한 브라우저에서만 처리합니다.</li>
        <li>FAQ, 신뢰 문구, 관련 도구 링크, 구조화 데이터를 함께 넣습니다.</li>
        <li>색인 상태와 사용 이벤트를 확인한 뒤 다음 도구를 고릅니다.</li>
      </ol>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-tool-catalog]");
    if (!root) return;

    const searchInput = root.querySelector("[data-tool-search]");
    const filterButtons = Array.from(root.querySelectorAll("[data-tool-filter]"));
    const items = Array.from(root.querySelectorAll("[data-tool-search-item]"));
    const countNode = root.querySelector("[data-tool-result-count]");
    const emptyNode = root.querySelector("[data-tool-empty]");
    let activeCategory = "all";
    let searchTimer = 0;

    function normalize(value) {
      return String(value || "").toLowerCase().replace(/\s+/g, " ").trim();
    }

    function track(eventName, visibleCount) {
      window.kdocTrack?.(eventName, {
        catalog_category: activeCategory,
        search_query_length: normalize(searchInput?.value).length,
        visible_count: visibleCount
      });
    }

    function applyFilters({ eventName } = {}) {
      const query = normalize(searchInput?.value);
      let visibleCount = 0;

      items.forEach((item) => {
        const matchesCategory =
          activeCategory === "all" || item.dataset.toolCategory === activeCategory;
        const matchesQuery = !query || normalize(item.dataset.toolSearchText).includes(query);
        const visible = matchesCategory && matchesQuery;
        item.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (countNode) countNode.textContent = `${visibleCount}개 도구`;
      if (emptyNode) emptyNode.hidden = visibleCount !== 0;
      if (eventName) track(eventName, visibleCount);
    }

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.dataset.toolFilter || "all";
        filterButtons.forEach((candidate) => {
          const selected = candidate === button;
          candidate.classList.toggle("is-active", selected);
          candidate.setAttribute("aria-pressed", String(selected));
        });
        applyFilters({ eventName: "catalog_filter_change" });
      });
    });

    searchInput?.addEventListener("input", () => {
      applyFilters();
      clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => {
        applyFilters({ eventName: "catalog_search_change" });
      }, 350);
    });

    applyFilters();
  })();
</script>
