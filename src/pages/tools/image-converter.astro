---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema } from "@/data/seo";

const tool = getTool("image-converter");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main
    class="page-shell"
    data-tool-id={tool.id}
    data-tool-title={tool.title}
  >
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>{tool.description} WebP가 열리지 않거나 JPG만 받는 제출처에 맞춰 이미지를 빠르게 정리합니다.</p>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="convert-workspace" data-image-converter>
      <form class="panel convert-panel" aria-label="이미지 형식 변환 입력">
        <div class="panel-title">
          <h2>이미지 입력</h2>
        </div>

        <label class="field">
          <span>이미지 파일</span>
          <span class="file-control">
            <input data-image-input type="file" accept="image/png,image/jpeg,image/webp" multiple />
            <span data-file-label>WebP/PNG/JPG 여러 장 선택</span>
          </span>
        </label>

        <label class="field">
          <span>출력 형식</span>
          <select data-output-format>
            <option value="image/jpeg">JPG</option>
            <option value="image/png">PNG</option>
            <option value="image/webp">WebP</option>
          </select>
        </label>

        <label class="field range-field">
          <span>품질 <strong data-quality-label>90</strong></span>
          <input data-quality type="range" min="50" max="95" step="1" value="90" />
        </label>

        <p class="note-box">
          최대 20장, 총 50MB, 파일당 12MB까지 처리합니다. JPG는 투명 배경을 지원하지 않아 흰 배경으로 저장합니다.
        </p>

        <div class="button-row">
          <button class="btn" type="button" data-sample>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7M3 3v6h6"/></svg>
            초기화
          </button>
          <button class="btn primary" type="button" data-convert disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M7 7h11l-3-3M17 17H6l3 3"/><path d="M18 7l-5 5M6 17l5-5"/></svg>
            <span data-convert-label>변환하기</span>
          </button>
        </div>
      </form>

      <section class="preview-panel convert-preview-panel" aria-label="이미지 형식 변환 결과">
        <div class="panel-title">
          <h2>변환 결과</h2>
          <span class="format-badge" data-format-badge>JPG</span>
        </div>

        <div class="convert-summary">
          <span>상태</span>
          <strong data-output-status>이미지를 선택하면 형식을 바꿀 수 있습니다.</strong>
          <p data-output-meta>변환된 파일은 아직 준비되지 않았습니다.</p>
        </div>

        <div class="convert-list" data-convert-list aria-live="polite">
          <p class="empty-state">선택된 이미지가 없습니다.</p>
        </div>
      </section>

      <aside class="side-panel">
        <div class="panel-title">
          <h3>처리 원칙</h3>
        </div>
        <ul class="status-list">
          <li><span class="status-dot"></span><span>이미지는 브라우저 캔버스에서만 처리합니다.</span></li>
          <li><span class="status-dot"></span><span>파일명과 원본 이미지는 분석 이벤트로 보내지 않습니다.</span></li>
          <li><span class="status-dot"></span><span>PNG/WebP 출력은 투명 영역을 유지할 수 있습니다.</span></li>
        </ul>
      </aside>
    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>변환할 WebP, PNG, JPG 이미지를 선택합니다.</li>
        <li>저장할 출력 형식을 JPG, PNG, WebP 중에서 고릅니다.</li>
        <li>변환하기를 누른 뒤 준비된 이미지를 저장합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline src="/scripts/file-tool-utils.js"></script>
  <script is:inline>
    (() => {
      const root = document.querySelector("[data-image-converter]");
      if (!root) return;
      const fileTools = window.KdocFileTools;
      if (!fileTools) return;

      const maxFiles = 20;
      const maxFileSize = 12 * 1024 * 1024;
      const maxTotalSize = 50 * 1024 * 1024;
      const input = root.querySelector("[data-image-input]");
      const fileLabel = root.querySelector("[data-file-label]");
      const outputFormat = root.querySelector("[data-output-format]");
      const qualityInput = root.querySelector("[data-quality]");
      const qualityLabel = root.querySelector("[data-quality-label]");
      const formatBadge = root.querySelector("[data-format-badge]");
      const convertButton = root.querySelector("[data-convert]");
      const convertLabel = root.querySelector("[data-convert-label]");
      const resetButton = root.querySelector("[data-reset]");
      const sampleButton = root.querySelector("[data-sample]");
      const outputStatus = root.querySelector("[data-output-status]");
      const outputMeta = root.querySelector("[data-output-meta]");
      const convertList = root.querySelector("[data-convert-list]");
      const formatter = new Intl.NumberFormat("ko-KR");
      let fileItems = [];
      let nextItemId = 1;

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "image-converter",
          tool_title: "WebP JPG 변환",
          ...params
        });
      }

      function toFiles(items = fileItems) {
        return items.map((item) => item.file);
      }

      function totalSize(nextFiles = toFiles()) {
        return fileTools.totalSize(nextFiles);
      }

      function totalOutputSize(items = fileItems) {
        return items.reduce((sum, item) => sum + (item.result?.size || 0), 0);
      }

      function outputExtension() {
        return fileTools.outputExtension(outputFormat.value);
      }

      function formatLabel(type) {
        if (type === "image/webp") return "WebP";
        if (type === "image/png") return "PNG";
        if (type === "image/jpeg") return "JPG";
        return "IMG";
      }

      function setMessage(status, meta = "") {
        outputStatus.textContent = status;
        outputMeta.textContent = meta;
      }

      function setBusy(isBusy) {
        convertButton.disabled = isBusy || fileItems.length === 0;
        convertLabel.textContent = isBusy ? "처리 중" : "변환하기";
      }

      function validationMessage(reason) {
        return fileTools.validationMessage(reason, "변환할 이미지를 선택해 주세요.");
      }

      function validateFiles(nextFiles) {
        return fileTools.validateImageFiles(nextFiles, { maxFiles, maxFileSize, maxTotalSize });
      }

      function releaseResult(item) {
        fileTools.revokeResult(item.result);
        item.result = null;
      }

      function releaseItems(items = fileItems) {
        fileTools.revokePreviewItems(items);
      }

      function setFileItems(nextFiles) {
        releaseItems();
        fileItems = fileTools.createFileItems(nextFiles, () => nextItemId++);
        renderFiles();
      }

      function updateControlState() {
        formatBadge.textContent = outputExtension().toUpperCase();
        qualityLabel.textContent = qualityInput.value;
      }

      function renderFiles() {
        updateControlState();
        convertButton.disabled = fileItems.length === 0;

        if (fileItems.length === 0) {
          fileLabel.textContent = "WebP/PNG/JPG 여러 장 선택";
          convertList.innerHTML = '<p class="empty-state">선택된 이미지가 없습니다.</p>';
          setMessage("이미지를 선택하면 형식을 바꿀 수 있습니다.", "변환된 파일은 아직 준비되지 않았습니다.");
          return;
        }

        fileLabel.textContent = `${formatter.format(fileItems.length)}장 선택`;
        convertList.innerHTML = fileItems
          .map((item, index) => {
            const result = item.result;
            const sourceLabel = formatLabel(item.file.type);
            return `
              <div class="convert-row" data-convert-row>
                <img src="${item.previewUrl}" alt="" loading="lazy" />
                <div>
                  <strong>${index + 1}번 이미지</strong>
                  <p>${sourceLabel} · ${fileTools.formatBytes(item.file.size)}${result ? ` → ${formatLabel(result.outputFormat)} · ${fileTools.formatBytes(result.size)}` : " 선택됨"}</p>
                </div>
                ${
                  result
                    ? `<a class="btn primary" href="${result.url}" download="converted-image-${index + 1}.${outputExtension()}" data-download-image data-before-size="${item.file.size}" data-after-size="${result.size}" data-source-type="${item.file.type}" data-output-format="${result.outputFormat}">저장</a>`
                    : '<span class="pending-badge">대기</span>'
                }
              </div>
            `;
          })
          .join("");

        const readyCount = fileItems.filter((item) => item.result).length;
        if (readyCount > 0) {
          setMessage(
            `변환 완료: ${formatter.format(readyCount)}장`,
            `총 ${fileTools.formatBytes(totalSize())} → ${fileTools.formatBytes(totalOutputSize())}`
          );
        } else {
          setMessage(
            `${formatter.format(fileItems.length)}장 선택됨`,
            `${formatLabel(outputFormat.value)} 형식으로 변환할 준비가 됐습니다.`
          );
        }
      }

      async function convertItem(item) {
        const image = await fileTools.imageFromFile(item.file);
        const sourceWidth = image.naturalWidth || image.width;
        const sourceHeight = image.naturalHeight || image.height;
        if (!sourceWidth || !sourceHeight) throw new Error("image_decode_failed");

        const background = outputFormat.value === "image/jpeg" ? "#ffffff" : "";
        const canvas = fileTools.drawImageOnCanvas(image, sourceWidth, sourceHeight, background);
        const blob = await fileTools.canvasToBlob(
          canvas,
          outputFormat.value,
          Number(qualityInput.value) / 100
        );
        releaseResult(item);
        item.result = {
          size: blob.size,
          url: URL.createObjectURL(blob),
          outputFormat: outputFormat.value
        };
      }

      async function convertImages() {
        const files = toFiles();
        const validation = validateFiles(files);
        if (!validation.ok) {
          const message = validationMessage(validation.reason);
          setMessage(message, "파일을 다시 선택한 뒤 시도해 주세요.");
          track("image_convert_validation_error", {
            reason: validation.reason,
            ...fileTools.safeFileAnalyticsPayload(files)
          });
          return;
        }

        setBusy(true);
        setMessage("이미지 변환 중", `${formatter.format(fileItems.length)}장 이미지를 정리하고 있습니다.`);
        try {
          for (const item of fileItems) {
            await convertItem(item);
          }
          renderFiles();
          track("image_convert_convert", {
            ...fileTools.safeFileAnalyticsPayload(files),
            output_size: totalOutputSize(),
            output_format: outputFormat.value,
            quality: Number(qualityInput.value)
          });
        } catch (error) {
          setMessage("이미지를 변환하지 못했습니다.", "이미지 파일을 다시 선택하거나 장수를 줄여서 시도해 주세요.");
          track("image_convert_validation_error", {
            reason: error?.message || "convert_failed"
          });
        } finally {
          setBusy(false);
        }
      }

      function sampleFile(label, color, width, height, type) {
        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext("2d");
        const gradient = ctx.createLinearGradient(0, 0, width, height);
        gradient.addColorStop(0, "#ffffff");
        gradient.addColorStop(1, "#eef3f6");
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, width, height);
        ctx.fillStyle = color;
        ctx.fillRect(0, Math.round(height * 0.58), width, Math.round(height * 0.42));
        ctx.strokeStyle = "rgba(20,33,47,0.22)";
        ctx.lineWidth = 10;
        ctx.strokeRect(70, 70, width - 140, height - 140);
        ctx.fillStyle = "#14212f";
        ctx.font = "900 72px sans-serif";
        ctx.fillText(label, 90, 165);
        ctx.font = "700 34px sans-serif";
        ctx.fillText(`${formatLabel(type)} sample`, 90, 225);
        return new Promise((resolve, reject) => {
          canvas.toBlob(
            (blob) => {
              if (!blob) {
                reject(new Error("sample_export_failed"));
                return;
              }
              resolve(new File([blob], `${label}.${fileTools.outputExtension(type)}`, { type }));
            },
            type,
            0.92
          );
        });
      }

      input.addEventListener("change", (event) => {
        const nextFiles = Array.from(event.target.files || []);
        const validation = validateFiles(nextFiles);
        if (!validation.ok) {
          const message = validationMessage(validation.reason);
          setFileItems([]);
          input.value = "";
          setMessage(message, "파일을 다시 선택해 주세요.");
          track("image_convert_validation_error", {
            reason: validation.reason,
            ...fileTools.safeFileAnalyticsPayload(nextFiles)
          });
          return;
        }
        setFileItems(nextFiles);
        track("image_convert_file_select", {
          ...fileTools.safeFileAnalyticsPayload(toFiles())
        });
      });

      for (const control of [outputFormat, qualityInput]) {
        control.addEventListener("input", () => {
          for (const item of fileItems) releaseResult(item);
          renderFiles();
        });
        control.addEventListener("change", () => {
          for (const item of fileItems) releaseResult(item);
          renderFiles();
        });
      }

      sampleButton.addEventListener("click", async () => {
        try {
          setFileItems([
            await sampleFile("webp-sample", "#117a7a", 1600, 1100, "image/webp"),
            await sampleFile("png-sample", "#b54708", 1400, 1600, "image/png")
          ]);
          input.value = "";
          track("image_convert_sample_apply", { file_count: fileItems.length });
        } catch (error) {
          setMessage("샘플 이미지를 만들지 못했습니다.", "현재 브라우저의 이미지 저장 지원을 확인해 주세요.");
          track("image_convert_validation_error", {
            reason: error?.message || "sample_failed"
          });
        }
      });

      resetButton.addEventListener("click", () => {
        setFileItems([]);
        input.value = "";
        outputFormat.value = "image/jpeg";
        qualityInput.value = "90";
        renderFiles();
        track("image_convert_reset");
      });

      convertButton.addEventListener("click", convertImages);

      convertList.addEventListener("click", (event) => {
        const link =
          event.target instanceof Element ? event.target.closest("[data-download-image]") : null;
        if (!link) return;
        track("image_convert_download", {
          source_type: link.dataset.sourceType || "unknown",
          output_format: link.dataset.outputFormat || outputFormat.value,
          before_size: Number(link.dataset.beforeSize || 0),
          after_size: Number(link.dataset.afterSize || 0)
        });
      });

      window.addEventListener("pagehide", () => releaseItems());

      renderFiles();
    })();
  </script>
</BaseLayout>

<style>
  .convert-workspace {
    display: grid;
    grid-template-columns: minmax(280px, 390px) minmax(0, 1fr) minmax(240px, 300px);
    gap: 18px;
    align-items: start;
  }

  .convert-panel,
  .convert-preview-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 18px;
  }

  .file-control {
    position: relative;
    display: flex;
    min-height: 44px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--muted);
    font-size: 14px;
    font-weight: 800;
    padding: 11px 12px;
  }

  .file-control input {
    position: absolute;
    inset: 0;
    cursor: pointer;
    opacity: 0;
  }

  .range-field {
    margin-top: 12px;
  }

  .range-field input {
    padding-inline: 0;
    accent-color: var(--accent);
  }

  .range-field strong {
    color: var(--accent-dark);
  }

  .format-badge,
  :global(.pending-badge) {
    border-radius: 7px;
    background: #e8f4f2;
    color: var(--accent-dark);
    font-size: 13px;
    font-weight: 900;
    padding: 5px 8px;
  }

  .convert-summary {
    display: grid;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #f8fbfc;
    padding: 18px;
  }

  .convert-summary > span,
  :global(.convert-row strong) {
    color: #344457;
    font-size: 13px;
    font-weight: 900;
  }

  .convert-summary strong {
    color: var(--ink);
    font-size: 24px;
    line-height: 1.3;
  }

  .convert-summary p,
  :global(.convert-row p) {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .convert-list {
    display: grid;
    gap: 8px;
    margin-top: 16px;
  }

  :global(.empty-state) {
    border: 1px dashed var(--line);
    border-radius: 8px;
    color: var(--muted);
    margin: 0;
    padding: 18px;
    text-align: center;
  }

  :global(.convert-row) {
    display: grid;
    grid-template-columns: 58px minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 12px;
  }

  :global(.convert-row img) {
    width: 58px;
    height: 58px;
    border: 1px solid var(--line);
    border-radius: 7px;
    background: #fff;
    object-fit: cover;
  }

  :global(.convert-row .btn) {
    min-height: 34px;
    padding: 8px 10px;
  }

  .button-row .btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  @media (max-width: 1100px) {
    .convert-workspace {
      grid-template-columns: minmax(280px, 390px) minmax(0, 1fr);
    }

    .convert-workspace .side-panel {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 760px) {
    .convert-workspace {
      grid-template-columns: 1fr;
    }

    :global(.convert-row) {
      grid-template-columns: 58px minmax(0, 1fr);
    }

    :global(.convert-row .btn),
    :global(.convert-row .pending-badge) {
      grid-column: 1 / -1;
      width: 100%;
      justify-self: stretch;
      text-align: center;
    }
  }
</style>
