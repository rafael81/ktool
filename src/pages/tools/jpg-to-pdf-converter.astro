---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema } from "@/data/seo";

const tool = getTool("jpg-to-pdf");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main
    class="page-shell"
    data-tool-id={tool.id}
    data-tool-title={tool.title}
  >
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>{tool.description} 주민등록등본 사진, 통장 사본, 사업자 서류처럼 여러 이미지를 한 PDF로 묶어야 할 때 빠르게 정리합니다.</p>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="pdf-workspace" data-jpg-pdf-tool>
      <form class="panel pdf-panel" aria-label="JPG PDF 변환 입력">
        <div class="panel-title">
          <h2>이미지 입력</h2>
        </div>

        <label class="field">
          <span>이미지 파일</span>
          <span class="file-control">
            <input data-image-input type="file" accept="image/png,image/jpeg,image/webp" multiple />
            <span data-file-label>JPG/PNG/WebP 여러 장 선택</span>
          </span>
        </label>

        <div class="field-grid two-columns">
          <label class="field">
            <span>페이지 크기</span>
            <select data-page-size>
              <option value="a4-portrait">A4 세로</option>
              <option value="a4-landscape">A4 가로</option>
              <option value="image">이미지 크기</option>
            </select>
          </label>

          <label class="field">
            <span>여백</span>
            <select data-margin>
              <option value="normal">보통</option>
              <option value="narrow">좁게</option>
              <option value="none">없음</option>
            </select>
          </label>
        </div>

        <p class="note-box">
          최대 20장, 총 50MB, 파일당 12MB까지 처리합니다. 선택 후 목록에서 이미지를 끌거나 버튼으로 순서를 조정할 수 있습니다.
        </p>

        <div class="compressed-intake-card" data-compressed-intake>
          <strong data-intake-title>정리한 이미지로 PDF 만들기</strong>
          <p data-intake-copy>사진 용량 줄이기, 이미지 편집, 형식 변환 도구에서 저장한 JPG/PNG/WebP 이미지를 여기서 다시 선택해 한 PDF로 묶습니다.</p>
          <ol>
            <li data-intake-step-files>저장한 이미지를 모두 선택합니다.</li>
            <li>목록 순서가 PDF 페이지 순서입니다.</li>
            <li>PDF 만들기 후 제출 전 마지막 확인에서 저장 준비 상태를 봅니다.</li>
          </ol>
        </div>

        <div class="preflight-card" data-preflight aria-live="polite">
          <strong>제출 전 마지막 확인</strong>
          <ul>
            <li data-preflight-item="files">이미지를 선택해 주세요.</li>
            <li data-preflight-item="order">PDF 페이지 순서는 선택 후 확인합니다.</li>
            <li data-preflight-item="settings">A4 크기와 여백을 제출처 기준에 맞춥니다.</li>
            <li data-preflight-item="output">PDF 만들기 후 저장 버튼이 열립니다.</li>
          </ul>
        </div>

        <div class="button-row">
          <button class="btn" type="button" data-sample>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7M3 3v6h6"/></svg>
            초기화
          </button>
          <button class="btn primary" type="button" data-generate disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 4h10l6 6v10H4z"/><path d="M14 4v6h6"/></svg>
            <span data-generate-label>PDF 만들기</span>
          </button>
        </div>
      </form>

      <section class="preview-panel pdf-preview-panel" aria-label="PDF 변환 상태">
        <div class="panel-title">
          <h2>변환 결과</h2>
          <span class="format-badge">PDF</span>
        </div>

        <div class="pdf-result-card">
          <span>상태</span>
          <strong data-output-status>이미지를 선택하면 PDF를 만들 수 있습니다.</strong>
          <p data-output-meta>파일은 아직 준비되지 않았습니다.</p>
          <a
            class="btn primary disabled"
            href="#"
            download="k-document-images.pdf"
            aria-disabled="true"
            data-download
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"/></svg>
            PDF 저장
          </a>
        </div>

        <div class="file-list" data-file-list aria-live="polite">
          <p class="empty-state">선택된 이미지가 없습니다.</p>
        </div>
      </section>

      <aside class="side-panel">
        <div class="panel-title">
          <h3>처리 원칙</h3>
        </div>
        <ul class="status-list">
          <li><span class="status-dot"></span><span>원본 이미지와 파일명은 서버로 보내지 않습니다.</span></li>
          <li><span class="status-dot"></span><span>목록에 보이는 순서대로 PDF 페이지를 만듭니다.</span></li>
          <li><span class="status-dot"></span><span>제출처의 원본성, 서명, 증빙 요건은 별도로 확인하세요.</span></li>
        </ul>
      </aside>
    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>PDF로 묶을 JPG, PNG, WebP 이미지를 선택합니다.</li>
        <li>필요하면 이미지 목록을 끌거나 위/아래 버튼으로 페이지 순서를 맞춥니다.</li>
        <li>제출 전 마지막 확인에서 순서, 용량, 페이지 설정을 보고 PDF를 저장합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline src="/scripts/file-tool-utils.js"></script>
  <script>
    // @ts-nocheck
    import { PDFDocument } from "pdf-lib";

    const root = document.querySelector("[data-jpg-pdf-tool]");
    if (root) {
      const fileTools = window.KdocFileTools;
      if (!fileTools) throw new Error("file_tool_utils_unavailable");
      const maxFiles = 20;
      const maxFileSize = 12 * 1024 * 1024;
      const maxTotalSize = 50 * 1024 * 1024;
      const maxImageSide = 2200;
      const pageSizes = {
        "a4-portrait": [595.28, 841.89],
        "a4-landscape": [841.89, 595.28]
      };
      const marginSizes = {
        none: 0,
        narrow: 24,
        normal: 48
      };

      const input = root.querySelector("[data-image-input]");
      const fileLabel = root.querySelector("[data-file-label]");
      const pageSizeSelect = root.querySelector("[data-page-size]");
      const marginSelect = root.querySelector("[data-margin]");
      const generateButton = root.querySelector("[data-generate]");
      const generateLabel = root.querySelector("[data-generate-label]");
      const resetButton = root.querySelector("[data-reset]");
      const sampleButton = root.querySelector("[data-sample]");
      const downloadLink = root.querySelector("[data-download]");
      const outputStatus = root.querySelector("[data-output-status]");
      const outputMeta = root.querySelector("[data-output-meta]");
      const fileList = root.querySelector("[data-file-list]");
      const compressedIntake = root.querySelector("[data-compressed-intake]");
      const intakeTitle = root.querySelector("[data-intake-title]");
      const intakeCopy = root.querySelector("[data-intake-copy]");
      const intakeStepFiles = root.querySelector("[data-intake-step-files]");
      const preflightItems = {
        files: root.querySelector('[data-preflight-item="files"]'),
        order: root.querySelector('[data-preflight-item="order"]'),
        settings: root.querySelector('[data-preflight-item="settings"]'),
        output: root.querySelector('[data-preflight-item="output"]')
      };
      const formatter = new Intl.NumberFormat("ko-KR");
      let fileItems = [];
      let pdfUrl = "";
      let outputBytes = 0;
      let nextItemId = 1;
      let dragSourceIndex = -1;

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "jpg-to-pdf",
          tool_title: "JPG PDF 변환",
          ...params
        });
      }

      const arrivalSource = new URLSearchParams(window.location.search).get("from");
      const arrivalSources = {
        "compressed-images": {
          title: "압축 이미지로 PDF 만들기",
          copy: "사진 용량 줄이기에서 저장한 JPG/PNG/WebP 이미지를 여기서 다시 선택해 한 PDF로 묶습니다.",
          step: "압축 도구에서 저장한 이미지를 모두 선택합니다.",
          event: "jpg_pdf_compressed_arrival"
        },
        "rotated-images": {
          title: "회전한 이미지로 PDF 만들기",
          copy: "이미지 회전에서 저장한 JPG/PNG/WebP 이미지를 여기서 다시 선택해 한 PDF로 묶습니다.",
          step: "회전 도구에서 저장한 이미지를 모두 선택합니다.",
          event: "jpg_pdf_rotated_arrival"
        },
        "resized-images": {
          title: "리사이즈한 이미지로 PDF 만들기",
          copy: "이미지 리사이즈에서 저장한 JPG/PNG/WebP 이미지를 여기서 다시 선택해 한 PDF로 묶습니다.",
          step: "리사이즈 도구에서 저장한 이미지를 모두 선택합니다.",
          event: "jpg_pdf_resized_arrival"
        },
        "cropped-images": {
          title: "잘라낸 이미지로 PDF 만들기",
          copy: "이미지 자르기에서 저장한 JPG/PNG/WebP 이미지를 여기서 다시 선택해 한 PDF로 묶습니다.",
          step: "자르기 도구에서 저장한 이미지를 선택합니다.",
          event: "jpg_pdf_cropped_arrival"
        },
        "format-converted-images": {
          title: "변환한 이미지로 PDF 만들기",
          copy: "WebP JPG 변환에서 저장한 JPG/PNG/WebP 이미지를 여기서 다시 선택해 한 PDF로 묶습니다.",
          step: "형식 변환 도구에서 저장한 이미지를 모두 선택합니다.",
          event: "jpg_pdf_format_converted_arrival"
        },
        "heic-converted-images": {
          title: "HEIC 변환 이미지로 PDF 만들기",
          copy: "HEIC JPG 변환에서 저장한 JPG/PNG 이미지를 여기서 다시 선택해 iPhone 사진을 한 PDF로 묶습니다.",
          step: "HEIC 변환 도구에서 저장한 이미지를 모두 선택합니다.",
          event: "jpg_pdf_heic_converted_arrival"
        }
      };
      const arrivalConfig = arrivalSources[arrivalSource];
      if (arrivalConfig) {
        intakeTitle.textContent = arrivalConfig.title;
        intakeCopy.textContent = arrivalConfig.copy;
        intakeStepFiles.textContent = arrivalConfig.step;
        compressedIntake.dataset.state = "highlight";
        track(arrivalConfig.event, { source: arrivalSource });
      }

      function formatBytes(bytes) {
        return fileTools.formatBytes(bytes);
      }

      function toFiles(items = fileItems) {
        return items.map((item) => item.file);
      }

      function totalSize(nextFiles = toFiles()) {
        return fileTools.totalSize(nextFiles);
      }

      function fileTypeLabel(file) {
        if (file.type === "image/jpeg") return "JPEG";
        if (file.type === "image/png") return "PNG";
        if (file.type === "image/webp") return "WEBP";
        return "IMG";
      }

      function setMessage(status, meta = "") {
        outputStatus.textContent = status;
        outputMeta.textContent = meta;
      }

      function setPreflightItem(key, status, text) {
        const item = preflightItems[key];
        if (!item) return;
        item.dataset.status = status;
        item.textContent = text;
      }

      function updatePreflight() {
        const files = toFiles();
        const countText = formatter.format(files.length);
        const sizeText = formatBytes(totalSize(files));

        if (files.length === 0) {
          setPreflightItem("files", "pending", "이미지를 선택해 주세요.");
          setPreflightItem("order", "pending", "PDF 페이지 순서는 선택 후 확인합니다.");
          setPreflightItem("settings", "ready", "A4 크기와 여백을 제출처 기준에 맞춥니다.");
          setPreflightItem("output", "pending", "PDF 만들기 후 저장 버튼이 열립니다.");
          return;
        }

        setPreflightItem("files", "ready", `${countText}장 선택됨, 총 ${sizeText}`);
        setPreflightItem(
          "order",
          "ready",
          files.length > 1
            ? "목록 순서대로 PDF 페이지가 만들어집니다."
            : "1장 PDF로 저장됩니다."
        );
        setPreflightItem(
          "settings",
          "ready",
          `${pageSizeSelect.options[pageSizeSelect.selectedIndex]?.text || "A4 세로"} · ${marginSelect.options[marginSelect.selectedIndex]?.text || "보통"} 여백`
        );
        setPreflightItem(
          "output",
          pdfUrl ? "ready" : "pending",
          pdfUrl ? `저장 준비 완료, 예상 ${formatBytes(outputBytes)}` : "PDF 만들기를 누르면 저장 버튼이 열립니다."
        );
      }

      function setBusy(isBusy) {
        generateButton.disabled = isBusy || fileItems.length === 0;
        generateLabel.textContent = isBusy ? "PDF 만드는 중" : "PDF 만들기";
      }

      function clearPdfUrl() {
        if (pdfUrl) URL.revokeObjectURL(pdfUrl);
        pdfUrl = "";
        outputBytes = 0;
        downloadLink.href = "#";
        downloadLink.classList.add("disabled");
        downloadLink.setAttribute("aria-disabled", "true");
        updatePreflight();
      }

      function releaseItems(items = fileItems) {
        fileTools.revokePreviewItems(items);
      }

      function createFileItems(nextFiles) {
        return fileTools.createFileItems(nextFiles, () => nextItemId++);
      }

      function setFileItems(nextFiles) {
        releaseItems();
        fileItems = createFileItems(nextFiles);
        renderFiles();
      }

      function renderFiles() {
        generateButton.disabled = fileItems.length === 0;
        clearPdfUrl();
        if (fileItems.length === 0) {
          fileLabel.textContent = "JPG/PNG/WebP 여러 장 선택";
          fileList.innerHTML = '<p class="empty-state">선택된 이미지가 없습니다.</p>';
          setMessage("이미지를 선택하면 PDF를 만들 수 있습니다.", "파일은 아직 준비되지 않았습니다.");
          updatePreflight();
          return;
        }

        fileLabel.textContent = `${formatter.format(fileItems.length)}장 선택`;
        fileList.innerHTML = fileItems
          .map(
            (item, index) => `
              <div class="file-row" data-file-row data-file-index="${index}" draggable="true" aria-label="${index + 1}번째 PDF 이미지">
                <img src="${item.previewUrl}" alt="" loading="lazy" />
                <span>${index + 1}</span>
                <strong>${fileTypeLabel(item.file)}</strong>
                <p>${formatBytes(item.file.size)}</p>
                <div class="file-actions">
                  <button type="button" data-move-file="${index}" data-direction="up" aria-label="${index + 1}번째 이미지를 앞으로 이동" ${index === 0 ? "disabled" : ""}>↑</button>
                  <button type="button" data-move-file="${index}" data-direction="down" aria-label="${index + 1}번째 이미지를 뒤로 이동" ${index === fileItems.length - 1 ? "disabled" : ""}>↓</button>
                  <button type="button" data-remove-file="${index}" aria-label="${index + 1}번째 이미지 삭제">×</button>
                </div>
              </div>
            `
          )
          .join("");
        setMessage(
          `${formatter.format(fileItems.length)}장 선택됨`,
          `총 ${formatBytes(totalSize())}, PDF 만들기를 누르면 변환합니다.`
        );
        updatePreflight();
      }

      function reorderFile(fromIndex, toIndex, method = "button") {
        if (fromIndex === toIndex) return;
        if (fromIndex < 0 || fromIndex >= fileItems.length) return;
        if (toIndex < 0 || toIndex >= fileItems.length) return;
        const nextItems = [...fileItems];
        const [movedItem] = nextItems.splice(fromIndex, 1);
        nextItems.splice(toIndex, 0, movedItem);
        fileItems = nextItems;
        renderFiles();
        track("jpg_pdf_reorder", {
          from_position: fromIndex + 1,
          to_position: toIndex + 1,
          file_count: fileItems.length,
          method
        });
      }

      function moveFile(index, direction) {
        const offset = direction === "up" ? -1 : 1;
        reorderFile(index, index + offset, "button");
      }

      function removeFile(index) {
        if (index < 0 || index >= fileItems.length) return;
        const nextItems = [...fileItems];
        const [removedItem] = nextItems.splice(index, 1);
        releaseItems([removedItem]);
        fileItems = nextItems;
        if (fileItems.length === 0) input.value = "";
        renderFiles();
        track("jpg_pdf_remove", {
          from_position: index + 1,
          file_count: fileItems.length
        });
      }

      function fileRowFromEvent(event) {
        const target = event.target instanceof Element ? event.target : null;
        return target?.closest("[data-file-row]");
      }

      function clearDragState() {
        fileList.querySelectorAll("[data-file-row]").forEach((row) => {
          row.classList.remove("is-dragging", "is-drag-over");
        });
      }

      function validateFiles(nextFiles) {
        return fileTools.validateImageFiles(nextFiles, { maxFiles, maxFileSize, maxTotalSize });
      }

      function validationMessage(reason) {
        return fileTools.validationMessage(reason, "PDF로 만들 이미지를 선택해 주세요.");
      }

      async function normalizeImage(file) {
        const exported = await fileTools.exportImageFile(file, {
          maxSide: maxImageSide,
          type: "image/jpeg",
          quality: 0.92
        });
        return {
          bytes: exported.bytes,
          width: exported.width,
          height: exported.height
        };
      }

      function pageSizeFor(image) {
        if (pageSizeSelect.value === "image") {
          const width = Math.max(240, Math.min(1440, image.width * 0.75));
          const height = Math.max(240, Math.min(1440, image.height * 0.75));
          return [width, height];
        }
        return pageSizes[pageSizeSelect.value] || pageSizes["a4-portrait"];
      }

      async function generatePdf() {
        const files = toFiles();
        const validation = validateFiles(files);
        if (!validation.ok) {
          const message = validationMessage(validation.reason);
          setMessage(message, "파일을 다시 선택한 뒤 시도해 주세요.");
          track("jpg_pdf_validation_error", { reason: validation.reason });
          return;
        }

        clearPdfUrl();
        setBusy(true);
        setMessage("PDF 만드는 중", `${formatter.format(files.length)}장 이미지를 정리하고 있습니다.`);

        try {
          const pdfDoc = await PDFDocument.create();
          const margin = marginSizes[marginSelect.value] ?? marginSizes.normal;

          for (const file of files) {
            const image = await normalizeImage(file);
            const embedded = await pdfDoc.embedJpg(image.bytes);
            const [pageWidth, pageHeight] = pageSizeFor(image);
            const page = pdfDoc.addPage([pageWidth, pageHeight]);
            const availableWidth = Math.max(1, pageWidth - margin * 2);
            const availableHeight = Math.max(1, pageHeight - margin * 2);
            const imageScale = Math.min(availableWidth / embedded.width, availableHeight / embedded.height);
            const drawWidth = embedded.width * imageScale;
            const drawHeight = embedded.height * imageScale;
            page.drawImage(embedded, {
              x: (pageWidth - drawWidth) / 2,
              y: (pageHeight - drawHeight) / 2,
              width: drawWidth,
              height: drawHeight
            });
          }

          const pdfBytes = await pdfDoc.save();
          outputBytes = pdfBytes.byteLength;
          const blob = new Blob([pdfBytes], { type: "application/pdf" });
          pdfUrl = URL.createObjectURL(blob);
          downloadLink.href = pdfUrl;
          downloadLink.classList.remove("disabled");
          downloadLink.removeAttribute("aria-disabled");
          setMessage(
            `PDF 준비 완료: ${formatter.format(files.length)}장`,
            `예상 파일 크기 ${formatBytes(outputBytes)}`
          );
          updatePreflight();
          track("jpg_pdf_generate", {
            ...fileTools.safeFileAnalyticsPayload(files),
            output_size: outputBytes,
            page_size: pageSizeSelect.value,
            margin: marginSelect.value
          });
        } catch (error) {
          setMessage("PDF를 만들지 못했습니다.", "이미지 파일을 다시 선택하거나 장수를 줄여서 시도해 주세요.");
          track("jpg_pdf_validation_error", {
            reason: error?.message || "pdf_generation_failed"
          });
        } finally {
          setBusy(false);
        }
      }

      function sampleFile(label, color, width, height) {
        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext("2d");
        ctx.fillStyle = "#ffffff";
        ctx.fillRect(0, 0, width, height);
        ctx.strokeStyle = "#dbe4ec";
        ctx.lineWidth = 12;
        ctx.strokeRect(36, 36, width - 72, height - 72);
        ctx.fillStyle = color;
        ctx.fillRect(76, 96, width - 152, 16);
        ctx.fillRect(76, 146, width - 220, 16);
        ctx.fillStyle = "#14212f";
        ctx.font = "900 54px sans-serif";
        ctx.fillText(label, 76, 250);
        ctx.font = "700 28px sans-serif";
        ctx.fillText("K문서툴 샘플 이미지", 76, 310);
        return new Promise((resolve) => {
          canvas.toBlob((blob) => {
            resolve(new File([blob], `${label}.jpg`, { type: "image/jpeg" }));
          }, "image/jpeg", 0.92);
        });
      }

      input.addEventListener("change", (event) => {
        const nextFiles = Array.from(event.target.files || []);
        const validation = validateFiles(nextFiles);
        if (!validation.ok) {
          const message = validationMessage(validation.reason);
          setFileItems([]);
          input.value = "";
          setMessage(message, "파일을 다시 선택해 주세요.");
          track("jpg_pdf_validation_error", {
            reason: validation.reason,
            ...fileTools.safeFileAnalyticsPayload(nextFiles)
          });
          return;
        }
        setFileItems(nextFiles);
        track("jpg_pdf_file_select", {
          ...fileTools.safeFileAnalyticsPayload(toFiles())
        });
      });

      pageSizeSelect.addEventListener("change", () => {
        clearPdfUrl();
        updatePreflight();
      });
      marginSelect.addEventListener("change", () => {
        clearPdfUrl();
        updatePreflight();
      });

      sampleButton.addEventListener("click", async () => {
        setFileItems([
          await sampleFile("document-scan", "#117a7a", 1200, 1600),
          await sampleFile("receipt-photo", "#b54708", 1200, 900)
        ]);
        input.value = "";
        track("jpg_pdf_sample_apply", { file_count: fileItems.length });
      });

      resetButton.addEventListener("click", () => {
        setFileItems([]);
        input.value = "";
        track("jpg_pdf_reset");
      });

      fileList.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const moveButton = target?.closest("[data-move-file]");
        if (moveButton) {
          moveFile(Number(moveButton.dataset.moveFile), moveButton.dataset.direction);
          return;
        }

        const removeButton = target?.closest("[data-remove-file]");
        if (removeButton) removeFile(Number(removeButton.dataset.removeFile));
      });

      fileList.addEventListener("dragstart", (event) => {
        const row = fileRowFromEvent(event);
        if (!row || !event.dataTransfer) return;
        dragSourceIndex = Number(row.dataset.fileIndex);
        row.classList.add("is-dragging");
        event.dataTransfer.effectAllowed = "move";
        event.dataTransfer.setData("text/plain", String(dragSourceIndex));
      });

      fileList.addEventListener("dragover", (event) => {
        const row = fileRowFromEvent(event);
        if (!row || dragSourceIndex < 0 || !event.dataTransfer) return;
        event.preventDefault();
        event.dataTransfer.dropEffect = "move";
        fileList.querySelectorAll(".is-drag-over").forEach((item) => {
          if (item !== row) item.classList.remove("is-drag-over");
        });
        row.classList.add("is-drag-over");
      });

      fileList.addEventListener("dragleave", (event) => {
        const row = fileRowFromEvent(event);
        const relatedTarget = event.relatedTarget instanceof Node ? event.relatedTarget : null;
        if (row && !row.contains(relatedTarget)) row.classList.remove("is-drag-over");
      });

      fileList.addEventListener("drop", (event) => {
        const row = fileRowFromEvent(event);
        if (!row || dragSourceIndex < 0) return;
        event.preventDefault();
        const targetIndex = Number(row.dataset.fileIndex);
        reorderFile(dragSourceIndex, targetIndex, "drag");
        dragSourceIndex = -1;
        clearDragState();
      });

      fileList.addEventListener("dragend", () => {
        dragSourceIndex = -1;
        clearDragState();
      });

      generateButton.addEventListener("click", generatePdf);

      downloadLink.addEventListener("click", (event) => {
        if (!pdfUrl) {
          event.preventDefault();
          return;
        }
        track("jpg_pdf_download", {
          file_count: fileItems.length,
          output_size: outputBytes,
          page_size: pageSizeSelect.value,
          margin: marginSelect.value
        });
      });

      window.addEventListener("pagehide", () => {
        releaseItems();
        clearPdfUrl();
      });

      renderFiles();
    }
  </script>
</BaseLayout>

