---
import BaseLayout from "@/layouts/BaseLayout.astro";
import IconGlyph from "@/components/IconGlyph.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema, webPageSchema } from "@/data/seo";

const tool = getTool("receipt");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  webPageSchema({
    name: tool.title,
    description: tool.metaDescription,
    path: tool.path,
    keywords: [
      tool.primaryQuery,
      ...tool.secondaryQueries,
      "영수증 무료 양식",
      "간이영수증 무료 양식",
      "영수증 PDF 저장"
    ]
  }),
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main
    class="page-shell"
    data-document-tool
    data-tool-id={tool.id}
    data-tool-title={tool.title}
    data-document-title="영수증"
    data-receiver-label="구매자"
    data-sample-supplier="오늘문구점"
    data-sample-supplier-meta="123-45-67890 · 서울시 중구"
    data-sample-receiver="홍길동"
    data-sample-note="결제수단: 계좌이체"
    data-sample-item-name="사무용품"
    data-sample-item-desc="A4 용지 및 필기구"
    data-sample-item-qty="1"
    data-sample-item-price="32000"
  >
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>구매자, 품목, 금액을 입력하면 영수증을 바로 만들고 인쇄하거나 PDF로 저장할 수 있습니다.</p>
        <div class="tool-trust-badges" data-receipt-trust-badges aria-label="주요 장점">
          <span>무료</span>
          <span>설치 없음</span>
          <span>입력값 저장 안 함</span>
          <span>PDF 저장</span>
        </div>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="workspace">
      <form class="panel" aria-label="영수증 입력">
        <div class="panel-title">
          <h2>영수증 정보</h2>
        </div>
        <div class="field-grid">
          <label class="field">
            <span>공급자</span>
            <input data-supplier value="오늘문구점" />
          </label>
          <label class="field">
            <span>사업자번호 / 주소</span>
            <input data-supplier-meta value="123-45-67890 · 서울시 중구" />
          </label>
          <label class="field">
            <span>구매자</span>
            <input data-receiver value="홍길동" required />
          </label>
          <label class="field">
            <span>거래일</span>
            <input data-date type="date" />
          </label>
          <label class="field">
            <span>부가세</span>
            <select data-vat-mode>
              <option value="included">포함</option>
              <option value="separate">별도</option>
              <option value="none">없음</option>
            </select>
          </label>
          <label class="field">
            <span>비고</span>
            <textarea data-note>결제수단: 계좌이체</textarea>
          </label>
        </div>

        <div class="items-editor">
          <div class="panel-title">
            <h3>품목</h3>
            <button class="btn" type="button" data-add-row>
              <IconGlyph name="plus" aria-hidden="true" />
              추가
            </button>
          </div>
          <div data-rows>
            <div class="item-row" data-row>
              <label class="field">
                <span>품목</span>
                <input data-item-name value="사무용품" />
              </label>
              <label class="field">
                <span>설명</span>
                <input data-item-desc value="A4 용지 및 필기구" />
              </label>
              <label class="field compact">
                <span>수량</span>
                <input data-item-qty inputmode="decimal" value="1" />
              </label>
              <label class="field compact">
                <span>단가</span>
                <input data-item-price inputmode="numeric" value="32000" />
              </label>
              <button class="btn row-remove" type="button" data-remove-row aria-label="품목 삭제">
                <IconGlyph name="x" aria-hidden="true" />
              </button>
            </div>
          </div>
        </div>

        <div class="button-row">
          <button class="btn" type="button" data-sample>
            <IconGlyph name="plus" aria-hidden="true" />
            샘플
          </button>
          <button class="btn" type="button" data-reset>
            <IconGlyph name="refresh" aria-hidden="true" />
            초기화
          </button>
          <button class="btn primary" type="button" data-print>
            <IconGlyph name="printer" aria-hidden="true" />
            인쇄/PDF
          </button>
        </div>
      </form>

      <section class="preview-panel" aria-label="영수증 미리보기">
        <div class="doc-page" data-document-preview></div>
      </section>

      <aside class="side-panel">
        <div class="panel-title">
          <h3>확인 사항</h3>
        </div>
        <ul class="status-list">
          <li><span class="status-dot"></span><span>세금계산서, 현금영수증, 카드 매출전표 발행을 대신하지 않습니다.</span></li>
          <li><span class="status-dot"></span><span>정산용 메모가 필요하면 비고에 결제수단과 입금일을 적어두세요.</span></li>
          <li><span class="status-dot"></span><span>입력한 구매자 정보는 서버로 보내지 않습니다.</span></li>
        </ul>
      </aside>
    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>공급자와 구매자 정보를 입력합니다.</li>
        <li>품목, 수량, 단가를 입력하고 부가세 방식을 선택합니다.</li>
        <li>미리보기를 확인한 뒤 인쇄하거나 PDF로 저장합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>
  <script is:inline src="/scripts/document-tool.js"></script>
</BaseLayout>

<style>
  .items-editor {
    margin-top: 18px;
  }

  .item-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    align-items: end;
    margin-bottom: 8px;
  }

  .row-remove {
    width: 42px;
    grid-column: 2;
    justify-self: end;
    padding-inline: 0;
  }

  .line-table {
    margin-top: 22px;
  }

  .document-note {
    border-top: 1px solid #cad6df;
    color: #344457;
    margin-top: 24px;
    padding-top: 14px;
    white-space: pre-wrap;
  }

  .tool-trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-top: 12px;
  }

  .tool-trust-badges span {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    border: 1px solid #d0d5dd;
    border-radius: 999px;
    background: #fff;
    color: #344054;
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    padding: 8px 12px;
    white-space: nowrap;
  }
</style>
