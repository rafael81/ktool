---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getRelatedTools, getTool } from "@/data/tools";
import { faqPageSchema, softwareApplicationSchema, webPageSchema } from "@/data/seo";
import {
  Check,
  Circle,
  Download,
  FileOutput,
  FolderOpen,
  Image as ImageIcon,
  PenLine,
  Plus,
  RefreshCw,
  RotateCcw,
  RotateCw,
  Type,
  X
} from "@lucide/astro";

const tool = getTool("pdf-edit");
const relatedTools = getRelatedTools(tool);
const structuredData = [
  webPageSchema({
    name: tool.title,
    description: tool.metaDescription,
    path: tool.path,
    keywords: [tool.primaryQuery, ...tool.secondaryQueries, "PDF 서명 무료", "PDF 도장 넣기", "PDF 텍스트 추가"]
  }),
  softwareApplicationSchema(tool, tool.featureList),
  faqPageSchema(tool.faqs)
];
---

<BaseLayout
  title={tool.pageTitle}
  description={tool.metaDescription}
  canonicalPath={tool.path}
  structuredData={structuredData}
>
  <main class="page-shell file-tool-shell" data-tool-id={tool.id} data-tool-title={tool.title}>
    <section class="tool-intro">
      <div>
        <h1>{tool.title}</h1>
        <p>PDF 위에 텍스트, 체크, 서명, 도장 이미지를 올리고 새 PDF로 저장하세요.</p>
      </div>
      <div class="quick-links">
        {
          relatedTools.map((item) => (
            <a
              href={item.path}
              data-analytics-event="tool_quick_link_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.shortTitle}
            >
              {item.shortTitle}
            </a>
          ))
        }
      </div>
    </section>

    <section class="pdf-edit-workspace" data-pdf-edit-tool>
      <form class="panel pdf-edit-panel pdf-upload-panel" aria-label="PDF 간편 편집 입력">
        <label class="pdf-dropzone upload-dropzone file-control" data-upload-zone>
          <input data-pdf-input type="file" accept="application/pdf,.pdf" />
          <span class="pdf-upload-icon" aria-hidden="true">
            <FolderOpen aria-hidden="true" />
          </span>
          <strong>편집할 PDF를 선택하세요</strong>
          <span data-file-label>PDF 1개 선택 · 미리보기에서 원하는 위치를 클릭</span>
          <span class="pdf-dropzone-badges" data-upload-badges aria-label="주요 장점">
            <span>무료</span>
            <span>설치 없음</span>
            <span>서버 전송 없음</span>
          </span>
          <em>PDF 선택</em>
          <small>최대 80MB · 암호 없는 PDF 지원</small>
        </label>

        <div class="tool-mode-card" aria-label="편집 도구">
          <div class="panel-title">
            <h2>도구</h2>
            <span class="format-badge" data-page-count-badge>0쪽</span>
          </div>
          <div class="mode-grid">
            <button class="mode-button is-active" type="button" data-tool-mode="text">
              <Type aria-hidden="true" />
              텍스트
            </button>
            <button class="mode-button" type="button" data-tool-mode="check">
              <Check aria-hidden="true" />
              체크
            </button>
            <button class="mode-button" type="button" data-tool-mode="cross">
              <X aria-hidden="true" />
              엑스
            </button>
            <button class="mode-button" type="button" data-tool-mode="circle">
              <Circle aria-hidden="true" />
              원형
            </button>
            <button class="mode-button" type="button" data-tool-mode="signature">
              <PenLine aria-hidden="true" />
              서명
            </button>
            <button class="mode-button" type="button" data-tool-mode="image">
              <ImageIcon aria-hidden="true" />
              도장/이미지
            </button>
          </div>
        </div>

        <div class="field-grid two-columns">
          <label class="field">
            <span>텍스트</span>
            <input data-text-input type="text" value="확인했습니다" maxlength="40" />
          </label>
          <label class="field">
            <span>크기</span>
            <select data-size-select>
              <option value="small">작게</option>
              <option value="medium" selected>보통</option>
              <option value="large">크게</option>
            </select>
          </label>
        </div>

        <div class="signature-card">
          <div>
            <strong>서명</strong>
            <span>마우스나 터치로 그리고 미리보기에서 위치를 클릭하세요.</span>
          </div>
          <canvas data-signature-pad width="360" height="120" aria-label="서명 그리기"></canvas>
          <div class="button-row compact">
            <button class="btn" type="button" data-signature-sample>
              <PenLine aria-hidden="true" />
              샘플 서명
            </button>
            <button class="btn" type="button" data-signature-clear>서명 지우기</button>
          </div>
        </div>

        <label class="field">
          <span>도장/이미지</span>
          <span class="mini-file-control">
            <input data-stamp-input type="file" accept="image/png,image/jpeg,image/webp" />
            <span data-stamp-label>PNG/JPG/WebP 선택 또는 샘플 도장 사용</span>
          </span>
        </label>
        <button class="btn" type="button" data-stamp-sample>
          <Plus aria-hidden="true" />
          샘플 도장
        </button>

        <div class="button-row pdf-action-row">
          <button class="btn" type="button" data-sample>
            <Plus aria-hidden="true" />
            샘플 PDF
          </button>
          <button class="btn" type="button" data-rotate-left disabled>
            <RotateCcw aria-hidden="true" />
            좌회전
          </button>
          <button class="btn" type="button" data-rotate-right disabled>
            <RotateCw aria-hidden="true" />
            우회전
          </button>
          <button class="btn" type="button" data-reset>
            <RefreshCw aria-hidden="true" />
            초기화
          </button>
          <button class="btn primary" type="button" data-generate disabled>
            <FileOutput aria-hidden="true" />
            <span data-generate-label>PDF 저장 준비</span>
          </button>
        </div>
      </form>

      <section class="preview-panel pdf-editor-preview-panel" aria-label="PDF 편집 미리보기">
        <div class="panel-title">
          <h2>미리보기</h2>
          <span class="format-badge" data-page-badge>1 / 1</span>
        </div>

        <div class="page-controls">
          <button class="btn" type="button" data-prev-page disabled>이전</button>
          <strong data-page-label>PDF를 선택하세요</strong>
          <button class="btn" type="button" data-next-page disabled>다음</button>
        </div>

        <div class="pdf-stage" data-pdf-stage aria-live="polite">
          <p class="empty-state">PDF를 업로드하면 여기서 위치를 클릭할 수 있습니다.</p>
        </div>

        <div class="pdf-result-card">
          <span>상태</span>
          <strong data-output-status>PDF를 선택하면 편집할 수 있습니다.</strong>
          <p data-output-meta>텍스트, 체크, 서명, 도장을 추가한 뒤 PDF를 저장하세요.</p>
          <div class="download-action-strip" data-pdf-download-hint hidden>
            <strong>저장 준비 완료</strong>
            <span>PDF 저장을 눌러 편집 파일을 내려받으세요.</span>
          </div>
          <a
            class="btn primary disabled"
            href="#"
            download="k-document-edited.pdf"
            aria-disabled="true"
            data-download
          >
            <Download aria-hidden="true" />
            PDF 저장
          </a>
        </div>

        <div class="annotation-list" data-annotation-list>
          <p class="empty-state">추가된 편집 요소가 없습니다.</p>
        </div>
      </section>
    </section>

    <section class="content-section">
      <h2>사용 방법</h2>
      <ol>
        <li>편집할 PDF를 선택합니다.</li>
        <li>텍스트, 체크, 원형, 서명, 도장/이미지 중 필요한 도구를 고릅니다.</li>
        <li>미리보기에서 넣을 위치를 클릭하고 PDF를 저장합니다.</li>
      </ol>
    </section>

    <section class="content-section">
      <h2>FAQ</h2>
      <div class="faq-list">
        {tool.faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <h2>관련 도구</h2>
        <p>{tool.userMoment}에 함께 쓰기 좋은 도구입니다.</p>
      </div>
      <div class="tool-grid">
        {
          relatedTools.map((item) => (
            <a
              class="tool-card"
              href={item.path}
              data-analytics-event="related_tool_click"
              data-analytics-tool-id={item.id}
              data-analytics-tool-title={item.title}
              data-analytics-label={item.title}
            >
              <span class="meta"><span class="meta-tag">{item.primaryQuery}</span></span>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline src="/scripts/file-tool-utils.js"></script>
  <script>
    // @ts-nocheck
    import pdfWorkerUrl from "pdfjs-dist/build/pdf.worker.mjs?url";

    const root = document.querySelector("[data-pdf-edit-tool]");
    if (root) {
      const fileTools = window.KdocFileTools;
      if (!fileTools) throw new Error("file_tool_utils_unavailable");

      const maxFileSize = 80 * 1024 * 1024;
      const maxPages = 80;
      const input = root.querySelector("[data-pdf-input]");
      const dropzone = root.querySelector("[data-upload-zone]");
      const fileLabel = root.querySelector("[data-file-label]");
      const pageCountBadge = root.querySelector("[data-page-count-badge]");
      const pageBadge = root.querySelector("[data-page-badge]");
      const pageLabel = root.querySelector("[data-page-label]");
      const stage = root.querySelector("[data-pdf-stage]");
      const textInput = root.querySelector("[data-text-input]");
      const sizeSelect = root.querySelector("[data-size-select]");
      const stampInput = root.querySelector("[data-stamp-input]");
      const stampLabel = root.querySelector("[data-stamp-label]");
      const signaturePad = root.querySelector("[data-signature-pad]");
      const signatureSampleButton = root.querySelector("[data-signature-sample]");
      const signatureClearButton = root.querySelector("[data-signature-clear]");
      const stampSampleButton = root.querySelector("[data-stamp-sample]");
      const sampleButton = root.querySelector("[data-sample]");
      const rotateLeftButton = root.querySelector("[data-rotate-left]");
      const rotateRightButton = root.querySelector("[data-rotate-right]");
      const prevButton = root.querySelector("[data-prev-page]");
      const nextButton = root.querySelector("[data-next-page]");
      const resetButton = root.querySelector("[data-reset]");
      const generateButton = root.querySelector("[data-generate]");
      const generateLabel = root.querySelector("[data-generate-label]");
      const outputStatus = root.querySelector("[data-output-status]");
      const outputMeta = root.querySelector("[data-output-meta]");
      const downloadHint = root.querySelector("[data-pdf-download-hint]");
      const downloadLink = root.querySelector("[data-download]");
      const annotationList = root.querySelector("[data-annotation-list]");
      const modeButtons = Array.from(root.querySelectorAll("[data-tool-mode]"));
      const formatter = new Intl.NumberFormat("ko-KR");

      let activeTool = "text";
      let fileItem = null;
      let sourceBytes = null;
      let pdfDocument = null;
      let pageCount = 0;
      let currentPageIndex = 0;
      let annotations = [];
      let rotations = [];
      let outputUrl = "";
      let outputBytes = 0;
      let nextAnnotationId = 1;
      let pdfLibPromise = null;
      let pdfJsPromise = null;
      let signatureDataUrl = "";
      let stampDataUrl = "";

      function track(eventName, params = {}) {
        window.kdocTrack?.(eventName, {
          tool_id: "pdf-edit",
          tool_title: "PDF 간편 편집(서명)",
          ...params
        });
      }

      function formatBytes(bytes) {
        return fileTools.formatBytes(bytes);
      }

      function setMessage(status, meta = "") {
        outputStatus.textContent = status;
        outputMeta.textContent = meta;
      }

      function clearOutput() {
        if (outputUrl) URL.revokeObjectURL(outputUrl);
        outputUrl = "";
        outputBytes = 0;
        downloadHint.hidden = true;
        downloadLink.href = "#";
        downloadLink.classList.add("disabled");
        downloadLink.setAttribute("aria-disabled", "true");
        downloadLink.dataset.outputSize = "";
        downloadLink.dataset.pageCount = "";
        downloadLink.dataset.annotationCount = "";
        downloadLink.dataset.rotatedPageCount = "";
      }

      async function loadPdfLib() {
        if (!pdfLibPromise) pdfLibPromise = import("pdf-lib");
        return pdfLibPromise;
      }

      async function loadPdfJs() {
        if (!pdfJsPromise) {
          pdfJsPromise = import("pdfjs-dist").then((pdfjs) => {
            pdfjs.GlobalWorkerOptions.workerSrc = pdfWorkerUrl;
            return pdfjs;
          });
        }
        return pdfJsPromise;
      }

      function safeFilePayload() {
        return fileItem ? fileTools.safeFileAnalyticsPayload([fileItem.file]) : { file_count: 0, total_size: 0, file_types: "" };
      }

      function validatePdf(file) {
        if (!file) return { ok: false, reason: "empty" };
        if (file.type && file.type !== "application/pdf") return { ok: false, reason: "unsupported_file_type" };
        if (!file.name.toLowerCase().endsWith(".pdf") && file.type !== "application/pdf") {
          return { ok: false, reason: "unsupported_file_type" };
        }
        if (file.size > maxFileSize) return { ok: false, reason: "file_too_large" };
        return { ok: true };
      }

      function validationMessage(reason) {
        if (reason === "unsupported_file_type") return "PDF 파일만 선택할 수 있습니다.";
        if (reason === "file_too_large") return "PDF는 80MB 이하만 사용할 수 있습니다.";
        if (reason === "too_many_pages") return "PDF는 최대 80쪽까지 편집할 수 있습니다.";
        if (reason === "missing_text") return "추가할 텍스트를 입력해 주세요.";
        if (reason === "missing_signature") return "서명을 먼저 그리거나 샘플 서명을 눌러 주세요.";
        if (reason === "missing_image") return "도장/이미지를 선택하거나 샘플 도장을 눌러 주세요.";
        return "편집할 PDF를 선택해 주세요.";
      }

      function setBusy(isBusy) {
        generateButton.disabled = isBusy || !canGenerate();
        generateLabel.textContent = isBusy ? "저장 준비 중" : "PDF 저장 준비";
        sampleButton.disabled = isBusy;
        resetButton.disabled = isBusy;
        rotateLeftButton.disabled = isBusy || !fileItem;
        rotateRightButton.disabled = isBusy || !fileItem;
      }

      function canGenerate() {
        return Boolean(fileItem) && (annotations.length > 0 || rotations.some((value) => value !== 0));
      }

      function syncButtons() {
        const hasFile = Boolean(fileItem);
        generateButton.disabled = !canGenerate();
        rotateLeftButton.disabled = !hasFile;
        rotateRightButton.disabled = !hasFile;
        prevButton.disabled = !hasFile || currentPageIndex <= 0;
        nextButton.disabled = !hasFile || currentPageIndex >= pageCount - 1;
        pageBadge.textContent = hasFile ? `${currentPageIndex + 1} / ${pageCount}` : "1 / 1";
        pageLabel.textContent = hasFile
          ? `${formatter.format(currentPageIndex + 1)}쪽 · 클릭해서 추가`
          : "PDF를 선택하세요";
      }

      function selectTool(toolName) {
        activeTool = toolName;
        for (const button of modeButtons) {
          button.classList.toggle("is-active", button.dataset.toolMode === toolName);
        }
        clearOutput();
        track("pdf_edit_tool_select", { edit_tool: activeTool });
      }

      function renderAnnotationList() {
        if (annotations.length === 0 && !rotations.some((value) => value !== 0)) {
          annotationList.innerHTML = '<p class="empty-state">추가된 편집 요소가 없습니다.</p>';
          return;
        }
        const rotationCount = rotations.filter((value) => value !== 0).length;
        const rows = annotations
          .map((annotation) => {
            const label = {
              text: "텍스트",
              check: "체크",
              cross: "엑스",
              circle: "원형",
              signature: "서명",
              image: "도장/이미지"
            }[annotation.type] || annotation.type;
            return `<div class="annotation-row" data-annotation-row="${annotation.id}">
              <span>${annotation.pageIndex + 1}쪽 · ${label}</span>
              <button type="button" data-remove-annotation="${annotation.id}">삭제</button>
            </div>`;
          })
          .join("");
        annotationList.innerHTML = `${rotationCount ? `<div class="annotation-row"><span>회전 적용 ${rotationCount}쪽</span></div>` : ""}${rows}`;
      }

      function drawOverlayMarkers() {
        const overlay = stage.querySelector("[data-annotation-overlay]");
        if (!overlay) return;
        overlay.innerHTML = annotations
          .filter((annotation) => annotation.pageIndex === currentPageIndex)
          .map((annotation) => {
            const label = {
              text: "T",
              check: "✓",
              cross: "×",
              circle: "○",
              signature: "서명",
              image: "이미지"
            }[annotation.type] || "";
            return `<button class="annotation-marker marker-${annotation.type}" type="button" style="left:${annotation.xPct * 100}%;top:${annotation.yPct * 100}%;" data-marker-id="${annotation.id}" aria-label="추가된 ${label}">${label}</button>`;
          })
          .join("");
      }

      async function renderCurrentPage() {
        if (!pdfDocument || !fileItem) {
          stage.innerHTML = '<p class="empty-state">PDF를 업로드하면 여기서 위치를 클릭할 수 있습니다.</p>';
          syncButtons();
          return;
        }

        const page = await pdfDocument.getPage(currentPageIndex + 1);
        const rotation = (((page.rotate || 0) + rotations[currentPageIndex]) % 360 + 360) % 360;
        const baseViewport = page.getViewport({ scale: 1, rotation });
        const fitScale = Math.min(1.35, Math.max(0.45, Math.min(760 / baseViewport.width, 900 / baseViewport.height)));
        const viewport = page.getViewport({ scale: fitScale, rotation });
        const canvas = document.createElement("canvas");
        canvas.width = Math.ceil(viewport.width);
        canvas.height = Math.ceil(viewport.height);
        const context = canvas.getContext("2d", { alpha: false });
        if (!context) throw new Error("canvas_context_unavailable");
        context.fillStyle = "#ffffff";
        context.fillRect(0, 0, canvas.width, canvas.height);
        await page.render({ canvasContext: context, viewport }).promise;
        page.cleanup?.();

        stage.innerHTML = '<div class="canvas-wrap" data-canvas-wrap><div class="annotation-overlay" data-annotation-overlay></div></div>';
        const wrap = stage.querySelector("[data-canvas-wrap]");
        wrap.prepend(canvas);
        drawOverlayMarkers();
        syncButtons();
      }

      async function loadPdfDocumentFromBytes() {
        const pdfjs = await loadPdfJs();
        if (pdfDocument) {
          try {
            await pdfDocument.destroy?.();
          } catch {}
        }
        pdfDocument = await pdfjs.getDocument({
          data: new Uint8Array(sourceBytes),
          stopAtErrors: true
        }).promise;
      }

      async function inspectPdf(file, method = "picker") {
        setBusy(true);
        setMessage("PDF 읽는 중", "페이지를 미리보기로 준비하고 있습니다.");
        try {
          sourceBytes = new Uint8Array(await file.arrayBuffer());
          await loadPdfDocumentFromBytes();
          pageCount = pdfDocument.numPages;
          if (pageCount > maxPages) throw new Error("too_many_pages");
          rotations = Array.from({ length: pageCount }, () => 0);
          currentPageIndex = 0;
          fileLabel.textContent = `${formatter.format(pageCount)}쪽 PDF 선택`;
          pageCountBadge.textContent = `${formatter.format(pageCount)}쪽`;
          setMessage("PDF 준비됨", "도구를 고르고 미리보기에서 위치를 클릭하세요.");
          track("pdf_edit_file_select", {
            method,
            ...fileTools.safeFileAnalyticsPayload([file]),
            page_count: pageCount
          });
          await renderCurrentPage();
        } catch (error) {
          const reason = error?.message === "too_many_pages" ? "too_many_pages" : error?.message || "pdf_read_failed";
          resetState(false);
          setMessage(validationMessage(reason), "암호가 있거나 손상된 PDF인지 확인해 주세요.");
          track("pdf_edit_validation_error", { reason });
        } finally {
          setBusy(false);
        }
      }

      function setFile(file, method = "picker") {
        const validation = validatePdf(file);
        if (!validation.ok) {
          resetState(false);
          setMessage(validationMessage(validation.reason), "파일을 다시 선택해 주세요.");
          track("pdf_edit_validation_error", { reason: validation.reason, ...fileTools.safeFileAnalyticsPayload(file ? [file] : []) });
          return;
        }
        clearOutput();
        if (fileItem?.previewUrl) URL.revokeObjectURL(fileItem.previewUrl);
        fileItem = fileTools.createFileItems([file], () => 1)[0];
        annotations = [];
        inspectPdf(file, method);
      }

      function handleFiles(files, method = "picker") {
        setFile(files[0], method);
      }

      async function createSamplePdf() {
        const { PDFDocument, StandardFonts, rgb } = await loadPdfLib();
        const pdfDoc = await PDFDocument.create();
        const titleFont = await pdfDoc.embedFont(StandardFonts.HelveticaBold);
        const bodyFont = await pdfDoc.embedFont(StandardFonts.Helvetica);
        for (let index = 0; index < 2; index += 1) {
          const page = pdfDoc.addPage([595.28, 841.89]);
          page.drawRectangle({ x: 42, y: 42, width: 511, height: 758, borderColor: rgb(0.82, 0.86, 0.92), borderWidth: 2 });
          page.drawText(`PDF Edit Sample ${index + 1}`, { x: 74, y: 690, size: 30, font: titleFont, color: rgb(0.08, 0.13, 0.19) });
          page.drawText("Click the preview to add text, check marks, signatures, and stamp images.", {
            x: 74,
            y: 650,
            size: 12,
            font: bodyFont,
            color: rgb(0.38, 0.44, 0.52)
          });
          page.drawRectangle({ x: 74, y: 548, width: 210, height: 34, borderColor: rgb(0.66, 0.72, 0.82), borderWidth: 1 });
          page.drawText("Approval:", { x: 84, y: 559, size: 13, font: bodyFont, color: rgb(0.2, 0.25, 0.33) });
          page.drawRectangle({ x: 74, y: 486, width: 210, height: 34, borderColor: rgb(0.66, 0.72, 0.82), borderWidth: 1 });
          page.drawText("Signature:", { x: 84, y: 497, size: 13, font: bodyFont, color: rgb(0.2, 0.25, 0.33) });
        }
        const bytes = await pdfDoc.save();
        return new File([bytes], "pdf-edit-sample.pdf", { type: "application/pdf" });
      }

      function sizeScale() {
        return { small: 0.78, medium: 1, large: 1.28 }[sizeSelect.value] || 1;
      }

      function makeTextDataUrl(text) {
        const canvas = document.createElement("canvas");
        const context = canvas.getContext("2d");
        if (!context) throw new Error("canvas_context_unavailable");
        const scale = sizeScale();
        const fontSize = Math.round(30 * scale);
        context.font = `700 ${fontSize}px sans-serif`;
        const width = Math.ceil(context.measureText(text).width + 30);
        const height = Math.ceil(fontSize + 24);
        canvas.width = width;
        canvas.height = height;
        const nextContext = canvas.getContext("2d");
        nextContext.font = `700 ${fontSize}px sans-serif`;
        nextContext.textBaseline = "middle";
        nextContext.fillStyle = "#111827";
        nextContext.fillText(text, 15, height / 2);
        return {
          dataUrl: canvas.toDataURL("image/png"),
          widthPt: Math.min(320, width * 0.58),
          heightPt: height * 0.58
        };
      }

      function getSignatureDataUrl() {
        if (!signatureDataUrl) signatureDataUrl = signaturePad.toDataURL("image/png");
        return signatureDataUrl;
      }

      function makeSampleStampDataUrl() {
        const canvas = document.createElement("canvas");
        canvas.width = 240;
        canvas.height = 120;
        const context = canvas.getContext("2d");
        context.clearRect(0, 0, canvas.width, canvas.height);
        context.strokeStyle = "#dc2626";
        context.lineWidth = 8;
        context.beginPath();
        context.ellipse(120, 60, 92, 42, 0, 0, Math.PI * 2);
        context.stroke();
        context.fillStyle = "#dc2626";
        context.font = "800 32px sans-serif";
        context.textAlign = "center";
        context.textBaseline = "middle";
        context.fillText("K문서툴", 120, 60);
        return canvas.toDataURL("image/png");
      }

      async function fileToDataUrl(file) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(String(reader.result || ""));
          reader.onerror = () => reject(new Error("image_read_failed"));
          reader.readAsDataURL(file);
        });
      }

      function dataUrlToUint8Array(dataUrl) {
        const base64 = dataUrl.split(",")[1] || "";
        const binary = atob(base64);
        const bytes = new Uint8Array(binary.length);
        for (let index = 0; index < binary.length; index += 1) bytes[index] = binary.charCodeAt(index);
        return bytes;
      }

      function addAnnotationAt(xPct, yPct) {
        if (!fileItem) return;
        const base = {
          id: nextAnnotationId++,
          pageIndex: currentPageIndex,
          type: activeTool,
          xPct: Math.max(0, Math.min(1, xPct)),
          yPct: Math.max(0, Math.min(1, yPct)),
          size: sizeSelect.value
        };

        if (activeTool === "text") {
          const text = textInput.value.trim();
          if (!text) {
            setMessage(validationMessage("missing_text"), "텍스트를 입력한 뒤 미리보기를 클릭해 주세요.");
            track("pdf_edit_validation_error", { reason: "missing_text" });
            return;
          }
          const rendered = makeTextDataUrl(text);
          annotations.push({ ...base, text_length: text.length, imageDataUrl: rendered.dataUrl, widthPt: rendered.widthPt, heightPt: rendered.heightPt });
        } else if (activeTool === "signature") {
          const dataUrl = getSignatureDataUrl();
          if (!dataUrl || !signatureHasInk()) {
            setMessage(validationMessage("missing_signature"), "서명을 먼저 준비해 주세요.");
            track("pdf_edit_validation_error", { reason: "missing_signature" });
            return;
          }
          annotations.push({ ...base, imageDataUrl: dataUrl, widthPt: 150 * sizeScale(), heightPt: 50 * sizeScale() });
        } else if (activeTool === "image") {
          if (!stampDataUrl) {
            setMessage(validationMessage("missing_image"), "도장/이미지를 먼저 준비해 주세요.");
            track("pdf_edit_validation_error", { reason: "missing_image" });
            return;
          }
          annotations.push({ ...base, imageDataUrl: stampDataUrl, widthPt: 130 * sizeScale(), heightPt: 64 * sizeScale() });
        } else {
          annotations.push(base);
        }

        clearOutput();
        drawOverlayMarkers();
        renderAnnotationList();
        syncButtons();
        setMessage("편집 요소 추가됨", `${annotations.length}개 요소가 PDF에 적용됩니다.`);
        track("pdf_edit_annotation_add", {
          edit_tool: activeTool,
          page_number: currentPageIndex + 1,
          annotation_count: annotations.length,
          size: sizeSelect.value
        });
      }

      function signatureHasInk() {
        const context = signaturePad.getContext("2d");
        const pixels = context.getImageData(0, 0, signaturePad.width, signaturePad.height).data;
        for (let index = 3; index < pixels.length; index += 4) {
          if (pixels[index] > 0) return true;
        }
        return false;
      }

      function setupSignaturePad() {
        const context = signaturePad.getContext("2d");
        context.lineWidth = 4;
        context.lineCap = "round";
        context.lineJoin = "round";
        context.strokeStyle = "#111827";
        let drawing = false;
        function point(event) {
          const rect = signaturePad.getBoundingClientRect();
          return {
            x: ((event.clientX - rect.left) / rect.width) * signaturePad.width,
            y: ((event.clientY - rect.top) / rect.height) * signaturePad.height
          };
        }
        signaturePad.addEventListener("pointerdown", (event) => {
          drawing = true;
          signaturePad.setPointerCapture(event.pointerId);
          const start = point(event);
          context.beginPath();
          context.moveTo(start.x, start.y);
        });
        signaturePad.addEventListener("pointermove", (event) => {
          if (!drawing) return;
          const next = point(event);
          context.lineTo(next.x, next.y);
          context.stroke();
          signatureDataUrl = "";
        });
        signaturePad.addEventListener("pointerup", () => {
          drawing = false;
          signatureDataUrl = signaturePad.toDataURL("image/png");
        });
      }

      function drawSampleSignature() {
        const context = signaturePad.getContext("2d");
        context.clearRect(0, 0, signaturePad.width, signaturePad.height);
        context.strokeStyle = "#111827";
        context.lineWidth = 5;
        context.lineCap = "round";
        context.beginPath();
        context.moveTo(38, 76);
        context.bezierCurveTo(86, 28, 104, 104, 148, 56);
        context.bezierCurveTo(172, 30, 190, 86, 228, 48);
        context.bezierCurveTo(248, 30, 274, 62, 326, 46);
        context.stroke();
        signatureDataUrl = signaturePad.toDataURL("image/png");
        track("pdf_edit_signature_ready", { method: "sample" });
      }

      async function embedPngImage(pdfDoc, dataUrl) {
        return pdfDoc.embedPng(dataUrlToUint8Array(dataUrl));
      }

      async function applyAnnotationsToPage(pdfDoc, page, pageIndex, helpers) {
        const { rgb, degrees } = helpers;
        const pageWidth = page.getWidth();
        const pageHeight = page.getHeight();
        const pageAnnotations = annotations.filter((annotation) => annotation.pageIndex === pageIndex);

        for (const annotation of pageAnnotations) {
          const x = annotation.xPct * pageWidth;
          const y = pageHeight - annotation.yPct * pageHeight;
          const scale = { small: 0.78, medium: 1, large: 1.28 }[annotation.size] || 1;
          if (annotation.type === "check") {
            const size = 24 * scale;
            page.drawLine({ start: { x: x - size * 0.45, y: y - size * 0.02 }, end: { x: x - size * 0.12, y: y - size * 0.34 }, thickness: 4 * scale, color: rgb(0.06, 0.58, 0.31) });
            page.drawLine({ start: { x: x - size * 0.12, y: y - size * 0.34 }, end: { x: x + size * 0.52, y: y + size * 0.38 }, thickness: 4 * scale, color: rgb(0.06, 0.58, 0.31) });
          } else if (annotation.type === "cross") {
            const size = 24 * scale;
            page.drawLine({ start: { x: x - size / 2, y: y - size / 2 }, end: { x: x + size / 2, y: y + size / 2 }, thickness: 4 * scale, color: rgb(0.82, 0.1, 0.1) });
            page.drawLine({ start: { x: x - size / 2, y: y + size / 2 }, end: { x: x + size / 2, y: y - size / 2 }, thickness: 4 * scale, color: rgb(0.82, 0.1, 0.1) });
          } else if (annotation.type === "circle") {
            const size = 34 * scale;
            page.drawEllipse({ x, y, xScale: size * 0.58, yScale: size * 0.42, borderColor: rgb(0.08, 0.37, 0.94), borderWidth: 3 * scale });
          } else if (annotation.imageDataUrl) {
            const image = await embedPngImage(pdfDoc, annotation.imageDataUrl);
            const width = annotation.widthPt || Math.min(220, image.width * 0.4);
            const height = annotation.heightPt || (width * image.height) / image.width;
            page.drawImage(image, {
              x: x - width / 2,
              y: y - height / 2,
              width,
              height
            });
          }
        }

        const rotation = rotations[pageIndex] || 0;
        if (rotation) page.setRotation(degrees(rotation));
      }

      async function generatePdf() {
        if (!fileItem || !sourceBytes) {
          setMessage(validationMessage("empty"), "PDF를 다시 선택해 주세요.");
          track("pdf_edit_validation_error", { reason: "empty" });
          return;
        }
        if (!canGenerate()) {
          setMessage("추가된 편집 요소가 없습니다.", "미리보기에서 위치를 클릭하거나 페이지를 회전해 주세요.");
          track("pdf_edit_validation_error", { reason: "no_edit" });
          return;
        }

        clearOutput();
        setBusy(true);
        setMessage("PDF 저장 준비 중", "편집 요소를 PDF에 적용하고 있습니다.");

        try {
          const { PDFDocument, rgb, degrees } = await loadPdfLib();
          const pdfDoc = await PDFDocument.load(sourceBytes);
          const pages = pdfDoc.getPages();
          for (let index = 0; index < pages.length; index += 1) {
            await applyAnnotationsToPage(pdfDoc, pages[index], index, { rgb, degrees });
          }
          const bytes = await pdfDoc.save();
          const blob = new Blob([bytes], { type: "application/pdf" });
          outputBytes = blob.size;
          outputUrl = URL.createObjectURL(blob);
          downloadLink.href = outputUrl;
          downloadLink.classList.remove("disabled");
          downloadLink.removeAttribute("aria-disabled");
          downloadLink.dataset.outputSize = String(outputBytes);
          downloadLink.dataset.pageCount = String(pageCount);
          downloadLink.dataset.annotationCount = String(annotations.length);
          downloadLink.dataset.rotatedPageCount = String(rotations.filter((value) => value !== 0).length);
          downloadHint.hidden = false;
          setMessage("PDF 준비 완료", `${formatter.format(pageCount)}쪽 · ${formatBytes(outputBytes)} · 편집 ${annotations.length}개`);
          track("pdf_edit_generate", {
            ...safeFilePayload(),
            page_count: pageCount,
            annotation_count: annotations.length,
            rotated_page_count: rotations.filter((value) => value !== 0).length,
            output_size: outputBytes,
            edit_tools: [...new Set(annotations.map((annotation) => annotation.type))].join(",")
          });
        } catch (error) {
          clearOutput();
          setMessage("PDF를 저장하지 못했습니다.", "암호가 있거나 손상된 PDF인지 확인해 주세요.");
          track("pdf_edit_validation_error", { reason: error?.message || "pdf_edit_failed" });
        } finally {
          setBusy(false);
        }
      }

      function resetState(trackReset = true) {
        clearOutput();
        if (fileItem?.previewUrl) URL.revokeObjectURL(fileItem.previewUrl);
        fileItem = null;
        sourceBytes = null;
        annotations = [];
        rotations = [];
        pageCount = 0;
        currentPageIndex = 0;
        input.value = "";
        pageCountBadge.textContent = "0쪽";
        fileLabel.textContent = "PDF 1개 선택 · 미리보기에서 원하는 위치를 클릭";
        stage.innerHTML = '<p class="empty-state">PDF를 업로드하면 여기서 위치를 클릭할 수 있습니다.</p>';
        renderAnnotationList();
        setMessage("PDF를 선택하면 편집할 수 있습니다.", "텍스트, 체크, 서명, 도장을 추가한 뒤 PDF를 저장하세요.");
        syncButtons();
        if (trackReset) track("pdf_edit_reset");
      }

      input.addEventListener("change", (event) => {
        handleFiles(Array.from(event.target.files || []), "picker");
      });

      if (dropzone) {
        ["dragenter", "dragover"].forEach((eventName) => {
          dropzone.addEventListener(eventName, (event) => {
            event.preventDefault();
            dropzone.classList.add("is-drag-over");
          });
        });
        ["dragleave", "drop"].forEach((eventName) => {
          dropzone.addEventListener(eventName, () => dropzone.classList.remove("is-drag-over"));
        });
        dropzone.addEventListener("drop", (event) => {
          event.preventDefault();
          handleFiles(Array.from(event.dataTransfer?.files || []), "drop");
        });
      }

      modeButtons.forEach((button) => {
        button.addEventListener("click", () => selectTool(button.dataset.toolMode));
      });

      stage.addEventListener("click", (event) => {
        const canvas = stage.querySelector("canvas");
        if (!canvas || !fileItem) return;
        const rect = canvas.getBoundingClientRect();
        if (event.clientX < rect.left || event.clientX > rect.right || event.clientY < rect.top || event.clientY > rect.bottom) return;
        addAnnotationAt((event.clientX - rect.left) / rect.width, (event.clientY - rect.top) / rect.height);
      });

      annotationList.addEventListener("click", (event) => {
        const button = event.target.closest("[data-remove-annotation]");
        if (!button) return;
        const id = Number(button.dataset.removeAnnotation);
        annotations = annotations.filter((annotation) => annotation.id !== id);
        clearOutput();
        drawOverlayMarkers();
        renderAnnotationList();
        syncButtons();
        track("pdf_edit_annotation_remove", { annotation_count: annotations.length });
      });

      prevButton.addEventListener("click", () => {
        currentPageIndex = Math.max(0, currentPageIndex - 1);
        renderCurrentPage();
        track("pdf_edit_page_change", { page_number: currentPageIndex + 1 });
      });

      nextButton.addEventListener("click", () => {
        currentPageIndex = Math.min(pageCount - 1, currentPageIndex + 1);
        renderCurrentPage();
        track("pdf_edit_page_change", { page_number: currentPageIndex + 1 });
      });

      rotateLeftButton.addEventListener("click", () => {
        rotations[currentPageIndex] = ((rotations[currentPageIndex] || 0) - 90 + 360) % 360;
        clearOutput();
        renderCurrentPage();
        renderAnnotationList();
        syncButtons();
        track("pdf_edit_rotate", { page_number: currentPageIndex + 1, rotation: rotations[currentPageIndex] });
      });

      rotateRightButton.addEventListener("click", () => {
        rotations[currentPageIndex] = ((rotations[currentPageIndex] || 0) + 90) % 360;
        clearOutput();
        renderCurrentPage();
        renderAnnotationList();
        syncButtons();
        track("pdf_edit_rotate", { page_number: currentPageIndex + 1, rotation: rotations[currentPageIndex] });
      });

      sampleButton.addEventListener("click", async () => {
        setBusy(true);
        try {
          const file = await createSamplePdf();
          track("pdf_edit_sample_apply", { file_count: 1 });
          setFile(file, "sample");
        } catch (error) {
          setMessage("샘플 PDF를 만들지 못했습니다.", "잠시 후 다시 시도해 주세요.");
          track("pdf_edit_validation_error", { reason: error?.message || "sample_create_failed" });
        } finally {
          setBusy(false);
        }
      });

      signatureSampleButton.addEventListener("click", drawSampleSignature);
      signatureClearButton.addEventListener("click", () => {
        const context = signaturePad.getContext("2d");
        context.clearRect(0, 0, signaturePad.width, signaturePad.height);
        signatureDataUrl = "";
        track("pdf_edit_signature_ready", { method: "clear" });
      });

      stampSampleButton.addEventListener("click", () => {
        stampDataUrl = makeSampleStampDataUrl();
        stampLabel.textContent = "샘플 도장 준비됨";
        track("pdf_edit_stamp_select", { method: "sample", file_count: 1 });
      });

      stampInput.addEventListener("change", async (event) => {
        const file = Array.from(event.target.files || [])[0];
        const validation = fileTools.validateImageFiles(file ? [file] : [], {
          maxFiles: 1,
          maxFileSize: 8 * 1024 * 1024,
          maxTotalSize: 8 * 1024 * 1024
        });
        if (!validation.ok) {
          stampDataUrl = "";
          stampLabel.textContent = "PNG/JPG/WebP 선택 또는 샘플 도장 사용";
          track("pdf_edit_validation_error", { reason: validation.reason });
          return;
        }
        stampDataUrl = await fileToDataUrl(file);
        stampLabel.textContent = `${formatBytes(file.size)} 이미지 준비됨`;
        track("pdf_edit_stamp_select", {
          method: "picker",
          ...fileTools.safeFileAnalyticsPayload([file])
        });
      });

      [textInput, sizeSelect].forEach((control) => {
        control.addEventListener("change", () => {
          clearOutput();
          track("pdf_edit_option_change", {
            edit_tool: activeTool,
            size: sizeSelect.value,
            text_length: textInput.value.trim().length
          });
        });
      });

      generateButton.addEventListener("click", generatePdf);
      resetButton.addEventListener("click", () => resetState(true));
      downloadLink.addEventListener("click", (event) => {
        if (!outputUrl) {
          event.preventDefault();
          return;
        }
        track("pdf_edit_download", {
          page_count: pageCount,
          annotation_count: annotations.length,
          rotated_page_count: rotations.filter((value) => value !== 0).length,
          output_size: outputBytes
        });
      });

      setupSignaturePad();
      renderAnnotationList();
      syncButtons();
    }
  </script>
</BaseLayout>

<style>
