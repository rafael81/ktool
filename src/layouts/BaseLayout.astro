---
import { toolCategories, tools } from "@/data/tools";

type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const { title, description, canonicalPath = "/", robots, structuredData } = Astro.props;
function normalizePath(path: string) {
  const withSlash = path.startsWith("/") ? path : `/${path}`;
  return withSlash === "/" ? "/" : `${withSlash.replace(/\/+$/, "")}/`;
}

const normalizedCanonicalPath = normalizePath(canonicalPath);
const canonical = new URL(
  normalizedCanonicalPath,
  Astro.site ?? "https://k-document-tool.pages.dev"
).toString();
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const jsonLdItems = structuredDataItems.map((item) =>
  JSON.stringify(item).replaceAll("<", "\\u003c")
);
const analyticsPage = {
  path: normalizedCanonicalPath,
  title
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="icon" href="/favicon.svg" />
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token":"54ee976818264e5bbc947006b289846f"}'
    ></script>
    {
      jsonLdItems.map((jsonLd) => (
        <script is:inline type="application/ld+json" set:html={jsonLd}></script>
      ))
    }
    <script is:inline define:vars={{ analyticsPage }}>
      (() => {
        const page = analyticsPage;

        function toolContext(node) {
          const root = node?.closest?.("[data-tool-id]");
          if (!root) return {};
          return {
            tool_id: root.dataset.toolId || null,
            tool_title: root.dataset.toolTitle || null
          };
        }

        function compact(value) {
          return String(value || "").replace(/\s+/g, " ").trim();
        }

        window.dataLayer = window.dataLayer || [];
        window.kdocTrack = function kdocTrack(eventName, params = {}) {
          const payload = {
            event: eventName,
            page_path: page.path,
            page_title: page.title,
            event_time: new Date().toISOString(),
            ...params
          };
          window.dataLayer.push(payload);
          window.dispatchEvent(new CustomEvent("kdoc:analytics", { detail: payload }));
          return payload;
        };

        function bootAnalytics() {
          const pageTool = document.querySelector("[data-tool-id]");
          window.kdocTrack("page_view", toolContext(pageTool));

          const startedTools = new Set();
          const markToolStart = (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;
            const root = target.closest("[data-tool-id]");
            if (!root) return;
            const toolId = root.dataset.toolId;
            if (!toolId || startedTools.has(toolId)) return;
            startedTools.add(toolId);
            window.kdocTrack("tool_start", toolContext(root));
          };

          document.addEventListener("input", markToolStart, true);
          document.addEventListener("change", markToolStart, true);
          document.addEventListener(
            "click",
            (event) => {
              const target =
                event.target instanceof Element
                  ? event.target.closest("[data-analytics-event]")
                  : null;
              if (!target) return;

              const params = {
                ...toolContext(target),
                label: target.dataset.analyticsLabel || compact(target.textContent),
                href: target instanceof HTMLAnchorElement ? target.href : undefined
              };

              if (target.dataset.analyticsToolId) params.tool_id = target.dataset.analyticsToolId;
              if (target.dataset.analyticsToolTitle) {
                params.tool_title = target.dataset.analyticsToolTitle;
              }

              window.kdocTrack(target.dataset.analyticsEvent, params);
            },
            true
          );
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", bootAnalytics, { once: true });
        } else {
          bootAnalytics();
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="K문서툴 홈">
        <span class="brand-mark">K</span>
        <span>문서툴</span>
      </a>
      <nav class="top-nav" aria-label="주요 도구">
        <a
          href="/tools/"
          data-analytics-event="catalog_nav_click"
          data-analytics-label="전체 도구"
        >
          전체 도구
        </a>
        {
          toolCategories.map((category) => (
            <a
              href={category.path}
              data-analytics-event="category_nav_click"
              data-analytics-label={category.shortTitle}
            >
              {category.shortTitle}
            </a>
          ))
        }
        {
          tools.map((tool) => (
            <a
              href={tool.path}
              data-analytics-event="tool_nav_click"
              data-analytics-tool-id={tool.id}
              data-analytics-tool-title={tool.title}
              data-analytics-label={tool.shortTitle}
            >
              {tool.shortTitle}
            </a>
          ))
        }
      </nav>
    </header>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f9fb;
    --surface: #ffffff;
    --surface-muted: #f1f5f8;
    --ink: #14212f;
    --muted: #607080;
    --line: #dbe4ec;
    --accent: #117a7a;
    --accent-dark: #0b5f61;
    --danger: #b42318;
    --success: #0f766e;
    --shadow: 0 18px 44px rgba(20, 33, 47, 0.08);
    --radius: 8px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--ink);
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(180deg, #ffffff 0, var(--bg) 360px),
      var(--bg);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    min-width: 0;
    min-height: 64px;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.92);
    padding: 0 32px;
    backdrop-filter: blur(14px);
  }

  .brand {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 0;
  }

  .brand-mark {
    display: inline-grid;
    width: 30px;
    height: 30px;
    place-items: center;
    border-radius: 7px;
    background: var(--accent);
    color: #fff;
    font-size: 18px;
    font-weight: 900;
  }

  .top-nav {
    display: flex;
    flex: 1 1 auto;
    max-width: 100%;
    min-width: 0;
    align-items: center;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .top-nav::-webkit-scrollbar {
    display: none;
  }

  .top-nav a {
    flex: 0 0 auto;
    border-radius: 8px;
    color: var(--muted);
    font-size: 14px;
    font-weight: 700;
    padding: 10px 12px;
    white-space: nowrap;
  }

  .top-nav a:hover,
  .top-nav a:focus-visible {
    background: var(--surface-muted);
    color: var(--ink);
    outline: none;
  }

  .page-shell {
    width: min(1440px, 100%);
    margin: 0 auto;
    padding: 32px;
  }

  .tool-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
    margin-bottom: 24px;
  }

  .tool-intro h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.02;
    letter-spacing: 0;
  }

  .tool-intro p {
    max-width: 760px;
    margin: 14px 0 0;
    color: var(--muted);
    font-size: 18px;
    line-height: 1.65;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .quick-links a {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--muted);
    font-size: 14px;
    font-weight: 800;
    padding: 10px 12px;
  }

  .workspace {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr) minmax(240px, 300px);
    gap: 18px;
    align-items: start;
  }

  .panel,
  .preview-panel,
  .side-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .panel,
  .side-panel {
    padding: 18px;
  }

  .preview-panel {
    min-height: 620px;
    overflow: auto;
    padding: 22px;
  }

  .panel-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }

  .panel-title h2,
  .panel-title h3 {
    margin: 0;
    font-size: 16px;
    line-height: 1.2;
  }

  .field-grid {
    display: grid;
    gap: 12px;
  }

  .field {
    display: grid;
    gap: 6px;
  }

  .field span,
  .field label,
  .field legend {
    color: #344457;
    font-size: 13px;
    font-weight: 800;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--ink);
    font-size: 15px;
    line-height: 1.4;
    padding: 11px 12px;
  }

  textarea {
    min-height: 78px;
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(17, 122, 122, 0.13);
    outline: none;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .btn {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--ink);
    cursor: pointer;
    font-size: 14px;
    font-weight: 800;
    padding: 10px 12px;
  }

  .btn svg {
    width: 16px;
    height: 16px;
    stroke-width: 2;
  }

  .btn.primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .btn:hover {
    border-color: #aec0ce;
    background: var(--surface-muted);
  }

  .btn.primary:hover {
    border-color: var(--accent-dark);
    background: var(--accent-dark);
  }

  .doc-page {
    width: min(100%, 794px);
    min-height: 560px;
    margin: 0 auto;
    border: 1px solid #cad6df;
    background: #fff;
    color: #1a2531;
    box-shadow: 0 16px 38px rgba(20, 33, 47, 0.12);
  }

  .doc-inner {
    padding: clamp(20px, 4vw, 42px);
  }

  .doc-title {
    margin: 0 0 24px;
    text-align: center;
    font-size: clamp(26px, 4vw, 36px);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .doc-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .doc-table th,
  .doc-table td {
    border: 1px solid #8b9aaa;
    padding: 9px 10px;
    text-align: left;
    vertical-align: top;
  }

  .doc-table th {
    background: #f2f6f8;
    font-weight: 800;
  }

  .doc-table .total-korean-row th,
  .doc-table .total-korean-row td {
    background: #f8fbfc;
  }

  .doc-table .korean-total {
    color: var(--ink);
    font-weight: 900;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  .doc-table .right {
    text-align: right;
  }

  .note-box {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #f8fbfc;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
    padding: 12px;
  }

  .content-section {
    width: min(1120px, 100%);
    margin: 54px auto 0;
  }

  .content-section h2 {
    margin: 0 0 14px;
    font-size: 24px;
    letter-spacing: 0;
  }

  .content-section p,
  .content-section li {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.75;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
  }

  .section-heading h2 {
    margin: 0;
  }

  .section-heading p {
    max-width: 640px;
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .tool-card {
    display: grid;
    min-height: 210px;
    align-content: start;
    gap: 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 20px;
    box-shadow: var(--shadow);
  }

  .tool-card .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tool-card strong {
    color: var(--ink);
    font-size: 22px;
    line-height: 1.25;
  }

  .tool-card p {
    margin: 0;
  }

  .meta-tag {
    width: max-content;
    max-width: 100%;
    border-radius: 7px;
    background: #e8f4f2;
    color: var(--accent-dark);
    font-size: 13px;
    font-weight: 900;
    padding: 5px 8px;
  }

  .meta-tag.muted {
    background: var(--surface-muted);
    color: var(--muted);
  }

  .trust-note {
    border-left: 3px solid var(--accent);
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
    padding-left: 12px;
  }

  .faq-list {
    display: grid;
    gap: 10px;
  }

  details {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 14px 16px;
  }

  summary {
    cursor: pointer;
    color: var(--ink);
    font-weight: 800;
  }

  .status-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .status-list li {
    display: flex;
    gap: 9px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    flex: 0 0 auto;
    border-radius: 99px;
    background: var(--accent);
    margin-top: 7px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 1100px) {
    .workspace {
      grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    }

    .side-panel {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
      padding: 14px 18px;
      position: static;
    }

    .top-nav {
      width: 100%;
      padding-bottom: 2px;
    }

    .page-shell {
      padding: 22px 16px 34px;
    }

    .tool-intro {
      grid-template-columns: 1fr;
    }

    .quick-links {
      justify-content: flex-start;
    }

    .section-heading {
      align-items: start;
      flex-direction: column;
    }

    .tool-grid {
      grid-template-columns: 1fr;
    }

    .workspace {
      grid-template-columns: 1fr;
    }

    .preview-panel {
      min-height: 0;
      padding: 14px;
    }

    .doc-inner {
      padding: 18px;
    }

    .doc-table {
      font-size: 12px;
      min-width: 620px;
    }

    .doc-inner {
      overflow-x: auto;
    }

    .button-row {
      margin-top: 14px;
    }
  }

  @media print {
    .site-header,
    .tool-intro,
    .panel,
    .side-panel,
    .content-section,
    .button-row {
      display: none !important;
    }

    body {
      background: #fff;
    }

    .page-shell,
    .workspace,
    .preview-panel {
      display: block;
      margin: 0;
      padding: 0;
      width: 100%;
      border: 0;
      box-shadow: none;
    }

    .doc-page {
      width: 100%;
      min-height: auto;
      border: 0;
      box-shadow: none;
    }
  }
</style>
