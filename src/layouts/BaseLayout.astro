  .catalog-filter-group button[data-tool-filter]:not([data-tool-filter="all"]):hover,
  .catalog-filter-group button[data-tool-filter]:not([data-tool-filter="all"]):focus-visible,
  .catalog-filter-group button[data-tool-filter]:not([data-tool-filter="all"]).is-active,
  .home-filter-list button[data-home-category-filter]:not([data-home-category-filter="all"]):hover,
  .home-filter-list button[data-home-category-filter]:not([data-home-category-filter="all"]):focus-visible,
