  /* Taste-skill redesign: search-first utility surface. */
  .site-header {
    background: rgba(255, 255, 255, 0.96);
  }

  .site-header-inner {
    width: min(1180px, 100%);
    height: 62px;
    padding: 0 20px;
  }

  .brand-symbol {
    width: 40px;
    height: 40px;
    border-radius: 10px;
  }

  .brand-symbol-svg {
    width: 40px;
    height: 40px;
  }

  .top-nav {
    justify-content: flex-start;
  }

  .top-nav a,
  .site-search-link {
    border-radius: 6px;
    font-size: 13.5px;
  }

  .home-page {
    width: min(1180px, 100%);
    padding: 24px 20px 72px;
  }

  .home-start {
    display: grid;
    grid-template-columns: minmax(220px, 300px) minmax(0, 1fr);
    gap: 30px;
    align-items: start;
    border-bottom: 1px solid var(--line);
    padding: 28px 0 34px;
  }

  .home-start-copy {
    position: sticky;
    top: 90px;
    display: grid;
    gap: 10px;
    justify-items: center;
    min-width: 0;
    padding-top: 4px;
    text-align: center;
  }

  .home-hero-visual {
    display: grid;
    width: 236px;
    height: 168px;
    place-items: center;
    margin: -8px 0 0;
  }

  .home-hero-illust {
    width: 236px;
    height: auto;
    overflow: visible;
  }

  .home-hero-illust path,
  .home-hero-illust rect,
  .home-hero-illust circle,
  .home-hero-illust ellipse {
    vector-effect: non-scaling-stroke;
  }

  .hero-stage-shadow {
    fill: rgba(21, 94, 239, 0.12);
  }

  .hero-tool-panel,
  .hero-tool-strip,
  .hero-document-mascot {
    transform-box: fill-box;
    transform-origin: center;
  }

  .hero-tool-panel-left {
    animation: hero-panel-drift-left 4.4s ease-in-out infinite;
  }

  .hero-tool-panel-right {
    animation: hero-panel-drift-right 4.8s ease-in-out infinite;
  }

  .hero-tool-strip {
    animation: hero-strip-rise 4.6s ease-in-out infinite;
  }

  .hero-document-mascot {
    animation: hero-document-bob 3.4s ease-in-out infinite;
  }

  .hero-panel-surface {
    fill: rgba(255, 255, 255, 0.95);
    stroke: #e4e9f3;
    stroke-width: 1.5;
  }

  .hero-panel-chip,
  .hero-image-tile {
    fill: #155eef;
  }

  .hero-panel-line {
    fill: none;
    stroke: #c7cedd;
    stroke-linecap: round;
    stroke-width: 4;
  }

  .hero-mini-chart,
  .hero-image-mountain {
    fill: none;
    stroke: #ffffff;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 3;
  }

  .hero-convert-arrow,
  .hero-tool-icon,
  .hero-tool-icon-muted,
  .hero-smile,
  .hero-shield-check,
  .hero-arm,
  .hero-leg {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hero-convert-arrow,
  .hero-tool-icon {
    stroke: #155eef;
    stroke-width: 3;
  }

  .hero-tool-icon-muted {
    stroke: #8aa6e8;
    stroke-width: 3;
  }

  .hero-document-page {
    fill: #ffffff;
    stroke: #101828;
    stroke-linejoin: round;
    stroke-width: 4;
  }

  .hero-document-fold-fill {
    fill: #dfe9fb;
    stroke: none;
  }

  .hero-document-fold {
    fill: none;
    stroke: #101828;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 4;
  }

  .hero-eye {
    fill: #101828;
  }

  .hero-smile,
  .hero-arm,
  .hero-leg {
    stroke: #101828;
    stroke-width: 4;
  }

  .hero-arm-right {
    animation: hero-arm-wave 2.8s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: left bottom;
  }

  .hero-shield-base {
    fill: #155eef;
    stroke: #155eef;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .hero-shield-check {
    stroke: #ffffff;
    stroke-width: 3;
  }

  .hero-orbit-dot {
    fill: #155eef;
    opacity: 0.56;
    animation: hero-dot-pulse 3.2s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }

  .hero-orbit-dot-two {
    animation-delay: -1.5s;
  }

  @keyframes hero-document-bob {
    0%,
    100% {
      transform: translateY(0) rotate(-0.4deg);
    }

    50% {
      transform: translateY(-4px) rotate(0.4deg);
    }
  }

  @keyframes hero-panel-drift-left {
    0%,
    100% {
      transform: translateY(0) rotate(-1deg);
    }

    50% {
      transform: translateY(-4px) rotate(0.4deg);
    }
  }

  @keyframes hero-panel-drift-right {
    0%,
    100% {
      transform: translateY(0) rotate(0.6deg);
    }

    50% {
      transform: translateY(-5px) rotate(-0.8deg);
    }
  }

  @keyframes hero-strip-rise {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-6px);
    }
  }

  @keyframes hero-arm-wave {
    0%,
    100% {
      transform: rotate(0deg);
    }

    50% {
      transform: rotate(-8deg);
    }
  }

  @keyframes hero-dot-pulse {
    0%,
    100% {
      opacity: 0.34;
      transform: scale(0.86);
    }

    50% {
      opacity: 0.76;
      transform: scale(1.08);
    }
  }

  .home-start-copy h1 {
