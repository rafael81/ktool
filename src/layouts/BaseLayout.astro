---
import { toolCategories, tools, type ToolCategoryId } from "@/data/tools";
import { workflowPackages, type WorkflowPackageId } from "@/data/workflowPackages";
import { problemPages } from "@/data/problemPages";
import { Search } from "@lucide/astro";
import ToolFeedback from "@/components/ToolFeedback.astro";
import {
  FEEDBACK_CONTEXTS,
  FEEDBACK_MAX_COMMENT_LENGTH,
  FEEDBACK_RATINGS,
  FEEDBACK_REASONS
} from "../../shared/feedback-contract.mjs";
import { execFileSync } from "node:child_process";
import {
  RESULT_EVENT_TYPES,
  SESSION_IDLE_MS,
  SESSION_MAX_MS,
  TOOL_PATH_BY_ID
} from "../../shared/funnel-contract.mjs";

type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const { title, description, canonicalPath = "/", robots, structuredData } = Astro.props;
function normalizePath(path: string) {
  const withSlash = path.startsWith("/") ? path : `/${path}`;
  return withSlash === "/" ? "/" : `${withSlash.replace(/\/+$/, "")}/`;
}

const normalizedCanonicalPath = normalizePath(canonicalPath);
const currentTool = tools.find((tool) => normalizePath(tool.path) === normalizedCanonicalPath);
const currentWorkflowPackage = workflowPackages.find(
  (workflowPackage) => normalizePath(workflowPackage.path) === normalizedCanonicalPath
);
const currentProblemPage = problemPages.find(
  (problemPage) => normalizePath(problemPage.path) === normalizedCanonicalPath
);
const isProblemHub = normalizedCanonicalPath === "/problems/";
const workflowCategoryMap: Record<WorkflowPackageId, ToolCategoryId> = {
  "photo-scan-submission": "image",
  "business-document-submission": "business",
  "freelance-billing": "business"
};
const currentWorkflowCategory = currentWorkflowPackage
  ? workflowCategoryMap[currentWorkflowPackage.id]
  : undefined;
const primaryWorkflowPackage = workflowPackages[0];
function isActivePath(path: string) {
  return normalizePath(path) === normalizedCanonicalPath;
}
function isActiveCategory(categoryId: ToolCategoryId) {
  const shouldHighlightWorkflowCategory = currentWorkflowPackage?.id !== primaryWorkflowPackage.id;
  return (
    currentTool?.category === categoryId ||
    (shouldHighlightWorkflowCategory && currentWorkflowCategory === categoryId)
  );
}
const canonical = new URL(
  normalizedCanonicalPath,
  Astro.site ?? "https://k-document-tool.pages.dev"
).toString();
const socialImage = new URL("/images/k-document-tool-hero.png", Astro.site ?? "https://k-document-tool.pages.dev").toString();
const currentCategory = currentTool
  ? toolCategories.find((category) => category.id === currentTool.category)
  : toolCategories.find((category) => normalizePath(category.path) === normalizedCanonicalPath);
const siteRoot = Astro.site ?? "https://k-document-tool.pages.dev";
function absoluteSiteUrl(path: string) {
  return new URL(normalizePath(path), siteRoot).toString();
}
const breadcrumbEntries = [
  { name: "K문서툴", path: "/" },
  ...(normalizedCanonicalPath === "/privacy/" ? [{ name: "개인정보 처리", path: "/privacy/" }] : []),
  ...(normalizedCanonicalPath === "/tools/" ? [{ name: "전체 도구", path: "/tools/" }] : []),
  ...(isProblemHub ? [{ name: "문제별 해결", path: "/problems/" }] : []),
  ...(normalizedCanonicalPath.startsWith("/tools/") &&
  normalizedCanonicalPath !== "/tools/" &&
  !currentTool
    ? [
        { name: "전체 도구", path: "/tools/" },
        { name: title.split(" - ")[0], path: normalizedCanonicalPath }
      ]
    : []),
  ...(currentCategory && !currentTool
    ? [{ name: currentCategory.title, path: currentCategory.path }]
    : []),
  ...(currentTool
    ? [
        { name: "전체 도구", path: "/tools/" },
        ...(currentCategory ? [{ name: currentCategory.title, path: currentCategory.path }] : []),
        { name: currentTool.title, path: currentTool.path }
      ]
    : []),
  ...(currentWorkflowPackage
    ? [
        { name: "제출용 파일 준비", path: "/tools/submission-file-prep/" },
        { name: currentWorkflowPackage.title, path: currentWorkflowPackage.path }
      ]
    : []),
  ...(currentProblemPage
    ? [
        { name: "문제별 해결", path: "/problems/" },
        { name: currentProblemPage.title, path: currentProblemPage.path }
      ]
    : [])
].filter((entry, index, entries) => {
  return entries.findIndex((item) => normalizePath(item.path) === normalizePath(entry.path)) === index;
});
const breadcrumbSchema =
  breadcrumbEntries.length > 1
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbEntries.map((entry, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: entry.name,
          item: absoluteSiteUrl(entry.path)
        }))
      }
    : undefined;
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const jsonLdItems = [...structuredDataItems, ...(breadcrumbSchema ? [breadcrumbSchema] : [])].map((item) =>
  JSON.stringify(item).replaceAll("<", "\\u003c")
);
const analyticsPage = {
  path: normalizedCanonicalPath,
  title,
  sessionIdleMs: SESSION_IDLE_MS,
  problems: problemPages.map((problemPage) => ({
    id: problemPage.id,
    title: problemPage.title,
    path: problemPage.path
  }))
};
function resolveBuildId() {
  const environmentId = import.meta.env.PUBLIC_BUILD_ID || process.env.CF_PAGES_COMMIT_SHA;
  if (environmentId && /^[0-9a-f]{7,40}$/i.test(environmentId)) return environmentId.slice(0, 12);
  try {
    return execFileSync("git", ["rev-parse", "--short=12", "HEAD"], { encoding: "utf8" }).trim();
  } catch {
    return "local";
  }
}
const funnelConfig = {
  endpoint: "/api/funnel-event",
  feedbackEndpoint: "/api/tool-feedback",
  buildId: resolveBuildId(),
  toolPaths: TOOL_PATH_BY_ID,
  resultEvents: RESULT_EVENT_TYPES,
  feedbackRatings: FEEDBACK_RATINGS,
  feedbackReasons: FEEDBACK_REASONS,
  feedbackContexts: FEEDBACK_CONTEXTS,
  feedbackMaxCommentLength: FEEDBACK_MAX_COMMENT_LENGTH,
  sessionIdleMs: SESSION_IDLE_MS,
  sessionMaxMs: SESSION_MAX_MS
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1672" />
    <meta property="og:image:height" content="941" />
    <meta property="og:image:alt" content="설치 없이 사용하는 K문서툴의 문서와 이미지 도구" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="/favicon.svg" />
    <script is:inline>
      (() => {
        const localHosts = new Set(["localhost", "127.0.0.1", "::1"]);
        if (localHosts.has(window.location.hostname)) return;
        if (
          navigator.globalPrivacyControl === true ||
          navigator.doNotTrack === "1" ||
          window.doNotTrack === "1"
        ) return;
        const beacon = document.createElement("script");
        beacon.defer = true;
        beacon.src = "https://static.cloudflareinsights.com/beacon.min.js";
        beacon.dataset.cfBeacon = '{"token":"54ee976818264e5bbc947006b289846f"}';
        document.head.appendChild(beacon);
      })();
    </script>
    <script is:inline define:vars={{ funnelConfig }}>
      window.__KDOC_FUNNEL_CONFIG__ = funnelConfig;
    </script>
    <script is:inline src="/scripts/funnel-analytics.js"></script>
    {
      jsonLdItems.map((jsonLd) => (
        <script is:inline type="application/ld+json" set:html={jsonLd}></script>
      ))
    }
    <script is:inline define:vars={{ analyticsPage }}>
      (() => {
        const page = analyticsPage;
        const knownProblems = new Map((page.problems || []).map((problem) => [problem.id, problem]));
        const knownProblemIds = new Set(knownProblems.keys());

        function toolContext(node) {
          const root = node?.closest?.("[data-tool-id]");
          if (!root) return {};
          return {
            tool_id: root.dataset.toolId || null,
            tool_title: root.dataset.toolTitle || null
          };
        }

        function problemContext(node) {
          const root = node?.closest?.("[data-problem-id]");
          if (!root) return {};
          return {
            problem_id: root.dataset.problemId || null,
            problem_title: root.dataset.problemTitle || null
          };
        }

        function pageContext(node) {
          return {
            ...toolContext(node),
            ...problemContext(node)
          };
        }

        function compact(value) {
          return String(value || "").replace(/\s+/g, " ").trim();
        }

        function safePreset(value) {
          const text = compact(value);
          return /^[a-z0-9-]{1,40}$/i.test(text) ? text : null;
        }

        const blockedAnalyticsKeys = new Set([
          "address",
          "business_number",
          "business_registration_number",
          "buyer_name",
          "customer_name",
          "document_text",
          "email",
          "file_name",
          "file_names",
          "filename",
          "image_bytes",
          "ocr_text",
          "phone",
          "raw_image",
          "supplier_name"
        ]);
        const safeHrefParams = new Set(["from", "preset", "problem_id", "shortcut_id", "source"]);

        function normalizeAnalyticsKey(key) {
          return String(key || "")
            .replace(/([a-z0-9])([A-Z])/g, "$1_$2")
            .replace(/[^a-z0-9]+/gi, "_")
            .replace(/^_+|_+$/g, "")
            .toLowerCase();
        }

        function isSensitiveAnalyticsKey(key) {
          const normalized = normalizeAnalyticsKey(key);
          return (
            blockedAnalyticsKeys.has(normalized) ||
            normalized.endsWith("_address") ||
            normalized.endsWith("_email") ||
            normalized.endsWith("_file_name") ||
            normalized.endsWith("_filename") ||
            normalized.endsWith("_phone")
          );
        }

        function safeAnalyticsHref(value) {
          try {
            const url = new URL(String(value), window.location.href);
            if (!["http:", "https:"].includes(url.protocol)) return undefined;
            if (url.origin !== window.location.origin) return url.origin;
            const params = new URLSearchParams();
            url.searchParams.forEach((paramValue, key) => {
              if (!safeHrefParams.has(key)) return;
              const text = compact(paramValue);
              if (/^[a-z0-9-]{1,80}$/i.test(text)) params.set(key, text);
            });
            const query = params.toString();
            return `${url.pathname}${query ? `?${query}` : ""}`;
          } catch {
            return undefined;
          }
        }

        function safeAnalyticsValue(key, value) {
          if (value == null || isSensitiveAnalyticsKey(key)) return undefined;
          if (key === "href") return safeAnalyticsHref(value);
          if (typeof value === "string") return compact(value).slice(0, 160);
          if (typeof value === "number") return Number.isFinite(value) ? value : undefined;
          if (typeof value === "boolean") return value;
          if (Array.isArray(value)) {
            const items = value
              .slice(0, 20)
              .map((item) => {
                if (typeof item === "string") return compact(item).slice(0, 80);
                if (typeof item === "number") return Number.isFinite(item) ? item : undefined;
                if (typeof item === "boolean") return item;
                return undefined;
              })
              .filter((item) => item != null);
            return items.length ? items : undefined;
          }
          return undefined;
        }

        function safeAnalyticsParams(params) {
          return Object.fromEntries(
            Object.entries(params || {})
              .map(([key, value]) => [key, safeAnalyticsValue(key, value)])
              .filter(([, value]) => value !== undefined)
          );
        }

        function isTextEntryTarget(target) {
          if (!(target instanceof Element)) return false;
          const tagName = target.tagName.toLowerCase();
          return (
            tagName === "input" ||
            tagName === "textarea" ||
            tagName === "select" ||
            target.isContentEditable
          );
        }

        function focusHomeSearch() {
          const input = document.querySelector("[data-home-search-input]");
          if (input instanceof HTMLInputElement) {
            document.querySelector("#tool-search")?.scrollIntoView({ block: "start" });
            input.focus();
            input.select();
            return true;
          }
          return false;
        }

        function showProblemArrivalBanner(problem) {
          const banner = document.querySelector("[data-problem-arrival]");
          if (!banner || !problem) return;
          const title = banner.querySelector("[data-problem-arrival-title]");
          const link = banner.querySelector("[data-problem-arrival-link]");
          if (title) title.textContent = problem.title;
          if (link instanceof HTMLAnchorElement) {
            link.href = problem.path;
            link.dataset.analyticsTargetProblemId = problem.id;
            link.dataset.analyticsTargetProblemTitle = problem.title;
          }
          banner.hidden = false;
        }

        window.dataLayer = window.dataLayer || [];
        window.kdocTrack = function kdocTrack(eventName, params = {}) {
          const payload = {
            ...safeAnalyticsParams(params),
            event: eventName,
            page_path: page.path,
            page_title: page.title,
            event_time: new Date().toISOString()
          };
          window.dataLayer.push(payload);
          window.dispatchEvent(new CustomEvent("kdoc:analytics", { detail: payload }));
          return payload;
        };

        function bootAnalytics() {
          const pageContextRoot = document.querySelector("[data-tool-id], [data-problem-id]");
          window.kdocTrack("page_view", pageContext(pageContextRoot));

          const pageTool = document.querySelector("[data-tool-id]");
          const searchParams = new URLSearchParams(window.location.search);
          const source = searchParams.get("source");
          const problemId = searchParams.get("problem_id");
          if (pageTool && source === "problem" && knownProblemIds.has(problemId)) {
            const problem = knownProblems.get(problemId);
            const params = {
              ...toolContext(pageTool),
              source: "problem",
              problem_id: problemId,
              problem_title: problem.title
            };
            const preset = safePreset(searchParams.get("preset"));
            if (preset) params.target_preset = preset;
            window.kdocTrack("tool_problem_arrival", params);
            showProblemArrivalBanner(problem);
          }

          const startedTools = new Map();
          const markToolStart = (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;
            const root = target.closest("[data-tool-id]");
            if (!root) return;
            const toolId = root.dataset.toolId;
            const now = Date.now();
            const lastStartedAt = startedTools.get(toolId);
            if (!toolId || (lastStartedAt && now - lastStartedAt < page.sessionIdleMs)) return;
            startedTools.set(toolId, now);
            window.kdocTrack("tool_start", toolContext(root));
          };

          document.addEventListener("input", markToolStart, true);
          document.addEventListener("change", markToolStart, true);
          document.addEventListener(
            "click",
            (event) => {
              const target =
                event.target instanceof Element
                  ? event.target.closest("[data-analytics-event]")
                  : null;
              if (!target) return;

              const params = {
                ...pageContext(target),
                label: target.dataset.analyticsLabel || compact(target.textContent),
                href: target instanceof HTMLAnchorElement ? target.href : undefined
              };

              if (target.dataset.analyticsToolId) params.tool_id = target.dataset.analyticsToolId;
              if (target.dataset.analyticsToolTitle) {
                params.tool_title = target.dataset.analyticsToolTitle;
              }
              if (target.dataset.analyticsShortcutId) {
                params.shortcut_id = target.dataset.analyticsShortcutId;
              }
              if (target.dataset.analyticsTargetPreset) {
                params.target_preset = target.dataset.analyticsTargetPreset;
              }
              if (target.dataset.analyticsPackageId) {
                params.package_id = target.dataset.analyticsPackageId;
              }
              if (target.dataset.analyticsProblemId) {
                params.problem_id = target.dataset.analyticsProblemId;
              }
              if (target.dataset.analyticsTargetToolId) {
                params.target_tool_id = target.dataset.analyticsTargetToolId;
              }
              if (target.dataset.analyticsTargetToolTitle) {
                params.target_tool_title = target.dataset.analyticsTargetToolTitle;
              }
              if (target.dataset.analyticsTargetProblemId) {
                params.target_problem_id = target.dataset.analyticsTargetProblemId;
              }
              if (target.dataset.analyticsTargetProblemTitle) {
                params.target_problem_title = target.dataset.analyticsTargetProblemTitle;
              }

              window.kdocTrack(target.dataset.analyticsEvent, params);
            },
            true
          );

          document.querySelector(".site-search-link")?.addEventListener("click", (event) => {
            if (!focusHomeSearch()) return;
            event.preventDefault();
            window.history.pushState(null, "", "/#tool-search");
          });

          document.addEventListener("keydown", (event) => {
            if (event.defaultPrevented || isTextEntryTarget(event.target)) return;
            const opensSearch = event.key.toLowerCase() === "k" && (event.metaKey || event.ctrlKey);
            if (!opensSearch) return;
            event.preventDefault();
            window.kdocTrack("header_search_click", {
              label: "검색",
              href: "/#tool-search",
              trigger: "keyboard"
            });
            if (!focusHomeSearch()) {
              window.location.assign("/#tool-search");
            }
          });

          if (window.location.hash === "#tool-search") {
            window.requestAnimationFrame(() => focusHomeSearch());
          }
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", bootAnalytics, { once: true });
        } else {
          bootAnalytics();
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/" aria-label="K문서툴 홈">
          <span class="brand-symbol" aria-hidden="true">
            <svg class="brand-symbol-svg" viewBox="0 0 44 44" focusable="false">
              <rect class="brand-symbol-back" x="6" y="9" width="24" height="28" rx="9" />
              <path class="brand-symbol-page" d="M17 5h12l9 9v19a8 8 0 0 1-8 8H17a8 8 0 0 1-8-8V13a8 8 0 0 1 8-8Z" />
              <path class="brand-symbol-fold" d="M29 5v7a3 3 0 0 0 3 3h6" />
              <path class="brand-symbol-line" d="M17 21h14M17 27h9" />
              <path class="brand-symbol-shield" d="M24 23l7 2.4v6.1c0 4.6-2.9 7.7-7 9.5-4.1-1.8-7-4.9-7-9.5v-6.1l7-2.4Z" />
              <path class="brand-symbol-check" d="M21 31l2.2 2.2 4.4-5" />
              <circle class="brand-symbol-dot" cx="12" cy="12" r="2.4" />
            </svg>
          </span>
        </a>
        <nav class="top-nav" aria-label="주요 도구">
          <a
            href="/tools/"
            class:list={{ "is-active": isActivePath("/tools/") }}
            aria-current={isActivePath("/tools/") ? "page" : undefined}
            data-analytics-event="catalog_nav_click"
            data-analytics-label="전체 도구"
          >
            전체 도구
          </a>
          <a
            href="/problems/"
            class:list={{ "is-active": isProblemHub || Boolean(currentProblemPage) }}
            aria-current={isProblemHub || currentProblemPage ? "page" : undefined}
            data-analytics-event="problem_hub_nav_click"
            data-analytics-label="문제 해결"
          >
            문제 해결
          </a>
          {
            toolCategories.map((category) => (
              <a
                href={category.path}
                class:list={{
                  "is-active": isActivePath(category.path) || isActiveCategory(category.id)
                }}
                aria-current={
                  isActivePath(category.path) || isActiveCategory(category.id) ? "page" : undefined
                }
                data-analytics-event="category_nav_click"
                data-analytics-label={category.shortTitle}
              >
                {category.shortTitle}
              </a>
            ))
          }
        </nav>
        <div class="site-actions">
          <a
            class="site-search-link"
            href="/#tool-search"
            data-analytics-event="header_search_click"
            data-analytics-label="검색"
          >
            <Search class="site-search-icon" aria-hidden="true" />
            <span>검색</span>
            <kbd>⌘K</kbd>
          </a>
        </div>
      </div>
    </header>
    {
      currentTool && (
        <div class="arrival-context" data-problem-arrival hidden>
          <div class="arrival-context-inner">
            <strong>이어하기</strong>
            <span>
              <b data-problem-arrival-title></b>에서 왔어요. 설정을 확인하고 바로 처리하세요.
            </span>
            <a
              href="/tools/"
              data-problem-arrival-link
              data-analytics-event="problem_arrival_back_click"
              data-analytics-tool-id={currentTool.id}
              data-analytics-tool-title={currentTool.title}
              data-analytics-label="문제 보기"
            >
              문제 보기
            </a>
          </div>
        </div>
      )
    }
    <slot />
    {currentTool && <ToolFeedback tool={currentTool} />}
    <footer class="site-footer">
      <div class="site-footer-inner">
        <span>파일과 입력 내용은 브라우저 안에서 처리합니다.</span>
        <div class="site-footer-links">
          {
            currentTool && (
              <button type="button" class="site-footer-feedback" data-feedback-open={currentTool.id} hidden>
                의견 보내기
              </button>
            )
          }
          <a href="/privacy/">개인정보 처리</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f8fb;
    --surface: #ffffff;
    --surface-muted: #f4f6fa;
    --paper: #ffffff;
    --ink: #101828;
    --muted: #667085;
    --line: #d0d5dd;
    --line-dark: #18181b;
    --accent: #155eef;
    --accent-dark: #1248b6;
    --stamp: #b42318;
    --danger: #b42318;
    --success: #067647;
    --shadow: 0 12px 32px rgba(15, 23, 42, 0.07);
    --radius: 8px;
    --font-sans: Pretendard, -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Segoe UI", sans-serif;
    font-family: var(--font-sans);
  }

  [data-tool-category],
  [data-home-search-category],
  [data-home-category-section],
  [data-analytics-tool-id],
  [data-analytics-target-tool-id],
  [data-tool-filter],
  [data-home-category-filter] {
    --tool-accent: var(--accent);
    --tool-tint: #eff4ff;
    --tool-border: #c7d7fe;
    --tool-hover: #f8fbff;
  }

  [data-tool-category="business"],
  [data-home-search-category="business"],
  [data-home-category-section="business"],
  [data-tool-filter="business"],
  [data-analytics-tool-id="business-nameplate"],
  [data-analytics-tool-id="transaction-statement"],
  [data-analytics-tool-id="estimate"],
  [data-analytics-tool-id="receipt"],
  [data-analytics-tool-id="invoice"],
  [data-analytics-tool-id="vat-calculator"],
  [data-analytics-tool-id="amount-korean"],
  [data-analytics-tool-id="withholding-tax"],
  [data-analytics-tool-id="stamp-background"],
  [data-home-category-filter="business"],
  [data-analytics-target-tool-id="business-nameplate"],
  [data-analytics-target-tool-id="transaction-statement"],
  [data-analytics-target-tool-id="estimate"],
  [data-analytics-target-tool-id="receipt"],
  [data-analytics-target-tool-id="invoice"],
  [data-analytics-target-tool-id="vat-calculator"],
  [data-analytics-target-tool-id="amount-korean"],
  [data-analytics-target-tool-id="withholding-tax"],
  [data-analytics-target-tool-id="stamp-background"] {
    --tool-accent: #155eef;
  }

  [data-tool-category="pdf"],
  [data-home-search-category="pdf"],
  [data-home-category-section="pdf"],
  [data-tool-filter="pdf"],
  [data-analytics-tool-id="pdf-edit"],
  [data-analytics-tool-id="pdf-split-half"],
  [data-analytics-tool-id="pdf-two-up"],
  [data-analytics-tool-id="pdf-crop"],
  [data-analytics-tool-id="pdf-text-extract"],
  [data-analytics-tool-id="pdf-split"],
  [data-analytics-tool-id="pdf-delete-pages"],
  [data-analytics-tool-id="pdf-merge"],
  [data-analytics-tool-id="pdf-to-image"],
  [data-analytics-tool-id="jpg-to-pdf"],
  [data-home-category-filter="pdf"],
  [data-analytics-target-tool-id="pdf-edit"],
  [data-analytics-target-tool-id="pdf-split-half"],
  [data-analytics-target-tool-id="pdf-two-up"],
  [data-analytics-target-tool-id="pdf-crop"],
  [data-analytics-target-tool-id="pdf-text-extract"],
  [data-analytics-target-tool-id="pdf-split"],
  [data-analytics-target-tool-id="pdf-delete-pages"],
  [data-analytics-target-tool-id="pdf-merge"],
  [data-analytics-target-tool-id="pdf-to-image"],
  [data-analytics-target-tool-id="jpg-to-pdf"] {
    --tool-accent: #be123c;
  }

  [data-tool-category="image"],
  [data-home-search-category="image"],
  [data-home-category-section="image"],
  [data-tool-filter="image"],
  [data-analytics-tool-id="photo-date-stamp"],
  [data-analytics-tool-id="photo-merge"],
  [data-analytics-tool-id="image-compressor"],
  [data-analytics-tool-id="image-resizer"],
  [data-analytics-tool-id="image-cropper"],
  [data-analytics-tool-id="image-rotator"],
  [data-analytics-tool-id="image-converter"],
  [data-analytics-tool-id="svg-crop"],
  [data-analytics-tool-id="image-base64"],
  [data-analytics-tool-id="video-to-gif"],
  [data-analytics-tool-id="heic-to-jpg"],
  [data-home-category-filter="image"],
  [data-analytics-target-tool-id="photo-date-stamp"],
  [data-analytics-target-tool-id="photo-merge"],
  [data-analytics-target-tool-id="image-compressor"],
  [data-analytics-target-tool-id="image-resizer"],
  [data-analytics-target-tool-id="image-cropper"],
  [data-analytics-target-tool-id="image-rotator"],
  [data-analytics-target-tool-id="image-converter"],
  [data-analytics-target-tool-id="svg-crop"],
  [data-analytics-target-tool-id="image-base64"],
  [data-analytics-target-tool-id="video-to-gif"],
  [data-analytics-target-tool-id="heic-to-jpg"] {
    --tool-accent: #9a4708;
  }

  [data-tool-category],
  [data-home-search-category],
  [data-home-category-section],
  [data-analytics-tool-id],
  [data-analytics-target-tool-id],
  [data-tool-filter],
  [data-home-category-filter] {
    --tool-tint: color-mix(in srgb, var(--tool-accent) 9%, #ffffff);
    --tool-border: color-mix(in srgb, var(--tool-accent) 28%, #d0d5dd);
    --tool-hover: color-mix(in srgb, var(--tool-accent) 5%, #ffffff);
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--ink);
  }

  body {
    margin: 0;
    min-width: 320px;
    background: var(--bg);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(16px);
  }

  .site-header-inner {
    display: flex;
    width: min(1500px, 100%);
    min-width: 0;
    height: 64px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .brand {
    display: inline-flex;
    flex: 0 0 auto;
    min-height: 44px;
    align-items: center;
    color: var(--ink);
  }

  .brand-symbol {
    display: inline-grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: 13px;
    color: var(--line-dark);
  }

  .brand-symbol-svg {
    width: 42px;
    height: 42px;
    overflow: visible;
  }

  .brand-symbol-back {
    fill: #eff4ff;
    stroke: #bfd1ff;
    stroke-width: 1.5;
  }

  .brand-symbol-page {
    fill: #fff;
    stroke: #18181b;
    stroke-linejoin: round;
    stroke-width: 2.4;
  }

  .brand-symbol-fold,
  .brand-symbol-line {
    fill: none;
    stroke: #18181b;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.1;
  }

  .brand-symbol-line {
    stroke: #667085;
    stroke-width: 1.8;
  }

  .brand-symbol-shield {
    fill: #155eef;
    stroke: #18181b;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .brand-symbol-check {
    fill: none;
    stroke: #fff;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .brand-symbol-dot {
    fill: #f5b544;
    stroke: #18181b;
    stroke-width: 1.4;
  }

  .top-nav {
    display: flex;
    flex: 1 1 auto;
    max-width: 100%;
    min-width: 0;
    align-items: center;
    justify-content: center;
    gap: 2px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .top-nav::-webkit-scrollbar {
    display: none;
  }

  .top-nav a {
    display: inline-flex;
    flex: 0 0 auto;
    min-height: 44px;
    align-items: center;
    border-radius: 8px;
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 10px;
    white-space: nowrap;
  }

  .top-nav a:hover,
  .top-nav a:focus-visible,
  .top-nav a.is-active,
  .top-nav a[aria-current] {
    background: var(--surface-muted);
    color: var(--ink);
    outline: none;
  }

  .top-nav a.is-active,
  .top-nav a[aria-current] {
    background: #eff4ff;
    color: var(--accent-dark);
  }

  .site-actions {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: flex-end;
  }

  .site-search-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: #344054;
    font-size: 14px;
    font-weight: 400;
    padding: 8px 10px;
    white-space: nowrap;
  }

  .site-search-link:hover,
  .site-search-link:focus-visible {
    border-color: #98a2b3;
    color: var(--ink);
    outline: none;
  }

  .site-search-icon {
    width: 16px;
    height: 16px;
    color: currentColor;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .site-search-link kbd {
    border: 1px solid #d0d5dd;
    border-radius: 5px;
    background: #f9fafb;
    color: #667085;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 800;
    line-height: 1;
    padding: 4px 5px;
  }

  .arrival-context {
    border-bottom: 1px solid #c7d7fe;
    background: #eff4ff;
  }

  .arrival-context[hidden] {
    display: none;
  }

  .arrival-context-inner {
    display: flex;
    width: min(1180px, 100%);
    min-height: 46px;
    align-items: center;
    gap: 10px;
    margin: 0 auto;
    padding: 8px 34px;
    color: #344054;
    font-size: 13.5px;
    line-height: 1.45;
  }

  .arrival-context strong {
    flex: 0 0 auto;
    color: var(--accent-dark);
    font-weight: 900;
  }

  .arrival-context span {
    min-width: 0;
  }

  .arrival-context b {
    color: var(--ink);
    font-weight: 800;
  }

  .arrival-context a {
    flex: 0 0 auto;
    margin-left: auto;
    color: var(--accent-dark);
    font-weight: 900;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .page-shell {
    width: min(1180px, 100%);
    margin: 0 auto;
    padding: 34px;
  }

  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 760px);
    min-height: 0;
    gap: 24px;
    align-items: start;
    border-bottom: 2px solid var(--line-dark);
    padding: clamp(34px, 6vw, 76px) 0 34px;
  }

  .hero-copy {
    display: grid;
    max-width: 760px;
    gap: 18px;
    align-content: center;
  }

  .hero-copy h1 {
    max-width: 820px;
    margin: 0;
    color: var(--ink);
    font-size: 27px;
    font-weight: 800;
    letter-spacing: -0.6px;
    line-height: 1.6;
    word-break: keep-all;
  }

  .hero-copy p {
    max-width: 660px;
    margin: 0;
    color: var(--muted);
    font-size: 15.5px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-actions a {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    border: 2px solid var(--line-dark);
    border-radius: 4px;
    background: var(--line-dark);
    color: var(--paper);
    font-size: 15px;
    font-weight: 800;
    padding: 12px 16px;
  }

  .hero-actions a.secondary {
    background: transparent;
    color: var(--ink);
  }

  .hero-search {
    display: grid;
    max-width: 720px;
    gap: 10px;
    border: 2px solid var(--line-dark);
    background: var(--paper);
    padding: 14px;
    box-shadow: 6px 6px 0 rgba(22, 28, 31, 0.11);
  }

  .hero-search-field {
    display: grid;
    gap: 7px;
  }

  .hero-search-field span,
  .hero-search-meta,
  .hero-search-row span,
  .hero-search-row em {
    font-family: var(--font-sans);
  }

  .hero-search-field span {
    color: var(--accent-dark);
    font-size: 12px;
    font-weight: 800;
  }

  .hero-search-field input {
    min-height: 54px;
    border: 2px solid var(--line-dark);
    background: #fffefa;
    font-size: 15px;
    font-weight: 400;
  }

  .hero-search-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
  }

  .hero-search-meta a {
    color: var(--accent-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hero-search-results {
    display: grid;
    max-height: 300px;
    overflow: auto;
    border-top: 1px solid var(--line);
  }

  .hero-search-row {
    display: grid;
    grid-template-columns: 86px minmax(0, 1fr) minmax(120px, auto);
    gap: 12px;
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding: 11px 0;
  }

  .hero-search-row[hidden] {
    display: none;
  }

  .hero-search-row:hover strong,
  .hero-search-row:focus-visible strong {
    color: var(--accent-dark);
  }

  .hero-search-row:focus-visible {
    box-shadow: 0 0 0 3px rgba(11, 111, 105, 0.14);
    outline: none;
  }

  .hero-search-row span,
  .hero-search-row em {
    color: var(--accent-dark);
    font-size: 12px;
    font-style: normal;
    font-weight: 800;
  }

  .hero-search-row strong {
    color: var(--ink);
    font-size: 16px;
    line-height: 1.25;
  }

  .hero-search-row em {
    justify-self: end;
    border: 1px solid #cfe0dc;
    border-radius: 4px;
    padding: 5px 7px;
    white-space: nowrap;
  }

  .hero-search-empty {
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
    padding-top: 10px;
  }

  .hero-search-empty[hidden] {
    display: none;
  }

  .search-empty-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }

  .search-empty-actions[hidden] {
    display: none;
  }

  .search-empty-actions a {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: #fff;
    color: var(--ink);
    font-size: 13px;
    font-weight: 800;
    line-height: 1.2;
    padding: 8px 10px;
    white-space: nowrap;
  }

  .search-empty-actions a:hover,
  .search-empty-actions a:focus-visible {
    border-color: var(--accent);
    background: #eff8f6;
    color: var(--accent-dark);
    outline: none;
  }

  .home-tool-chip:hover span,
  .home-tool-chip:focus-visible span {
    color: var(--accent-dark);
  }

  .home-tool-chip:focus-visible {
    box-shadow: 0 0 0 3px rgba(11, 111, 105, 0.14);
    outline: none;
  }

  .home-tool-chip em {
    color: var(--accent-dark);
    font-family: var(--font-sans);
    font-size: 12px;
    font-style: normal;
    font-weight: 900;
  }

  .home-tool-groups {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    border-top: 2px solid var(--line-dark);
    padding-top: 18px;
  }

  .home-tool-group {
    display: grid;
    align-content: start;
    gap: 10px;
  }

  .home-tool-group h3 {
    margin: 0;
    color: var(--accent-dark);
    font-size: 15px;
    line-height: 1.2;
  }

  .home-tool-chip-list {
    display: grid;
    gap: 8px;
  }

  .home-tool-chip {
    display: grid;
    min-height: 44px;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    align-items: center;
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 10px 12px;
  }

  .home-tool-chip span {
    color: var(--ink);
    font-size: 15px;
    font-weight: 800;
    line-height: 1.25;
  }

  .hero-evidence {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    max-width: 640px;
  }

  .hero-evidence span {
    display: grid;
    gap: 3px;
    border-top: 2px solid var(--line-dark);
    padding-top: 9px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.45;
  }

  .hero-evidence strong {
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 15px;
  }

  .workbench {
    position: relative;
    min-height: 520px;
    border: 2px solid var(--line-dark);
    background: #ebe4d8;
    padding: 24px;
    box-shadow: 10px 10px 0 rgba(22, 28, 31, 0.13);
  }

  .queue-sheet {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 0;
    border: 2px solid var(--line-dark);
    background: var(--paper);
  }

  .queue-header,
  .queue-row {
    display: grid;
    grid-template-columns: 112px minmax(0, 1fr) 104px;
    gap: 14px;
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding: 15px 16px;
  }

  .queue-header {
    background: var(--line-dark);
    color: var(--paper);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .queue-row:last-child {
    border-bottom: 0;
  }

  .queue-row span:first-child,
  .queue-row span:last-child {
    color: var(--accent-dark);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
  }

  .queue-row strong {
    display: block;
    color: var(--ink);
    font-size: 19px;
    line-height: 1.35;
  }

  .queue-row em {
    display: block;
    margin-top: 4px;
    color: var(--muted);
    font-style: normal;
    font-size: 13px;
    line-height: 1.55;
  }

  .paper-note {
    position: absolute;
    right: 28px;
    bottom: 28px;
    width: min(250px, 42%);
    border: 2px solid var(--line-dark);
    background: #fff6dc;
    padding: 16px;
    transform: rotate(-1.7deg);
    box-shadow: 5px 5px 0 rgba(22, 28, 31, 0.12);
  }

  .paper-note strong {
    display: block;
    color: var(--stamp);
    font-family: var(--font-sans);
    font-size: 13px;
    margin-bottom: 8px;
  }

  .paper-note span {
    color: var(--ink);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.55;
  }

  .desk-ruler {
    position: absolute;
    left: 18px;
    bottom: 42px;
    width: 44%;
    height: 32px;
    border: 2px solid var(--line-dark);
    background: #d9c79e;
    transform: rotate(2deg);
  }

  .tool-intro {
    display: grid;
    grid-template-columns: 1fr;
    width: min(920px, 100%);
    gap: 14px;
    align-items: center;
    margin: 0 auto 24px;
    text-align: center;
  }

  .tool-intro h1 {
    margin: 0;
    color: var(--ink);
    font-size: 25px;
    font-weight: 800;
    line-height: 1.32;
    letter-spacing: -0.6px;
    word-break: keep-all;
  }

  .tool-intro p {
    max-width: 680px;
    margin: 0 auto;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
    word-break: keep-all;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }

  .quick-links a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--paper);
    color: var(--muted);
    font-size: 13.5px;
    font-weight: 700;
    padding: 10px 12px;
  }

  .problem-promise-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
  }

  .problem-promise-list span {
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface-muted);
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.2;
    padding: 6px 9px;
  }

  .workspace {
    display: grid;
    grid-template-columns: minmax(300px, 420px) minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .panel,
  .preview-panel,
  .side-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .panel,
  .side-panel {
    padding: 18px;
  }

  .side-panel {
    display: none;
  }

  .preview-panel {
    min-height: 620px;
    overflow: hidden;
    padding: 22px;
  }

  .panel-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }

  .panel-title h2,
  .panel-title h3 {
    margin: 0;
    font-size: 16px;
    line-height: 1.2;
  }

  .field-grid {
    display: grid;
    gap: 12px;
  }

  .field {
    display: grid;
    gap: 6px;
  }

  .field span,
  .field label,
  .field legend {
    color: #344457;
    font-size: 13px;
    font-weight: 800;
  }

  input,
  select,
  textarea {
    width: 100%;
    min-height: 44px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--paper);
    color: var(--ink);
    font-size: 15px;
    line-height: 1.4;
    padding: 11px 12px;
  }

  textarea {
    min-height: 78px;
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(17, 122, 122, 0.13);
    outline: none;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .btn {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--paper);
    color: var(--ink);
