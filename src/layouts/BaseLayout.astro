  .home-tool-card[data-analytics-tool-id] {
    border-color: var(--tool-border);
    background: #fff;
  }

  .home-tool-card[data-analytics-tool-id]:hover,
  .home-tool-card[data-analytics-tool-id]:focus-visible {
    border-color: var(--tool-accent);
    background: #fff;
  }

  .home-tool-card[data-analytics-tool-id]:hover em,
  .home-tool-card[data-analytics-tool-id]:focus-visible em {
