    background: var(--tool-hover);
  }

  .catalog-quick-icon,
  .home-quick-icon,
  .home-icon-tile,
  .home-category-icon,
  .home-tool-card-icon {
    border-color: var(--tool-border);
    background: var(--tool-tint);
    color: var(--tool-accent);
  }

  .catalog-quick-start[data-analytics-tool-id] .catalog-quick-icon,
  .home-quick-start[data-analytics-tool-id] .home-quick-icon,
  .home-page .hero-search-row[data-analytics-tool-id] .home-icon-tile,
