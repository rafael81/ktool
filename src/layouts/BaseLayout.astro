---
import { toolCategories, tools, type ToolCategoryId } from "@/data/tools";
import { workflowPackages, type WorkflowPackageId } from "@/data/workflowPackages";

type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const { title, description, canonicalPath = "/", robots, structuredData } = Astro.props;
function normalizePath(path: string) {
  const withSlash = path.startsWith("/") ? path : `/${path}`;
  return withSlash === "/" ? "/" : `${withSlash.replace(/\/+$/, "")}/`;
}

const normalizedCanonicalPath = normalizePath(canonicalPath);
const currentTool = tools.find((tool) => normalizePath(tool.path) === normalizedCanonicalPath);
const currentWorkflowPackage = workflowPackages.find(
  (workflowPackage) => normalizePath(workflowPackage.path) === normalizedCanonicalPath
);
const workflowCategoryMap: Record<WorkflowPackageId, ToolCategoryId> = {
  "photo-scan-submission": "image",
  "business-document-submission": "business",
  "freelance-billing": "business"
};
const currentWorkflowCategory = currentWorkflowPackage
  ? workflowCategoryMap[currentWorkflowPackage.id]
  : undefined;
const primaryWorkflowPackage = workflowPackages[0];
function isActivePath(path: string) {
  return normalizePath(path) === normalizedCanonicalPath;
}
function isActiveCategory(categoryId: ToolCategoryId) {
  const shouldHighlightWorkflowCategory = currentWorkflowPackage?.id !== primaryWorkflowPackage.id;
  return (
    currentTool?.category === categoryId ||
    (shouldHighlightWorkflowCategory && currentWorkflowCategory === categoryId)
  );
}
const canonical = new URL(
  normalizedCanonicalPath,
  Astro.site ?? "https://k-document-tool.pages.dev"
).toString();
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const jsonLdItems = structuredDataItems.map((item) =>
  JSON.stringify(item).replaceAll("<", "\\u003c")
);
const analyticsPage = {
  path: normalizedCanonicalPath,
  title
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600;700&family=IBM+Plex+Sans+KR:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const localHosts = new Set(["localhost", "127.0.0.1", "::1"]);
        if (localHosts.has(window.location.hostname)) return;
        const beacon = document.createElement("script");
        beacon.defer = true;
        beacon.src = "https://static.cloudflareinsights.com/beacon.min.js";
        beacon.dataset.cfBeacon = '{"token":"54ee976818264e5bbc947006b289846f"}';
        document.head.appendChild(beacon);
      })();
    </script>
    {
      jsonLdItems.map((jsonLd) => (
        <script is:inline type="application/ld+json" set:html={jsonLd}></script>
      ))
    }
    <script is:inline define:vars={{ analyticsPage }}>
      (() => {
        const page = analyticsPage;

        function toolContext(node) {
          const root = node?.closest?.("[data-tool-id]");
          if (!root) return {};
          return {
            tool_id: root.dataset.toolId || null,
            tool_title: root.dataset.toolTitle || null
          };
        }

        function compact(value) {
          return String(value || "").replace(/\s+/g, " ").trim();
        }

        window.dataLayer = window.dataLayer || [];
        window.kdocTrack = function kdocTrack(eventName, params = {}) {
          const payload = {
            event: eventName,
            page_path: page.path,
            page_title: page.title,
            event_time: new Date().toISOString(),
            ...params
          };
          window.dataLayer.push(payload);
          window.dispatchEvent(new CustomEvent("kdoc:analytics", { detail: payload }));
          return payload;
        };

        function bootAnalytics() {
          const pageTool = document.querySelector("[data-tool-id]");
          window.kdocTrack("page_view", toolContext(pageTool));

          const startedTools = new Set();
          const markToolStart = (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;
            const root = target.closest("[data-tool-id]");
            if (!root) return;
            const toolId = root.dataset.toolId;
            if (!toolId || startedTools.has(toolId)) return;
            startedTools.add(toolId);
            window.kdocTrack("tool_start", toolContext(root));
          };

          document.addEventListener("input", markToolStart, true);
          document.addEventListener("change", markToolStart, true);
          document.addEventListener(
            "click",
            (event) => {
              const target =
                event.target instanceof Element
                  ? event.target.closest("[data-analytics-event]")
                  : null;
              if (!target) return;

              const params = {
                ...toolContext(target),
                label: target.dataset.analyticsLabel || compact(target.textContent),
                href: target instanceof HTMLAnchorElement ? target.href : undefined
              };

              if (target.dataset.analyticsToolId) params.tool_id = target.dataset.analyticsToolId;
              if (target.dataset.analyticsToolTitle) {
                params.tool_title = target.dataset.analyticsToolTitle;
              }
              if (target.dataset.analyticsShortcutId) {
                params.shortcut_id = target.dataset.analyticsShortcutId;
              }
              if (target.dataset.analyticsTargetPreset) {
                params.target_preset = target.dataset.analyticsTargetPreset;
              }
              if (target.dataset.analyticsPackageId) {
                params.package_id = target.dataset.analyticsPackageId;
              }
              if (target.dataset.analyticsProblemId) {
                params.problem_id = target.dataset.analyticsProblemId;
              }
              if (target.dataset.analyticsTargetToolId) {
                params.target_tool_id = target.dataset.analyticsTargetToolId;
              }
              if (target.dataset.analyticsTargetToolTitle) {
                params.target_tool_title = target.dataset.analyticsTargetToolTitle;
              }

              window.kdocTrack(target.dataset.analyticsEvent, params);
            },
            true
          );
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", bootAnalytics, { once: true });
        } else {
          bootAnalytics();
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="K문서툴 홈">
        <span class="brand-mark">K</span>
        <span>문서툴</span>
      </a>
      <nav class="top-nav" aria-label="주요 도구">
        <a
          href="/tools/"
          class:list={{ "is-active": isActivePath("/tools/") }}
          aria-current={isActivePath("/tools/") ? "page" : undefined}
          data-analytics-event="catalog_nav_click"
          data-analytics-label="전체 도구"
        >
          전체 도구
        </a>
        <a
          href="/tools/submission-file-prep/"
          class:list={{ "is-active": isActivePath("/tools/submission-file-prep/") }}
          aria-current={isActivePath("/tools/submission-file-prep/") ? "page" : undefined}
          data-analytics-event="workflow_nav_click"
          data-analytics-label="제출용 파일 준비"
        >
          제출 준비
        </a>
        <a
          href={primaryWorkflowPackage.path}
          class:list={{ "is-active": isActivePath(primaryWorkflowPackage.path) }}
          aria-current={isActivePath(primaryWorkflowPackage.path) ? "page" : undefined}
          data-analytics-event="package_nav_click"
          data-analytics-package-id={primaryWorkflowPackage.id}
          data-analytics-label={primaryWorkflowPackage.title}
        >
          {primaryWorkflowPackage.shortTitle}
        </a>
        {
          toolCategories.map((category) => (
            <a
              href={category.path}
              class:list={{
                "is-active": isActivePath(category.path) || isActiveCategory(category.id)
              }}
              aria-current={
                isActivePath(category.path) || isActiveCategory(category.id) ? "page" : undefined
              }
              data-analytics-event="category_nav_click"
              data-analytics-label={category.shortTitle}
            >
              {category.shortTitle}
            </a>
          ))
        }
      </nav>
    </header>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f6f7f9;
    --surface: #ffffff;
    --surface-muted: #f2f4f7;
    --paper: #ffffff;
    --ink: #09090b;
    --muted: #667085;
    --line: #d9dee7;
    --line-dark: #18181b;
    --accent: #155eef;
    --accent-dark: #1248b6;
    --stamp: #b42318;
    --danger: #b42318;
    --success: #067647;
    --shadow: 0 18px 44px rgba(15, 23, 42, 0.08);
    --radius: 10px;
    font-family:
      "IBM Plex Sans KR", "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--ink);
  }

  body {
    margin: 0;
    min-width: 320px;
    background: linear-gradient(180deg, #ffffff 0, var(--bg) 420px), var(--bg);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    min-width: 0;
    min-height: 68px;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.94);
    padding: 0 34px;
    backdrop-filter: blur(16px);
  }

  .brand {
    display: inline-flex;
    flex: 0 0 auto;
    min-height: 44px;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    font-size: 21px;
    font-weight: 800;
    letter-spacing: 0;
  }

  .brand-mark {
    display: inline-grid;
    width: 30px;
    height: 30px;
    place-items: center;
    border: 1px solid var(--line-dark);
    border-radius: 8px;
    background: var(--line-dark);
    color: #fff;
    font-size: 18px;
    font-weight: 900;
  }

  .top-nav {
    display: flex;
    flex: 1 1 auto;
    max-width: 100%;
    min-width: 0;
    align-items: center;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .top-nav::-webkit-scrollbar {
    display: none;
  }

  .top-nav a {
    display: inline-flex;
    flex: 0 0 auto;
    min-height: 44px;
    align-items: center;
    border-radius: 8px;
    color: var(--muted);
    font-size: 14px;
    font-weight: 700;
    padding: 10px 12px;
    white-space: nowrap;
  }

  .top-nav a:hover,
  .top-nav a:focus-visible,
  .top-nav a.is-active,
  .top-nav a[aria-current] {
    background: var(--surface-muted);
    color: var(--ink);
    outline: none;
  }

  .top-nav a.is-active,
  .top-nav a[aria-current] {
    background: #eff4ff;
    color: var(--accent-dark);
  }

  .page-shell {
    width: min(1440px, 100%);
    margin: 0 auto;
    padding: 34px;
  }

  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 760px);
    min-height: 0;
    gap: 24px;
    align-items: start;
    border-bottom: 2px solid var(--line-dark);
    padding: clamp(34px, 6vw, 76px) 0 34px;
  }

  .hero-copy {
    display: grid;
    max-width: 760px;
    gap: 18px;
    align-content: center;
  }

  .hero-copy h1 {
    max-width: 820px;
    margin: 0;
    color: var(--ink);
    font-size: clamp(40px, 5.8vw, 72px);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.02;
    word-break: keep-all;
  }

  .hero-copy p {
    max-width: 660px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(16px, 1.8vw, 20px);
    line-height: 1.45;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-actions a {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    border: 2px solid var(--line-dark);
    border-radius: 4px;
    background: var(--line-dark);
    color: var(--paper);
    font-size: 15px;
    font-weight: 800;
    padding: 12px 16px;
  }

  .hero-actions a.secondary {
    background: transparent;
    color: var(--ink);
  }

  .hero-search {
    display: grid;
    max-width: 720px;
    gap: 10px;
    border: 2px solid var(--line-dark);
    background: var(--paper);
    padding: 14px;
    box-shadow: 6px 6px 0 rgba(22, 28, 31, 0.11);
  }

  .hero-search-field {
    display: grid;
    gap: 7px;
  }

  .hero-search-field span,
  .hero-search-meta,
  .hero-search-row span,
  .hero-search-row em {
    font-family: "IBM Plex Mono", monospace;
  }

  .hero-search-field span {
    color: var(--accent-dark);
    font-size: 12px;
    font-weight: 800;
  }

  .hero-search-field input {
    min-height: 54px;
    border: 2px solid var(--line-dark);
    background: #fffefa;
    font-size: 18px;
    font-weight: 700;
  }

  .hero-search-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
  }

  .hero-search-meta a {
    color: var(--accent-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hero-search-results {
    display: grid;
    max-height: 300px;
    overflow: auto;
    border-top: 1px solid var(--line);
  }

  .hero-search-row {
    display: grid;
    grid-template-columns: 86px minmax(0, 1fr) minmax(120px, auto);
    gap: 12px;
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding: 11px 0;
  }

  .hero-search-row[hidden] {
    display: none;
  }

  .hero-search-row:hover strong,
  .hero-search-row:focus-visible strong {
    color: var(--accent-dark);
  }

  .hero-search-row:focus-visible {
    box-shadow: 0 0 0 3px rgba(11, 111, 105, 0.14);
    outline: none;
  }

  .hero-search-row span,
  .hero-search-row em {
    color: var(--accent-dark);
    font-size: 12px;
    font-style: normal;
    font-weight: 800;
  }

  .hero-search-row strong {
    color: var(--ink);
    font-size: 16px;
    line-height: 1.25;
  }

  .hero-search-row em {
    justify-self: end;
    border: 1px solid #cfe0dc;
    border-radius: 4px;
    padding: 5px 7px;
    white-space: nowrap;
  }

  .hero-search-empty {
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
    padding-top: 10px;
  }

  .hero-search-empty[hidden] {
    display: none;
  }

  .home-tool-chip:hover span,
  .home-tool-chip:focus-visible span {
    color: var(--accent-dark);
  }

  .home-tool-chip:focus-visible {
    box-shadow: 0 0 0 3px rgba(11, 111, 105, 0.14);
    outline: none;
  }

  .home-tool-chip em {
    color: var(--accent-dark);
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    font-style: normal;
    font-weight: 900;
  }

  .home-tool-groups {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    border-top: 2px solid var(--line-dark);
    padding-top: 18px;
  }

  .home-tool-group {
    display: grid;
    align-content: start;
    gap: 10px;
  }

  .home-tool-group h3 {
    margin: 0;
    color: var(--accent-dark);
    font-size: 15px;
    line-height: 1.2;
  }

  .home-tool-chip-list {
    display: grid;
    gap: 8px;
  }

  .home-tool-chip {
    display: grid;
    min-height: 44px;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    align-items: center;
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 10px 12px;
  }

  .home-tool-chip span {
    color: var(--ink);
    font-size: 15px;
    font-weight: 800;
    line-height: 1.25;
  }

  .hero-evidence {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    max-width: 640px;
  }

  .hero-evidence span {
    display: grid;
    gap: 3px;
    border-top: 2px solid var(--line-dark);
    padding-top: 9px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.45;
  }

  .hero-evidence strong {
    color: var(--ink);
    font-family: "IBM Plex Mono", monospace;
    font-size: 15px;
  }

  .workbench {
    position: relative;
    min-height: 520px;
    border: 2px solid var(--line-dark);
    background:
      linear-gradient(90deg, rgba(22, 28, 31, 0.05) 1px, transparent 1px) 0 0 / 28px 28px,
      linear-gradient(180deg, rgba(22, 28, 31, 0.05) 1px, transparent 1px) 0 0 / 28px 28px,
      #ebe4d8;
    padding: 24px;
    box-shadow: 10px 10px 0 rgba(22, 28, 31, 0.13);
  }

  .queue-sheet {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 0;
    border: 2px solid var(--line-dark);
    background: var(--paper);
  }

  .queue-header,
  .queue-row {
    display: grid;
    grid-template-columns: 112px minmax(0, 1fr) 104px;
    gap: 14px;
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding: 15px 16px;
  }

  .queue-header {
    background: var(--line-dark);
    color: var(--paper);
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .queue-row:last-child {
    border-bottom: 0;
  }

  .queue-row span:first-child,
  .queue-row span:last-child {
    color: var(--accent-dark);
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    font-weight: 700;
  }

  .queue-row strong {
    display: block;
    color: var(--ink);
    font-size: 19px;
    line-height: 1.35;
  }

  .queue-row em {
    display: block;
    margin-top: 4px;
    color: var(--muted);
    font-style: normal;
    font-size: 13px;
    line-height: 1.55;
  }

  .paper-note {
    position: absolute;
    right: 28px;
    bottom: 28px;
    width: min(250px, 42%);
    border: 2px solid var(--line-dark);
    background: #fff6dc;
    padding: 16px;
    transform: rotate(-1.7deg);
    box-shadow: 5px 5px 0 rgba(22, 28, 31, 0.12);
  }

  .paper-note strong {
    display: block;
    color: var(--stamp);
    font-family: "IBM Plex Mono", monospace;
    font-size: 13px;
    margin-bottom: 8px;
  }

  .paper-note span {
    color: var(--ink);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.55;
  }

  .desk-ruler {
    position: absolute;
    left: 18px;
    bottom: 42px;
    width: 44%;
    height: 32px;
    border: 2px solid var(--line-dark);
    background:
      repeating-linear-gradient(90deg, var(--line-dark) 0 1px, transparent 1px 22px),
      #d9c79e;
    transform: rotate(2deg);
  }

  .tool-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
    margin-bottom: 24px;
  }

  .tool-intro h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(34px, 5vw, 60px);
    line-height: 1;
    letter-spacing: 0;
  }

  .tool-intro p {
    max-width: 760px;
    margin: 14px 0 0;
    color: var(--muted);
    font-size: 18px;
    line-height: 1.65;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .quick-links a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--paper);
    color: var(--muted);
    font-size: 14px;
    font-weight: 800;
    padding: 10px 12px;
  }

  .workspace {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr) minmax(240px, 300px);
    gap: 18px;
    align-items: start;
  }

  .panel,
  .preview-panel,
  .side-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .panel,
  .side-panel {
    padding: 18px;
  }

  .preview-panel {
    min-height: 620px;
    overflow: auto;
    padding: 22px;
  }

  .panel-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }

  .panel-title h2,
  .panel-title h3 {
    margin: 0;
    font-size: 16px;
    line-height: 1.2;
  }

  .field-grid {
    display: grid;
    gap: 12px;
  }

  .field {
    display: grid;
    gap: 6px;
  }

  .field span,
  .field label,
  .field legend {
    color: #344457;
    font-size: 13px;
    font-weight: 800;
  }

  input,
  select,
  textarea {
    width: 100%;
    min-height: 44px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--paper);
    color: var(--ink);
    font-size: 15px;
    line-height: 1.4;
    padding: 11px 12px;
  }

  textarea {
